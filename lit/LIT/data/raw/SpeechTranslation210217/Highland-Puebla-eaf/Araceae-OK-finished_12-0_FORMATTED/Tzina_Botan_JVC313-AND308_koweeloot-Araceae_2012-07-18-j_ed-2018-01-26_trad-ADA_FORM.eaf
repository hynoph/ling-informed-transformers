        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
                <ANNOTATION_VALUE>wa:n ika kitetsi:lowa:yah nochi ne:n *semilla**,</ANNOTATION_VALUE>
