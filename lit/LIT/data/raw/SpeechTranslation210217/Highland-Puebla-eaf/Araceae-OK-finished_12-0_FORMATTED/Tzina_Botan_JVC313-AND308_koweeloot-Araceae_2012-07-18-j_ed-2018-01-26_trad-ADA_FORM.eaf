            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>sí, pues una parte de nuestro alimento lo dejamos desperdiciar, hay allá en el monte y no lo traemos porque no...,</ANNOTATION_VALUE>
