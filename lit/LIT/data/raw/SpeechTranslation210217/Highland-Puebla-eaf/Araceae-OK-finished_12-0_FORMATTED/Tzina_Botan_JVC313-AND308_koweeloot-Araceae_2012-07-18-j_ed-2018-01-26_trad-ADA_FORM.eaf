        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>Queda muy bien (el agua), queda muy bien, este, que...,</ANNOTATION_VALUE>
