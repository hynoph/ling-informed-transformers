                <ANNOTATION_VALUE>nia:ya kowtah, ka:sika n' ike:span etok itech i:n kowit, ka:sika wehweikowit ike:span</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
