        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts191">
                <ANNOTATION_VALUE>A:mo, a:mo miak kipia.</ANNOTATION_VALUE>
