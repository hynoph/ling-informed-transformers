        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>También contiene savia, cuando aún está verde también contiene savia pero una vez que se madura,</ANNOTATION_VALUE>
