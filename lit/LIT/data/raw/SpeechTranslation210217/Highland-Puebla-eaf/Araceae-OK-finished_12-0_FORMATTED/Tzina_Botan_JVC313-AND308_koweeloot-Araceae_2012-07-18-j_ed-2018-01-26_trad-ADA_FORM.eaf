        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>Entó:s yehwa yo:n neh nikitaya wa:n no: ke:masá: ne:wí:n</ANNOTATION_VALUE>
