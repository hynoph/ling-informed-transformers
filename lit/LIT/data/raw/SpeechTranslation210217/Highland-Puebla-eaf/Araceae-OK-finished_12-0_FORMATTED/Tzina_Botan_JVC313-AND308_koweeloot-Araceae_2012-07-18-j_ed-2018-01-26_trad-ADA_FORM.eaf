        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>Sí, pero ya se lava, quitándole toda la pulpa, sí, se lava muy bien y </ANNOTATION_VALUE>
