        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>wa:n kita:ta:lia:yah *semilla** wa:n ke:mah kitetsi:lowa:yah iwa:n yo:n xiwit.</ANNOTATION_VALUE>
