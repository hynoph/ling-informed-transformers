        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>Ke:mah, niki:xmattok, niki:xmattok metstsonkilit ta: nejó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>no: mahyá: chihchi:chi:ltik ne:n ikowyotsi:n, se: ki:xmati *que** yeh metstsonkilit *porque** yo:n okseki no: taman, yeh ista:k wa:n i:n okseki no: taman.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>Niki:xmattok ta: no: nejó:n i:pa tikwa:nih n' tehwa:n, tiktekih wa:n tike:ktiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>Wa:n nejó:n tik..., neh nike:n..., neh nochipa nik..., nikchi:wa achto nejó:n nike:ktia wa:n ke:mah niketsa ya n' ko:mit mah molo:nto ya *para cuando** molo:ntok a ke:mah nikpanta:lia ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>Wa:n ke:mah nejó:n para se: k..., se: ka:ko:lwia. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>Ke:mah, para mah pa:ti kwaltsi:n, mah pa:ti kwaltsi:n oso neh i:ksá: nikchi:wa achto n'tewa:tsa nochi, ne:n, a:ko:lin</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>wa:n ke:mah para nejó:n nikpanta:lia ya para a:mo nika:n niki:ki:xtihtiw achto niktewa:tsa nochi n' a:ko:lin wa:n ke:mah *cuando** n'panta:lihtiw a ne:n kiltsí:n ihwa:k a nikwe:chohtok n' a:ko:lin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>Wa:n ke:mah nikpante:kilia *cuando** oksiki a pos nikpante:kilia ya para a:mo, para a:mo mah kostia. Kwaltsi:n ki:sa ye:kxoxoktsí:n neli wa:n mah kwaltsi:n se: kichi:wa ye:kmiak a:ko:lin mah se: kita:lili kwaltsi:n ki:sa wa:n kwaltsi:n se: kikwa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>A:mo, yo:n se: kito:ka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>Yo:n se: kito:ka, pero yo:n ne:nke:n miakia, mah se: kito:ka wa:n miakia wa:n telniman nejó:n, niman panki:sa komo se: kito:ka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>Ke:mah, ikamohyo:tsi:n mah se: kito:ka, ka:mpa yo:n panki:stok tsikitsitsi:n wa:n se: kito:ka kwaltsi:n mochi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>A:man ke:mah, a:man monamaka *porque** a:mo kachi kanah tei ok, *porque** ka:mpa ke:meh yo:n komo se: kito:ka ka:mpa paya:n mochi:was.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>Pero komo ihkó:n teihsá: se: kito:kak, tatampa moka:wa ka:n kwaltia ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>Pero komo n..., ka:mpa paya:n ke:mah, kiye:kna:miki wa:n mochi:wa kwaltsi:n no: ye:kwehwei.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>Ke:mah, *porque** seki ki..., seki neli kinemi:ltiah ihkó:n neli kinamakah, pero neli ka:mpa kipiah ok, pero ka:mpa poliwtok a pos neli ka:n, neli poliwis *porque** komo teihsá: se: kito:kak wa:n tatampa moka:wa ka:n moskaltia ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>Ta: yo:n kwelita no: ka:mpa paya:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts76" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>Ke:mah, *porque** ekintsi:n tasohti *porque** ke:meh yo:n neli yehwa yo:n nochi kikwih nochi yo:n xiwpah tein para kwa:tsa ya teihsá pos *por eso** ka:n teh mochi:waok. Ta: ne: ke:man neli motachi:waya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>*porque** a:mo kikwiah yehwa yo:ni ne: ke:man ne:n tota:tahwa:n. Ihwa:k ka:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>ka:n teh kichi:wtoyah teihsá: kikowayah nochi ne: Kwesala:n mah nejó:n kikowatih teihsá: para nejó:n ika ta...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>tawa:tsaskeh ta: ekintsi:n nochi yehwa ya n' kikwih *por eso** poliwi n' teihsá:, *pero de** komo a:mo nejó:n teh se: kita:lia ka:n poliwis teihsá:, ta: mochi:was.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>Pero mah se: *kicuidaro** neli n' ta:ltsi:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>Ke:mah. Ke:mah we:lik neli yo:n para ato:l, pero yo:n tikihtowa se: 'kwe:chowa, neh n'mattok *que** se: 'kwe:chowa tein yo:n ki:sa yo:n ihista:k a, itesyo ya n' kilwiah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>yo:n neli se: 'kwe:chowa ya *porque** a:mo wel se: kipanta:lia ok ne:n ka:mpa se: kichi:wtok n' ato:l *porque** kihtowah *que** te:tenahwayo:tih komo nejó:n se: kipanta:lia ok yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>Yo:n se: kikwi*puro** tein nochi kamoh sah, yo:n mahyá: teiktik nochi ata, ne:stok n' tein ikamohyotsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>yehwa yo:n neh iwki n'chi:wa neli, niktehtekia wa:n ke:mah nikmolo:ntihtok a ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>tixti. Achto nikpa:ta wa:n ompa nik..., niktsetselowa ika n' tatsetselo:lo:ni wa:n ke:mah niktikoketsa ya wa:n *cuando** molo:ntok a: yo:n nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>nikpante:milia ya yehwa yo:n nejó:n ne:n kamohtsi:n wa:n nikpanta:lia ika tsiktsi:n epaso:t wa:n yehwa yo:n ne:n tsiktsi:n istatsi:n iwa:n chi:l no: se: kita:lilia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>wa:n se: tai a. Neli we:lik kwaltsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>A:mo, nejó:n ohonkak, no: ohonkak pero, pero ka:mpa titato:kah, onkak ok no: n' ompa pero nejó:n a:mo semi miak ok neli no:, achto *más** mochi:waya *porque** nejó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>*de que** neli a:mo teh onkaya wa:n *de que** sepa, nejó:n, takahfe:nyowak ekintsi:n pos ka:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>ka:n tei ok neli ohonkak pero tepitsi:n ya sah. Ke:mah. Pero sepa, sepa nejó:n i:n ke:man nikwa:lkwik seki ne: nejó:n tein tsikitsitsi:n wa:n nikta:lih ompa kaltsi:ntan nejó:n mochi:wtok a n' ekintsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>Pos ka:n nochi se: 'ko:wtok ok wa:n komo a:mo mah nochi se: 'ko:wto wa:n komo a:mo se: kipia ne:n tapatalo:ni i:pa ka:n, i:pa ka:n se: kikwis ma:s te:ilwihtoskeh pero komo a:mo se: kipia a:mo se: kikwis. Ke:mah. Wa:n komo se: konkaltia pos ompa sah se: kiteki wa:n se: kikwa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a103" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>Pos a:mo nikmati. Neh n'mattok i:pa yehwa sah yo:ni para se:..., para se: kikwa:s wa:n yehwa ya yo:n nikihtowa neli n' ikamohyotsi:n para s..., para se: kichi:wa ato:l, pero ihkó:n para *más** teihsá: a:mo nikmati, neh n'mattok i:pa yehwa sah para ato:l se: kichi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>Kikwah no:. To:tolimeh kikwah. Kikwah *porque** neh nejó:n nikta:lihka ya se: n' ompa ka:mpa noto:tolwa:n nikintsaktok wa:n a:mo ke:man kwaltiak, kikwahkeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Wa:n a:man nikahchi:w, ekintsi:n nejó:n mokopi:n ya n' ixiwyotsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>Ke:mah, kikwah n' to:tolimeh wa:n mahyá: xokoxtiw sah, *pero de que** nikahchi:w kwaltiak a n' ekintsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>Ke:mah, *porque** kikwah tapialmeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>Pos a:mo teihsá:, tasohka:matik miak no: n' teh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts170" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>Neh nimono:tsa ni....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts174">
                <ANNOTATION_VALUE>Neh nimono:tsa niMaría Salazar Osollo, niwi:tsa de San Miguel.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Rubén Macario Martínez" PARTICIPANT="Rubén Macario Martínez" TIER_ID="RMM Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Disculpame señora, también quiero preguntarte si es que conoces ese (planta) que le llaman metsonkilit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>Y como, como lo preparan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>Si es que sus hojas también saben ricas o como es que lo preparan para comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>Y según dicen que cuando las hojas se echan a la olla ha que moverlas para que se ponga amarrillo. Y para que se deshaga bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>Y otra pregunta que quiero hacerte es donde tienen ese quelite</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>si es que lo siembra o nace por si sola, o se da por si sola.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>(Se siembra) el rizoma. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Y yo pienso que ese quelite,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>que anteriormente había mucha porque lo cuidaban mucho nuestros abuelos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Pero ahora nosotros decimos, como que decimos que ya no lo sembramos porque parece que, parece que ya no lo atendemos muy bien porque decimos que ya no lo consumimos mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Pero no es verdad, pues este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>lo comeriamos nada más que nosotros ya no les eneñamos a nuestros hijos que con eso se mantengan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Y de verdad que es bonito atenderlo porque actualmente ese quelite también hasta se vende.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Actualmente se vende.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Pues si, anteriormente nosotros teniamos mucho, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>acá por la parte de abajo, por acá por..., tengo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>un terrenito pequeño aquí por Xaltipan y ahí es donde abundaba mucho ese quelite.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Pero también se extinguió, se extinguió tal vez por...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>porque usan mucho esas herbicidas para secar las hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Entonces todo eso hizo a que ese quelite se exterminara, me acuerdo  que hace mucho tiemo nosotros teniamos mucho por allá y como dices, hay que dandole los cuidados necesarios,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>se da. Porque ahora ya se escasea.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Se escasea mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Si, y veía de veras que anteriormente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>comian las hojas (de la mafafa).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>y el rizoma lo hacían atole, hacían atole del rizoma</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>(primero) lo lavaban y lo molían. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Lo molían o sino lo rebanaban muy fino y lo rebanaban en pedazos finos y lo molían para preparar el atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Y lo probaba y de veras que es muy rico, y ese es muy bonito que así, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>pues decimos nosotros que no...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>que no es necesario estar comprandolo sino que nada más ahay que ir a traerlo y ya nada más hay que prepararlo si es que uno puede.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Y actualmente todavía tiene allá en su...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>junto a su casa o también ya se extinguió como allá nosotros ya no hay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Pues es muy bonito la iniciativa que tienes de,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>que pudieras reproducir las plantas porque veo que ahora todo se vende como el, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>tan solo el quelite si nosotros...,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>lo echamos a perder ya se pierde y después de que ya se extermina ya tenemos que comprarlo pagandolo y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>por ejemplo donde sabemos que lo tenemos ya nada màs lo vamos a cortar y ahì ya tenemos para nuestra comida..., para comer. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Y es la verdad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Si. Pues es muy bonito y sabìas que ese quelite,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>bueno, solamente sabes que se usa para consumo en comida y el camote para atole y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>no, no se ocupa para algun uso màs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Y los animales tambièn se lo han de comer. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>A pues por eso ahora ya no abunda porque...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Pues nada màs fue eso de nuestra platica, muchas gracias que me platicaste como lo preparas y este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>para que sirve su camote. Pues eso es todo lo que querìamos saber, muchas gracias.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Yo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Yo me llamo Rubèn Maqcario Martìnez y vengo de Chilcuahuta perteneciente a San Miguel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Salazar Osollo" PARTICIPANT="María Salazar Osollo" TIER_ID="MSO Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Si, conozco, conozco el metsonkilit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>es como de tallos rojizos y por eso se reconoce que es el metsonkilit, porque los otros son diferentes, son de (tallo) blanco y (el metsonklit) es diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>Conozco esa planta, pues siempre lo hemos comido, lo vamos a cortar y lo limpiamos (esto es deshebrar las hojas tirando las venas y guardando el puro quelite).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Y lo que yo siempre hago es limpiar primero las hojas y mientras tanto paro la olla con agua para que esté hirviendo, y cuando ya está hirviendo ya echo las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>Si. Y posteriormente ya le agrego ajonjolí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Si, es para que se deshaga bonito, que deshaga bonito o a veces yo hago que primero tuesto el ajonjolí </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>y posteriormente ya lo echo a la olla para no estar retirandolo del fuego, primero tuesto todo el ajonjolí y cuando ya echo el quelite aprovecho para moler el ajonjolí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Y cuando ya hierve, es cuando ya le agrego el ajonjolí, para que no se ponga amarilla (la comida). Sale muy rica la comida, bien verdecita y si se le agrega mucho ajonjolí sale mucho más rica la comida y se come a gusto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>No, ese se siembra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>Se siembra y se abunda muy fácilmente, se abunda y cuando lo siembra uno en poco tiempo nacen más retoños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Si, se siembra el rizoma, se siembra el que ya tiene un retoño pequeño y se da muy bonito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>Ahora si, ahora se vende porque ya casi no hay, porque si se siembra en los sitios abiertos si se da.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>Pero si siembra uno otra (planta), el (metsonkilit) ya queda bajo la sombra y ya no sirve.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Pero en los lugares donde no hay sombra se adapta muy bien y se hacen matas grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>Si porque de veras que unos piensan así y lo venden, pero donde aún lo tienen porque hay lugares donde ya no abunda, pero donde ya se está exterminando pues se va acabar de exterminar porque al sembrar algo que le haga sombra (el metsonkilit) ya no crece.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Pues ese también abunda pero en lugares sin sombra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Si, pues actualmente escasea mucho eso porque como ocupan todas esas herbicidas para secar las malas hierbas por eso ya no se da nada. Pues anteriormente se daba de todo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>porque nuestros abuelos no usaban todo eso. En ese tiempo  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>no compraban todo en Cuetzalan, no compraban herbicidas para fumigar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>y actualmente ya todos usan las herbicidas para fumigar por eso se extermina todo, pero al no sar esas herbicidas pues se da de todo en el campo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Pero hay que cuidar la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Si. Si de veras que es muy sabroso ese atole, pero lo que dices que se muele son los que les llaman camotes, salen blancos, eso es lo que yo sé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>eso si se muele porque ya no se pueden meter así donde está haciendo el atole, porque dicen que da comezón en la boca si es que uno echa (los camotes) en el atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Se ocupa el puro camote, se reconoce porque es como desmoronado, luego se distingue lo que es el puro camote,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>eso es lo que yo hago, lo rebano pero antes ya tengo el atole hirviendo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Primero deshago la masa y posteriormente lo cuelo con un sedazo y ya lo pongo al fuego y cuando ya está hirviendo, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>ya le echo ese camote y le agrego un poco de epazote, una poca de sal y también se le pone un poco de chile,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>y ya se toma. Es muy rico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>No, de ese todavía hay en algunas partes, donde sembramos (milpa) hay todavía pero ya no mucho, anteriormente abundaba más pero </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>de que pues de veras como no había nada y ahora que ya es cafetal pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>ya no hay mucho, hay pero ya muy poco. Pero hace poco traje unas lantas chicas y las sembré ahí junto a la casa y ahora ya se está adaptando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Pues ya no hay que estar comprando todo y cuando hay que estar comprando todo y si no tiene uno el dinero no lo va uno a comprar aunque le esten ofeciendo a uno (el quelite) y no habiendo dinero pues no lo va a comprar uno. Si. Y si uno lo tiene sembrado pues nada màs se corta ahì y ya hay para la comida. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Pues no sè. Yo solo sè que es para comida y nada màs el camote se usa para preparar atole, pero no sè de algùn otro uso màs, yo solo sè que se usa para preparar atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Los guajolotes tambièn se lo comen. Se lo comen porque yo ya habìa plantado donde tengo encerrado mis guajolotes y se lo comieron, no lo dejaron crecer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Y lo cambiè de lugar y ahora ya le saliò una hojita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Si, se lo comen los guajolotes y asì se va pudriendo nada màs, pero de que lo cambiè de lugar ahora ya esta creciendo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Si porque se lo comen los animales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Pues no hay de què, gracias tambièn a ti.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Yo me llamo...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Yo me llamo Marìa Salazar Osollo y vengo de San Miguel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
