        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>[mo]mahma:ytia wa:n kwali kitila:nah *hasta** ta:lpan sewetsiki, seweyak.</ANNOTATION_VALUE>
