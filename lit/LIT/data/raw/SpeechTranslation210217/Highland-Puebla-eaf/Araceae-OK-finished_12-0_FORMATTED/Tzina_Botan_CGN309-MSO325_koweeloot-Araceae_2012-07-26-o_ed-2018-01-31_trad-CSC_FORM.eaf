        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>con una astilla de madera o con un olote y con eso se le retira el pellejo que tiene.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Se le quita el pellejo. No, no porque da mucho comezón en la boca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Da mucha comezón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Da mucha comezón y de que ya se le quita el pellejo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>se echa en una olla de barro y con eso se hierve, si son unos cuatro elotes también son muchos los granos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>También se hace mucho, eso se hierve con una olla de barro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>cuando ya hierve bien empiezan a subir los pellejos que cubre los granos porque estan como cubiertos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>como la anona. Estan cubiertos como con un pellejo fino.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Y cuando ya hierve bien pues sale (el pellejo), y como ya se ha cocido bien entonces ya se saca del fuego.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Y cuando ya se enfria pues...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Antes de pararlo (la olla) al fuego, se desgrana (el elote) con una astilla de madera o con un olote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Se va moviendo así, tallandolo  para que se vaya desgranando y así se van deshaciendo los granos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Y entonces ya se hierve, como te digo que ya se hierve,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>cuando ya hierve bien ya sale lo que tiene como pellejo fino</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>se queda en la orilla de la olla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>de que ya hierve. Si y de que ya hierve pues ya se coce bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>ya se retira de fuego y se pone en un lugar arrinconado para que se enfríe ,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>y por otro lado pues ya se hierve el atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>El atole si es... Si es...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>si es que se va a mezclar con atole, pues primero se hierve el agua, el agua de masa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>y cuando ya hierve bien se le agrega ese frijol, pero antes (ese frijol) lo lava uno varias veces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Lo lava uno varias veces para que salga lo que da comezón. Pues sale porque hierve bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Si, se lava muchas veces y ya lo agrega uno,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>cuando ya hierve bien entonces ya lo retira uno del fuego. Y posteriormente...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Pues se martaja, porque anteriormente no había, ese, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>molino de nixtamal de luz o molino de mano, todo se molia (en ele metate).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Y lo afina uno. Tiene que ser muy fino. No, pues la masa tiene que ser bien fina y ya se pone a hervir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>se cuela para que hierva bien y cuando ya hierve la masa se coce bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>También se endulza. Si, es dulce, es dulce si es eso...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>se endulza con panela y si no con azucar, actualmente ya no usamos mucho la panela, usamos màs el azucar. Si, pero ya nada màs es contada la gente que usa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>la panela para preparar el atole, todo se hace con panela.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Si, eso se mete en la olla para que hierva junto con</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>las semillas que se le echan. Y entonces ya hierve bien y posteriormente ya cada quien se sirve para tomar el atole. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Si, y es muy rico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>eso no lo connoces. Lo has visto nada màs de lejos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Si, pues se da en lo alto. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Se da en lo alto, tienen que empatar un palo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>con un palo (largo) empatan un machete y con eso lo cortan desde abajo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>En un palo (largo) amarran el (machete) y con eso lo cortan porque se da en lo alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>no, no, pues... Si. Si, y el que sabe subir a los árboles, se sube y ya lo corta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>porque se da en lo alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Si. Pero yo pienso que ha de dar comezón en la boca cuando el fruto todavía no se madura donde lo pone uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>Pues anteriormente este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>lo llega uno a poner como si de verdad fuera un elote como cuando siembran y van a traer los elotes y primero lo ponen en la mesa y después lo hierve uno. Y ese no, ese ahí esta por mucho tiempo hasta que se parte en la superficie. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Asi. Si porque todavía tiene su sabia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Y de que ya está mucho tiempo pues por eso es que se parte en la superficie.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>se parte y su sabia se seca, sale su sabia y ya se parte..., y ya lo toma uno para moverlo con la madera</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>se le quita su cascara.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Si. Su cascara.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>Y eso es lo que ya queda por adentro (del fruto) el maicito, como si fuera maíz, pero pues no es maíz, ya es el fruto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>Es como frijol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>Si, eso dicen que son negros como el frijol, dicen que así es, a mi me platicò una señora que ella dice que le llama frijol. Si dice, pero yo le digo que no sé porque yo nunca lo he preparado, de veras que yo siempre he escuchado que es rico ese atole pero le digo que yo nunca lo he preparado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>Si pues es muy rico el atole, pero hay que saber prepararlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Si, pero primero tiene que estar mucho tiempo en la mesa para que se le salga lo que da comezón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>Se parten, se parten y... Antes yo lo mpreparaba mucho. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>Si, yo lo preparaba cada año, lo preparaba como dos veces al año porque vivía el difunto y lo iba a traer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>De que vivía lo iba a traer y estaba repitiendo: "yo traje el koe:lo:t, que se madure bien y a ver cuando preparas el atole porque todavìa se va a madurar".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>Si. Si, por eso lo preparaba. Pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Nunca lo has preparado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>Si. Si, pues ese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>Nunca lo preparaste. No pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>es rico el atole nada más hay que prepararlo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>Parece que nada más hay un solo tipo, nada más hay un solo tipo. Si nada más es asi, nada más es así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>A lo mejor desde adentro de la tierra y ya se sube. Si. Y como actualmente ya nadie lo va a traer, yo pienso que ya se echa a perder ahí, se riegan sus semillas y ahí vuelven a nacer. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>Y ahí vuelve a nacer. Se da en los montes, en lugares limpios no se da. Se da en los montes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a447" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>Si ues de veras que allá por A:tekohkomol y por Tahchikteko abunda mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>Si, se da mucho por allá, hacìa allá de Ta:lchi:chi:l se da mucho. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Si, hay más. Si hay más. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>No.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Si. Todo allá por Tahchiktekko todo eso hay, lo ve uno desde abajo hacia arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a452" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>donde hay, luego les dice uno: Ahí hay de ese kowe:lo:t, lo deberiamos de llevar para hervirlo y tomar (el atole).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a469" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>Pero no lo puede cortar uno porque se da en lo alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>Si, es muy alto... Ya tienen que ser los quienes saben subir, porque ellos se van deslizando y lo van cortar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Pero los que no pueden ya es cuando empatan un palo (con el machete).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>y amarran el machete en un palo y ya con eso lo cortan desde el suelo hacia arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>Si, Si. Lo traen y lo llegan a poner en la mesa, y entonces...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>y ahí se le seca la sabia y así esta hasta madurarse bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>Ahí esta por lo menos unos ocho días.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>Cuando ya se madura se parte. Si, se parte y se madura bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>pues es lo que ya te digo que lo hierve uno,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>se hierve separado con una olla, y cuando ya hierve bien...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>cuando hierve flota la espuma... Y se queda en la orilla de la olla.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>Si. Flota la espuma. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>Si. Ahí se viene a quedar. Si, flota la espuma.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>Eso es lo que queda en la orilla de la olla entonces</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a260">
                <ANNOTATION_VALUE>Ya nada más. Y de veras que yo nunca le retiré lo que flota al hervir, yo solamente lo dejaba hervir,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>y entonces cuando ya se coce, porque cuando ya se coce como que se parten (las semillas).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>Si, se parten y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>se retira del fuego y que se enfríe un poco para lavarlo muchas veces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>Y en otro (fogón) ya esta hirviendo el atolito, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a266">
                <ANNOTATION_VALUE>primero se endulza y cuando lo prueba uno y ya está (cocido) que ya no tiene sabor a masa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a489" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>entonces ya se le agrega esa semilla. Y cuando ya hierve bien entonces, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>ya se retira del fuego y ya se sirve uno, lo enfría uno y ya se toma. Si. Si, todo ya esta bien (entendido) y pues yo eso es todo lo que te pregunté si es que conoces ese fruto. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a491" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>Si, pues se da muy bonito, y cuando voy en este tiempo cuando hay... Porque ese solo se da en los meses de febrero y marzo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>Si, en ese mes se da eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a493" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>Si, nada más se da cada año. Si, nada más cada año, nada más que nunca he visto como es su flor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a494" ANNOTATION_REF="a276">
                <ANNOTATION_VALUE>No sé, pero normalmente ya siempre lo voy a ver cuando ya es un elote pegado en la superficie de los árboles... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a495" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>Porque cuando aún es tierno, es de color verde. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a496" ANNOTATION_REF="a279">
                <ANNOTATION_VALUE>Y el que ya está maduro tiende a ser blanquesino, como si fuera, como si fuera una mazorca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a497" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>Lo ve uno de lejos donde hay, son así (de tamaño).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a498" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>Unos se hacen hasta de este tamaño de grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a499" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>En lugares donde se adapta y le gusta el terreno se hacen grandes. No tanto... Y de veras que en los lugares donde le gusta el clima, se hacen muy grandes los frutos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a507" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>Le gusta el terreno fértil. Pues eso es todo lo que te pregunté, si es que lo conoces y si has tomado ese atolito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a508" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>Si. Si, eso es, nada más hay que ir a cortarlo y... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a509" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>se llega a poner en la mesa. Ahi se madura hasta partirse. Y cuando ve uno que ya se pela entonces, es cuando ya lo mueve uno con un palito para quitarle la cascara.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a510" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>con lo que está cubierto y posteriormente ya se desgrana. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a511" ANNOTATION_REF="a294">
                <ANNOTATION_VALUE>Y ya se echa en la olla para que se ponga a hervir. Y eso es todo, no es algo muy dificil.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a512" ANNOTATION_REF="a298">
                <ANNOTATION_VALUE>Pues yo me llamo Celina González Nazario y vengo de San Miguel Tzinacapan. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
