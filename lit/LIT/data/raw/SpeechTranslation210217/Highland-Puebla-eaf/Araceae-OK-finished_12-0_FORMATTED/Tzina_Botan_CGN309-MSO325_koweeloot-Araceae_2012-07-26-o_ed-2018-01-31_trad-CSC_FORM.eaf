    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Salazar Osollo" PARTICIPANT="María Salazar Osollo" TIER_ID="MSO Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Pues también lo conozco, pero no... Solamente conozco sus hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>También sabes que sus hojas se dan en las superficies de los árboles, a lo mejor en las superficies de los árboles... Si, se da en los árboles grandes, como allá por Kali:ka:mpa, por A:tekohkomol se da mucho de eso. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Si, y sé que su tallo se va extendiendo en el árbol. Como que va subiendo también y sus hojas son muy..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Si. Son muy anchas y agujeradas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>No ese no es así, pero el otro es muy agujerada (en las hojas). Si, y ese de veras que lo conozco y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>nada más que nunca..., nunca he visto sus frutos, conozco sus hojas y el tallo pero nunca o he visto como da su fruto. No, no conozco (el fruto), conozco sus hojas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Aa así se hace.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Aa ya se maduró.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>¿Y como saben que ya se maduró, se dan cuenta en la cascara o como es que saben que ya se maduró?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>A también se incha. ¿Y como es su pellejo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
