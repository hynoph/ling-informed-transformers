    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Pues yo conozco el &lt;i&gt;iswatsitsi:n&lt;/i&gt;, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>se encuentra en muchos lugares y se corta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>En donde las</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>personas tienen un terrenito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>para evitar problemas de invasión siembran esa planta en sus colindancias, la planta es usada para linderos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Esa planta es..., es muy suave, las tuzas les gusta alimentarse de esa planta pero,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>este siempre</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>cuando se tumba a veces también retoña el tallo. Retoña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Y pues esa planta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>se usa para este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>nosotros decimos que se usa para seña, se siembra este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>para que así se vea.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Las flores de esa planta es..., este también son moraditas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>y son como si fueran espigas de la milpa su..., la espiga.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Esa que le llaman espiga,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>así son sus..., sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Así son sus flores y de altura así crece. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Algunas plantas también crecen así de alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>El de color rojo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>y el blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Esa planta hay dos tipos, yo lo..., lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>yo sé que hay dos tipos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>de este, y se...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>En algunas partes ve uno tirada la planta en el suelo cuando es cortada por la tuza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Esa la..., se la come, creo, tal vez tendrá su..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>su..., tendrá camote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>O si no, uno ve que se come la corteza en la superficie del tronco</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Lo corta, esa que le llaman &lt;i&gt;a:yo:iswat y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>pues acá nosotros siempre así lo llamamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>A:yo:iswat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Esa planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Y todos le llaman a:yo:xiwit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>todos,algunos así lo llaman,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>y pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>esa planta también es bonita,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>para sembrarla así, también lo..., también se usa para corral.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>Esa planta también se usa para corral así se siembra también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>también se siembra en hilera, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>también retoña y crece al..., al..., bueno crece alto y se da así bonita la planta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>Tapa a otras plantas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>O en algunas partes también la siembran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>O tambiém ocupan como adorno junto con otras flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Todo lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>también se usa para eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Y esa planta, esa la..., y algunos le llamamos este,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>palmita. Pero no, nosotros platicamos y lo llamamos diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>Sí lo llamamos de otra forma y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>pues esa planta se usa, se usa, este pa..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>Ese no se chiquea, donde se tira el tallo ahí retoña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>Retoña y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>a veces este su..., el otro, al pie del tronco</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>desde que empieza a crecer es de color rojo y así es toda la hoja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>Todo es de color rojo y el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>el otro es de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a463" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>Sí es blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>Es blanco y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a465" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>ese es lo que yo lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a466" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>conozco que sólo hay dos tipos. Sí, pero.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a467" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>pues este, esos dos tipos son los que yo conozco y para qué se usan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a468" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>Lo usan también lo..., en algunas partes siembran en hileras en las colindancias de los terrenos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a469" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Siembran en hileras o en otras partes siembran siquiera tres matas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>O siembran cuatro matas para,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>para darse a conocer en donde colindan sus terrenos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>Para eso sirve todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>Para eso ocupan, para que puedan ve..., ver</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>y así lo usan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>Y eso es lo que te platico que en algunos lugares siembran en hilera las varas para corral.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>En algunos lugares hay un voladero así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>para que no se derrumbe el terreno, para que no se derrumbe la tierra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>pues la siembran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>Siembran y las mismas plantas detienen la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>Ya lo detiene.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>En algunas partes he visto, o para que no pasen los pollitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>las siembran para corral y cuando crecen ya las plantas les cortan las puntas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Tumban la mata y queda el tocón</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>Se queda el tocón y lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>este después así empieza a retoñar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Sí eso es lo que yo sé y tal vez, usted ta lvez lo sabe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>A son más largas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a505" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>Pues yo no lo..., lo conozco esa planta este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a506" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>este, lo..., conozco. Pero el otro que es diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a507" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>Así me platican, yo les digo a otros que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
