        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>*igualito** nemi ne:wí:n kowtah, we:i ihkó:n.</ANNOTATION_VALUE>
