        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>yowi *hasta** ihkó:n [mo]pampilo:ti wa:n ista:k n' iteyo.</ANNOTATION_VALUE>
