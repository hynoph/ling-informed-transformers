    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Comentarios" PARTICIPANT="Comments" TIER_ID="Comments">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts7">
                <ANNOTATION_VALUE>{Aunque dijo que había cuatro tipos (na:wi) menciona solamente tres incluyendo el ahmo:lkilit que no es Amaranthaceae sino Phytolacca rivinoides  de la familia Phytolaccaceae}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts85">
                <ANNOTATION_VALUE>{En español 'perdiz', los de la familia Phasianidae}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>Ahora don Tacho platícanos cuantos tipos de wa:wkilit conoce usted.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>¿Y de los quelites que me platicas que son dos, el de color blanco y el rojo cómo son sus..., sus...,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>sus flores cómo son, son erectas o se cuelgan hacia abajo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>¿Y sus semillas son comestibles o no?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Bueno pues parece que ya es todo lo que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>nos platicaste de los dos quelites que conoces. Ahora dinos este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>tu nombre y del pueblo de donde vienes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>Este yo conozco cuatro tipos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>El primero es blanco, segundo que es rojo y otro que se da en el bosque.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>El que se da en el bosque es el que nosotros también le llamamos ahmo:lkilit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>Así le llamamos y todos esos son este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>ese es comestible, se exprime fuertemente con las manos y se prepara con salsa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>Nosotros le llamamos quiltonile, le llamamos quiltonile.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>Y otro también es igual, ése también es rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Ese también es bueno preparado con salsa, primero se exprime.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>Lo exprimen bien el quelite hervido, enseguida trituran los chiles para la salsa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>y ya se..., ya se consume.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Hay dos formas de preparar la comida, también se pueden freir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>Limpian el quelite, le sacan las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>porque se juntan los quelites con las semillas, las semillas son negras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>No hierven con las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>porque se hierve unto con las semillas el quelite sale de color negro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Yo conoz..., conozco dos formas de preparar, se..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>primero lo hierven en caldo y después lo guisan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>Lo guisan con manteca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>Y pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>eso es lo que yo sé, este lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>preparan la comida y ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>Pues el quelite de color rojo crece un poco alto y sus hojas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>en el haz tienen así como venitas, así tiene sus ramitas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>sus hojas son lisas. Y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>el quelite crece así derecho, en la punta de la planta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>va saliendo sus ramas y ahí se dan sus semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Sus semillas son de color negro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>Y el otro pues uno se da cuenta porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>el quelite de hojas blancas este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>crece y la punta se cuelga hacia abajo con sus semillas de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Tiene las semillas de color blanco y el otro quelite que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>se da en el bosque, quiltonile del bosque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>sus frutos se cuelgan por racimos sus..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>frutos son de color rojo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>después de que se secan van tomando un color amarillo hasta convertirse en negro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>Los pájaros también se alimentan con los frutos de ese quelite. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Esos frutos aprovechan los pájaros. Las semillas de los otros quelites nunca he visto que se los coman.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>El que se alimenta de esos frutos es el pájaro que le llaman</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>perdíz.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>El perdíz por allá en el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>bosque hay muchos perdices.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>No sé si la conocen pero es como un pollito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>Es muy parecido a un pollito que anda tri..., trillando por ahí</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>es igualito pero así anda en el bosque.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Enonces se alimenta de esos frutos, también anda debajo de otras plantas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>así veíamos antes a nuestros abuelos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>les ponían una cuerda</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>ponían así una cuerda torcida,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>algunos le llaman una mata de</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>al pie de la mata de quiltonile,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>y ahí se..., ahí iba el pajarito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>ahí metía su cabeza dentro de la cuerda, entonces se..., ahorcaba y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>empezaba a revolotear</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>el perdíz.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Los perdices son grandes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>son así de grandes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>como un pollito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Son como unos pollitos, son así de grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Esos son los que yo conozco, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>conozco esos pájaros y ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Pues los demás quiltoniles este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>este, más lo..., el otro quiltonile lo veo muy poco,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>el otro quiltonil, es el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>en donde ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Esa planta no puedo decir que la siembran así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>limpian el terreno y riegan así las semillas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>limpian bonito el terreno y rie..., riegan las semillas así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Nosotros decimos que riegan las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Limpian bien las semillas y las riegan así, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>cuando las plantas van creciendo así parejas se ve sí como un plano verde.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Cuando germinan las semillas así van creciendo las pequeñas plantas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>ya se cortan así muy verdes y tienen una fragancia agradable, se hierven los quelites en caldo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>También se pueden freir con manteca. (Freir con aceite o manteca. Guisar con salsa.)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>también le da un buen sabor si se le agrega la cebolla.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Nosotros veíamos a nuestros abuelos que así lo preparaban,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>lo..., hervían y lo exprimian bien con las manos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>y ponían en un plato de barro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>En el plato le echaban salsa de chiltepín.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Así queda muy sabrosa la comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Le da un buen sabor a,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>los quelites.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Y entonces este para...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>yo lo probé pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>que es muy sabroso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Así queda muy sabrosa esa comida,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>de quelites, esos quelites.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Así es, se comen todos así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Los quelites tiernos se les puede comer hasta los ta..., tallos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Al estar tiernos son buenos, pero cuando cuando los quelites ya están pasados no se pueden comer con el tallo están son duros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Pero cuando están tiernos se aprovecha,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>cuando todavía no, cuando todavía no producen semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Cuando ya tienen semillas ya tienen el mismo sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Ya no es igual porque los quelites se mezclan este con,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>cuando hierven se mezclan con las..., semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Pues el quelite ya no tiene el mismo sabor. También lo limpian porque,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>si ya están recios pues al..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>hervirlos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>junto con las semillas se mezcla y queda de color negra la</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>comida. Y el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>quelite blan..., blanco pues este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>el caldo no cambia de color, así sigue siendo de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Pero el caldo del quelite de color rojo, este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>queda así de color rojo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>el caldo queda todo así de color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Es rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>El agua le..., le echan es..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>porque las hojas del quelite son rojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>todo el tallo es de color ojo hasta la punta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Entonces cuando hierven,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>el caldo se convierte en rojo. Es de color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Y el otro de color blanco no se convierte en color rojo, ese pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>así queda de color blanco porque no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>no tiene un color.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>y el otro pues quien sabe por qué, creo que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>siempre ha sido de ese color hasta el tallo de,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>creo que así es la semilla cuando se riega. Pero otras personas dicen que la siembran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Pues yo lo..., lo vi hace años, lo..., riegan así en el suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Ahí nacen las plantas, algunas partes los ve uno así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>que están creciendo muchas plantas pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Ahí los corta uno y se..., llevan a la casa también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Pues eso es lo que yo lo..., lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>lo sé. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Pues el de color rojo crece así hacia arriba</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>y después de florear se cuelga hacia abajo un poco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Y otro que es,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>yo veía que el de color blanco,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>es igual, crece hacía arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Crece hacia arriba de..., sus semillas se van formando en hileras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Se van produciendo así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Entonces cuando las semillas ma..., maduran se cuelgan así hacia abajo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Y el otro pues también es igual, así se va..., de lado hacia abajo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Este no, yo creo que por el peso de las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>He visto que así se va de lado por sus semillas, porque produce muchas semillas así se..., se cuelga.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>La mata crece erecta, pero siempre sel va..., de lado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Así es, eso es lo que yo lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Pues las semillas nunca, nunca he visto que alguien las consuma,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>o que uno vea que se coman los pájaros, no.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>A..., así caen al suelo y germinan después</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Las  semillas germinan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Y nunca veo que se consuman o que alguien las consuma.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Eso es todo, se come el..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Del quelite no solo se consumen las hojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>se come todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Se come hasta el tallo si los quelites están tier..., tiernos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>se come todo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Todo, todo es comestible. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
