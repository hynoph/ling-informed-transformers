        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>kowtah ne:n kilto:ni:l, tehwa:n tikiliah kilto:ni:l,</ANNOTATION_VALUE>
