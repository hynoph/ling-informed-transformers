        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>pos yo:n mopihpilowa *por racimitos** ne:n i..., iteyo.</ANNOTATION_VALUE>
