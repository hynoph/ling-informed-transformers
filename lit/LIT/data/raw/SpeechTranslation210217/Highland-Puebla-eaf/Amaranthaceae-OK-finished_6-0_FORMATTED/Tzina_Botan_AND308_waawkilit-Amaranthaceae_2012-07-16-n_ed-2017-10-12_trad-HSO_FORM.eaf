            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>wa:n ompa mo..., ompa yowi nijó:n chiktehtsi:n,</ANNOTATION_VALUE>
