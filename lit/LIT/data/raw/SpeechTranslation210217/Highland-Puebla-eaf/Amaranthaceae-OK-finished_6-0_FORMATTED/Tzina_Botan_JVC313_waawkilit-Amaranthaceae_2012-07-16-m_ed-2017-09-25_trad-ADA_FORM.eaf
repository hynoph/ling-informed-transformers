        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>Ye:kma:alaxtsitsí:n pos no: kimanah wa:n ka:yohpatah kwaltsi:n we:lik no: ke:meh yo:n wa:wkilit, tatsoyo:n we:lik, kwaltsi:n yo:n.</ANNOTATION_VALUE>
