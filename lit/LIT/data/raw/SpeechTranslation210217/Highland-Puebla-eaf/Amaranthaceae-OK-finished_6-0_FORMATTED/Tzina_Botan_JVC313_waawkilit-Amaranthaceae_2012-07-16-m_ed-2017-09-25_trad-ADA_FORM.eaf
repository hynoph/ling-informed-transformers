        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>Tsikitsi:tsi:n wa:n a:mo kikwih ika *rollo**, ki..., kololte:mah sah n' tokni:wa:n kinamakah.</ANNOTATION_VALUE>
