        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>Ke:mah, nejó:n, ne:wí:n ahkokopa tak mochi:wa sah, pero onkak *semilla** ompa kika:wah.</ANNOTATION_VALUE>
