        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>Wa:n i:n seki wa:wkilit nochi we:lik tatsoyo:n.</ANNOTATION_VALUE>
