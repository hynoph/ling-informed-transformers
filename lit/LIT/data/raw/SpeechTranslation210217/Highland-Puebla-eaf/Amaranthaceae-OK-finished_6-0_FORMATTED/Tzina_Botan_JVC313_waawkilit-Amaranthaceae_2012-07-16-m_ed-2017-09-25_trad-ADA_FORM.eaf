        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>Nochi we:lik, sayoh mah se: kimati, mah mah se: kikwa sah.</ANNOTATION_VALUE>
