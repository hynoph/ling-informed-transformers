        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>Pero a:mo wa:wte..., a:mo wa:wkilit, sano no: taman yo:n xiwit.</ANNOTATION_VALUE>
