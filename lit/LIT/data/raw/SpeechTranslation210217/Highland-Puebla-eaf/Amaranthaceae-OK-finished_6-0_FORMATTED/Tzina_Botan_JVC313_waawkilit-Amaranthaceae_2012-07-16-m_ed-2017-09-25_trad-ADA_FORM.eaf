            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>Chika:waya wa:n a:mo kitekih, mo..., ompa paxi:i:ni *semilla** wa:n *cuando**,</ANNOTATION_VALUE>
