        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>Yo:n tsikitsitsi:n kitekih, yo:n, yo:n kwi:kwilwa:wkilit, a:mo chi:chi:lwa:wkilit.</ANNOTATION_VALUE>
