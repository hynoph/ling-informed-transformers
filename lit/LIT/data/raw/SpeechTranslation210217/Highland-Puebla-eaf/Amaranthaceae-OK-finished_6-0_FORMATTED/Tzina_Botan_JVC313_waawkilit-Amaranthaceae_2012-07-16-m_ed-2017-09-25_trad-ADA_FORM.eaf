        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>I:n, yo:n, a:mo, yo:n, yo:n kwa:lkwih seki, seki pané: wa:wkilit mochi:wa ne: para ahkokopa, nika:n ahkwa:kopa kito:kah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts181">
                <ANNOTATION_VALUE>Mochi:wa kimi:lowah ne:n wehweika n' tekitih, sake:ra seh se: *estajo**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts182" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>Nochi yehwa n' kitepe:wah yo:n pané: kilit. Pero i:pa kitekih iteyo sah, a:mo kitekih ikilyo.</ANNOTATION_VALUE>
