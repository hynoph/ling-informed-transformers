        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>Pero mi:lah nikita n' ki..., kitekitih, ka:mpa mi:lme:watih ya, *antes** a kitekitih yo:n kiltsí:n para monamakiliah.</ANNOTATION_VALUE>
