        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>*En lugar** kime:waskiah, ehkaw mochi:waskia, kitekih me:..., wa:wkilit wa:n kinamakah tsikits..., *por eso** e:ktsikitsi:n kinamakah ata.</ANNOTATION_VALUE>
