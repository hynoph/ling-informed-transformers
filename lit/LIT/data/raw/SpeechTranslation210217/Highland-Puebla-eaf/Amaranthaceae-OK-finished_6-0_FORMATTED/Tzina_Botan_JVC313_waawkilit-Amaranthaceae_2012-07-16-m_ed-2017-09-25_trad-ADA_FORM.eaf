        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>Wa:n nika:n tehwa:n kito:kah n' chi:chi:lwa:wkilit wa:n kito:kah n' ista:k wa:wkilit.</ANNOTATION_VALUE>
