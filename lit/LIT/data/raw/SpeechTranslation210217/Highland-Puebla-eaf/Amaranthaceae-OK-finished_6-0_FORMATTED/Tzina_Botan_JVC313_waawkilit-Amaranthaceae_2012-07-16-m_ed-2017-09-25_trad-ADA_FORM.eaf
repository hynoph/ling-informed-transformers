        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>Nika:n tehwa:n tiki:xmatih, a:mo tiki:xmatih nika:n, n' Ecatlán ki..., nochi kinamakah</ANNOTATION_VALUE>
