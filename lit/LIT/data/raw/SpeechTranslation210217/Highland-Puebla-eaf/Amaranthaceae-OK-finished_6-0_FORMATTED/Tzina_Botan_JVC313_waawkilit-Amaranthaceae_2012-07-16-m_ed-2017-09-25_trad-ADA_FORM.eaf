        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>Pero no: we:lik ka:yohpatah, se: kikwiti wehwei, wa:n ma:alaxtik yo:n, ma:k...,</ANNOTATION_VALUE>
