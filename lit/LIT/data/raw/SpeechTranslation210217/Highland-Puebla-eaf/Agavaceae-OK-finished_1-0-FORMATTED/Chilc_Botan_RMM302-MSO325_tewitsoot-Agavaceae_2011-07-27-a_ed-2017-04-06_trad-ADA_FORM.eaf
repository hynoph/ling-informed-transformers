    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="María Salazar Osollo" TIER_ID="María Salazar Osollo">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>Pos ke:mah, neh nikmaattok *que** kikwitih ne: para ahkokopa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>Pero a:mo nikmati ke:ní:w motano:tsa, pero ne: ahkwa:kopa kikwitih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a126" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>Ompaka ne: para ahkokopa 'kwitih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>Ke:mah, *porque** i:pa, i:pa nejó:n nikinka:kakilia:ni ke ompa ne: n' kikwitih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>Pero a:mo nikelna:miki ke:ní:w motano:tsa. Pero neli yo:n ompa ko:nkwih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>Pos tehwa:n i:pa tiki:xmatih, nejó:n, tewi:tso:t. Eh, tewi:tso:t. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>Pos miakeh yowih, nochi n' tein, tein ma:lto:mohmeh yetokeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>Komo e:yi:n, na:wi:n wa:n nochi, komo nochi motapowiah n' tein okseki, *porque** tein tikiliah pos se: tein,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>tein ma:lto:moh yetok tein taeka:ntok pos yeh tikiliah tein we:i tota:tah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>Yehwa yo:ni, komo moyo:le:wkeh nochi,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>kipiah se: nechiko:lis achto no: wa:n monohno:tsah nochi yo:n de non..., tein nochi n' tein yetokeh nejó:n, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>ne:n, nejó:n, *todiostsitsi:n** tio:pan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>Yehwa ya yo:ni monohno:tsah nochi wa:n komo nochi mota:kamatih, nochi yowih, pos miakeh yowih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts56" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>Ke:mah, yehwa n' tein, tein ompa ne: nejó:n yetikah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>yehwa n' tein taeka:ntok. Wa:n ompa sepa se: kitohtokatok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>Pos mosempale:wiah no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts74" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>Pero *cuando** se: ilwit mosempale:wiah yehwa yo:ni wa:n komo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>komo nochi yahkeh n' ka:mpa yehwa yo:n nikihtowa tein, tein ta..., taeka:ntok, ne:n, to...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>*tosantito** pos yehwa ya yo:ni tein taeka:ntok yo:n ompa nochi mochi:wa ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>wa:n ke:mah *cuando** yo:n kwaltia ya ne:n xo:chitsí:n kichihchi:wah ya pos,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>ki..., kiwi:kah ya n' ompa, ne:n, nejó:n, ne:n tio:pan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>Ompa ya n' kwi:kah, ompa ya ika tachihchi:wah pero komo nochi mopale:wiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>Wa:n komo a:mo nochi mopale:wihkeh pos a:mo nochi kintachihchi:wiah yo:n de xa:ntohkone:meh. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>A:, wa:n no: tik..., tikchi:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>A:, ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>Ajá.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts182" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>Ke:mah ta: onkak neli n' kihtowah wa:n neli n' kihtowah ka:mpa yo:n onkak neli kihtowah ke no: ye:kwitsyoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts188">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts202">
                <ANNOTATION_VALUE>Ke:mah, neli n' kihtowah ke witsyoh, eh..., eh..., ke:mah pos ta: kimattokehtein i:pa yowih neli *porque** neli *cuando** yo:n nikihtowa tehwa:n ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>nokni:w neli no: te:chyo:le:wka ke mah, nejó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>mah tehwa:n ne:, mah tikta:li:ka:n no: xo:chitsi:ni, tehwa:n te:chyo:le:wka, pero i:pa ne:chilwih yeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
                <ANNOTATION_VALUE>ke yeh, nejó:n, mah tehwan sayoh ni..., mah sayoh nika:ketsati:w yo:n xo:chitsi:ni wa:n yeh kikowas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts210" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>Wa:n neli yeh kikowaya wa:n neh nikona:ketsaya pero neli yehwa ne:, nejó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>nota:tahtsi:n neli ya:yahka no: *cuando** konkwikah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts216" TIME_SLOT_REF2="ts218">
                <ANNOTATION_VALUE>Wa:n neli n' kihtowa ke neli ye:kwitsyoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts220" TIME_SLOT_REF2="ts222">
                <ANNOTATION_VALUE>Wa:n kihtowa, "wa:n kinekih" kihtowa "mah se: kwi:ka" kihtowa, nejó:n, yo:n tepos tein ika nantate:xi:mah. Ke:mah, yehwa yo:ni kwi:kayah neli wa:n neli pos neli kiniwi:ka tepos.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>Pero neli *cuando** yo:n kehkoltiah ya, pos kihtowah seki:n, yehwa:n tein *tepota:dos** de, ne:n, tein i:n okseki:n, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
                <ANNOTATION_VALUE>nejó:n, xa:ntohtsitsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>kihtowah, "A:man", kihtowa, "mah tiki:xti:ka:n ya m' popo:chtsí:n, wi:tseh ya", kihtowah. *Porque cuando** yo:n wi:tsa ya neli, ne:n, tepos kakistitiwi:ts.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>No:, nejó:n, tsahtsiki a ke ehko ya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts232" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>Entó:s ihwa:k a yo:n kihtowah, xki:xti:ka:n ya kihtowah n' popo:ch wa:n tiowih tikpopo:chwi:tih.</ANNOTATION_VALUE>
