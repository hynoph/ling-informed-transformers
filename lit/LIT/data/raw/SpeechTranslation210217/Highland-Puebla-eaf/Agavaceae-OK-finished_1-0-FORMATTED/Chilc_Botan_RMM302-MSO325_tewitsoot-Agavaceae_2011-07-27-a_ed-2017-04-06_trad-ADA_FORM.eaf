        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a508" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Pues nosotros la conocemos con el nombre de tewi:tsot. Si, tewi:tsot. Mmm.</ANNOTATION_VALUE>
