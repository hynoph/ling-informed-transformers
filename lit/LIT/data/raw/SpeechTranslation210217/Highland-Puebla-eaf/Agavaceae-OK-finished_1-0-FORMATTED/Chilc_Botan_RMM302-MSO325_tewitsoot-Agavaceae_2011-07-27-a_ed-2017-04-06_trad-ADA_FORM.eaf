            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a461" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
                <ANNOTATION_VALUE>pos kiahsika:mattokeh nochi, nochi ke:ní:w yo:n talna:miki:lis mochi:wa. Pero ke:meh i:n tehwa:n tinemih,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a462" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
                <ANNOTATION_VALUE>mah tikihto:kan tehwa:n, *este**, wehkatsi:n ya de ne: ka:mpa n....,</ANNOTATION_VALUE>
