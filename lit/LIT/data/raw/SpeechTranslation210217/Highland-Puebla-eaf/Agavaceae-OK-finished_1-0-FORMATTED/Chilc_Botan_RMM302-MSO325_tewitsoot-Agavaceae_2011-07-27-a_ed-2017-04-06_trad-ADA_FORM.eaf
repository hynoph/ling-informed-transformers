        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>Pos yeh *mismo** [mo]te:nta:lih, yehwa ne: mote:nta:lih n' tokni:w, n' tokni:w ne: tein tayeka:ntok ne: mayo:ltomoh yehwa n' kihtoh. Kihtowa "a:mo teh ximolwi:ka:n", kihtowa "neh nika:n, tehwa:n tikitatih ke:ní:w t'chi:waskeh para titakwa:skeh, para t'mahse:waskeh n' taxkaltsí:n".</ANNOTATION_VALUE>
