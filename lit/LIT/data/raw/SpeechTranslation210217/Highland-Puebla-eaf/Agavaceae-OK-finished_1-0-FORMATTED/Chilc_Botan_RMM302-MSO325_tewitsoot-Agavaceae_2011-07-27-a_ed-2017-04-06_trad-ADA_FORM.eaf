                <ANNOTATION_VALUE>Ah, empezaron a comer. Si, pues da hambre pero...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a621" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>Mm, si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a642" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>Y luego ya empiezan a hacer las ruedas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a643" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>Cuando llega el día de la fiesta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a644" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>¿Y qué (hicieron) cuando salieron de la casa del mayordomo para llevar el arreglo a la iglesia?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a645" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>Al llevar las flores a la iglesia hubo... porque yo sé que cuando salen de la casa a la iglesia para llevar las flores</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a646" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>arregladas, cuando todo lo han hecho, suficiente para arreglar el altar de la imagen mayor eu es patron y las otras imágenes menore.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a647" ANNOTATION_REF="a275">
                <ANNOTATION_VALUE>una vez más, antes de salir de la casa con las flores, las sahuman y luego ya las llevan a la iglesia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a648" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>Si, yo sé que así lo hacen, cuando ya salen de la casa del mayordomo para llevar las flores a la iglesia, ya las llevan, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a649" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>Ya las acomodan sobre el fierro (quizá las llevan en camioneta)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a650" ANNOTATION_REF="a284">
                <ANNOTATION_VALUE>y luego otra vez se sahúman los arreglos florales antes de llegar a la iglesia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a651" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>Y luego ya inician a arreglar el altar mayor y los altares de otras imágenes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a652" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>Y ya empiezan a arreglar el altar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a653" ANNOTATION_REF="a288">
                <ANNOTATION_VALUE>por eso digo ...,  cuando mi hermano fue mayordomo nosotros lo apoyamos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a654" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>en ese entonces todovia arreglaron el altar (de otra forma) con el xo:chipetat, un arreglo grande.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a655" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>Ese arreglo lo ponen colgado. Lo habían hecho y habían hecho un arreglo sobre la superficie de la pared, tapizando con las flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a656" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>Si, yo sé que así lo hacen, así lo hicieron, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a671" ANNOTATION_REF="a300">
                <ANNOTATION_VALUE>[en esa parte] también adornaron.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a672" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>Si. Siempre así lo hace, cada vez que terminan de arreglar la iglesia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a673" ANNOTATION_REF="a308">
                <ANNOTATION_VALUE> Ah, pues, es cierto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a674" ANNOTATION_REF="a310">
                <ANNOTATION_VALUE>Ya nunca fuiste. Ya no, pues yo se que el arreglo de la iglesia lo realizan en esos dias,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a675" ANNOTATION_REF="a311">
                <ANNOTATION_VALUE>Como el veintiseis de septiembre ya adornan la iglesia porque ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a676" ANNOTATION_REF="a312">
                <ANNOTATION_VALUE>O a veces adornan mucho más antes porque se arealizan bautizos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a677" ANNOTATION_REF="a313">
                <ANNOTATION_VALUE>o los jovenes hacen la primera comunion por eso el arreglo de la iglesia lo hacen mucho más antes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a678" ANNOTATION_REF="a314">
                <ANNOTATION_VALUE>Pero es cierto, cuando el arreglo lo hacen mucho más antes, el dia veinti (siete)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a679" ANNOTATION_REF="a315">
                <ANNOTATION_VALUE>(veinti) siete de septiembre, en esos dias,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a680" ANNOTATION_REF="a316">
                <ANNOTATION_VALUE>ya bajan la imagen de su nicho al piso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a681" ANNOTATION_REF="a317">
                <ANNOTATION_VALUE>Si, ya lo bajan de su nicho al piso, es en ese dia porque yo también ahí estuve, ese dia fue cuando bajaron la imagen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a686" ANNOTATION_REF="a318">
                <ANNOTATION_VALUE>y ahí estábamos, sahumamos la imagen. Mientras todavía está en el nicho</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a687" ANNOTATION_REF="a319">
                <ANNOTATION_VALUE>y así lo bajan, pues tiene (escaleras) por donde subirse</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a688" ANNOTATION_REF="a321">
                <ANNOTATION_VALUE>Una vez que lo bajaron, por delante llevaban el sahumerio</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a689" ANNOTATION_REF="a322">
                <ANNOTATION_VALUE>El mayordomo es el que trae el sahumerio en la mano  lo trae el mayordomo del patrón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a690" ANNOTATION_REF="a323">
                <ANNOTATION_VALUE>y las personas que les llaman como diputados, por lo menos unos tres o cuatro, entre todos se ayudan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a711" ANNOTATION_REF="a324">
                <ANNOTATION_VALUE>Éramos muchas, fuimos como siete mujeres. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a712" ANNOTATION_REF="a325">
                <ANNOTATION_VALUE>Yo sé perfectamente porque fui (a ayudar).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a713" ANNOTATION_REF="a331">
                <ANNOTATION_VALUE>No. Pues el que decide (quizá coordina) es el mayordomo de la imagen del patrón del pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a714" ANNOTATION_REF="a332">
                <ANNOTATION_VALUE>Es el que presencía todas las actividades de la iglesia e incluso cuando bajan la imagen debe estar presente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a715" ANNOTATION_REF="a333">
                <ANNOTATION_VALUE>Debe estar ahí, es el mayordomo de la imagen del patrón del pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a716" ANNOTATION_REF="a334">
                <ANNOTATION_VALUE>Si, va el mayordomo del patrón porque yo he visto que es el que le quita todo lo que tiene (los accesorios y ropa de la imagen al bajarlo del nicho y posteriormente cambiarle la ropa)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a717" ANNOTATION_REF="a335">
                <ANNOTATION_VALUE>Todo lo que tiene en la cabeza y en la mano tiene una pieza de madera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a718" ANNOTATION_REF="a336">
                <ANNOTATION_VALUE>Y todo lo que tiene en la mano, todo se lo quitan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a719" ANNOTATION_REF="a337">
                <ANNOTATION_VALUE>Si, así lo bajan, las alas también se las quitan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a720" ANNOTATION_REF="a338">
                <ANNOTATION_VALUE>Pero hace todo esto es el presidente auxiliar. No es permitido que haga otra persona, es el presidente quien le quita todos los accesorios que tiene la imagen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a721" ANNOTATION_REF="a339">
                <ANNOTATION_VALUE>Después de haberlo bajado lo ponen sobre una pieza grande echa de madera,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a722" ANNOTATION_REF="a340">
                <ANNOTATION_VALUE>y ya puesto abajo sobre la madera ya inician a vestirlo y le ponen nuevamente los accesorios y ya lo acomodan sobre unos palos que servirán para sostenerlo en el momento de la procesión. Se lo amarran bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a723" ANNOTATION_REF="a341">
                <ANNOTATION_VALUE>(Las piezas de madera que se lo ponen atravesado) se lo amarran bien y al terminar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a724" ANNOTATION_REF="a342">
                <ANNOTATION_VALUE>al terminar de amarrar  y ya lo acomodan y cuando se realice la, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a725" ANNOTATION_REF="a343">
                <ANNOTATION_VALUE>cuando ya se realice la misa, si, ¿como se dice? pues ya toman de los palos amarramos al imagen para sostenerlo y llevar a la procesión </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a726" ANNOTATION_REF="a344">
                <ANNOTATION_VALUE>Si, cuando se realiza esa parte del rito de la fiesta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a727" ANNOTATION_REF="a345">
                <ANNOTATION_VALUE>Pues si, antes de bajarlo le quitan todos los accesorios y abajo ya le colocan los accesorios y le ponen los palos atravesados (para sostenerlo para la procesión)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a728" ANNOTATION_REF="a347">
                <ANNOTATION_VALUE>Lo amarran bien pero ...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a729" ANNOTATION_REF="a348">
                <ANNOTATION_VALUE>Pues no lo hace cualquier persona, el que podía hacer muy bien era el señor Luis Domínguez, pero ya falleció.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a730" ANNOTATION_REF="a350">
                <ANNOTATION_VALUE>El sabía muy bien hacer el amarre, yo siempre veía que a él se lo dejaban para que le amarre los palos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a731" ANNOTATION_REF="a351">
                <ANNOTATION_VALUE>de tal manera que quedara muy bien. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a732" ANNOTATION_REF="a353">
                <ANNOTATION_VALUE>Si. Actualmente no sé, pero parece que quedaron sus hijos, ellos saben hacer el amarre de los palos de la imagen. José y Miguel son los que pueden hacer el amarre porque el papá, el señor Luis por mucho tiempo fue el que le amarraba los palos con el lazo a la imagen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a733" ANNOTATION_REF="a354">
                <ANNOTATION_VALUE>(Don Luis Domínguez) por mucho tiempo le amarró los palos a la imagen y también era diputado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a734" ANNOTATION_REF="a355">
                <ANNOTATION_VALUE>Por eso sé que el sabía, pues veíamos cómo lo hacía.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a735" ANNOTATION_REF="a363">
                <ANNOTATION_VALUE>No, la bendición se realiza el dia veintisiete de septiembre, es cuando bendicen toda la ropa nueva que se lo regalan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a736" ANNOTATION_REF="a365">
                <ANNOTATION_VALUE>En ese dia. Solamente bendicen toda la vestimente nueva de la imagen</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a737" ANNOTATION_REF="a367">
                <ANNOTATION_VALUE>Aha, realizan la bendición de la vestimenta del patrón de la iglesia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a738" ANNOTATION_REF="a368">
                <ANNOTATION_VALUE>Si. Ese dia solamente eso realizan y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a739" ANNOTATION_REF="a369">
                <ANNOTATION_VALUE>pues ese día la imagen que le sigue tambien estrena ropa. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a740" ANNOTATION_REF="a371">
                <ANNOTATION_VALUE>Ese mismo dia también le compran ropa a..., el que le llaman San Francisco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a741" ANNOTATION_REF="a373">
                <ANNOTATION_VALUE>A:, Eso es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a742" ANNOTATION_REF="a374">
                <ANNOTATION_VALUE>En ese dia, se hacía la bendición de todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a743" ANNOTATION_REF="a376">
                <ANNOTATION_VALUE>No, pues no sé, la verdad no sé porqué, eso empezó hace poco en que se festeja al mismo tiempo, pero la fiesta de esa imagen se celebra en,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a760" ANNOTATION_REF="a377">
                <ANNOTATION_VALUE>Parece que se le festeja es el dia veinte de marzo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a761" ANNOTATION_REF="a379">
                <ANNOTATION_VALUE>No. No se le festeja el mismo dia pero no se porqué (ahora hacen así), eso empezaron a realizar hace poco tiempo, hace como</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a762" ANNOTATION_REF="a381">
                <ANNOTATION_VALUE>unos cuatro o cinco años, no recuerdo bien, pero empezó cuando se realiza, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a763" ANNOTATION_REF="a383">
                <ANNOTATION_VALUE>(un dia) se realizó la procesión y también lo anexaron pero antes, la imagen de San Gabriel no se sacaba durante la procesión.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a764" ANNOTATION_REF="a386">
                <ANNOTATION_VALUE>No, pue syo sé que lo conocen como San Miguel (el más pequeño- San Miguelkone:t).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a765" ANNOTATION_REF="a388">
                <ANNOTATION_VALUE>Si, la imagen al que le llaman San Miguekone:t porque el otro es San Miguel grande.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a766" ANNOTATION_REF="a390">
                <ANNOTATION_VALUE>Y otro le llaman San Miguel kone:t. Si, yo sé que siempre le han llamado con ese nombre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a767" ANNOTATION_REF="a392">
                <ANNOTATION_VALUE>Si. Si, es el que se sigue, (en orden de importancia), pues yo siempre he escuchado que le han llamado como San Miguelkone:t y el otro como San Miguel grande, es el que le festejan la fiesta. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a768" ANNOTATION_REF="a393">
                <ANNOTATION_VALUE>Pero en el mes de septiembre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a769" ANNOTATION_REF="a395">
                <ANNOTATION_VALUE>SI, es lo que yo comento, el dia veintisiete y el veinti...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a770" ANNOTATION_REF="a396">
                <ANNOTATION_VALUE>(veinti)ocho, ese día, es la entrada de la cera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a771" ANNOTATION_REF="a398">
                <ANNOTATION_VALUE>Si, es la entrada de la cera. El dia de la entrada de la cera, acude mucha gente (a la casa del mayordomo) para acompañar a la imagen conocido como San Miguel grande (we:i San Miguelito),</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a772" ANNOTATION_REF="a400">
                <ANNOTATION_VALUE>Acude mucha gente, van los diferente grupos de danzantes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a773" ANNOTATION_REF="a402">
                <ANNOTATION_VALUE>Hay muchos tipos de danzantes. Por lo menos unos diez grupos de danzantes. Son muchos, yo sé que son muchos. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a774" ANNOTATION_REF="a405">
                <ANNOTATION_VALUE>No, viene mucha gente a visitar la imagen, viene gente de otros pueblos lejanos, no solamente festeja al gente que vive en el pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a775" ANNOTATION_REF="a407">
                <ANNOTATION_VALUE>si, vienen de otros lugares lejanos a visitar la imagen. Si, viene mucha gente el dia que hacen la entrada de la cera y en el dia de la fiesta pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a776" ANNOTATION_REF="a408">
                <ANNOTATION_VALUE>el dia veintinueve, es el dia que celebran la fiesta de la imagen grande de San Miguel conocido como "We:i San Miguelito".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a777" ANNOTATION_REF="a409">
                <ANNOTATION_VALUE>Ese dia se le festeja,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a778" ANNOTATION_REF="a410">
                <ANNOTATION_VALUE>ese dia, si uno quiere se puede ir a las tres de la mañana,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a779" ANNOTATION_REF="a411">
                <ANNOTATION_VALUE>porque los músicos van desde muy temparanos (en la madrugada) a </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a780" ANNOTATION_REF="a413">
                <ANNOTATION_VALUE>cantarle las mañanitas. Eso es,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a781" ANNOTATION_REF="a414">
                <ANNOTATION_VALUE>y cuando ya se acaba el evento, si acaso termina a eso de las</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a784" ANNOTATION_REF="a415">
                <ANNOTATION_VALUE>seis de la mañana o siete de la mañana, entonces ya se regresa uno a la casa del mayordomo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a785" ANNOTATION_REF="a416">
                <ANNOTATION_VALUE>ahí llega uno, al llegar allí, a uno le dan de comer (almuerzo) o por lo menos dan un atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a786" ANNOTATION_REF="a417">
                <ANNOTATION_VALUE>Si, pero todos los que van a tocar la musica de las mañanitas a San Miguelito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a787" ANNOTATION_REF="a418">
                <ANNOTATION_VALUE>a todos les dan de comer (almorzar). los llevan a la casa del mayordomo de la imagen de San Miguel Grande.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a788" ANNOTATION_REF="a419">
                <ANNOTATION_VALUE>los invitan a todos. A todos les dan de comer (almorzar).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a789" ANNOTATION_REF="a420">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a831" ANNOTATION_REF="a430">
                <ANNOTATION_VALUE>Pues yo veo que sigue igual, siguen haciendo las costumbres como antes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a832" ANNOTATION_REF="a431">
                <ANNOTATION_VALUE>Si, porque veo que siguen bailando varios grupos de danzantes. Si, yo veo que siguen practicando igual.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a833" ANNOTATION_REF="a433">
                <ANNOTATION_VALUE>Pues se juntan varios grupos, por lo menos unos doce grupos de danzantes, ¡Son muchos!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a834" ANNOTATION_REF="a435">
                <ANNOTATION_VALUE>¡Son muchos! Si, son muchos. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a835" ANNOTATION_REF="a437">
                <ANNOTATION_VALUE>Son de diferentes tipos de danzantes, no es de un solo, si son distintos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a836" ANNOTATION_REF="a438">
                <ANNOTATION_VALUE>Si.  Es todo lo que yo sé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a837" ANNOTATION_REF="a446">
                <ANNOTATION_VALUE>Pues así se perderán.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a838" ANNOTATION_REF="a449">
                <ANNOTATION_VALUE>A:, ahí no se hace igual, pero nosotros allá en nuestro pueblo pues se hace la mejor fiesta porque participan diferentes danzantes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a839" ANNOTATION_REF="a451">
                <ANNOTATION_VALUE>Yo creo que (estas costumbres) nunca se perderán, pues ahora, los jovenes les gusta participar, hay mujeres que danzan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a840" ANNOTATION_REF="a452">
                <ANNOTATION_VALUE>Y hace tiempo no era así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a841" ANNOTATION_REF="a454">
                <ANNOTATION_VALUE>Mm. Ahora, las mujeres también participan, yo creo que nunca desaparecerá porque los jovenes les interesa conservar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a842" ANNOTATION_REF="a467">
                <ANNOTATION_VALUE>Pues ya está haciéndose la fiesta, pues uno no sabe. Pues yo tampoco sabía pero como te digo que cuando mi hermanos nos había invitado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a843" ANNOTATION_REF="a468">
                <ANNOTATION_VALUE>fue cuando vi todo. Pero no sé, quizá otras personas sepan más que yo, quien sabe, pero yo te cuento solamente de lo que ví (en ese entonces) pero es cierto, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a844" ANNOTATION_REF="a469">
                <ANNOTATION_VALUE>así uno va aprendiendo de cómo se hacen las actividades.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a790" ANNOTATION_REF="a474">
                <ANNOTATION_VALUE>Si, pues así lo vienen practicando desde hace mucho tiempo. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a845" ANNOTATION_REF="a477">
                <ANNOTATION_VALUE>Si, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a846" ANNOTATION_REF="a479">
                <ANNOTATION_VALUE>No es nada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a847" ANNOTATION_REF="a480">
                <ANNOTATION_VALUE>Si, no es nada, muchas gracias. Yo me llamo María Salazar Osollo, vengo de San Miguel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
