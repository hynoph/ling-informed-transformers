        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a599" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Luego nos fuimos pero también nos pusimos con el mayordomo mayor (para las actividades), quien es es el responsable de ver las actividades a realizar para la fiesta</ANNOTATION_VALUE>
