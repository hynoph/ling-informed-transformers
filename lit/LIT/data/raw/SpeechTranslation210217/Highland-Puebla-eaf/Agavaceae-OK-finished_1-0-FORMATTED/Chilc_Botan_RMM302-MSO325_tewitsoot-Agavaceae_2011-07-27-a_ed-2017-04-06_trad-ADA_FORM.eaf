            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a587" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>para que nosotros fueramos como diputados (persona que se encarga de hacer el arreglo floral del altar) pero él nos anticipó, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a588" ANNOTATION_REF="a220">
