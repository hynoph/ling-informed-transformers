            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a466" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts705">
                <ANNOTATION_VALUE>tehwa:n ihwa:k tiahsih i:pa mochi:wtok a ne:n ilwitsí:n. I:pa mochi:wtok a n' ilwitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a470" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
                <ANNOTATION_VALUE>Pos tak neh niki:xehekowa i:pa iwki sah eski ta: ke:meh neli tehwa:tsi:n. Pos no: tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a471" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
                <ANNOTATION_VALUE>no: moi:xpan no:, moi:xpan pano:tiwi:ts a wa:n moi:xpan onkak a nel..., nejó:n ilwitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a472" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
                <ANNOTATION_VALUE>Nochi nejó:n tachihchi:walis, nejó:n talna:miki:lis pos</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a473" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts719">
                <ANNOTATION_VALUE>neh niki:xehekowa i:pa iwki sah eski. Neli wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a475" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
                <ANNOTATION_VALUE>t'chiaskiah mah a:mo ke:man koto:niskia ne: yo:n talna:miki:lis,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a476" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts724">
                <ANNOTATION_VALUE>mah kisentokaskia para ihkó:n pos nochi mah nochipa kwaltsi:n ki:sa n' ilwitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a478" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts729">
                <ANNOTATION_VALUE>Pos yehwa sah yo:n ika nimitsnohno:ts, *es...**, tasohka:matik miak. Neh nimono:tsa Rubén Macario Martínez, niwa:le:wa de nika:n Chilcuauhta, nipowi ne:pa, nika:n San Miguel.Pero neh achi wehkatsi:n ninemi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Rubén Macario Martínez" PARTICIPANT="Rubén Macario Martínez" TIER_ID="RMM Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>A ver señora, yo quiero saber sobre</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>el conocimiento de los antepasados, en aquéllos tiempos usted, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>quizá usted sepa cómo elaboraban, este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>sobre el conocimiento de la elaboración del arreglo floral.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Yo no sé de donde lo traen, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>quizá usted sepa en donde lo colectan, yo me imagino que también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>debe haber un lugar especifico en donde se produzca ese tipo de flor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a489" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>¿Y cómo se llama esa flor?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Tewi:tsot.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a491" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Y cuando van a cortar el tewi:tso:t (flor de cucharilla), ¿Cuántas personas van?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>o ¿Cómo se organizan cuando van a traerlas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a493" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Aha. Y eso, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a494" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Las imagenes que van después del patrón del pueblo. Porque me imagino hay uno que es la imagen mayor, el que tiene la delantera, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a495" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>el patrón mayor, el que está al fondo de la iglesia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a496" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Él.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a497" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Y los santos más pequeños tienen</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a498" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>deben tener quien les ponga las flores, tiene que ser el mismo dia, cuando todos deciden ir a traer las flores, ese mismo dia tienen que ponerle el arreglo de las imágenes más pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a499" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Bueno, podemos decir que cuando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a500" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>cuando llega el día de la fiesta patronal, ponen los arreglos florales de la cucharilla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a501" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>o entre todos se ayudan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Se ayudan entre todos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a526" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Yo también sé que hacen de esa manera, te cuento de lo que sé,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a527" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>una me había tocado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a528" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>hacer esta tradición que se trae desde hace mucho tiempo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a529" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>Es verdad como lo comentas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a530" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>así como tú me comentas, también te voy a comentar, que ambos comentemos de lo que hemos visto a lo largo de nuestras vidas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a531" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>Tambiéb me había tocado arreglarle el altar un,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a532" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>una imagen. Por tener esa imagen, me avisaron que...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a533" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Porque hay un solo día específico que se debe realizar esa actividad. No son tantos dias. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a534" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Empieza por el mes de julio o</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a535" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>o a veces un poco antes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a536" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Nos avisan en junio o en julio para que...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a537" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>uno sea el mayordomo de una imagen</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a538" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Una vez me invitaron, vino una persona a verme en mi casa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a539" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>la autoridad. Pues hay una autoridad comisionada para invitar a las personas para que sean mayordomos alguien, visita casa por casa (hasta completar el número de mayordomos que necesitan.)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a540" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Vino a mi casa como dos ocasiones.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a541" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Pues yo le pensé bien y me gusto ser...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a542" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>pues como decimos, no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a543" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>no podemos rechazar cuando nos invitan  a ser mayordomos, pues se trata de nuestro pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a544" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Entonces acepté ser mayordomo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a545" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>Fue la primera vez que acepté ser mayordomo, apoyar en esa actividad religiosa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a546" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Si, también colaboré en la mayordomía.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a547" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>A mi me había tocado la imagen mas pequeña respecto a la orden de importancia, el hecho de que yo fuera mayordomo de una imagen no tan importante, no significó que mi participación no fuera importante en la fiesta patronal...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a548" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>que no me hayan considerado, sin embargo también me consderaron en las actividades de la fiestra patronal,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a549" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>en la fiesta, cuando se acercaba la fiesta empezaron a organizarse</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a550" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>Mientras más se acercaba el dia de la fiesta patronal </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a551" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Ya muy próximo a la fiesta del pueblo, vinieron a avisarme para que los apoye en ir a traer algo, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a552" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>algo de flor de cucharilla por allá arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a553" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Pero es verdad, como tu comentas, yo tampoco sé en donde se da esta flor</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a554" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>Empecé a preguntar. Le digo, ¿Y hasta donde vamos? Me responde, "Vamos hasta por allá arriba, en la parte donde hace mucho frio" me dice, "por esa parte hay esa flor".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a555" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>¿Y cómo se llama el lugar? Dice, "Pues ya veremos por donde nos vamos" dijo, "Por Santa Cruz</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a556" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>ó vamos a Tepeyahualco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a557" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>O vemos por donde vamos (a conseguir). Pero,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a558" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Bueno, ¿Vas a ir o no? Le contesté, "Pues yo cre que sí voy a ir" le contesté, "y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a559" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>Y por qué no, no puedo rechazar esa comisión para eso acepté ser mayordomo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a560" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>me propusieron para apoyar en estas actividades, pues voy a ayudar para la hacer </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a561" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>lo que se viene haciendo desde hace tiempo, así le dije, lo que nos dejaron nuestros antepasados, le dije.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a562" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>Me fuí, salimos muy temprano, quizá eran como a las tres, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a563" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>tres de la mañana, en la madrugada, nos levantamos y nos fuimos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a564" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>Nos fuimos en camión, íbamos avanzando poco a poco y ya cuando nos íbamos acercando al lugar, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a565" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>nos desviamos y allá donde llegamos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a566" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>llegamos al lugar donde hay flores, tomamos nuestra herramienta para cortar l</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a567" ANNOTATION_REF="a206">
                <ANNOTATION_VALUE>las flores. Hay muchísimas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a568" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>Hay muchisimas. Hay muchísimas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a569" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>Tiene muchas espinas y es cierto como tú comentas, como vamos varias personas para cortar las flores, pues lo hacemos muy rápido, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a570" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>digamos que, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a571" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>nadie estuvo solamente viendo que hacíamos, sino que todos trabajamos. Llevamos un costal y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a572" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>cada quien llevó un costal y un lazó de ixtle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a573" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>El lazo de ixtle lo cortamos en pezados y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a574" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>con ello fuimos amarrando cada cabeza de la flor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a582" ANNOTATION_REF="a216">
                <ANNOTATION_VALUE>se envuelven en costales para protegerse de las espinas y ya se acarrean, cargandolas con las manos. Por las espinas es dificil agarrarlas, se debe buscar la manera de agarrarlas para no espinarse. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
