                <ANNOTATION_VALUE>tiknohno:tsato neli yo:n tio:tak wa:n pe:wkeh tikilwiah ya ke:ní:w n' totaxkaltsi:n tikilwiah pos</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
