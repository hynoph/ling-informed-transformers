        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
                <ANNOTATION_VALUE>Tein neli, yehwa tak nochi yowal yo:n motekiti:ltihkeh yehwa yo:n tokni:wa:n, kichi:wkeh seki tamaltsí:n.</ANNOTATION_VALUE>
