        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a463" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
                <ANNOTATION_VALUE>ka:mpa mochi:wa n' ilwitsí:n, pos no: tiowih tehwa:n, no: 'tapale:wi:tih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a464" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
                <ANNOTATION_VALUE>A:mo ihwa:k *cuando mero, mero este**, mah tikihto:ka:n tehwa:n yo:n,</ANNOTATION_VALUE>
