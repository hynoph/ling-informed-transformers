            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a510" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Si son tres ó cuatro ó si todos los mayordomos se comunican entre ellos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a511" ANNOTATION_REF="a136">
