            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a595" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>Dicen "ahora saquemos el sahumerio para sahumar porque ya vienen. Porque cuando vienen llegando, a lo lejos se escucha que camión que los transporta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
