        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>No sé si tú conozcas a la flor del hule, se parece y son blancas y un poco alargadas. Sobre la superficie de...,</ANNOTATION_VALUE>
