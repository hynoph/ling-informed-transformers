        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>Así es, se puede usar para eso.</ANNOTATION_VALUE>
