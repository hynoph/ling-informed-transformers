        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Cortamos las flores y como todavia no tenemos uso de razón, las ensartamos y con ellas hacemos collares.</ANNOTATION_VALUE>
