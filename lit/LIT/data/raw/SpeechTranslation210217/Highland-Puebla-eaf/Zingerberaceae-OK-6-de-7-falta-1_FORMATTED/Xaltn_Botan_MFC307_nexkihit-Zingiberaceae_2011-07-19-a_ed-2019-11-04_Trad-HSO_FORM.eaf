    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Bueno señora pues ahora platícanos acerca del,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>&lt;i&gt;nexkihit&lt;/i&gt; que se da por aquí, si es comestible, para qué se usan sus hojas, si las raices se usan para curar algo, o platícanos algo de lo que usted sabe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Bueno decías hace rato que este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>las hojas del &lt;i&gt;nexkihit&lt;/i&gt; se pueden ocupar para envolver los tamales. Usted nos dijo del</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>&lt;i&gt;etixtamal&lt;/i&gt;. ¿Qué otro tamal se puede envolver con estas hojas?/</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a501" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>También nos platicas que los ejotes también se ocupan para preparar tamales, se revuelven con la masa. ¿Cuáles son los ejotes que se pueden usar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Puedes platicarnos cómo es la planta del &lt;i&gt;chichime:kohexo:t&lt;/i&gt;, cómo son sus hojas y el frijol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a524" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE> Y el frijol que le llamas pitañelo ¿cómo es?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a525" ANNOTATION_REF="a210">
                <ANNOTATION_VALUE>Ahora en qué mes se da el frijol &lt;i&gt;chichime:koh&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a526" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>Y el &lt;i&gt;etsitsi:n&lt;/i&gt; ¿cuando se da?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a527" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>Bueno hace rato nos platicabas también que cuando maduran los frutos del,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a528" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>&lt;i&gt;nexkihit&lt;/i&gt; se van a traer. ¿Puedes platicarnos con calma cómo se limpia?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a633" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>Ahora dices que cuando lo..., hierves el &lt;i&gt;nexkihit&lt;/i&gt; que ya está limpio le agregas algunas hojas. ¿Qué hojas le agregas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a634" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>Bueno, ahora, el &lt;i&gt;nexkihit&lt;/i&gt; que hay ¿es uno nada más o hay otro que le llaman &lt;i&gt;itahta:y&lt;/i&gt;?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a635" ANNOTATION_REF="a301">
                <ANNOTATION_VALUE>¿Nos puedes platicar cómo es la planta y si también se usan sus hojas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a636" ANNOTATION_REF="a320">
                <ANNOTATION_VALUE>Y el que usted le llama &lt;i&gt;xoko:ktamalistat&lt;/i&gt; ¿usaban las hojas para envolver el &lt;i&gt;xoko:tamal&lt;/i&gt;?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a637" ANNOTATION_REF="a329">
                <ANNOTATION_VALUE>Ahora dices, este, que envolvias los tamales con esas hojas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a638" ANNOTATION_REF="a330">
                <ANNOTATION_VALUE>usabas una, dos, tres o cuántas hojas porque esta planta tiene las hojas más pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a639" ANNOTATION_REF="a342">
                <ANNOTATION_VALUE>Parece que es todo lo que nos platicaste acerca del &lt;i&gt;nexkihit&lt;/i&gt;, este, ¿O tienes algo que platicarnos todavía?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a640" ANNOTATION_REF="a368">
                <ANNOTATION_VALUE>Bueno pues si fue todo lo del &lt;i&gt;nexkihit&lt;/i&gt; dínos tu nombre y del pueblo de donde vienes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a641" ANNOTATION_REF="a371">
                <ANNOTATION_VALUE>¿Puedes decirnos tu nombre?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Ocotlán Fermín Cabrera" PARTICIPANT="María Ocotlán Fermín Cabrera" TIER_ID="MFC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Mm. Sí, este lo..., cuando maduran los frutos del &lt;i&gt;nexkihit&lt;/i&gt; los vamos a cortar en donde se producen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>Y al llegar a la casa los pelamos y lo limpiamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>después de pelarlos primero lo..., restregamos la pulpa con las manos y ya hacemos la comida</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>lo restregamos como cuando lavamos el nixtamal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Y entonces ya lo, si es necesario lo..., lo colamos con una coladera que le llamamos cedazo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Si vemos que es difícil quitarle las semillas con las manos. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>Enseguida lo hervimos y le agregamos algunas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Le agremos hojas o bien la agregamos cebolla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>para consu..., consumirlo ya.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>Y lo..., también le decimos,  también hacemos ya las tortillas porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>para comer las tortillas calientes con la comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>De este..., después de comer, ya..., ya comimos tod..., toda la familia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Entonces este se..., nos acordamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>comprar los frijoles,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>lo..., un poquito de ejotes o si tenemos los ejotitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>cortamos las hojas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>las partimos. Le quitamos la nervadura central de la hoja,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>y ya hacemos los tamalitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>revolvemos muy bien la masa con los frijoles,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>las revolvemos con la masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>Le agregamos sal y un poquito de manteca lo..., también le agregamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Y ya le ponemos este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>ahora, actualmente ya no usamos mucho la..., sal caliza, ahora ya usamos carbonato.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Para que se cuezan bien los tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Luego cuando ya se cuec..., sacamos uno,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>y lo probamos si tiene buen sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Si ya tiene un buen sabor, ya se cosieron los frijolitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>entonces sacamos del fogón la olla y lo..., nos sentamos a comer, llamamos a</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>si tenemos hijos o puede ser nue..., nue..., nuestro esposo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>le decimos que ya coma también porque ya se cocieron los tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Y este, de..., que ya se cuecen los tamalitos, entonces llamamos a nuestros hijos para que ya vengan a comer junto con nosotros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Les decimos, "Coman, yo preparé una,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>salsa. Salsita para dar..., darle sabor</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>para que..., poder comer junto con los tamalitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Pero es cierto que lo..., pero a veces</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>que también, también, podriamos preparar los tamales de frijol molido,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>también preparamos los tamales de frijol molido, hervimos los frijoles y molemos </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>preparamos la masa y lo..., lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>lo preparamos con nuestras manos o en el mismo metate,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>cortamos en tres pedazos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>y lo ponemos..., las bolitas de masa las rodamos en el metate,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>para que aumente la masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Si vemos que no cabe en el metate, dividimos la masa en dos partes y apartamos la otra mitad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>y aquí ponemos ya la,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>pero nuestra masa volvemos a rodar en el metate,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>para que con eso vuelva aumentar. Si vemos que otra vez no cabe,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>y las bolitas de masa deben ser de este tamaño no mu..., muy grandes. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Sacamos siquiera tres pedacitos y luego hacemos este, comemos, este lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>hervimos los tamales envueltos con hojas de &lt;i&gt;nexkihit&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Con hojas de &lt;i&gt;nexkihit&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>otra ves lo..., hacemos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>y hervimos un...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>si pensamos matar una gallinita, preparamos la comida de gallina</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>para comerlo preparado con ajonjolí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>La carne de pollo lo vamos a preparar con ajonjolí para comerlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Consumimos carne de gallina porque nos gusta, tiene otro olor diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Tiene un buen olor, también le da sabor al,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>le da un buen sabor al frijol molido hecho en tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Al darle sabor pues sale muy sabro..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>si nos  da una buena vida  nuest...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>nuest..., nuestro padre, pues comemos a gusto, comemos bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Si llega la tarde, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>ya en la tarde descansamos contentos. Yo no estás con..., enojado o estás lo..., pensando o, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>te encuentras triste porque no comiste.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Y co..., comiste bien, entonces ya te..., te vas a dormir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Ya lavas tus trastes en la cocina,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>lavas tus platos con, los..., con jabón, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a443" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>ya guardas y luego lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a444" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>ya te vas a..., te..., vas a descansar, ya vas a dormir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a445" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Ya vas a dormir contento. Ya no tienes hambre, ya no tienes sed, no haz..., ya haz tomado tu cafecito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a446" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Cenas muy bien y luego te..., te..., ya te vas a dormir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a447" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Cuando amanece, si se acabaron los tamalitos, vuelves a preparar pero aunque ya sean tortillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Y si quedó un poco de, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>pipían pues aprovechas para comer con las tortillas que haz pre..., preparado en el comal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>En el comal se cuecen nuestras tortillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>y nuevamente le damos  de comer a nue..., nuestro esposo y él se va a trabajar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a452" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Cuando llegue pues tienes que..., estarlo esperando, qué va a comer, qué es lo que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a453" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>con qué  va a llegar a descansar, qué lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a454" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>qué tal si viene con hambre, qué tal si tiene sed,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a455" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>lo..., le preparas su atolito y le das para que se lo tome.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a456" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>También debe tomar para que pueda descansar contento.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Nosotros decimos eso para que..., refresque su corazoncito porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>viene cansado. Al llegar cansado pues también tiene derecho de que nosotras</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>lo..., lo tenemos que cuidar a nues..., nuestro esposo con quien convivimos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Él va a trabajar y yo me quedo trabajando en mi cocina. Empieza, él sale</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>y yo empiezo a lavar. Lavo su ropa para que..., se seque su ropa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>me va a pedir o qué tal si llega con ropa mojada para que se cambie otra vez.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a463" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Si está seca la ropa, entonces se cambia de ropa cuando llegue si se mojó.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Porque él se va a trabajar, él no me está esperando en la casa para que...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a465" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>a ver que..., qué voy a hacer en mi cocina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a466" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>No, él sale a trabajar cuando se encuentra sano</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a467" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>se encuentra bien, no está enfermo. Pero cuando se enferma pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a468" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>uno no lo manda a ninguna parte. No sale a ninguna parte, ¿por qué? porque está enfermo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a469" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Y es así, como dicen que este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>a veces se encuentra el &lt;i&gt;nexkihit&lt;/i&gt;, a veces va al campo a buscar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Va a buscarlo, dice ahí voy a verlo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>si encontré en tu cafetal o en tu terreno pues lo traigo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Tráelo y lo vamos a comer </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>"Lo vas a preparar" "Pues si está bien"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Yo estoy para preparalo y lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>voy a ver qué voy a preparar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Tú ve a ver contento al ca..., campo porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>a veces,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>están madurando los plátanos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>o a veces se maduran los cafecitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>y no este..., ahí se..., ahí sa caen en el suelo si nadie los recogió.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Y de que no se..., si uno levanta la cosecha y se,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>se seca en el sol,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>pues después también ya nos sirve.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a489" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>&lt;i&gt;Etixtamal&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Todos, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a491" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>la masa que se revuelve con frijoles del ejote,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>y se..., y el otro es el &lt;i&gt;etixtamal&lt;/i&gt; que también se envuelven con estas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a493" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>para que también obtengan un buen sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a494" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Y si piensas que vas a comer acompañado con carne de pollito y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a495" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>pues preparas el pollito y t..., mientras que este hirviendo la comida,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a496" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>pues también que esten hirviendo los tamalitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a497" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>para que comas tamales con pollo. Se cuecen los tamalitos y se cuece la carne de pollo pues ya comes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a498" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Mueles el ajonjolí y luego ya le agregas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a499" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Consigues unas cuatro hojas de pimienta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a500" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>y le agregas para que le..., le de un buen sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a503" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>y enseguida se,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>pues ya come uno. Ya no se, no se hace otra cosa más, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a505" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>nada más eso se hace. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a506" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Pues se pueden usar el que le llamamos &lt;i&gt;chichime:koh&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a507" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>o se usa el que le llamamos &lt;i&gt;pitaleño&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a508" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>los frijoles que les llamamos &lt;i&gt;etsitsi:n&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a509" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Los ejotitos que a veces traen acá,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a510" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>acá en el pueblo de Cuetzalan.Traen los ejotitos pues los...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a511" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>si no tenemos lo compramos y si tenemos pues cortamos y hacemos los tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a512" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Y pues ya el &lt;i&gt;chichime:koh, si encontramos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a513" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>pues también compramos y pre..., preparamos los tamales,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a514" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>ya hacemos los tamales. Vamos a traer las hojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a515" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>y ya envolvemos los tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a516" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Si hay que ponerle sal al gusto, hay que agregarle sal y un poquito de manteca o,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a517" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>aceite. Si tienes el aceite pues lo..., fries.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a518" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Fries el aceite para que se queme bien,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a519" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>luego lo sacas de fuego para que se enfrie. Dejas que se enfrie y enseguida lo..., lo..,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a520" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>después de que se enfria, lo tomas con una mano,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a521" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>y al sentir que ya está frio pues ya le..., pones a la masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a522" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>Pruebas la masa si ya tiene la sal para que los frijoles también tengan sal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a523" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>No este, no debes comer sin sal, debes ponerle bien la sal y enseguida empiezas a comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a529" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>¿Las hojas? Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a530" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>Se puede pero, el este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a531" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>frijol &lt;i&gt;chichimeko&lt;/i&gt; su..., su..., se extiende a lo largo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a532" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Se siembran tres frijoles pues se..., y diriamos nosotros que la mata se extiende alrededor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a533" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>Se extiende alrededor, con muchas ramas y al extenderse llega lejos,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a534" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Una mata se puede extender una buena parte de terreno porque se multiplican las..., las mismas ramas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a535" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Le llamamos ramas a la planta que se ramifica. Sus ramas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a536" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>porque se multiplican.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a537" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Y entonces se va ramificando, y en sus ramas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a538" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>ahí emiezan a brotar las flores</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a539" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>y ya se van formando los ejotes. Cuando caen las flores ya se van formando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a540" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>los ejotitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a541" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>Cuando ya van madurando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a542" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>empiezan a tomar un color amarillo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a543" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>Pero entonces si ya están amarillos y en ese momento vas a verlo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a544" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>cortar los ejotes y al llegar a la casa ya preparas los</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a545" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>ya lo..., pelas los ejotes. A v..., a ver qué piensas preparar. Si vas a comer comida de frijoles</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a546" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>o la vas a comer revuelto los frijoles con masa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a547" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>y si ya tienes las hojas del &lt;i&gt;nexkihit&lt;/i&gt; pues las usas para..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a548" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>ya tienes revuelta la masa, envuelves los tamales y los hierves. Cuando ya se cuecen pues ya comes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a549" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Son los que le llamamos &lt;i&gt;etsitsi:n&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a550" ANNOTATION_REF="a206">
                <ANNOTATION_VALUE>El que le llamamos &lt;i&gt;etsitsi:n&lt;/i&gt; son las matas que se dan así y se</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a551" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>llenan de granos de frijol los ejotes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a552" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>Es el que lo siembran por acá también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a553" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>Eso es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a554" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>M..., ya en estos meses.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a555" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>Ahora ya hay cosecha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a556" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>En algunas partes ya se empieza a dar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a557" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>mm, en donde sembraron el frijol más antes y aguantó el calor pues ya se empiezan a dar los ejotes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a558" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>pues este ya hay ejotes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a559" ANNOTATION_REF="a216">
                <ANNOTATION_VALUE>Sí ya hay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a560" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>También en estos meses.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a561" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>Pero lo siembran en mayo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a562" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>Lo siembran en mayo, limpian el terreno y tumban los árboles,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a563" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>después de limpiar. Lo..., levantan la basura,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a564" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>y luego este lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a565" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>o bien keman la basura. Si no levantan la basura entonces la queman. Y en donde queman la basura, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a566" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>ahí ya lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a567" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>ya van sembrando los frijolitos, así no muy lejos entre una mata y la otra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a568" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>Van sembrando unos cuatro frijolitos. No crecen altas las matas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a569" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>Se dan bien los ejotes, lo, si se adap..., si se adaptan las matas también producen bien,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a570" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>se dan bien, crece la mata alrededor en círculo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a571" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>en círculo. Por los cuatro frijolitos que se siembran,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a572" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>n..., crece la mata en forma de círculo y luego ya se van colgando ahí los ejotes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a573" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>Ahí se van colgando, antes florece y después ya se van colgando los ejotitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a574" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>Has..., y si ves que la mata ya tiene ho..., hojas amarillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a575" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>luego te pones a pensar que los ejotes ya están maduros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a576" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>Uno luego se da cuenta que ya están maduros..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a577" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>Entonces pues ya los vamos a..., cortar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a578" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Preparamos unos este, los tamales que les llamamos pi:k..., les llamamos &lt;i&gt;pi:ksa&lt;/i&gt; o si no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a579" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>secamos los frijoles para preparar comida de frijoles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a580" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>podemos preparar frijoles con quelites.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a581" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>Buscas el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a582" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>el &lt;i&gt;metstsonkilit&lt;/i&gt; o buscas las guías de espinoso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a583" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>y lo hierves junto con los frijoles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a584" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Se cuesen juntos. Al cocerce juntos entonces lo..., si piensas agregarle ajonjolí pues ya le pones ajonjolí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a585" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>Así también es muy sabroso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a586" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>Sí. Eso es lo que les digo que se..., lo agarra uno así..., que..., se cuela así, se pone un,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a587" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>una jícara &lt;i&gt;tsiwahkal&lt;/i&gt; y entonces se cuela así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a588" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>Así se cuela muy bien entonces también van saliendo las semillitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a589" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>Pero primero lo..., así restriegas bien los frutos para que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a590" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>se vayan chispando las semillas dentro de su..., la pulpa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a591" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>Y entonces ya salen las semillitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a592" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>Después ya le vas sacando lo que queda, agarras uno por uno las semillas para que salgan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a593" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>la vas limpiando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a594" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>Lo limpias así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a595" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>Le sacas lo que es aro..., lo que es la pulpa y las semillas van quedando otro lado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a596" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>Después lo metes en el agua y luego uno por uno le vas quitando así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a597" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>lo limpias. Aqui de este lado pones lo limpio y acá vas dejando las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a598" ANNOTATION_REF="a258">
                <ANNOTATION_VALUE>Y si ves este, hay</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a599" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>como que las semillas también son vanas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a600" ANNOTATION_REF="a260">
                <ANNOTATION_VALUE>entonces no salen de la pulpa. Entonces le vas quitando las semillas vanas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a601" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>acá las vas poniendo y acá otro lado vas apartando lo que ya está limpio,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a602" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>para que después ya agarras el cedazo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a603" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>y lo lo..., cuelas ya.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a604" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>Es mejor colarlo con cedazo que sale más rápido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a605" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>Porque si lo haces de otra forma pues quien sabe cuando vas a terminar de limpiar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a606" ANNOTATION_REF="a266">
                <ANNOTATION_VALUE>porque es difícil.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a607" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>Es difícil porque tiene mu..., muchas semillitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a608" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>No tiene dos o tres sino que tiene muchas. Mmm. Tiene muchas semillitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a609" ANNOTATION_REF="a269">
                <ANNOTATION_VALUE>Y como te platico que unas semillas también salen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a610" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>vanas entonces quedan dentro de la pulpa. Y los macizos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a611" ANNOTATION_REF="a271">
                <ANNOTATION_VALUE>que ya son maduros se van apartando así. Cuando se cuela se apartan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a612" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>Y estos de..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a613" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>las que no son buenas entonces se quedan en la pulpa. Pues lo tienes que limpiar así con calma.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a614" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>Para que jales aquel y acá se van quedando las semillas que están vanas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a615" ANNOTATION_REF="a275">
                <ANNOTATION_VALUE>Aquí dejas la pulpa para hervirla y para que la puedas consumir. Lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a616" ANNOTATION_REF="a276">
                <ANNOTATION_VALUE>le echas agua y luego lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a617" ANNOTATION_REF="a277">
                <ANNOTATION_VALUE>con el ce..., cedazo lo cuelas para que entonces se..., quede el agua limpio nuevamente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a618" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>Luego lo pones a hervir. Buscas ya la ollita con que la vas a hervir y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a619" ANNOTATION_REF="a279">
                <ANNOTATION_VALUE>ya lo echas ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a620" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>Luego ya lo pones a hervir en el fogón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a621" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>Cuando ya está hirviendo consigues de inmediato las,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a622" ANNOTATION_REF="a282">
                <ANNOTATION_VALUE>las hojas, le agregas la sal y las hojas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a623" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>y ya lo pruebas si ya huele a cocido, entonces lo retiras del fogón y lo paras por ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a624" ANNOTATION_REF="a284">
                <ANNOTATION_VALUE>Si sabes que ya viene a la persona que le vas a dar de comer pues hazlo rápidamente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a625" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>ya haces las tortillitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a626" ANNOTATION_REF="a286">
                <ANNOTATION_VALUE>Haces tus tortillitas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a627" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>y lo..., llega él pues ya empieza a comer. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a628" ANNOTATION_REF="a288">
                <ANNOTATION_VALUE>Mm. Tiene, ya tienes su cafecito, ya tienes a ver qué va a tomar si es aguita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a629" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>Si no hay azúcar pues preparas un poquito de atolito para que se lo tome.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a630" ANNOTATION_REF="a290">
                <ANNOTATION_VALUE>Atole de masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a631" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>Eso es lo que se hace. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a632" ANNOTATION_REF="a292">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a642" ANNOTATION_REF="a294">
                <ANNOTATION_VALUE>Este pimienta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a643" ANNOTATION_REF="a295">
                <ANNOTATION_VALUE>Sí, se le agregan las hojas de pimienta para que le den un buen sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a644" ANNOTATION_REF="a297">
                <ANNOTATION_VALUE>También hay uno que es el &lt;i&gt;itahta:y&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a645" ANNOTATION_REF="a298">
                <ANNOTATION_VALUE>Tiene el que le llaman &lt;i&gt;itahta:y&lt;/i&gt; y abunda mucho por aquí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a646" ANNOTATION_REF="a299">
                <ANNOTATION_VALUE>Por acá. Y le llaman &lt;i&gt;xoko:ktamaliswat&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a647" ANNOTATION_REF="a300">
                <ANNOTATION_VALUE>Tal vez lo..., tal vez la conoces también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a648" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>Pues las hojas se pueden usar pero sus frutos no se usan, no se usan porque son muy chiquititos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a649" ANNOTATION_REF="a303">
                <ANNOTATION_VALUE>Son más pequeños. También tiene el que le llaman &lt;i&gt;itahta:y&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a650" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>Pero los frutos son más pequeños y también tienen un olor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a651" ANNOTATION_REF="a305">
                <ANNOTATION_VALUE>Tienen un olor igual</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a652" ANNOTATION_REF="a306">
                <ANNOTATION_VALUE>pero pues yo sé que le llaman tamal..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a653" ANNOTATION_REF="a307">
                <ANNOTATION_VALUE>&lt;i&gt;xoko:ktamaliswat&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a654" ANNOTATION_REF="a308">
                <ANNOTATION_VALUE>Mm. Porque hace muchos años veíamos a nuestros padres,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a655" ANNOTATION_REF="a309">
                <ANNOTATION_VALUE>hacían fermentar una bolita de masa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a656" ANNOTATION_REF="a310">
                <ANNOTATION_VALUE>y le agregaban manteca. Le agregaban manteca</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a657" ANNOTATION_REF="a311">
                <ANNOTATION_VALUE>y si se fermentaba más de lo normal, le agregaban otra bolita de masa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a658" ANNOTATION_REF="a312">
                <ANNOTATION_VALUE>y la revolvian bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a659" ANNOTATION_REF="a313">
                <ANNOTATION_VALUE>Le agregan manteca, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a660" ANNOTATION_REF="a314">
                <ANNOTATION_VALUE>y empiezan a preparar unos tamalitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a661" ANNOTATION_REF="a315">
                <ANNOTATION_VALUE>Al preparar esos tamalitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a662" ANNOTATION_REF="a316">
                <ANNOTATION_VALUE>pues también tienen otro sabor diferente de los de..., demás tamalitos, tienen otro olor diferente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a663" ANNOTATION_REF="a317">
                <ANNOTATION_VALUE>porque esos se llaman &lt;i&gt;xoko:ktamal&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a664" ANNOTATION_REF="a318">
                <ANNOTATION_VALUE>Bueno más le llaman &lt;i&gt;xoko:tamal&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a665" ANNOTATION_REF="a319">
                <ANNOTATION_VALUE>Por qué le llaman &lt;i&gt;xoko:tamal&lt;/i&gt; porque la masa está fermentada. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a666" ANNOTATION_REF="a321">
                <ANNOTATION_VALUE>Mm. Sí, esas mismas hojas usaban para envolverlas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a667" ANNOTATION_REF="a322">
                <ANNOTATION_VALUE>Actualmente ya no lo hacemos porque la verdad todo vamos cambiando nu..., nuestra forma de alimentarnos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a668" ANNOTATION_REF="a323">
                <ANNOTATION_VALUE>Pero yo conozco el sabor que tiene esa com..., masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a669" ANNOTATION_REF="a324">
                <ANNOTATION_VALUE>Porque antes también los preparaba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a670" ANNOTATION_REF="a325">
                <ANNOTATION_VALUE>Cuando yo crecí también lo hacía porque me gustaba consumirlo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a671" ANNOTATION_REF="a326">
                <ANNOTATION_VALUE>Molía el chiltepín junto con la masa para ya no preparar la salsa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a672" ANNOTATION_REF="a327">
                <ANNOTATION_VALUE>Cuando se cuecen los tamales ya tienen picante.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a673" ANNOTATION_REF="a328">
                <ANNOTATION_VALUE>Y si quiero llevarlos al campo, pues los llevo pero ya tienen picante. Ya no tengo por qué llevar aparte los chiles para comsumir. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a674" ANNOTATION_REF="a331">
                <ANNOTATION_VALUE>Este a veces cuando las hojas eran pequeñas, usábamos dos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a675" ANNOTATION_REF="a333">
                <ANNOTATION_VALUE>Pero si la..., la..., masa es un poco más grande pues usábamos dos hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a676" ANNOTATION_REF="a334">
                <ANNOTATION_VALUE>Pero si la hoja es pequeña y la masa es más grande,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a677" ANNOTATION_REF="a335">
                <ANNOTATION_VALUE>pues usas uno nada más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a678" ANNOTATION_REF="a336">
                <ANNOTATION_VALUE>por qué usas uno nada más, porque,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a679" ANNOTATION_REF="a337">
                <ANNOTATION_VALUE>es delgada la hoja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a680" ANNOTATION_REF="a338">
                <ANNOTATION_VALUE>Son delgadas la hojas, no son anchas como el &lt;i&gt;nexkihiswat&lt;/i&gt;, porque se dan así nada más de tamaño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a681" ANNOTATION_REF="a339">
                <ANNOTATION_VALUE>Mm. Por ahí se dan luego. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a682" ANNOTATION_REF="a340">
                <ANNOTATION_VALUE>Por allá nosotros no se da.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a683" ANNOTATION_REF="a341">
                <ANNOTATION_VALUE>Por aquí sí se dan. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a684" ANNOTATION_REF="a343">
                <ANNOTATION_VALUE>Este del &lt;i&gt;nexkihit&lt;/i&gt; parece que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a685" ANNOTATION_REF="a344">
                <ANNOTATION_VALUE>bueno pues no tiene algo más de su..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a686" ANNOTATION_REF="a345">
                <ANNOTATION_VALUE>que yo les pueda hablar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a687" ANNOTATION_REF="a346">
                <ANNOTATION_VALUE>Parece que es todo lo que les platiqué que se usan para</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a688" ANNOTATION_REF="a347">
                <ANNOTATION_VALUE>para los tamales de frijol molido usamos esas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a689" ANNOTATION_REF="a348">
                <ANNOTATION_VALUE>Y los frutos los cosumimos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a690" ANNOTATION_REF="a349">
                <ANNOTATION_VALUE>Y su..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a691" ANNOTATION_REF="a350">
                <ANNOTATION_VALUE>se usan para envolver dos tipos de tamales, dos y tres tipos, se usan estas hojas para envolverlos. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a692" ANNOTATION_REF="a351">
                <ANNOTATION_VALUE>Como los tamales de &lt;i&gt;chichime:koh&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a693" ANNOTATION_REF="a352">
                <ANNOTATION_VALUE>los tamales de frijoles que les llamamos &lt;i&gt;etsitsí:n&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a694" ANNOTATION_REF="a353">
                <ANNOTATION_VALUE>y los que les llamamos este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a695" ANNOTATION_REF="a354">
                <ANNOTATION_VALUE>otras personas hacen, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a696" ANNOTATION_REF="a355">
                <ANNOTATION_VALUE>tamales de haba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a697" ANNOTATION_REF="a356">
                <ANNOTATION_VALUE>Pues también se pueden preparar tamales de haba y se envuelven con estas hojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a698" ANNOTATION_REF="a357">
                <ANNOTATION_VALUE>para que le den sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a699" ANNOTATION_REF="a358">
                <ANNOTATION_VALUE>Porque tienen otro olor diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a700" ANNOTATION_REF="a359">
                <ANNOTATION_VALUE>Y el que le llamamos &lt;i&gt;nexkoko:kiswat&lt;/i&gt; pues ese tiene otro olor pero si se preparan los tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a701" ANNOTATION_REF="a360">
                <ANNOTATION_VALUE>Son tamales pero son diferentes, los que llevan este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a702" ANNOTATION_REF="a361">
                <ANNOTATION_VALUE>si preparas salsa. Pero te digo que para la salsa se muele este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a703" ANNOTATION_REF="a362">
                <ANNOTATION_VALUE>se muele el chile, se muele el jitomate y todo molido el condimento que va a llevar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a704" ANNOTATION_REF="a363">
                <ANNOTATION_VALUE>Si le vas a poner cilantro o le vas a poner cebolla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a705" ANNOTATION_REF="a364">
                <ANNOTATION_VALUE>pues lo mueles todo para que le de un buen sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a706" ANNOTATION_REF="a365">
                <ANNOTATION_VALUE>Mm. Y lo..., también preparas tamales de haba</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a707" ANNOTATION_REF="a366">
                <ANNOTATION_VALUE>ejotes de aba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a708" ANNOTATION_REF="a367">
                <ANNOTATION_VALUE>Con los ejotes de haba también puedes preparar tamales. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a709" ANNOTATION_REF="a369">
                <ANNOTATION_VALUE>Pues yo ven..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a710" ANNOTATION_REF="a370">
                <ANNOTATION_VALUE>ya sabes cómo me llamo y vengo de Xaltipan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a711" ANNOTATION_REF="a372">
