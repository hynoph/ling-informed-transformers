        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
                <ANNOTATION_VALUE>wa:n ke:mah ne: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>*o bien** tachichinowah. Komo a:mo kololowah sah n' tahsoltsí:n, entó:s tachichinowah. Wa:n ka:mpa tachichinowah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
                <ANNOTATION_VALUE>ompa ya ne: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
                <ANNOTATION_VALUE>kita:lihtiwih ya n' etsitsí:n, a:mo we:wehka, ihko:kó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
                <ANNOTATION_VALUE>Sake:ra nahna:wi, na:wi etsí:n. A:mo wehkapania.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
                <ANNOTATION_VALUE>Mochi:wa, komo kwaltsi:n ta:ki, ti..., kinemilia *que** no: ta:kis kwaltsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
                <ANNOTATION_VALUE>kwaltsi:n mochi:wa se: malakachtsí:n ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
                <ANNOTATION_VALUE>malakachtsí:n. De na:wi etsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
                <ANNOTATION_VALUE>n..., ahsi se: malakachtsí:n ihkó:n motahta:lia, ke:mah mopihpilowa ya ompa n' etsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
                <ANNOTATION_VALUE>Ompa mopihpil[owa], xo:chiowa wa:n mopihpilowa ya n' etsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
                <ANNOTATION_VALUE>*Has...**, wa:n ke:mah tikita ma:..., ma:kostia ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
                <ANNOTATION_VALUE>pos tiknemilia *que** chika:wak a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
                <ANNOTATION_VALUE>No:, niman se: ki:xehekowa *que** chika:wak a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
                <ANNOTATION_VALUE>Entó:s pos tiowih tik..., tiktekitih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
                <ANNOTATION_VALUE>Tikchi:wah seki, ne:, yehwa ya ne:n pi:k..., tikiliah pi:ksa wa:n koma:mo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
                <ANNOTATION_VALUE>tikwa:tsa wa:n tikchi:wa n' emo:ltsí:n ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
                <ANNOTATION_VALUE>Weli tikta:lilia ne: seki kiltsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
                <ANNOTATION_VALUE>Tikte:mowa, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
                <ANNOTATION_VALUE>metstsonkilit (Xanthosoma violaceum Schott) *o** t'te:mowa yo:n witskilit,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
                <ANNOTATION_VALUE>wa:n iwa:n, iwa:n t'pante:ma.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
                <ANNOTATION_VALUE>Iwa:n oksi. Wa:n de iwa:n oksi a pos ke:mah tik..., komo t'nemilia t'ta:lili:ti n' a:ko:lin, tika:ko:lwia ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
                <ANNOTATION_VALUE>Yehwa yo:n no: we:lik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
                <ANNOTATION_VALUE>Ke:mah. Yehwa yo:n name:chilihtok se: ki..., mahyá: se: kikwi..., mah..., iwkwí:n se: kitsetselowa, se: kita:lia se:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>se: tsiwahkaltsí:n ihkó:n wa:n ompa ihkwí:n se: kitsetselowa ihkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
                <ANNOTATION_VALUE>Ihkó:n kwaltsi:n se: kitsetselowa no: kihki:sa n' iteyotsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
                <ANNOTATION_VALUE>Pero kwali ..., *primero** ihkó:n t'chi:wa, kwaltsi:n t'ma:xakwalowa para ne:</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
                <ANNOTATION_VALUE>mah kokopika n' i..., itech n' inakayotsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
                <ANNOTATION_VALUE>Wa:n ke:mah, ki:sa ya n' iteyotsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
                <ANNOTATION_VALUE>Ke:mah yo:n tiki:xtilia ya, tein moka:wa ya pos tikwi sehse: ya, sehse: ya, tiki:xtilia sehse: ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
                <ANNOTATION_VALUE>wa:n tikchipa:wa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
                <ANNOTATION_VALUE>Tikchipa:wa ya ihkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
                <ANNOTATION_VALUE>Tiki:xtilia ne:n ahwia:..., ke:meh eskia ne:n nakatsí:n wa:n tetsitsí:n, nika:n moka:wa ya *semilla**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>*Después** tika:pachowa ya wa:n ke:mah se:, se: [...]t'tila:na ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
                <ANNOTATION_VALUE>wa:n tikchipa:wa. Nika:n t'ta:lihtiw a n' tein chipa:wak wa:n nika:n tika:wtiw a *semilla**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
                <ANNOTATION_VALUE>Wa:n komo tikita ne:, seki onkak</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
                <ANNOTATION_VALUE>*como que** no: mahyá: patsaktik n' iteyotsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
                <ANNOTATION_VALUE>entó:s a:mo ki:sa iwa:n ne:n nakatsí:n. Entó:s tiki:xtilia yeh, tiki:xtilia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
                <ANNOTATION_VALUE>wa:n nika:n tikte:ma ya yeh wa:n nika:n t'ta:lia ya n' chipa:wak,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
                <ANNOTATION_VALUE>para ke:mah ne: tikwi a xola:soh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
                <ANNOTATION_VALUE>wa:n tik..., tiktsetselowa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>*Mejor** ika xola:soh, ihsiwka ki:sa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
                <ANNOTATION_VALUE>Pero komo ompa titahmattok ihkó:n, pos, 'mati ke:maniá:n tiktamichipa:wati,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
                <ANNOTATION_VALUE>*porque** owih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
                <ANNOTATION_VALUE>Owih *porque** m..., pos miak n' iteyotsi:n/</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
                <ANNOTATION_VALUE>A:mo kipia o:me, e:yi, ta: kipia miak. Mmm. Kipia miak n' iteyotsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
                <ANNOTATION_VALUE>Wa:n ke:meh nimitsilia *que** seki ki:sa neli no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
                <ANNOTATION_VALUE>patsaktik n' iteyotsi:n yehwa yo:n moka:wa iwa:n nakatsi:n. Wa:n tein *macizo**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
                <ANNOTATION_VALUE>chika:wak a, pos yeh ne: pi:xowi ihkó:n. Se: kitsetselowa pi:xowi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
                <ANNOTATION_VALUE>Wa:n yeh n' de i:n s...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
                <ANNOTATION_VALUE>*como que** no: a:mo kwahkwali entó:s iwa:n moka:wa ya nakatsí:n. Pos kipia *que** t'chipa:wati ihkó:n yo:li:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
                <ANNOTATION_VALUE>Para t'tila:na ne: wa:n nika:n moka:wtiw a *semillita** tein patsaktik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
                <ANNOTATION_VALUE>Nika:n tika:wa ya para nakatsí:n para yehwa ya n' tikmanas wa:n yehwa ya n' tikwa:s. Tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
                <ANNOTATION_VALUE>tikte:kilia n' a:t wa:n ke:mah tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
                <ANNOTATION_VALUE>ika ya xa..., ne: xola:soh tiktsetselowa ya para ke:mah mochi..., moka:wa chipa:wak a n' a:tsí:n sepa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
                <ANNOTATION_VALUE>Ke:mah tikmana ya. T'te:mowa, t'pahpa:ka ya moko:ntsi:n, toni ika t'manati wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
                <ANNOTATION_VALUE>ompa t'te:ka ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
                <ANNOTATION_VALUE>Ompa t'tikoketsa mah molo:ni a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
                <ANNOTATION_VALUE>*Que de** molo:niki pos *carrera** tikwiti a, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
                <ANNOTATION_VALUE>tikwiti a ne: xiwtsí:n wa:n t'ta:lilia a n' istatsí:n wa:n t'ta:lilia ya xiwtsí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
                <ANNOTATION_VALUE>wa:n tikekowa ya komo ahwia:k a de oksik, entó:s pos tiki:xtia ya, ne:pa tiketsa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
                <ANNOTATION_VALUE>Ta:ká:n t'mattok wi:tsa ya ne:n a:koni n' tamahse:wtehko pos *carrera** tikchi:wa ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
                <ANNOTATION_VALUE>tikta:lia ya motaxkaltsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
                <ANNOTATION_VALUE>Tikta:lia motaxkaltsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
                <ANNOTATION_VALUE>wa:n tik..., ehko yeh, pos yeh takwa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
                <ANNOTATION_VALUE>Mm. Kipia, tikpia ya n' ikahfe:ntsi:n, tikpia ya, ne:n, *a ver** ton tai:s, a:tsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
                <ANNOTATION_VALUE>Ta:ká:n a:mo kipia ne:n *iazúcartsi:n** pos tikchi:wilia tepitsi:n *atolito** para yehwa ya yo:n tai:s.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
                <ANNOTATION_VALUE>Ato:ltsí:n de tixti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
                <ANNOTATION_VALUE>Yehwa se: kichihchi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
                <ANNOTATION_VALUE>Ne: *pimienta**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
                <ANNOTATION_VALUE>Ke:mah *pimienta** se: kita:lilia para no: kahwia:lia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
                <ANNOTATION_VALUE>Kipia n' itahta:y.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
                <ANNOTATION_VALUE>Kipia n' itahta:y wa:n nika:wí:n semi mochi:wa n' itahta:y.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
                <ANNOTATION_VALUE>Nika:wí:n. Ata kiliah xoko:ktamaliswat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
                <ANNOTATION_VALUE>Xa: t'momaka..., xa: no: tiki:xmati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
                <ANNOTATION_VALUE>Pos i:n ixiwyo ke:mah, pero n' iteyo yeh a:mo, a:mo se: kikwi *porque** yeh *más** tsikitsitsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
                <ANNOTATION_VALUE>Yeh *más** no:nohne:l. No: kipia n' itahta:y.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
                <ANNOTATION_VALUE>Pero *más** no:nohne:l wa:n no: *igual** n' kipia n' ahwia:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
                <ANNOTATION_VALUE>*De igual** n' ahwia:k</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
                <ANNOTATION_VALUE>pero pos neh n'mattok soh kiliah *que** tamal...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
                <ANNOTATION_VALUE>xoko:ktamaliswat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
                <ANNOTATION_VALUE>Mm. *Porque** ne: wehka:w tota:tahwa:n tikinitayah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
                <ANNOTATION_VALUE>kixokoltia:yah se: *bolita** tixtsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
                <ANNOTATION_VALUE>wa:n kita:liliayah *mantecatsi:n**. Kita:liliah *mantecatsi:n**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
                <ANNOTATION_VALUE>wa:n komo telpano:k de xoko:k, 'kwe:chowah se: *bolita** de tixtsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
                <ANNOTATION_VALUE>wa:n kima:nelowah iwa:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
                <ANNOTATION_VALUE>Kita:liliah *mantecatsi:n**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
                <ANNOTATION_VALUE>wa:n ke:mah kichihchi:wah no: *tamalitos** a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
                <ANNOTATION_VALUE>De kichi:wah n' tamaltsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
                <ANNOTATION_VALUE>no: taman ahwia:k, de n' okseki la..., okseki tamaltsí:n, no: taman ahwia:k,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
                <ANNOTATION_VALUE>*porque** yeh mono:tsa xoko:ktamaltsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
                <ANNOTATION_VALUE>Xokotamal, *bueno más**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
                <ANNOTATION_VALUE>Xokotamal, ¿ke:yeh?, *porque**, porin xoko:k n' tixti. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
                <ANNOTATION_VALUE>Mm. Yehwa n' ika kipihpi:kiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
                <ANNOTATION_VALUE>A:man a:mo tikchi:wah *porque** neli ne: nochi tiki:xpatatiwih n' to..., totakwalis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
                <ANNOTATION_VALUE>Pero neh nikmattok ke:ní:w we:lik yo:n tapal..., ne:n tixtsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
                <ANNOTATION_VALUE>*Porque antes** no: nikchi:waya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
                <ANNOTATION_VALUE>*Cuando** neh nimoskaltih no: n'chi:waya *porque** nikwelitaya de nikwa:s.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
                <ANNOTATION_VALUE>Nikwe:cholia chi:ltekpintsi:n para ne: a:mo nikchi:wtok chi:ltamo:ltal ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
                <ANNOTATION_VALUE>Ne: niki:xtia pero koko:k a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
                <ANNOTATION_VALUE>Wa:n komo n'neki nikwi:kas ka:sá: ika kowtah, pos nikwi:ka pero koko:k a. A:mo nikwi:katok *aparte** ne:n *chilito** para nikwa:s. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts599">
                <ANNOTATION_VALUE>Ne: i:ksá: tikwiah tein sehse: semi achi no:nohne:l, tikwiah o:me.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts598" TIME_SLOT_REF2="ts600">
                <ANNOTATION_VALUE>Pero komo tsi..., ts..., wa:n no: komo achi we:i n' tixtsí:n pos tikwi o:me n' iswat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
                <ANNOTATION_VALUE>Pero komo achi nohne:l n' tixtsí:n pos wa:n iswatsí:n achi we:i,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
                <ANNOTATION_VALUE>pos tikwi se: sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
                <ANNOTATION_VALUE>Se: sah tiksenkwi *porque** ke:yeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
                <ANNOTATION_VALUE>ne: pitsa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts610">
                <ANNOTATION_VALUE>Pitsa:wak, a:mo pa:pata:wak ke:meh nexkihiswat, *porque** yeh mochi:wa ihko:ntsi:n sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts611" TIME_SLOT_REF2="ts612">
                <ANNOTATION_VALUE>Mm. Ampo:wí:n *cerca** onkas. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts614">
                <ANNOTATION_VALUE>Ne:wí:n tehwa:n a:mo tei.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts615" TIME_SLOT_REF2="ts616">
                <ANNOTATION_VALUE>Nika:wí:n onkak. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
                <ANNOTATION_VALUE>Ne: nexkihitsi:n pané:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts622">
                <ANNOTATION_VALUE>*bueno** pos a:mo teihsá: *más** kipia i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts624">
                <ANNOTATION_VALUE>itahto:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts625" TIME_SLOT_REF2="ts626">
                <ANNOTATION_VALUE>Pané: yehwa sah, ke:meh name:chilih *que** para,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
                <ANNOTATION_VALUE>para n' etixtaxkaltsi:n nochi yehwa tikwih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
                <ANNOTATION_VALUE>Wa:n *isemillita** pos tikwah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts632">
                <ANNOTATION_VALUE>Wa:n i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts633" TIME_SLOT_REF2="ts634">
                <ANNOTATION_VALUE>ne: de o:me taman tamaltsí:n, o:me taman wa:n e:yi taman, pos nochi ika se: kipihpi:ki n' tixtsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts636">
                <ANNOTATION_VALUE>Ke:meh chichime:koh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a352" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts638">
                <ANNOTATION_VALUE>ke:meh yehwa, ne:n, tikiliah etsitsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
                <ANNOTATION_VALUE>wa:n ke:meh, ne:n, tikiliah, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">
                <ANNOTATION_VALUE>yo:n seki ata kichi:wah, ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts643" TIME_SLOT_REF2="ts644">
                <ANNOTATION_VALUE>*de habas**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
                <ANNOTATION_VALUE>Pos no: kwali se: kichi:wa *de habas** wa:n no: yehwa n' ika se: kipi:ki,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
                <ANNOTATION_VALUE>para kikwi n' ahwia:kka:yo:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
                <ANNOTATION_VALUE>*Porque** yeh no: taman ahwia:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts652">
                <ANNOTATION_VALUE>Wa:n ne:n tikihtowah nexkoko:kiswat yeh no: taman ahwia:k p[ero][k]omo se: kichi:wa iwa:n *tamalito**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts654">
                <ANNOTATION_VALUE>Tamaltsí:n pero yeh no: taman, yeh iwi:kal, ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts656">
                <ANNOTATION_VALUE>komo tikchi:wa *salsa. Salsa** takwe:chol nimitsilia</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts657" TIME_SLOT_REF2="ts658">
                <ANNOTATION_VALUE>takwecho:l n' chi:l, wa:n takwe:chol n' tomat wa:n takwe:chol nochi toni n' iahwia:kka kipiati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
                <ANNOTATION_VALUE>Ta:ká:n kipias *cilantro o** ta:ká:n kipias *cebolla**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts662">
                <ANNOTATION_VALUE>pos nochi tikwe:chowa para kwaltsi:n ahwia:ya ika.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts663" TIME_SLOT_REF2="ts664">
                <ANNOTATION_VALUE>Mm. Wa:n yo:n tik..., tikchi:wa ya yehwa ya ne:n *habas**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts666">
                <ANNOTATION_VALUE>*habasexo:t**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts667" TIME_SLOT_REF2="ts668">
                <ANNOTATION_VALUE>*Hasbasexo:t** no: kwaltia n' tamaltsí:n. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
                <ANNOTATION_VALUE>Pos neh ni...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
                <ANNOTATION_VALUE>tikmattok a ampó:n ke:ní:w nimono:tsa wa:n niwa:le:w Xaltipan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
                <ANNOTATION_VALUE>Ke:mah, pos ka:n *delicado**, ta: pos, *es...**, niMaría Ocotlán Fermín Cabrera.</ANNOTATION_VALUE>
