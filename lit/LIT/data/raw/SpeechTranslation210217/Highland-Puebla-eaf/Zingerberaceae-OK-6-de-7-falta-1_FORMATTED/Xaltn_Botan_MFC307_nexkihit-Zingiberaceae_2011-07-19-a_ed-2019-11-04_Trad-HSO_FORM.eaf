        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
                <ANNOTATION_VALUE>wa:n kitachipa:wiah. Ki..., taololowah ika n' tahsoltsí:n,</ANNOTATION_VALUE>
