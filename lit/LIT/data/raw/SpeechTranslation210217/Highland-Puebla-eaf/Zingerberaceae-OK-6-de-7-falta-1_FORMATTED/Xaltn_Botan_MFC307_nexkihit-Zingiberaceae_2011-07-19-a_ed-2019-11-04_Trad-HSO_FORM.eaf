        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
                <ANNOTATION_VALUE>Mayo kito:kah, kitachipa:wiah, kitate:xi:miah,</ANNOTATION_VALUE>
