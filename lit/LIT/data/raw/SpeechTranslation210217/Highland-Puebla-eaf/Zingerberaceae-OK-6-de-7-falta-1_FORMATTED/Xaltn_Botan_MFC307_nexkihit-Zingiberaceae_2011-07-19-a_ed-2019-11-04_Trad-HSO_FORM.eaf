    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="Eleuterio Gorostiza Salazar">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>*Bueno** na:nah pos ekintsi:n xte:chtapowi, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>i:n nika:wí:n mochi:wa ne: nexkihit ox se: kikwa, ixiwyo toni, ne:n, kwaltia, inalwayo ta:ká:n pahti *o**, tein teh tiknekis, *este**, tein teh tikmattos xte:chtapowi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>*Bueno** tikihtowa:ya ye:wa ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>ixiwyo nexkihit kwali ika se: kipihpi:ki tamal. Teh tite:chili de,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts232" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>etixtamal. ¿Katí:n oksé: tamal no: kwali ika se: kipihpi:ki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
                <ANNOTATION_VALUE>No: tikihtowa ika ne:n exo:t kwali se: kichi:wa tamal, se: kima:nelowa iwa:n tixti. ¿Katí:n exo:t kwali se: kikwi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
                <ANNOTATION_VALUE>Kwali tite:chtapowi:s ke:niwki ne:n chichime:kohexo:t, ixiwyo wa:n et ke:niwki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
                <ANNOTATION_VALUE>Wa:n i:n, i:n et, *este**, tikilia *pitaleño**, ¿ke:niwki?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
                <ANNOTATION_VALUE>A:man ke:maniá:n, itech katí:n me:tsti onkak, ne:n, chichime:koh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
                <ANNOTATION_VALUE>Wa:n e:tsitsi:n, ¿ke:maniá:n, ne:n, mochi:wa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
                <ANNOTATION_VALUE>*Bueno**, ye:wa tite:chilia:ya no, ihwa:k oksi, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
                <ANNOTATION_VALUE>nexkihit se: kikwiti. ¿kwali tite:chtapowi:snochi, *este**, yo:li:k, ke:ní:w se: kichipa:wa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
                <ANNOTATION_VALUE>A:man tikihtowa, ne:n, ihwa:k tik..., tikmana ya ne:n nexkihit tein tachipa:w a, t'ta:lilia xiwit. ¿Ton xiwyo t'ta:lilia?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
                <ANNOTATION_VALUE>*Bueno**, a:man ne:n, de i:n nexkihit, ¿i:pa nexkihit sah onkak *o** xa: no: kipia itahta:y?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
                <ANNOTATION_VALUE>¿Kwali tite:chtapowi:s ke:niwki yo:n wa:n ox no: se: kikwi n' ixiwyo?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
                <ANNOTATION_VALUE>Wa:n i:n, tikihtowa, *este**, xoko:ktamalistat, ¿yehwa n' ika kipihpi:kih, kipihpi:kiah i:n xokotamal?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
                <ANNOTATION_VALUE>A:man i:n tikihtowa, *este**, iswat ika tikpihpi:kia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
                <ANNOTATION_VALUE>se:, o:me oso e:yi oso ka:nachi, *porque** i:n achi pisi:ltik n' ixiwyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts617" TIME_SLOT_REF2="ts618">
                <ANNOTATION_VALUE>Pané: nochi a n' tein tite:chtapowih i:n nexkihit, *este**, ¿oso tikpia ok teihsá: tein tite:chili:s nexkihit?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
                <ANNOTATION_VALUE>*Bueno pues** komohkó:n nochi a i:n, *este**, nexkihit, xte:chili moto:ka:y wa:n xola:l ka:mpa tiwa:le:w.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
                <ANNOTATION_VALUE>¿Kwali tikihto:s moto:ka:y?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Comentarios" PARTICIPANT="Comments" TIER_ID="Comments">
