        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
                <ANNOTATION_VALUE>tein n' tehwa:n ne:n ke..., ne:ka to:nal ika timotekipanohkeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
