        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
                <ANNOTATION_VALUE>¿Ke:yeh? *Porque** tikwa:yah nochi kowta:kilo:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
                <ANNOTATION_VALUE>Tikwa:yah nochi, *este**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>tein nika:wí:n tehwa:n tike:waltiah, tein nika:wí:n tehwa:n tik..., tik..., tiktohto:kah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
                <ANNOTATION_VALUE>A:xka:n a:mo, a:xka:n tikitah n' topi:pilwa:n,</ANNOTATION_VALUE>
