        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
                <ANNOTATION_VALUE>mahyá:, mahyá: yo:n, *este**, ke:n nikihto:s neh, mahyá:, mahyá:,</ANNOTATION_VALUE>
