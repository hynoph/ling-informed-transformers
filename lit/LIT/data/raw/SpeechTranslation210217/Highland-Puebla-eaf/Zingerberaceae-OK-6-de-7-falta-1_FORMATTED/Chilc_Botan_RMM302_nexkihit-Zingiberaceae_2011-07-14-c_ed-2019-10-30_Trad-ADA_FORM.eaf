            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a446" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>Y las otras plantas no es así, solamente las arrancas y las tiras por ahí, nuevamente la planta se desarrolla. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a447" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>¿Porqué? porque sabemos que no nos va a ayudar para nada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a209">
