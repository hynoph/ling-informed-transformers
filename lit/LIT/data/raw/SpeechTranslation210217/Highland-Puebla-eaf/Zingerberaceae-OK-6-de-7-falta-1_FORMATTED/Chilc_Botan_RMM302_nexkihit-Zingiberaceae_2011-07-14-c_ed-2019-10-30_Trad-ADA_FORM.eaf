        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Cortan las hojas y lo parten en dos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Lo parten en dos, sacan (la hoja en dos piezas)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>De cada hoja, lo parten y sale dos piezas para envolver dos tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>¿Porqué?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Le quitan la vena principal, le quitan la vena principal porque ésta vena no es flexible, entonces, si tiene esta vena, no sirve para envolver la masa revuelta con frijol (tamal)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Es necesario partirlo en dos (para quitarle la vena),</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>alcanza para envolver dos tamales en una hoja de esa planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>¿Y porqué les gusta mucho esa hoja? Los tamales salen muy sabrosos, los tamalitos salen muy sabrosos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Mm. Entonces, eso es lo que nosotros tenemos presente</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>que nuestros abuelos y padres  nos lo enseñaron en aquéllos tiempos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>pues ese conocimiento, hasta ahora no se nos olvida pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a94">
