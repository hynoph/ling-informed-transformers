        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
                <ANNOTATION_VALUE>teltapa. *Porque** te..., mahyá: tikihtowah tehwa:n telchika:wak ne:n iahwia:kka:yo.</ANNOTATION_VALUE>
