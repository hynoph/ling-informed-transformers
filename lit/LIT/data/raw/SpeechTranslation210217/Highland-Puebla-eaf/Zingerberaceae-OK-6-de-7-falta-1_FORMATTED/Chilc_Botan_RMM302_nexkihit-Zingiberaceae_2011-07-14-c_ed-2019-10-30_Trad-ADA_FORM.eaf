        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
                <ANNOTATION_VALUE>mahyá: yo:n a:mo teihsá: eskia. Pos 'ma:pa:ta ihkó:n tamipa:ti nochi ika ie:wayo, a:mo tikihto:tih tikmahse:watih.</ANNOTATION_VALUE>
