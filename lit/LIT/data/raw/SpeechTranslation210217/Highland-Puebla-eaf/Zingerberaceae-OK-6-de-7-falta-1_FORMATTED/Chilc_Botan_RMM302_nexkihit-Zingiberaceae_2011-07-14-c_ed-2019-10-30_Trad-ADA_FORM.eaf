        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
                <ANNOTATION_VALUE>pos ne: nejó:n talna:miki:lis mah a:mo tikelka:waka:n, ke:meh tikihtowah, name:chilia neh ika yo:n</ANNOTATION_VALUE>
