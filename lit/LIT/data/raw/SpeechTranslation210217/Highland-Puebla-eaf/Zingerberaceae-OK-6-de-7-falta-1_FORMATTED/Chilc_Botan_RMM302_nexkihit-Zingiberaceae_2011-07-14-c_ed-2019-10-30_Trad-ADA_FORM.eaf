        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
                <ANNOTATION_VALUE>No: kikwah, yehwa yo:n no: kikwah *porque** tikmatis ke:yeh *porque** yo:n *más** kimahse:wah *porque** a:mo kin..., a:mo kit..., kimattokeh *que** a:mo na:kin kitekiti ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
