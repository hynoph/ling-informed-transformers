                <ANNOTATION_VALUE>A:xka:n ixiwyo, ne:chilihtoya ne: no..., no..., note:iskaltihka:w, n' ixiwyo no: kwali kikwih para tamal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
