        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
                <ANNOTATION_VALUE>Wa:n nexkihit a:mo, nexkihit i:pa *importa** kipia *que** tiktahtachkwili:s wa:n tikto:kat..., tiktsi:nta:li:ti:w,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
