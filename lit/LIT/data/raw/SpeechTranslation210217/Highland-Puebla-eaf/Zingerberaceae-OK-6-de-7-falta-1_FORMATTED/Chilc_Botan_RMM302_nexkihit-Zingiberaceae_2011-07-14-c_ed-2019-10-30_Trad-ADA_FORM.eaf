        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>A:mo mone:neki, sanoke yo:n sayoh xiktamo:ta ihko:ni sah ne:n i..., n' itesyotsi:n, xtamo:ta ihkó:n itesyo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
