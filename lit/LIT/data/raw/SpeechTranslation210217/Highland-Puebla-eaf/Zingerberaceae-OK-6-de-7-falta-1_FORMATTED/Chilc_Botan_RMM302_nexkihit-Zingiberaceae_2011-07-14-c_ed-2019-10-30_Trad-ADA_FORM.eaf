            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>Digamos nosotros ya nos enfermamos, ya no es lo mismo como nos alimentamos en aquéllos tiempos. Ahora, por eso te digo, les cuento aquí,</ANNOTATION_VALUE>
