        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
                <ANNOTATION_VALUE>kowta:kilo:tsí:n *porque**</ANNOTATION_VALUE>
