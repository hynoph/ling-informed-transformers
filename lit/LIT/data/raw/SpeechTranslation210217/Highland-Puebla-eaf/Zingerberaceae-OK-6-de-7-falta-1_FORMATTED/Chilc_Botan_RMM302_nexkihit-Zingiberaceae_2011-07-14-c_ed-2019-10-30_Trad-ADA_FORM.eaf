                <ANNOTATION_VALUE>Pero kitel..., kitelahwia:k..., kitelahwia:k..., kitelahwia:kchi:wa ne:n tixti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
                <ANNOTATION_VALUE>A:mo *igual** ke:meh n' okseki tamaliswat *porque** n' okseki tamaliswatsí:n,</ANNOTATION_VALUE>
