            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a210">
                <ANNOTATION_VALUE>también se chiquea, digamoslo así porque saben que nos ..., bueno sabemos que con ello nos podemos ayudar en las actividades. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>Ahora, otra cosa, no sé, mm,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>el nexkihit del que te digo,</ANNOTATION_VALUE>
