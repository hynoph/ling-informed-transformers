            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
                <ANNOTATION_VALUE>no: mone:nektiki:sa mah tikihto:ka:n tehwa:n *porque** kimattokeh *que** te:ch..., tik..., bueno** tikmattokeh *que** te:chpale:witi yo:n iswa..., yo:n xiwtsí:n. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
