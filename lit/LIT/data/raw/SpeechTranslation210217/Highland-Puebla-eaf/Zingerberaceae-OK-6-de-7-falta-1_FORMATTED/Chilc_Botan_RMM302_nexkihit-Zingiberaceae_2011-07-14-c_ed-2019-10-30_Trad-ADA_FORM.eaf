        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
                <ANNOTATION_VALUE>Wa:n tein te:chpale:wia tikmattokeh se: ta:kilo:tsí:n tein te:chpale:wia pos,</ANNOTATION_VALUE>
