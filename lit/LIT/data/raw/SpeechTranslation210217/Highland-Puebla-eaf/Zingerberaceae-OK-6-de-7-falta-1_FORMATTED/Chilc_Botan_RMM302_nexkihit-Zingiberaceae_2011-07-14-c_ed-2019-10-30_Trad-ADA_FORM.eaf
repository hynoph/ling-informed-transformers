                <ANNOTATION_VALUE>Wa:n okseki a:mo, okseki sayoh xwiwita wa:n xtamo:ta ne:wí:n wa:n ompa pe:wa selia ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
                <ANNOTATION_VALUE>¿Ke:yeh? *Porque** tikmattokeh *que** a:mo teh te:chpale:wi:ti para tei.</ANNOTATION_VALUE>
