        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>También lo comen, esos frutos también lo comen porque sabes porqué, esos lo comen más porque los mismos animales saben que nadie los cosecha,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>pues el fruto es muy parecido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Es muy parecido al nexkihit, solo te digo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>que no se puede comer pues porque los frutos son muy pequeños, no hay mucho qué sacarle para comer,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>es más cáscara,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>es pura cáscara.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>Ahora, las hojas,mi mamá me dijo que las hojas también se pueden usar para envolver tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>pero el olor se le impregna mucho a la masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>Los otros tipos de hojas que se usan para envolver tamales no tienen ese mismo olor,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>pues también tiene un olor pero ese olor no impregna a la masa pero el otro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>el olor si queda impregnada. Porque el olor es muy fuerte, digamoslo así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Por eso no lo ocupan para envolver los tamales. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>Ese no, ese lo usan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>solamente una hoja, una, una hoja completa se usa para envolver un tamal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>Porque, ¿Sabes porqué?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>Porque la vena principal de esa hoja no es gruesa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>porque son muy pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>Y pues casi no la usan, pues sabes, que ahora hay bastante, tenemos bastante de las hojas del nexkoko:kistat, digo del nexkihiiswat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a199">
