            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>Ciertamente como yo les digo lo que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a223">
