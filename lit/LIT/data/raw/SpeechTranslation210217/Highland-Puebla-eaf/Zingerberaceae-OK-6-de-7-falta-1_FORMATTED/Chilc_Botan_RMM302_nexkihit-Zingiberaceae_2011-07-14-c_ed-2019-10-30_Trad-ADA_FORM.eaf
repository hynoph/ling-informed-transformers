        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Como yo, este, en aquéllos tiempos a mí me gustaba mucho, donde veo que va a germinar ..., porque esas semillas se siembran al arboreo,</ANNOTATION_VALUE>
