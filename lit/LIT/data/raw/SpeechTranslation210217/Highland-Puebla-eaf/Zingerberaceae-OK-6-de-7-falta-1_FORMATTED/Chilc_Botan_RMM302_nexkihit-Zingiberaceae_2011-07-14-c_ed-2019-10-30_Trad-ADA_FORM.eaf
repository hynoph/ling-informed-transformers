            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
                <ANNOTATION_VALUE>¿Toni xkwali, toni xmahse:wa n' ke:meh yo:n? Wa:n nexkihit name:chilia neh</ANNOTATION_VALUE>
