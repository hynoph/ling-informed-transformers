        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
                <ANNOTATION_VALUE>Pos yehwa yo:n talna:miki:lis mah a:mo tikelka:wa:ka:n, mah tikine:xtili:ka:n topi:pilwa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>to..., toxwi:wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
                <ANNOTATION_VALUE>mah nochi tikimachtihtia:ka:n ke:ní:w n' tamahse:waskeh. *Porque** n' a:man nikita neh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
                <ANNOTATION_VALUE>a:man nikita n' koyo:pi:pil mah tikihto:ka:n tehwa:n, n' topi:pilwa:n nochi mo..., mo:...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
                <ANNOTATION_VALUE>mokoyo:nekih ya, a:mo no: kinekih kikwa:skeh ok n' tein tehwa:n tikmahse:wayah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
