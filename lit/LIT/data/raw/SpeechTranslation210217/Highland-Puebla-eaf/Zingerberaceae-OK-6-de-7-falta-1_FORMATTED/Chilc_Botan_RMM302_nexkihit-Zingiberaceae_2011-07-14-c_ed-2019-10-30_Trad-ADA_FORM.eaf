            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
                <ANNOTATION_VALUE>Neli ke:meh neh name:chilia tein tik..., tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
                <ANNOTATION_VALUE>moma:t..., timoma:patili:skiah ne:</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
                <ANNOTATION_VALUE>xola:l, towe:ixola:l, mah tikito:tih timoma:patili:tih tapalo:ltsí:n tein, tein mok..., tein moix..., tein se: kixta:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
                <ANNOTATION_VALUE>Yo:n kowtetsí:n tiktekitih sah wa:n tikchihchi:wah wa:n ompa tikpal..., ompa timopale:wiah tepitsi:n ika ya, yehwa yo:n neh name:chilwia.</ANNOTATION_VALUE>
