        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
                <ANNOTATION_VALUE>kikwa:snekih nochi koyo:tapalo:l,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
                <ANNOTATION_VALUE>pero ta: te:chi:wilih *mal**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
                <ANNOTATION_VALUE>Mah tikihto:ka:n tehwa:n te:ch..., te:chkokowa ya n' a:man. A:mo *ig...,** a:mo iw..., a:mo iwki ok ke:meh ne:ka tie:mpoh timotekipanohkeh. A:xka:n *por eso** nimitsilia neh name:ch..., name:chtapowia nika:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
                <ANNOTATION_VALUE>timonohno:ts..., timose:pannohno:tstokeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
                <ANNOTATION_VALUE>timon..., [timo]se:pani:xeheko:ltihtokeh nochi ke:ní:w motepan..., ke:ní:w deke, ke:ní:w motekipano:skeh n' topi:pilwa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
                <ANNOTATION_VALUE>toxwi:wa:n, mah tikini:xeka:naka:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>Ihkó:n ke:meh ne:ka to:nal tehwa:n timotekipanohkeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
                <ANNOTATION_VALUE>a:xka:n no: *igual** mah tehwa:n mah tikitaka:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
                <ANNOTATION_VALUE>mah tikine:xtili:ka:n ke:ní:w takwa:skeh, ke:ní:w tapalo:skeh, toni kimahse:waskeh, toni we:lik nika:n tehwa:n kow..., tokowta:kilo:w.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
                <ANNOTATION_VALUE>Mm. A:mo nikmati *que** ox iwki a name:chnohno:tstok *o** a:mo iwki n' ke:meh name:chtapowihtok pero,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
                <ANNOTATION_VALUE>yo:n semi kwaltsi:n mah tikihto:ka:n tehwa:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
                <ANNOTATION_VALUE>Mah, mah tikinchipa:wakpiaka:n topi:pilwa:n *porque** a:xka:n i:n tein a:man onkak tapalo:l, *este**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
                <ANNOTATION_VALUE>koyo:tapalo:l mah tikihto:ka:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
                <ANNOTATION_VALUE>a:mo *igual** ke:meh ma:se:waltapalo:l, ma:se:waltapalo:l *siempre** tikihtowah tehwa:n *más** chipa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
                <ANNOTATION_VALUE>Mm. Wa:n sayoh ximonemili no: n' tehwa:tsi:n, a:mo nikmati</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
                <ANNOTATION_VALUE>kox, ox iwki a nimitsnohno:tstok, pero neh nimitstapowihtok *lo que** tein neli.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
                <ANNOTATION_VALUE>Wa:n mah tik..., mah t'ta:li:ka:n itech toyo:lo, mah a:mo t..., mah a:mo tikelka:waka:n, mah t´ta:li:ka:n itech totalna:miki:lis para ihkó:n pos</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
                <ANNOTATION_VALUE>nochipa kwaltsi:n tikimpiaskeh topi:pilwa:n wa:n toxwi:wa:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
                <ANNOTATION_VALUE>Yehwa sah yo:n name:chtapowih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
                <ANNOTATION_VALUE>'Ne:chtapohpolwi:ka:n miak neh noto:ka:y Rubén Macario</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
                <ANNOTATION_VALUE>Martínez, de ..., neh niwa:le:w de Chi:lkwowtah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
                <ANNOTATION_VALUE>Wa:n nika:n, *este**, nik..., kel..., nika:n nipowi nika:n San Miguel. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Rubén Macario Martínez" PARTICIPANT="Rubén Macario Martínez" TIER_ID="RMM Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>Bueno, este, yo les voy a contar sobre el nexkihiiswat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>El que nosotros lo conocemos, este, lo ocupamos para,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>para varios, tiene varios usos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Yo me llamo Rubén Macario.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Vengo de Chilcoutah,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>pertenezco a San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>Yo les voy a contar de la hoja, de la hoja del nexkihit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Las hojas del nexkihit, nosotros lo ocupamos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>las hojas las ocupamos para envolver tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Al que nosotros le llamamos el piksatamal, le quitan la cáscara a los frijoles (y se revuelve con masa y luego) ya se envuelven (con las hojas)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Y los frutos nosotros preparamos para comida, con ello nos alimentamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>Ese lo cortan cuando ya está maduro porque cuando aún están inmaduros,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>pues cuando están inmaduros, no sirven, decimos porque aún no están maduros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>Pero cuando ya empiezan a madurar, se maduran, se vuelven ..., los frutos son negros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Así, ya se sabe que ya están listos para comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>Entonces que uno busque esos frutos, que uno los corte,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>y se le quite la cáscara.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Se le quita la cáscara, la cascarita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Y luego de que se la haya quitado la cáscara,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>empiezan a machacar con las manos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Con las manos lo machacan en agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>Lo disuelven bien, bien, lo disuelven, entonces quedan las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>se le sale. Y solamente queda la pulpa del fruto,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>la pulpa, sí, la pulpa, nosotros así le llamamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>se quedan las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Entonces toman (la pulpa) y la machacan sobre la palma de las manos para ir sacandole algunas semillas que hayan quedado porque si uno se come las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>al masticarlas las semillas, tiene un dolor desagradable y no es sabroso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Entonces lo limpian muy bien, le quitan todas las semillas y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>le quitan el corazón del fruto porque hay frutos que tienen el corazón o como si fuera médula, se parece,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>como si fuera, como si fuera un palito que tiene en el centro del fruto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Ese es el corazoncito del fruto del nexkihit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Entonces, todo eso se lo quitan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Solamente se queda pura pulpa, muy fina, como si fuera una telita pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>pura pulpa, pulpa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Lo agarran y lo limpian bien y luego</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>lo ponen en un, en un recipiente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>y el agua se pone por separado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Se pone en otro recipiente y en otro ponen la pulpa de ese fruto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Entonces lo agarran, toman un,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>algo con el que, que, con ello lo cernen, lo... No sé si lo conoces, no sé ustedes cómo le llaman, nosotros le llamamos, este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>le llamamos cedazo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Con ello lo limpian, con ello cernen el agua (para que no quede ninguna semilla).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>alguna basurilla o cualquier cosa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>La masa o con el que preparan un atole, con ello cernen el agua para atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Ocupan ese, ese cedazo y ahí vierten el agua del ese,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>el agua de la pulpa del nexkihit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Entonces, el agua sale libre de impurezas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Y las semillas quedan sobre el cedazo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Entonces para que no pase ninguna semilla, lo cernen, el agua queda libre de impurezas y luego ya lo vierten a la olla de barro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>en la olla de barro para hervirlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Entonces toman la pulpa de los frutos del nexkihit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>y ahí mismo lo echan, que hierva todo junto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Y ponen unos dos o tres hojas de,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>dos o tres hojas de pimienta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Y ya queda lista la comida, lista para comer la comida. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Sí. Pues nosotros, pues nosotros,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>lo sabemos pues nosotros nos alimentamos con ello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>No podemos decirte que no es sabroso, pues con ello nos alimentamos desde cuando éramos muy pequeños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Así nos alimentaron nuestros abuelos y padres,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>pues nosotros nunca se nos olvida ese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>tipo de comida, pues hasta ahora lo conocemos, aunque ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Ahora como nosotros vamos conociendo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>también a nuestros hijos les vamos enseñando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>cómo prepararlo para comer,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Cómo van a hervirlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Eso no se olvida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Ahora, las hojas también se usan.</ANNOTATION_VALUE>
