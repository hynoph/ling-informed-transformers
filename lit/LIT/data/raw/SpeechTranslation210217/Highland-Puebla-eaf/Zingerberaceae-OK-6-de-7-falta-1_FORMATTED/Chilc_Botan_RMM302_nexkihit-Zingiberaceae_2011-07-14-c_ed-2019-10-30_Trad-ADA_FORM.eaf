        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
                <ANNOTATION_VALUE>Ika yo:n a:mo kikwih para n..., para kipi:skeh ne:n taxkaltsí:n. Ke:mah.</ANNOTATION_VALUE>
