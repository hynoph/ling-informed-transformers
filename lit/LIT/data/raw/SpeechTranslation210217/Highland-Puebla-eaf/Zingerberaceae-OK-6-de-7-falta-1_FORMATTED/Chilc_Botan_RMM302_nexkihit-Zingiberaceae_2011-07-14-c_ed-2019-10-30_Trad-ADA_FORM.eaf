            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
                <ANNOTATION_VALUE>Wa:n *hasta** a:mo no: okachi kikwih, tikma:tis ke:meh a:man telonkak, tel..., ka:mpa, ka:mpa tiktelpiah yehwa yo:n iswa..., n' iswatsí:n nexkoko:kiswat, a:chá: nexkihiswat,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
