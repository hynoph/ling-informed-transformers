        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>No sé, este, quieres preguntarme otro tipo de conocimiento, este,</ANNOTATION_VALUE>
