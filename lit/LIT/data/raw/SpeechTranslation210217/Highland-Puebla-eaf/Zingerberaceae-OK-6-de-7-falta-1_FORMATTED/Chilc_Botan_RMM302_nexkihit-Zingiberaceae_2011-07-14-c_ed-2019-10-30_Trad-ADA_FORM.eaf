            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>Es mejor usar las hojas que siempre usamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>porque pues de por sí las conocemos. Hasta mis padres y mis abuelos me dicen que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>de estas hay, sólo porque nació, nació por sí sola.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>No se chiquea, solamente por ahí se tira el rizoma, se tira por ahí el rizoma,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a443" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>ahí salen nuevas plántulas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a444" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Y el nexkihit no es así. El nexkihit es necesario hacerle un hoyo y sembrarla, ir a sembrarla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a445" ANNOTATION_REF="a206">
