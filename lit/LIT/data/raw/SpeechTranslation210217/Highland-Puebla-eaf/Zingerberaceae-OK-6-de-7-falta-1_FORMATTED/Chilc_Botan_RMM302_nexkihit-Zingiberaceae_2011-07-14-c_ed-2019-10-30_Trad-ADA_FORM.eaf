        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a456" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>Este les he platicado sobre esa planta y </ANNOTATION_VALUE>
