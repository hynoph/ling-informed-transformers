        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
                <ANNOTATION_VALUE>kachi *más** kwali t'tatekiwtiah n' okseki tein tikmattokeh i:pa tikwih,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
                <ANNOTATION_VALUE>*porque** pos yo:n i:pa tiki:xmattokeh tehwa:n. *Hasta** note:iskaltihka:wa:n wa:n nowe:ita:twa:n ne:chilia:nih *que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
                <ANNOTATION_VALUE>pos i:n onkak i:n sayoh *porque** ya, *porque** i:pa onkak sah.</ANNOTATION_VALUE>
