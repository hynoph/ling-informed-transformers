        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
                <ANNOTATION_VALUE>*Mismo** yehwa nexkihit, sanoke nimitsilia neh,</ANNOTATION_VALUE>
