        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Todos son sabroso, tanto &lt;i&gt;xoxoktomakilit&lt;i&gt; y el &lt;i&gt;mora:dohtomakilit&lt;i&gt;, todos son sabrosos.</ANNOTATION_VALUE>
