        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>es más sabroso, este, como son dos tipos de los que crecen en los terrenos de cultivo,</ANNOTATION_VALUE>
