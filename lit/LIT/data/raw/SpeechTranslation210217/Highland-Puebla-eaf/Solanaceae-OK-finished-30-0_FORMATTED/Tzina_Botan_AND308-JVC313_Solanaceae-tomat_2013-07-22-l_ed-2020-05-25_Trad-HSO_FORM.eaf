        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts91">
                <ANNOTATION_VALUE>De yehwa n' ta:..., ki..., kikwah tak n' iteyo, de n' ta:kilo:t ya de n' tomat.</ANNOTATION_VALUE>
