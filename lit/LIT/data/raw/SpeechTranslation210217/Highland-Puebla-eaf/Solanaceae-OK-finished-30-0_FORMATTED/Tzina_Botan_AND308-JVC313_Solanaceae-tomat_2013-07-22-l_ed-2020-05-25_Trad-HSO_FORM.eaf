        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a454" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts553">
                <ANNOTATION_VALUE>Nochi nankichichinowa:yah *o** nankololowa:yah nochi n....</ANNOTATION_VALUE>
