        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts509">
                <ANNOTATION_VALUE>Achka se: kite:mili nijó:n kownex, ta:mo no: kihtowah no: kwa:tsa.</ANNOTATION_VALUE>
