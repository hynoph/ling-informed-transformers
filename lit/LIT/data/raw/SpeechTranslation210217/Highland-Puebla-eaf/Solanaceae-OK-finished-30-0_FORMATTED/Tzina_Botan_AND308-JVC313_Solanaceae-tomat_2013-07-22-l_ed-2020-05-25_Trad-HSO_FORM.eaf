        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>Nijó:n a:skameh pos no: tak 'kwaliah, seki 'kohkoyo:niah.</ANNOTATION_VALUE>
