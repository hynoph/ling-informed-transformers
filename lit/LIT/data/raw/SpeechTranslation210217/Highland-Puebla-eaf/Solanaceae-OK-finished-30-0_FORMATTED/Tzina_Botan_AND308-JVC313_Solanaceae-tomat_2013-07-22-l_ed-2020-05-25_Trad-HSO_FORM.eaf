        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>Wa:n yo:n no: seki yo:n kiliah n', yo:n, okwilimeh yo:n</ANNOTATION_VALUE>
