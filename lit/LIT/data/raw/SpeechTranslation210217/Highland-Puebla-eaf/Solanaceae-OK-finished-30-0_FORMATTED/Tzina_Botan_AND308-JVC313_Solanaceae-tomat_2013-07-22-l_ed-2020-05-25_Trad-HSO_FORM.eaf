        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>ompa mota:liah nijó:n a:skameh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
