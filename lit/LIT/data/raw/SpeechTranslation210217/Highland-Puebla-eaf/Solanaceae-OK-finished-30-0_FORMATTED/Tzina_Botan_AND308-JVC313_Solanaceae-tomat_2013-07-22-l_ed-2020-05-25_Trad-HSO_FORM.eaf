        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a472" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts589">
                <ANNOTATION_VALUE>No: *morado** kwaltsi:n.</ANNOTATION_VALUE>
