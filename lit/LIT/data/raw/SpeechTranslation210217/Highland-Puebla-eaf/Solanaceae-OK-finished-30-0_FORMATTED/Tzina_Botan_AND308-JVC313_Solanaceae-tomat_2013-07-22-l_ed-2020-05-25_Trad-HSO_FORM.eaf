                <ANNOTATION_VALUE>A:, *porque** sepa nika:n timona:mikih</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
