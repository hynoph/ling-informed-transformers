        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a452" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts549">
                <ANNOTATION_VALUE>A:, nankichichinowa:yah ne:n tah..., tahsolx para ne:.</ANNOTATION_VALUE>
