        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts292" TIME_SLOT_REF2="ts294">
                <ANNOTATION_VALUE>para ompa t'ta:lia n' tomatsí:n para a:mo wehweliwi.</ANNOTATION_VALUE>
