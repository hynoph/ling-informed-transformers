        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
                <ANNOTATION_VALUE>de ta:ki ihkó:n se: *viaje** t'tekis, ke:mah tikteki a n' tomatsí:n wa:n</ANNOTATION_VALUE>
