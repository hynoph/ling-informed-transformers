                <ANNOTATION_VALUE>Wa:n no: seki okwiltsitsí:n no:, no: kikwih, imahma:ko wa:n tak yo:n no: 'kohkoyo:niah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
