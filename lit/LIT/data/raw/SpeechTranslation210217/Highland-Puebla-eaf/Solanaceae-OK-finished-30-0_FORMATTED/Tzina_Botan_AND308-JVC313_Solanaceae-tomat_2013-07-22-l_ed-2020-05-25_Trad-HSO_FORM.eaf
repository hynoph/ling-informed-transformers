        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>No: *hasta** ke:masá: n' ima:ko no: se: ki..., se: kita,</ANNOTATION_VALUE>
