        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>tiki:xmattok *que** yo:n tomat, tein yo:n nika:n kiliah ne:, de nika:n tomat kiliah</ANNOTATION_VALUE>
