        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
                <ANNOTATION_VALUE>ne: mo..., ta:ki sake:ra ka:n ohka:n, e:xka:n wa:n</ANNOTATION_VALUE>
