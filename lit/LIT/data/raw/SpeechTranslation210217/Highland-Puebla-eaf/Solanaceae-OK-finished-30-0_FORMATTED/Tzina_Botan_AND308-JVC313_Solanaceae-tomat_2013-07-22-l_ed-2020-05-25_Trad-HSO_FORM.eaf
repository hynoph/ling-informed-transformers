            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts491">
                <ANNOTATION_VALUE>Porin xaxakachtik tepitsi:n a:mo kwi:ka.</ANNOTATION_VALUE>
