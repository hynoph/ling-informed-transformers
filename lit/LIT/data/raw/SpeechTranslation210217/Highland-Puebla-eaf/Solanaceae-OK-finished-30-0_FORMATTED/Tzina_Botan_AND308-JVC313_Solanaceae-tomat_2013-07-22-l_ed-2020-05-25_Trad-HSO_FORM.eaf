        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts406" TIME_SLOT_REF2="ts408">
                <ANNOTATION_VALUE>Wa:n nika:n tehwa:n tomatsí:n mochi:wa,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
