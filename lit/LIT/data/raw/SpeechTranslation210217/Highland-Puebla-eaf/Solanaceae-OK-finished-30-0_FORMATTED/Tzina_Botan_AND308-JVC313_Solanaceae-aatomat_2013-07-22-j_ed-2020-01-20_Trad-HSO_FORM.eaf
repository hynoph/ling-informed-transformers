        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>Wa:n sepa de n..., de hkó:n de chika:waya ya pané: kohkostia, ne:n, ie:wayo.</ANNOTATION_VALUE>
