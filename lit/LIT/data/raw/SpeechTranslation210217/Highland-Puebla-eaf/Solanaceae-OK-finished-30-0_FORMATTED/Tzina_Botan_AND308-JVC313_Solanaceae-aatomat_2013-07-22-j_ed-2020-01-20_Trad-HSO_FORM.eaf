            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts523">
                <ANNOTATION_VALUE>tato:k mochi:wa, katí:n me:tsti, katí:n, ne:n, ....</ANNOTATION_VALUE>
