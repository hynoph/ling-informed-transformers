        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>wa:n nona:nahtsi:n no: kimatik *desde cuando** katka siwa:pil</ANNOTATION_VALUE>
