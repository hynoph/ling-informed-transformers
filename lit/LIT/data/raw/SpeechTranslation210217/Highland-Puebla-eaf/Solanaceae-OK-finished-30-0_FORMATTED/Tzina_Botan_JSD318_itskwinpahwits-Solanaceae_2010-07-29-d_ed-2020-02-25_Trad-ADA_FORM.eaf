        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>Iwki sah a:mo tiyo:ltos, ti:xnentos sah ihkó:n ke:meh se: teisá:..., a:mo.</ANNOTATION_VALUE>
