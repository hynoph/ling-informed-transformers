        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a117" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>Yeh kipia seki o..., seki xiwit, seki xiwit kipia we:weyak, pata:wak</ANNOTATION_VALUE>
