        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>wa:n se: no: witsto:tomat pero tein ixta:wat mochi:wa, tein ne: kihtowa moso:sowa.</ANNOTATION_VALUE>
