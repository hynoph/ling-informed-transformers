        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>wa:n kitikotamo:tah. Chichinawi yo:n itomioh, ke:meskia ixki.</ANNOTATION_VALUE>
