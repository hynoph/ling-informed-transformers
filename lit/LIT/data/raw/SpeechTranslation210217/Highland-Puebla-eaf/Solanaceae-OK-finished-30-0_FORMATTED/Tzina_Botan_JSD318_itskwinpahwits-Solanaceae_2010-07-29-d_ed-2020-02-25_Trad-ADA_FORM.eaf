        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>tama:tsa:la:n sah ta:ká:n tikahsik yo:n, yo:n, yo:n xiwit ka:ni onkak.</ANNOTATION_VALUE>
