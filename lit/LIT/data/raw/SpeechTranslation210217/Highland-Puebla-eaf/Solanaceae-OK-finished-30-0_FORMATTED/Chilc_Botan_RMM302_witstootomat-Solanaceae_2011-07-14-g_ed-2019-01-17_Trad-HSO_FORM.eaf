        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Pues a mí me decían mis..., mis abuelos que le llaman &lt;i&gt;witsto:tomat&lt;/i&gt; porque,</ANNOTATION_VALUE>
