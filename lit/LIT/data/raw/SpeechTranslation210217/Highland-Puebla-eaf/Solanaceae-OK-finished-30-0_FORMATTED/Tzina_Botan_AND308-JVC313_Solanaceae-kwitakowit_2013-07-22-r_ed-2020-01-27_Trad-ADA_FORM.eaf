            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Y también sé que le llaman &lt;i&gt;kwitakokowit&lt;/i&gt;, con ello se cura el perro cuando se empacha.</ANNOTATION_VALUE>
