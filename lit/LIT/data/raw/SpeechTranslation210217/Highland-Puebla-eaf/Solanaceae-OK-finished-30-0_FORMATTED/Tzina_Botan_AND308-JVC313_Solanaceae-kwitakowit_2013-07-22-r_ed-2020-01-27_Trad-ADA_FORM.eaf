        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Sí, pues yo solamente he visto, este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a106">
