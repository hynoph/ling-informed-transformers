        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>mochi:wa seki *boli...**, seki mahyá:, mahyá:, mahyá: tikihtowah tehwa:n, *este**,</ANNOTATION_VALUE>
