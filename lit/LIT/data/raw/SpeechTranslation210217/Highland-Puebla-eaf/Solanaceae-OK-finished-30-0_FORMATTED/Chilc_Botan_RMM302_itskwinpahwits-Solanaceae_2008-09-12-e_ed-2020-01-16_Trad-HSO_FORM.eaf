        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>Kipia witsti n' ixiwyo wa:n ikowyo no: kipia witsti.</ANNOTATION_VALUE>
