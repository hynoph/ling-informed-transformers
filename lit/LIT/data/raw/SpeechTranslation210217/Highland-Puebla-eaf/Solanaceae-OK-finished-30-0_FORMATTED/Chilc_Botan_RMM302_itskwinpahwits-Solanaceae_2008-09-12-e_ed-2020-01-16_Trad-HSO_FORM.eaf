        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>Ke:meh n' ampó:n tikitas, tikitas se: sepa ata yo:n ix..., ikowyo</ANNOTATION_VALUE>
