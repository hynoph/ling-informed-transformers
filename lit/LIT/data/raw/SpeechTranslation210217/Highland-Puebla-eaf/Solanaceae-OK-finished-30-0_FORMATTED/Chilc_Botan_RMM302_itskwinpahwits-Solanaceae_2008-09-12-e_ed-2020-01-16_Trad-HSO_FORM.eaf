        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>Ka:mpa yeski mochi:wa yo:n, yo:n a:mo moneki tikto:kas, yo:n mochi:wa sah.</ANNOTATION_VALUE>
