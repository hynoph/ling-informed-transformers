        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>Wa:n yo:n, yo:n, *este**, n' ixo:chio ista:k.</ANNOTATION_VALUE>
