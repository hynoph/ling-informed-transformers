        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>Wa:n ixiwyo, ixiwyo wi..., ma:wihwitsioh.</ANNOTATION_VALUE>
