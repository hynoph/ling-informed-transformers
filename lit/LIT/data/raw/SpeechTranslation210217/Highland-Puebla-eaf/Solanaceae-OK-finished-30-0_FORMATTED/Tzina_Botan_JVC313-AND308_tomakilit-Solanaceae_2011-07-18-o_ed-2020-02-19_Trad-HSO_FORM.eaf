        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts290" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>Ka:n ta: ta:taman k..., nochi kiltsitsi:n ta:taman ne: ahwia:k a *compadrito**.</ANNOTATION_VALUE>
