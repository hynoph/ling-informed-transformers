        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts282" TIME_SLOT_REF2="ts284">
                <ANNOTATION_VALUE>Ta: se:, se: takwalistapowi ika.</ANNOTATION_VALUE>
