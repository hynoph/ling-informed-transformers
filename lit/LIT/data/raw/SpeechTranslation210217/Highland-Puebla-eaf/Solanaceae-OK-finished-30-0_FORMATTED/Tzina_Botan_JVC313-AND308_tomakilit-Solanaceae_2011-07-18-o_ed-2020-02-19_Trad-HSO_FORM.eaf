        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts286" TIME_SLOT_REF2="ts288">
                <ANNOTATION_VALUE>A: ke:mah *compadrito** yo:n. Se: mayana neli. Se: maya:na.</ANNOTATION_VALUE>
