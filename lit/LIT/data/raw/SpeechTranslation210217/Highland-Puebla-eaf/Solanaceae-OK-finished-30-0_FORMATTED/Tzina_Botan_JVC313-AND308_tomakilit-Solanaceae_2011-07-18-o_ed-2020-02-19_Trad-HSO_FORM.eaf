        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts270" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>Kanah, kanah, ihkó:n. Tehwa:n no: iwki sah tikwah, ompa tehwa:n a:mo kipatiliah.</ANNOTATION_VALUE>
