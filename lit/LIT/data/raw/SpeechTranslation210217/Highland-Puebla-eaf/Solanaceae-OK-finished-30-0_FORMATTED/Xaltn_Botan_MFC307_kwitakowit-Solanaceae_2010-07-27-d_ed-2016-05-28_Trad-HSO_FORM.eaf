        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Le hago la limpia y ave... cuando termino de limpiar este...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a72">
