        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>Cuando lo..., también debes bañar al niño con las hojas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a53">
