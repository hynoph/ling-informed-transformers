        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>y despues la flor se abre, si, la flor se abre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Po eso le llaman kwa:nakatsitsi:n.</ANNOTATION_VALUE>
