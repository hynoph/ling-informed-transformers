        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>Yo sé que lo preparan y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>se consume y queda muy poco de agua. Si, y ya les dan a los niños que están enfermos.</ANNOTATION_VALUE>
