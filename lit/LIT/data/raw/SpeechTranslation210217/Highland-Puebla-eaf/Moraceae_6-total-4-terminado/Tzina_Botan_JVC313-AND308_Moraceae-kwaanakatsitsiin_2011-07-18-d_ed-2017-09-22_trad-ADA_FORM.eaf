            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>Y las víboras que son largas, quiza las conocidas como kowa:we:wentsi:n.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>La víbora conocida como we:wentsi:n creemos que muerde. Esta no muerde, sino que se cuelga sobre uno, se adhiere a la piel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a207">
