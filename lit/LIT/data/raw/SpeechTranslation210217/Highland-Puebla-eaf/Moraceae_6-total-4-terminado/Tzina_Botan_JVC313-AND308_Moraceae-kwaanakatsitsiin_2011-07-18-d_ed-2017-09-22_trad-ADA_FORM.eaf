        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Le llaman kwa:nakatsitsi:n porque al crecer así, no crece alta, así se desarrolla.</ANNOTATION_VALUE>
