        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>unas hojas y lo hacían así y</ANNOTATION_VALUE>
