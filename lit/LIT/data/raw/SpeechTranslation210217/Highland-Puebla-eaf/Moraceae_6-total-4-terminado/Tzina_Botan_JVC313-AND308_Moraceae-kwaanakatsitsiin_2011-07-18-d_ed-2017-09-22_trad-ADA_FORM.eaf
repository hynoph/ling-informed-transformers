        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>le llaman a:xi:wah, si, a:xi:wah, lo ocupaban</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Si, son cucharas de ..., No.</ANNOTATION_VALUE>
