        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts477">
                <ANNOTATION_VALUE>Ma:tankeh xiwit,yo:n nochi nikelka:wka pero yikintsi:n nimo..., nochi nik....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts478" TIME_SLOT_REF2="ts480">
                <ANNOTATION_VALUE>Seko sah nochi, sayoh, ma:tankeh xiwit tiki:xmati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
                <ANNOTATION_VALUE>Chakay xiwit n' iselo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
                <ANNOTATION_VALUE>Miak nochi se: kisentilia wa:n seko sah kimanah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
                <ANNOTATION_VALUE>Kimanah wa:n yehwa yo:n nochi, motokotsowa n' a:tsí:n wa:n ika ki..., ka:ltiah se: kone:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
                <ANNOTATION_VALUE>Yehwa yo:n semi, semi kwali yo:n xiwit *o**..., yehwa ya n' topah, xiwpah. Tikiliah xiwpah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
                <ANNOTATION_VALUE>Xiwpah *porque** nochi miak xiwtsitsí:n kiliah xiwpah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
                <ANNOTATION_VALUE>para seko sah kimanah. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
                <ANNOTATION_VALUE>Yehwa yo:n neh nikmati, yehwa sah yo:n neh nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
                <ANNOTATION_VALUE>nikitani. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
                <ANNOTATION_VALUE>Pos kintsi:n ke:meh i:n tehwa:n timonohno:tsah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
                <ANNOTATION_VALUE>nochi timotapowiah wa:n se:meh de n...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
                <ANNOTATION_VALUE>na:nahmeh no: monohno:tsah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
                <ANNOTATION_VALUE>Niman kihtowah, kintsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
                <ANNOTATION_VALUE>okseko tikta:lili:tih n' itilmahtsi:n se: kone:tsi:n *o** tehwa:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
                <ANNOTATION_VALUE>Wa:n at..., *antes** a:mo kimatiah, wehka:w ya ihkó:n na:nahmeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
                <ANNOTATION_VALUE>pos ki..., kise:nta:lia:yah tilmah ma:s se:, de se: kone:tsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
                <ANNOTATION_VALUE>*porque antes** kitapa:kia:yah itech n',</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
                <ANNOTATION_VALUE>se: tetsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
                <ANNOTATION_VALUE>Kintapa:kia:yah ihkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
                <ANNOTATION_VALUE>Wa:n kintsi:n a:mo, kintsi:n te:chtapa:kiah itech yo:n kaltsi:ntan oso yowih ne:wí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
                <ANNOTATION_VALUE>tapa:katih pos *aparte** kita:liah ya n' tilmahtsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
                <ANNOTATION_VALUE>*hasta** kipihpilowah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
                <ANNOTATION_VALUE>Kintsi:n, nikneltoka ke:meh no: tikmati,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
                <ANNOTATION_VALUE>ikintsi:n koto:nik de nijó:n ko..., kokolis de yo:n netati:l, kintsi:n a:mo okachi se: te:kakilia ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
                <ANNOTATION_VALUE>A:mo kachi se: te:kakilia ok, kintsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
                <ANNOTATION_VALUE>pos no: kinkwi n' kokolis n' kone:meh pero,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
                <ANNOTATION_VALUE>pos no: se: taman.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
                <ANNOTATION_VALUE>Pero netati:l kintsi:n a:mo, wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
                <ANNOTATION_VALUE>wehka:w ya ne:n tota:tahwa:n te:chilia:yah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
                <ANNOTATION_VALUE>yehwa nijó:n nemia wa:n ika, ika mikiah ne:n kone:meh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
                <ANNOTATION_VALUE>Ke:meh eskia, ne:n, wa:kiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
                <ANNOTATION_VALUE>Wa:kiah *porque** nijó:n ke:meh eskia se: tatatiw.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
                <ANNOTATION_VALUE>Ke:meh i:n e:wat de i:n to..., te:wayo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
                <ANNOTATION_VALUE>pos nochi ko..., ki..., tsahtsaya:nia ihkó:n, koto:nia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
                <ANNOTATION_VALUE>Koto:nia wa:n ya:ya ihkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
                <ANNOTATION_VALUE>Ne:nemia, ke:meh eskia nochi te:ne:nemi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
                <ANNOTATION_VALUE>Te:ne:nemi se: ima:ko, se: imetsko, nochi se: *ilomo**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
                <ANNOTATION_VALUE>*hasta** itech, *hasta** se: itson nika:n *hasta** xi:nia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
                <ANNOTATION_VALUE>Para se: kone:t nochi xi:nia n' itson.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
                <ANNOTATION_VALUE>Wa:n kintsi:n a:mo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
                <ANNOTATION_VALUE>Ekintsi:n tikitah se: kone:tsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
                <ANNOTATION_VALUE>pos nochi kipia n' itson.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
                <ANNOTATION_VALUE>Wa:n ke:masá: de yo:n te:kwi yo:n netati:l,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
                <ANNOTATION_VALUE>nochi xi:ni, ne:n, se: itson.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
                <ANNOTATION_VALUE>We:wehka sah moka:wa, *o** k..., *antes** ihkó:n tikitayah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
                <ANNOTATION_VALUE>Yohyowaltik xi:nia n' tson..., n' tsonti, se: itson.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
                <ANNOTATION_VALUE>Ke:mah. Yehwa yo:n neh nikmati sah. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
                <ANNOTATION_VALUE>Pos nehwa nimono:tsa Anastacio Nicolás Damián.</ANNOTATION_VALUE>
