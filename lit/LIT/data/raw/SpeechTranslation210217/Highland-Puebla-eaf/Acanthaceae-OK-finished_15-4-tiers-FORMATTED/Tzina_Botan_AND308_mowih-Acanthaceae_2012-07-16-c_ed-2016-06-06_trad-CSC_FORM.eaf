        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
                <ANNOTATION_VALUE>ma:ltantsi:n no: semi kwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>Yo:n ika s..., no: se: tai.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts198">
                <ANNOTATION_VALUE>Se: kitai:ltia n' kone:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>Para te:chma:..., te:ch..., te:chna:miki oso kina:miki se: kone:t,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts202">
                <ANNOTATION_VALUE>pero miak, miak xiwtsitsí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>kima:nelowah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>Nochi iwa:n mowihxiwit kima:nelowah wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
                <ANNOTATION_VALUE>pos nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
                <ANNOTATION_VALUE>kina:miki se: kone:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>Nehwa ihkó:n nikmattok *porque** seki *hasta**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>de yo:n pos, se: te:te:mi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
                <ANNOTATION_VALUE>Koma:mo se: kipahtia se: kone:t, se: te:te:mi *porque**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a117" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
                <ANNOTATION_VALUE>pos nochi tatatiw.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>Tatatiw, chi:chi:le:wtiw ihkó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a119" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
                <ANNOTATION_VALUE>wa:n de pe:wa ya se: kita se: kone:t de pahtitiw,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>nijó:n yohyowaltik ne: moka:wa, achi ti:le:wi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a121" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
                <ANNOTATION_VALUE>Ke:meh eskia yo:n tihti:le:wi de pahtitiw ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>Entó:s *después** moka:wa pos a:mo nochi,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>a:mo nochi kwali moka:wa ok, ke:masá: mo..., moka:wa ihkó:n yohyowaltik,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>achi nijó:n tihti:ltik ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>*Porque** a:mo weli, a:mo kwal..., kwali moka:wa ok, ke:meh eskia yo:n, xihxi:pe:wi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a126" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
                <ANNOTATION_VALUE>Yehwa yo:n neh nikmati de yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>de yo:n xiwtsí:n, yo:n semi kwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
                <ANNOTATION_VALUE>*Por eso** kwali, ka:nsika nijó:n ki..., kito:ktokeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a129" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
                <ANNOTATION_VALUE>Kito:ktokeh, pero neh nikita pané: a:mo semi wehkapania.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts244">
                <ANNOTATION_VALUE>A:mo semi wehkapania pero yo:n semi kwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>Ka:nsika kito:ktokeh ihkó:n xi...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
                <ANNOTATION_VALUE>kaltsi:ntan kito:ktokeh, no: ka:mpa mona:mikih ihkó:n kwali no: kita:liah yo:n *matita**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>Entó:s selia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
                <ANNOTATION_VALUE>Mochi:wa ihko:kó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>ihko:kó:n ne:n seki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
                <ANNOTATION_VALUE>Nijó:n, moyewalowa ihko:ni wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>ihkó:n de wehkapania wa:n ompa se: kiteki a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
                <ANNOTATION_VALUE>Se: kiteki wa:n yehwa yo:n kimanah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
                <ANNOTATION_VALUE>Yehwa yo:n sakapal no: semi kwali, n' sakapal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
                <ANNOTATION_VALUE>A:, pos yehwa a:mo nikelna:mikia, no: ne:n teahwach.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
                <ANNOTATION_VALUE>Miak taman de yo:n xiwtsitsí:n nikmattok de n...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
                <ANNOTATION_VALUE>Pos ika te:cha:ltia:yah *porque** tota..., tomomá:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
                <ANNOTATION_VALUE>tomomá:n te:cha:ltia:ya ihkó:n wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>yo:n teahwach xa: no: tiki:xmati, teahwach yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
                <ANNOTATION_VALUE>tsikitsitsi:n teke:span ne:n e:wi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>Kwaltsi:n, ke:meh eskia ihkó:n yowi, ihkó:n yowi n' i..., n' ixiwyo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>momah..., [mo]mahma:yo:tia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n se: kikwiti no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
                <ANNOTATION_VALUE>Se: kise:ma:nelowa nochi n' xiwtsitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
                <ANNOTATION_VALUE>Nochi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
                <ANNOTATION_VALUE>Entó:s ika ka:ltiah ya ne:n kone:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
                <ANNOTATION_VALUE>Komo kwali, kwali, we:i a n' kone:tsí:n pos kitai:ltiah tsikilitsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
                <ANNOTATION_VALUE>Tai wa:n ke:mah nijó:n ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>nochi ka:ltiah *hasta** nika:n kita:liliah n' ipanko nochi ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
                <ANNOTATION_VALUE>ihkó:n xiwpach, nochi ne:n tama:nelo:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
                <ANNOTATION_VALUE>Ke:mah, yehwa i:n, kimilowah ika n' a:ya:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
                <ANNOTATION_VALUE>A:ya:t kimilowah wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
                <ANNOTATION_VALUE>kite:kah ya ne:n mi:to:nia, pos ika yo:n, yo:n kwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
                <ANNOTATION_VALUE>Nijó:n semi kwali nijó:n, nijó:n xiwtsitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
                <ANNOTATION_VALUE>Ne: okotsokowxiwit xa: no: tiki:xmati, yeh we:i kowit mochi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
                <ANNOTATION_VALUE>Pero ne:n imahma:yo kwaltsi:n nijó:n pané: ma:y..., ma:yohyowaltik wa:n kipia ihkó:n pané: n' ite:mpi:l,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
                <ANNOTATION_VALUE>ihko:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
                <ANNOTATION_VALUE>Entó:s se: kima:xakwalowa semi ahwia:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
                <ANNOTATION_VALUE>Ahwia:k yo:n xiwtsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
                <ANNOTATION_VALUE>Katí:n ne:n tsi:tsika:s, yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
                <ANNOTATION_VALUE>*porque** n' tsi:tsika:s miak taman onkak, wehwei seki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
                <ANNOTATION_VALUE>Wa:n yo:n de n' se: kikwi para pahti yo:n ka:nsika se: kita tep..., tepe:tsi:ntan *o** ka:nsika nehkwí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
                <ANNOTATION_VALUE>Tsikitsitsi:n ihkó:n, ma:nehnextik wa:n ma:ahalaxtik,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
                <ANNOTATION_VALUE>se: mokwi:ltia, ye:k semi te:kokoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
