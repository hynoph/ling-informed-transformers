        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Y sus hojas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>pues no crece mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>A veces lo siembra uno junto a las casas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Y pues cuando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>un niño se enferma de...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>la enfermedad del escarlatina, nosotros le decimos escarlatina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Le decimos escarlatina porque,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>este (la piel del bebé) pareciera que se va requemando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>En sus manos en o en sus pies.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Todo en su lomo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>Entonces así se va extendiendo esa enfermedad en la piel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>Esa enfermedad de la escarlatina,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>así le llaman porque a veces,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>revuelven la ropa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>de la mamá del bebé o alguién a quien le lavan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>Le agarra esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Por eso le llaman escarlatina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Ya es cuando empiezan a buscar de algún remedio</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>que lo pueda curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Entonces cortan las hojas del mowih, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>y lo hierven, lo hierven bien</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>y se hierve hasta reducir el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Le agregan algo de agua para que reduzca así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Y pues ya le dan a beber,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Le dan a beber un poco y lo bañan con esa misma agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>porque esa enfermedad se presenta mediante pequeños granitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>algunos granos se rompen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>y esa enfermedad se va extendiendo en manchas requemadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>Después hasta...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>En un principio la piel se pone rojiza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Y cuando ya se van perdiendo los granos se hacen redondos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Se hacen así redondos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>Nacen en todas partes del cuerpo, en la espalda, en la cabeza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>A los bebés les salen los granos en todas partes del cuerpo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Y las hojas del mowih, son muy buenas para eso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>porque para esa enfermedad de la escarlatina,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>se necesitan muchas cosas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>A lo mejor tu sabes también, porque yo sé que con eso nos curaban anteriormente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>unos ocupaban el omikilit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>el okotsohxiwit, la vergonzosa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a348" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>raices de la escobilla, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>el tsi:tsika:s de plantas chiquitas que se da al pie de los cerros,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>del que se roza uno y es urticante.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Eso es todo lo que ocupan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>también usan el sakapal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Usan el sakapal y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>muchas otras hierbas revueltas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>A veces lo revuelven junto con,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>esta hierba,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>y lo ponen en una olla de barro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Anteriormente nosotros le deciamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>nuestros abuelos le decían me:liohko:mit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Actualmente le decimos ollita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>con eso, con eso lo hervian.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Y entonces hervian las hierbas, le echaban algo de agua pero se reducía al hervir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Después le daba a beber un poco y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>con eso bañan el bebé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Lo bañan y después</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Después le tienden unas cobijas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>le tienden unas cobijas en su cama.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Le dicen cama porque así le ponían.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Entonces este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Después lo envuelven bien con la cobija.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Y suda el enfermo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Se cura. Se cura ese bebé pero se necesitan muchas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>se necesitan muchas hierbas y ya se revuelven junto con las hojas del mowih.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Yo sé que eso es lo que se ocupa porque veía antes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>que con eso bañaban a mis hermanos...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>con eso les bañaban bien. Despedazan las hierbas y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>los residuos que quedan al revolver todas las hierbas </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>les ponen en la cabeza a los niños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Les ponen en su estomago o aqui.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Porque esa enfermedad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>es muy peligrosa porque puede hasta morir el niño si no fue atendido a tiempo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Porque se va requemando, se va requemando eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Se va requemando porque,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>pues eso es lo que le hace mal a un niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>O hasta nosotros también porque si nos lavan nuestra ropa, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>porque a veces revuelven</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>con la ropa de la mujer (recien aliviada),</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>cuando revuelven la ropa, es cuando le aggarra a uno es enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Para curar esa enfermedad pues se ocupan esas hierbas que les digo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>el o:mekilit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>el o:mekilit y el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>este, raices de la vergonzosa, la escobilla, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>el tsi:tsika:s,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>el okotsohkowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Todo eso lo revuelven con un poco de ma:ltantsi:n,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>el ma:ltantsi:n también es muy bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>A veces también se toma.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Se le a beber el niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Para que le alivie a uno o para que alivie al niño,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>pero muchas hierbas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Revuelven muchas hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Las revuelven junto  con las hojas del mowih y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>pues este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>le cura al bebé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Eso es lo que yo sé porque algunos hasta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>se inchan por esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Si no cura a uno el bebé se enferma uno porque (aquí no explica bien lo que quiere decir, esta confuso)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>pues todo se va requemando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Se va requemando y al mismo tiempo se va poniendo colorado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Y cuando uno ve que el niño ya se va curando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>van quedando manchas negras y redondas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Cuando ya se va curando, se hacen unas manchas negras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Entonces después se queda, pues no todo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>ya no queda bien, a veces quedan manchas redondas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>quedan manchas negras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Porque ya no queda bien la piel, queda co o si fuera pelada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Eso es lo que yo sé de esa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>de esa hierba, esa hierba es muy buena.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Por eso en algunos lugares lo cultivan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Lo cultivan pero yo veo que no crece muy alta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>No crece muy alta pero es muy efectiva para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>En algunos lugares lo cultivan..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>En algunos lugares lo cultivan junto a las casas o donde limitan sus terrenos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>La planta retoña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Y se hacen de este tamaño,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>unos son de este tamaño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Se hace una mata grande y redondeada,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>crece de este tamaño y ya es ahí donde uno corta las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Ya lo corta uno y es lo que hierven.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>El sakapal también es muy bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>A y no me acordaba que también se ocupa el teahwach.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Sé de muchas hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Con eso nos bañaban nuestras mamás,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>nuestra mamá nos bañaba con esas hierbas y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>el teahwach, a lo mejor también conoces el teahwach,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>son plantas pequeñitas que abundan en las superficies de las piedras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Sus hojas son asi (seguramente muestra con las manos)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>se ramifica.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Y eso es lo que uno va a buscar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Se revuelven todas las hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Se revuelve todo junto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Y ya con eso bañan el bebé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a443" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Si el bebé ya está grande pues les dan a beber un poco de esa agua preparada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a444" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Y de que ya se lo toma este...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a445" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>lo bañan bien en todo su cuerpo con esa agua</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a446" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>con todo los residuos de las hierbas hervidas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a447" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Y de ahí lo envuelven con una cobija.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Lo envuelven con una cobija y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>lo acuestan, suda y con eso se compone.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Esas hierbitas son muy efectivas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>El okotsohxiwit también lo has de conocer, ese se hace un árbol grande.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a452" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Pero sus hojas son redondas y con picos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a453" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>así. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a454" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Cuando se restriega con las mannos desprende un olor muy rico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a455" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>Esas hojas tienen un olor rico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a456" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Cuál, el tsi:tsikas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>porque del tsi:tsika:s hay muchos tipos, unos son grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Y el que se ocupa para remedio, se puede encontrar al pie de los cerros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Son plantas pequeñas, de hojas grisáceas y lisas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>cuando se roza uno con esas hojas arde la piel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Arde en la parte donde uno se roza con las hojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Ya sea en las manos o en los pies.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a463" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Hasta salen granitos en la piel, esa es</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>se le tiene miedo en donde abunda. Hay lugares donde abunda mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a465" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Aunque no haya en abundancia pero se reconoce luego.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a466" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Si uno va pasando por ahí..., (y se roza uno) duele mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a467" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Eso es, pero eso es muy bueno cuando lo revuelven.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a468" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>hay otro tsi:tsika:s que crece grande pero no sirve para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a469" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>Esas nada más sirven para...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>Anteriormente nuestros abuelos con eso envolvian la carne.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Pero ese no sirve para este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>no sirve para remedio. El que sirve es el de plantas chiquitas..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Eso es lo que yo sé, si, eso es lo que les puedo decir. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>Pues esa hierba pinta el agua de color morado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>se restriegan las hojas con las manos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>sus hojas son negras y la tinta sale negra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>Entonces ya le echan agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>y ya lo pinta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Pinta el agua porque lo revuelven. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>el agua se pinta de color gris, de color morado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Si, eso es...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>Y de que ya paran.., se me habia olvidado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>revuelven todas las hierbas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>todo queda morado de que se revuelven las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>Como ya se revuelve todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Eso es,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a489" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>el agua se cambia de color, auque sea agua limpia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>pero de que se revuelve todo, entonces</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a491" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>se revuelve todo y ya queda como si fuera </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>bien moradito, de color gris.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a493" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>Y ya es lo que se ocupa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a494" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>Ya se ocupa para, para...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a495" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>con eso ya lo curan a uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a496" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Hasta uno lo pueden curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a497" ANNOTATION_REF="a206">
                <ANNOTATION_VALUE>Hasta uno también se puede curar con eso, n nada más a los niños, porque a veces también le agarra a uno,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a498" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>si uno no es de valiente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a499" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>Esa enfermedad es, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a500" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>si no se atiende uno o no atienden el niño puede provocar a muerte.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a501" ANNOTATION_REF="a210">
                <ANNOTATION_VALUE>Se hacen grandes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>se hincha uno, se hincha uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a503" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>Se hace grande hasta la cabeza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>Pero con esas hierbas, esas hierbas son muy buenas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a505" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>Son muy buenas, bueno yo veía a mi hermano</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a506" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>él era pequeño y le habian agarrado esos granos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a507" ANNOTATION_REF="a216">
                <ANNOTATION_VALUE>Le habían lavado su ropa en la orila del arroyo en un, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a508" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>en una piedra redonda y le hizo, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a509" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>Le hizo daño de que no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a510" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>no le hizo bien de que ahí le lavaron y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a511" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>a lo mejor ahí habían lavado otras personas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a512" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>Y como revolvieron la ropa pues le agarró la enfermedad de la escarlatina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a513" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>Entonces se extendió la enfermedad hasta en su cabeza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a514" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>Empezó a hincharse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a515" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>Y buscamos todas esas hierbas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a516" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>revolvieron todo y prepararon.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a517" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>Y lo bañaron con esa agua preparada y se alivió.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a518" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>Y se alivió de la hinchazón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a519" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>La hinchazón es cuando se llena la persona</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a520" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>en las manos o en los pies.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a521" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>Y ya no tiene uno el apetito para comer,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a522" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>nada más bosteza uno. Asi es eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a523" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>Pero esas hierbas son muy efectivas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a524" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Muchos saben de eso y muchos no saben.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a525" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>Yo sé porque a veces voy a traer esa hierba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a526" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>Voy a traer en grandes cantidades, en costal, también he ido a traer sauco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a527" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>El sauco también es bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a528" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>El sauco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a529" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>Se puede revolver todo junto,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a530" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>con el ma:ltantsi:n y otras hierbas más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a531" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>Para que a los niños les haga un buen efecto, hay ocupar muchas hierbas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a532" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>se consiguen las hierbas por costales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a533" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>A veces he ido a traerlas por las orillas del río Tozan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a534" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>Allá voy porque allá siempre encuentro eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a535" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>También se ocupa el chakayxiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a536" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>Las hojas de quiebracha también se ocupan...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a537" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>se prepara todo junto, conoces las hojas de la quiebracha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a538" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Las hojas tiernas del chakay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a539" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>Se junta muchos tipos de hierbas y se hierven todo junto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a540" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>Lo hierven y ya con eso bañan al bebé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a541" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>Eso es muy bueno, ese es el remedio para nosotros, le decimos remedio de hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a542" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>Le llaman remedio de hierbas porque se ocupan muchos tipos de hierbas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a543" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>y se hierven todo junto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a544" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>Eso es todo lo que yo sé,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a545" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>lo que he visto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a546" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>Pues actualmente como ya estamos platicando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a547" ANNOTATION_REF="a258">
                <ANNOTATION_VALUE>nos platicamos todo y alguien...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a548" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>las mujeres también se platican de esto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a551" ANNOTATION_REF="a260">
                <ANNOTATION_VALUE>Luego dicen, ahorita</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a552" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>vamos a separar la ropa del bebé y nuestra ropa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a553" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>Y anteriormente las señoras no sabían,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a554" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>y juntaban la ropa del bebé (con la ropa de la mujer recien aliviada),</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a555" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>porque antes les lavaban</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a556" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>en una piedrita (en una laja).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a557" ANNOTATION_REF="a266">
                <ANNOTATION_VALUE>Ahí les lavaban.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a558" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>Ahora ya no, actualmente nos lavan en la casa o van por ahí,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a559" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>a lavar pero ya separan la ropa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a560" ANNOTATION_REF="a269">
                <ANNOTATION_VALUE>hasta para tender lo separan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a561" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>Ahora te creo lo que tu sabes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a562" ANNOTATION_REF="a271">
                <ANNOTATION_VALUE>actualmente ya no hay mucha de esa enfermedad, actualmente ya no se escucha mucho de esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a563" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>Actualmente ya se escucha hablar mucho de eso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a564" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>hay enfermedades con los niños,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a565" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>pero de otras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a566" ANNOTATION_REF="a275">
                <ANNOTATION_VALUE>Pero de la escarlatina ya no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a567" ANNOTATION_REF="a276">
                <ANNOTATION_VALUE>y anteriormente nos decián nuestros padres,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a568" ANNOTATION_REF="a277">
                <ANNOTATION_VALUE>que esa enfermdedad abundaba y con eso fallecián los bebés.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a569" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>Como si fuera que se resecaban.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a570" ANNOTATION_REF="a279">
                <ANNOTATION_VALUE>Se resecaban porque eso es como si se fuera requemando uno. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a572" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>Como nuestra piel,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a573" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>se deshacia la piel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a574" ANNOTATION_REF="a282">
                <ANNOTATION_VALUE>Se despedazaba la piel y se iba </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a571" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>desprendiendo más, se extiende en todo el cuerpo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a575" ANNOTATION_REF="a284">
                <ANNOTATION_VALUE>Se extiende en las manos, en los pies y en la espalda,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a576" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>hasta en la cabeza y a veces hasta se cae el cabello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a577" ANNOTATION_REF="a286">
                <ANNOTATION_VALUE>A los bebés se les caía el cabello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a578" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>Y ahora ya no.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a579" ANNOTATION_REF="a288">
                <ANNOTATION_VALUE>Ahora vemos a un niño,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a580" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>pero tiene todo su cabello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a581" ANNOTATION_REF="a290">
                <ANNOTATION_VALUE>Y a veces de que nos agarra esa enfermedad de la escarlatina,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a582" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>se cae todo nuestro cabello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a583" ANNOTATION_REF="a292">
                <ANNOTATION_VALUE>Antes veiamos como los niñños tenian poco cabello pr lo mismo de esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a584" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>Se caia el cabello por rollos y por partes redondos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a585" ANNOTATION_REF="a294">
                <ANNOTATION_VALUE>Si. Eso es lo que yo sé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a586" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>Pues yo me llamo Anastacio Nicolas Damián.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a587" ANNOTATION_REF="a297">
                <ANNOTATION_VALUE>Vengo del pueblo de San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>onoces el mowih?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>Dinos como son sus flores, sus tallos y sus hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Y el mowih dices que se revuelve con otras hierbas, y si es solo el mowih,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>pinta el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a549" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>Actualmente esa enfermedad de la escarlatina ya casi no hay, yo no la conozco, quien sabe porqué ya no hay?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a550" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>A lo mejor ya se extinguió o porqué será?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a588" ANNOTATION_REF="a295">
                <ANNOTATION_VALUE>Pues si ya es todo, dinos tu nombre y el nombre tu comunidad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
