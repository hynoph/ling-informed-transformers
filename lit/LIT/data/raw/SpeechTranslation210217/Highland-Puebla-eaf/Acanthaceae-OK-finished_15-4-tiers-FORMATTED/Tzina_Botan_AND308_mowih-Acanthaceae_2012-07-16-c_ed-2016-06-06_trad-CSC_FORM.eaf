    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="Eleuterio Gorostiza Salazar">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>¿Tiki:xmati, ne:n, mowih?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>'Te:chilwi ke:niwki, ne:n, ixiwyo, ixo:chio, ikowyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
                <ANNOTATION_VALUE>Wa:n yehwa, ne:n, yo:n mowih, de, tikihtowa kima:nelowah iwa:n okseki xiwit, komohkó:n ise:lti,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
                <ANNOTATION_VALUE>pané:, *este**, kitapalwia n' a:t ata.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
                <ANNOTATION_VALUE>Ekintsi:n yehwa yo:n kokolis tikihtowa netati:l tak a:mo kachi onkak ok, *porque** a:mo, a:mo se: kita yo:n, neh a:mo niki:xmati, a:mo, a:mo se: kimati *que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
                <ANNOTATION_VALUE>tak koto:n, ke:ní:w yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
                <ANNOTATION_VALUE>Pos komo nochi yehwa ya, ne:, sayoh, ne:n, moto:ka:y wa:n moxola:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>Si, lo conozco. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>Pues yo lo veía que no crece muy alto,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>pues para ser mas sinceros, nunca he visto sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>Pero sus hojas son lisas.</ANNOTATION_VALUE>
