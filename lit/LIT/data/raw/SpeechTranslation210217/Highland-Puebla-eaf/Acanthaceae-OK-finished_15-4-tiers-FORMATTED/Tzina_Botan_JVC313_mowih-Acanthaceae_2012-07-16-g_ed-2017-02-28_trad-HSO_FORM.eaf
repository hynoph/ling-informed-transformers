        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>Pero yehwa yo:n xiwit semi kwali, yo:n kimanah, ke:meh *moradito** yo:n ia:yo mahyá:,</ANNOTATION_VALUE>
