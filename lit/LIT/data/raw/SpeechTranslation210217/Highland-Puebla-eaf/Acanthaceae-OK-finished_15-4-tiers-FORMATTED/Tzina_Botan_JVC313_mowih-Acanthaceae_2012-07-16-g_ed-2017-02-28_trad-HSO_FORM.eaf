        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>*cuando** tsahtsiskwih ke:mah *hasta moradohtia** m' pili.</ANNOTATION_VALUE>
