        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Sólo a los niños pequeños cuando lloran se ponen morados y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
