        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>Yo:n komo a:mo kipahtihkeh, ika miki yo:n kokolis.</ANNOTATION_VALUE>
