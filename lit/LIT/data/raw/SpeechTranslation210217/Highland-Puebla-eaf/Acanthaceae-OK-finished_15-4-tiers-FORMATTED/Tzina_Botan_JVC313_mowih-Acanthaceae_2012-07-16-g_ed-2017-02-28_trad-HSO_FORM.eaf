        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>yehwa yo:n kimanah wa:n kina:ltiah m' pilimeh. Kelka:wah yo:n.</ANNOTATION_VALUE>
