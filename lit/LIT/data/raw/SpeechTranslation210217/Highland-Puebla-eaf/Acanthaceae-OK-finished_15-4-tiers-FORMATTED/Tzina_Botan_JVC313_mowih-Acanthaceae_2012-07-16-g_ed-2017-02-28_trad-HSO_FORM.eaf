        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>lloran, hacen berrinche y si no fueron aten..., atendidos por su mamá</ANNOTATION_VALUE>
