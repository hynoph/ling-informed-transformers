        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>Wa:n we:weyak, ke:meh tikita yo:n kiliah, *este**, kiliah yehwa n...,</ANNOTATION_VALUE>
