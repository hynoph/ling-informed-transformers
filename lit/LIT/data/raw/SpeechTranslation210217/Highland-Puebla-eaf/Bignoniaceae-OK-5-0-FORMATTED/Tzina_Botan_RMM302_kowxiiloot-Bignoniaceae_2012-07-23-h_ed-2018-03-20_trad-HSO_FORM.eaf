        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>*Cuando** sepa tikmatis *que** chika:wak a, mahyá: no: kohkostia.</ANNOTATION_VALUE>
