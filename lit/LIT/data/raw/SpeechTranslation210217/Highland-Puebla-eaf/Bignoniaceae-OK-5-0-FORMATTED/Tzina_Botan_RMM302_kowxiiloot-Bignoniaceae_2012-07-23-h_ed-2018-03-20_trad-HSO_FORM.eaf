        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>wa:n ike:span de n' kowit ompa moskaltia yo:n ixo:chiotsi:n.</ANNOTATION_VALUE>
