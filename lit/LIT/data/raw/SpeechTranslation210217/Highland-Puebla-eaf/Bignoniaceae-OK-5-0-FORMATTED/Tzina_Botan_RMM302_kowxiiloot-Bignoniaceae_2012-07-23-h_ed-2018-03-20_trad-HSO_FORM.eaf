        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>*me...**, seki ihista:k, mahyá:, mahyá: tikihto:ka:n tehwa:n, *este, medio** xohxoxoktik.</ANNOTATION_VALUE>
