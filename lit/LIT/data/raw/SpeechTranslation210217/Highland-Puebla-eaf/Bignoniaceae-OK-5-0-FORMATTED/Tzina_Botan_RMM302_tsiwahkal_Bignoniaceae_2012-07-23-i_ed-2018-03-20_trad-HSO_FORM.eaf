        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>*O** tikihto:ti tikixwa:lti:ti wa:n tik..., yo:n kwali tiki:..., tikteki n' imaxalotsi:n,</ANNOTATION_VALUE>
