        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>para kwaltsi:n tiki:tskia wa:n tikpi:pi:tsa ika ne: mokahfe:ntsi:n. Nikitaya ne: no..., nowe:ita:twa:n ne: ke:man ihkó:n ika taya:yah yehwa:n inkahfe:ntsi:n.</ANNOTATION_VALUE>
