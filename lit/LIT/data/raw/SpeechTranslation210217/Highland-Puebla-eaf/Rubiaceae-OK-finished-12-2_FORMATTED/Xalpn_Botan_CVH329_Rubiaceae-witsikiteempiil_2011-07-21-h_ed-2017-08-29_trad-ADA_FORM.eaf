    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="Amelia Domínguez Alcántara" TIER_ID="Amelia Domínguez Alcántara">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>*Bueno**, a:xka:n na:nah i:n xiwtsí:n nika:n tikwa:lkwik,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>neh a:mo niki:xmati ke:ní:w mono:tsa, n'neki xne:chili ke:ní:w mono:tsa wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>xa: tikmati ton kokolis kipahtia *o** ke:ní:w n' tikwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>¿Ton achi n' tikwi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>¿Wa:n i:n a:tsí:n taih, kwalka:n, oso tio:takpa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>*Bueno** yehwa i:n xiwtsí:n tikihtowa mono:tsa wi:tsikite:mpi:l, ¿i:pa sayoh yehwa yo:n kokolis kipahtia?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a101" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>Tikihtowa *que** i:n xiwtsí:n wi..., i:n wi:tsikite:mpi:l no: te:na:miki komohkó:n se: ekaeski:sa, ¿ke:ní:w se: kichi:wa, se: tai, se: kikwahkwa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>Komohkó:n se: ka..., se: ekaeski:sa, ¿ka:nachi ixiwyotsi:n se: kikwi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>¿I:pa ise:lti sah se: kikwi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts147">
                <ANNOTATION_VALUE>Komohkó:n se: ekaeski:sa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Ke:mah na:no, ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a121" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>pos neh a:mo niki:xmati semi i:n kowtsí:n, ne:, ¿ka:ni mochi:wa?, ne: ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>¿Yehwa i:n kowtsí:n wehkapan moskaltia?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
                <ANNOTATION_VALUE>Wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
                <ANNOTATION_VALUE>¿no: xo:chiowa wa:n teyowa, ke:ní:wki n' ixo:chiotsi:n wa:n iteyotsin?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>¿Wa:n iteyo:tsi:n a:mo kwaltia para pahti?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts217">
                <ANNOTATION_VALUE>¿Yehwa i:n tein oksik a *o** tein xoxowik?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts221">
                <ANNOTATION_VALUE>Tikihtowa *que** se: kikwi tahko *litro** refi:noh, ¿wa:n ton achi, ne:n, iteyotsi:n, ne:, wi:tsikite:mpi:l?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts225">
                <ANNOTATION_VALUE>Se: tama:tsol.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
                <ANNOTATION_VALUE>¿Wa:n a:mo pala:ni n' iteyotsi:n a:pachiwtok?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>Pos semi kwali etok na:nah nika:n tine:chyo:lmela:w i:n xiwtsí:n, a:mo nikmatia komohkó:n pahti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts251">
                <ANNOTATION_VALUE>Ne: tikihtowa n' iteyotsi:n no: kwaltia para pahti, ¿i:pa yehwa sah?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
                <ANNOTATION_VALUE>¿Tapialtsi:n, chiktehtsi:n a:mo kikwa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
                <ANNOTATION_VALUE>¿Kati:yeh chiktehmeh semi kitelwe:liliah?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
                <ANNOTATION_VALUE>Pos miak tasokma:tik na:no tine:chyo:lmela:w *que**, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>ika, *bueno** i:n xiwtsí:n xa: no: i:ksá: niktatekiwti:s ta: neli i:ksá: se: mokokowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>Ke:mah pos tel miak tasohka:matik. Neh noto:ka:y Amelia Domínguez, nikayo:t ompa ne:</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>se: xola:ltsí:n mono:tsa Ziltepec, ahkotsi:n ne: Xaltipan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts283">
                <ANNOTATION_VALUE>¿Tehwa:tsi:n moto:ka:y?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
