        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>No es necesario (que lo preparen en té) que se lo tomen sino que machacan las hojas con las manos y el extracto lo echan en la apertura de la herida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a100">
