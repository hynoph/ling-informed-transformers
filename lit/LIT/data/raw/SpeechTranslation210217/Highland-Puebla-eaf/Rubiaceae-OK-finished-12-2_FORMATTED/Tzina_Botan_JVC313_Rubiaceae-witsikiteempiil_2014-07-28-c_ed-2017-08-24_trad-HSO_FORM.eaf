        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Pues claro que sí, yo conozco esa, esa</ANNOTATION_VALUE>
