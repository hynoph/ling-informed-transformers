            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>para una cortada, es parecido como el tsi:nich que se usa para las heridas, el wi:tsikite:mpi:l también es bueno este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a132">
