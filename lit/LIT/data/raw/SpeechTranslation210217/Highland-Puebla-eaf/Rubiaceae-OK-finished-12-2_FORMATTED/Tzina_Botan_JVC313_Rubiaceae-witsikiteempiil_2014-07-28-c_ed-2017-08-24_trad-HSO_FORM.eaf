                <ANNOTATION_VALUE>ki:sa yo:n pahpata wa:kik, tein pahpatake:se:wat</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>wa:n 'ki:xtiah ata yo:n ichti, kipia *hilito** ata.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>Yehwa yo:n ki..., ki..., kiki:xtiliah ki..., kitila:nah, ke:ní:w n' kichi:wayah 'ki:xtilia:yah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>wa:n mo..., mo..., ox kitekiah wa:n kitila:nayah ki..., ki..., na:lki:sa n' i:htik pahpatakowit ata yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>i..., i..., *hilo** oso itech n' ike:se:wayo kitila:na n' *hilo** wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>kitetsi:lowah kit ne:n ta:tahmeh wa:n ke:mah ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>kite:motih, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>*islabo:ntet** wa:n yehwa yo:n wi:tsikikowit kit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>itech ki..., kima:mali:nah ihkó:n kit, ompa kita:liah kit, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>kita:liah, ne:n, tamali:ntsí:n tein kichi:wah ya, kixa:xakwaloh ihkwí:n kichi:wah iwa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>mahyá: *trompo** kihto:tiah wa:n ke:mah de kawa:nis taxo:ta yehwa ya kit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts120" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>Xo:ta kit yo:n ki..., ne:chilia:ya nowe:ita:tah ki..., seki ta:tahmeh kitaya ihkó:n kichi:wayah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>Ke:mah, *porque**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>a:mo we:i tei katka *cerillo** wa:n i:n sa:te:pan ne:siko ya, *cuando** pe:wak ne:si a *cerillo**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>nejó:n onkaya *cerillo, pero** xo:..., ...tex, itech *machete**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts130" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>oso itech tet, itech yo:n, itech yo:n *eslabo:ntet**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>'Ki:xtiah *cerillo** wa:n itech tet kixola:wah xo:tatiki:sa wa:n komo a:mo *machete**, kiki:xtia *cerillo**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>kixola:wa wa:n xo:tak a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Pero kwahkwali *cerillo** onkaya tak, pero ekintsi:n a:mo xo:ta itech yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>*Hasta** tein yo:n kinamakah ika *cajitas** a:mo xo:ta sake:ra, kwa:kopi:ni sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Yehwa yehwa:n ki..., yehwa:n ki..., kihtowa:yah *que** wi:tsikowit ika kikwiah, ne:n, timali:n kichi:wayah ki..., timali:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>Kiliah timali:n pori ompa kichi:chiwa:yah ihkó:n, kima:xakwalowah ihkwí:n *fuerte**, ihkwí:n kima:malakachowah *hasta** kawa:ni wa:n xo:ta ya de kawa:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts146" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>E:h, *porque**, ne:n, *eslabón** xo:ta ata komohkó:n se: kitsowi:tek ika *machete**, ki:sa n' timo:yo:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>Yo:n se: kineltoka *que** neli, neli n' tein kihtowah n' ta:tahmeh, neli kichi:wayah tit, ika 'ki:xtia:yah ika.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>A:mo teh *cerillo** pos yehwa yo:n kichi:wayah, kixo:taltia:yah ika.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts154" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>Wa:kik. Wa:kik kit, wa:kik *por eso para, para re...,** kawa:nia wa:n xo:ta no: n' kowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>De kawa:ni moye:..., mochi:wa tekol ya wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
                <ANNOTATION_VALUE>wa:n xo:ta ya, de ga..., ta..., i:n *tanto** wa:n pos,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
                <ANNOTATION_VALUE>de mochi:wa tekol a xo:ta ya ne: yo:n i:x..., i:..., pahpatai:x.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>Pero yehwa sah 'kwiah pah..., pahpatai:x, sayoh tein potoktik sah n' kits..., i..., kichi:wayah ika, tein pahpa..., pahpata...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts170">
                <ANNOTATION_VALUE>*pahpatahilo**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>Yeh kichi:wayah ika yo:n tit, kiki:xtia:yah wa:n ke:mah kixo:taltiah wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts174">
                <ANNOTATION_VALUE>para motaxo:taltilia:yah *o para** ..., ma:s kalihtik yehwa n' kikwiah kit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>Yo:n para kowtah, pos aya:mo, a:mo kikwiah *cerillo**, yehwa sah n' ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts180">
                <ANNOTATION_VALUE>kite:mowah n' *eslabón** wa:n yehwa n' 'kwitih tsiktsi:n kowit, kima:malakachowah wa:n kixo:taltiah ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
                <ANNOTATION_VALUE>Iwki ne:chiliah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts188">
                <ANNOTATION_VALUE>A:, pos n' ikowyo kwaltia para kowtati:l, *porque** semi takwa:wak n' kowit ata, takwa:wak semi panih..., takwa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts190">
                <ANNOTATION_VALUE>Takwa:wak, ne:n, ih..., i..., kwaltsi:n tekoloh yo:n kowit *porque** yo:n ye:ktakwa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts192" TIME_SLOT_REF2="ts194">
                <ANNOTATION_VALUE>Wa:n a:mo semi wehweit..., wehweikowit mochi:wa. A:mo mochi:wa se:, se: tanawa:l, mochi:wa telwe:i ihkwi:ntsi:n sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts196" TIME_SLOT_REF2="ts198">
                <ANNOTATION_VALUE>*Pero eso** telwe:i. *Lo más** mochi:wa [...]tako:tsi:n sah ihkwí:n sah de, de we:i sah, ke:meh yo:n ohtat sah de pitsa:wak. A:mo mochi:wa wehwei.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts202">
                <ANNOTATION_VALUE>A:mo tikahsi ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>Pos semi wehkapan mochi:wa de tein a:mo kachi, a:mo kite:ntekih,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts206" TIME_SLOT_REF2="ts208">
                <ANNOTATION_VALUE>mochi:wa telwehkapan *siquiera** se: e:yi *metro** sah, *demás** a:mo, a:mo mochi:wa *más** wehkapan. *Lo más** tsikitsi:n, ihkwi:ntsi:n se: kitas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
                <ANNOTATION_VALUE>Ke:mah. Pero nejó:n semi takwa:wak n' ikowyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>Yo:n ata xama:ni, komo se: kipostek xaxamaka wa:n soh para se: mometskalakili:s.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
                <ANNOTATION_VALUE>Yo:n xama..., mo..., xaxa..., moka..., xahxama:ni wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
                <ANNOTATION_VALUE>kihki:sa mahyá: ..., *bueno** ma..., we:weyakaxtik ki:sa mahyá: yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>mahyá: yo:n, *este**, okot se: kitatapatsa, ye:k..., ye:kki:sa miak mah ye..., para se: pa..., mometskoko:s ye:kkwali etok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts222" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>Ke:mah, e:kki:sa ihkó:n komo tikxama:nih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
                <ANNOTATION_VALUE>Wa:n motapowa mahyá: *garsota** moka:wa wa:n timometskwa:telo:s kalaktiki:sa ya, yo:n semi *delicado** yo:n kowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>Ye:ktakwa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>Yehwa yo:n. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts236" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>Pos.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts244" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>E:..., pané: nochi, nochi n' *tiempo** onkak. Nochi n' *tiempo**, yo:n a:mo ika *tiempo**, nochi n' *tiempo** onkak yo:n xo:chitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
                <ANNOTATION_VALUE>Ke:mah, yeh..., yeh..., xa:, xa: t'matis teh ox kwali ki..., para toni n' kitatekiwtiah *porque** seki ma:ski kon..., tikone:meh tikihtowah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>pero te:chiliah n' ta:tahmeh wa:n se: kita:lia *cuidado**, a:mo se: kelka:wa, se: kimattok para toni n' *servi:rowa** neli. Miak taman kitatekiwtiah yo:n xiwtsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
                <ANNOTATION_VALUE>A:, *cuando** xoxowik tela:yoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts266" TIME_SLOT_REF2="ts268">
                <ANNOTATION_VALUE>A:yoh semi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts270" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>A:..., a:ki:stok ata d..., *hasta** poxkawi *tanto** [...]a:ki:stok tata:mpa, a:it ke:yeh *hasta, hasta** poxkawi ata. Wa:n moka:wa xoxoktik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts280" TIME_SLOT_REF2="ts282">
                <ANNOTATION_VALUE>Tela:yoh eski *por eso** iwki mochi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
                <ANNOTATION_VALUE>A:, yo:n ke:mah wehka:wa *porque** ye:..., ye:ka:yoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts290" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>A:yoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts296" TIME_SLOT_REF2="ts298">
                <ANNOTATION_VALUE>Ompa selia ata. Wetstok ta:lpan, selistok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
