            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Si uno se corta con machete, las hojas de wi:tsiki..., se pueden ocupar,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>se cortan las ho..., ho..., hojas tiernas, las..., las hojas tiernas y las machacan con las manos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a106">
