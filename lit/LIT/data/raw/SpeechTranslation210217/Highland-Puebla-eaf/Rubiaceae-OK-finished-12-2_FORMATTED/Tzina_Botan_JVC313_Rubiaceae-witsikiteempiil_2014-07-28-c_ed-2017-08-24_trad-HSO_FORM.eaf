            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Si queremos las hojas o sus..., sus..., sus flores</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>le llaman wi:tsikite:mpi:l porque sus flores son alargadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Pero nosotros lo..., lo conocemos wi:tsiki..., por wi:tsikikowit. Pero he escuchado por ahí que otras personas le llaman wi:tsikite:mpi:l.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
