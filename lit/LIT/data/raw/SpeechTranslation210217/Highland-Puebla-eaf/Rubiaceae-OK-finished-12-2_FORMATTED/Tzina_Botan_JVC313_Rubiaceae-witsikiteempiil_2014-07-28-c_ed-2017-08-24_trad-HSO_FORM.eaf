            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>usan las hojas para bañar a los niños. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Pues la madera dicen, a mí me decían mis abuelitos que hace muchos años,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>ya hace mucho tiempo, este vendían, no había, este ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Bueno, y s..., no, no es mi abuelito, otros ancianos me decían,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>la madera usaban para prender fuego que le llamaban timali:n. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Dicen que cortaban del plátano,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>las fibras delgadas que salen de la corteza seca</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>le sacaban las fibras delgadas que tiene, son como unos hilitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Ocupaban eso, le..., le sacaban, le..., jalaban, quien sabe cómo hacían para sacarle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>y lo..., lo..., creo que cortaban y jalaban, le..., le..., salen dentro de la corteza del plátano si te haz dado cuenta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>hi..., hi..., hilo o en la corteza del tallo de plátano jalaban los hilos y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>los ancianos torcían los hilos y en seguida lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>buscaban este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>piedras de islabo:ntet y la madera de wi:tsikikowit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>en la madera la..., tuercen así el hilo, enseguida jalan este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>el hilo torcido, giran la madera varias veces  así </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>como si hicieran bailar un trompo sobre la piedra, entonces al calentar prende el fuego.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Dicen que prende el fuego lo..., me decía mi abuelo que..., veía que algunos ancianos así lo hacían.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Sí porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>casi no había cerillos, los cerillos aparecieron después</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>había cerillos pero prendi..., prendian en un machete.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>o en una piedra, en la, en la piedra que le llaman eslabo:ntet.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Sacan el cerillo y lo deslizan en la piedra y prende el fuego rápidamente, o si no en un machete,sacan el cerillo </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>lo deslizan y prende el fuego al instante. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Pero creo que había buenos cerillos, porque actualmente ya no se prende en eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Hasta los que se venden por cajitas no prenden, se desprenden rápidamente de la cabeza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Eso es lo que..., eso  es lo..., decían que la madera de wi:tsikikowit usaban para prender el timali:n</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Le llaman timali:n porque hacían girar fuertemente con las manos, así lo hacían girar hasta calentarse y después de calentarse prendía el fuego. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Eh, porque la piedra de eslabón si prende si uno le pega con un machete, salen las chispas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>Eso es creible, es cierto, es cierto lo que dicen los ancianos, es cierto que producían el fuego con la madera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>No había cerillos pues hacían eso para prender el fuego.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Seca. Dicen que estaba seca, estaba seca para que..., al calentarse debía de prender rápidamente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>De que se calienta se..., prende y se vuelve brasa y pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>después de prender, de ga..., se..., es de este tanto y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>de convertirse en brasa ya prenden las fi..., fi..., fibras del tallo del plátano. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Pero sólo eso usaban las fibras del tallo del plá..., plátano, usaban sólo las fibras que parecían hilos, lo..., su..., usaban las fibras que sacaban de la cprteza del tallo del plá..., plá..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
