        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>a:chka ni..., achka kipia ne:n i..., n' i..., imaxalwa:n.</ANNOTATION_VALUE>
