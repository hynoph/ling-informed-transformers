                <ANNOTATION_VALUE>Wa:n ma:..., ma:...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>*medio** ma:t..., ma:..., tepitsi:n mahyá:, mahyá: tikihtowah tehwa:n ma:tohmiyoh.</ANNOTATION_VALUE>
