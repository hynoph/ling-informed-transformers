        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>wa:n onkak n' tein yo:n *medio** ah..., mahyá: tikihtowah achi *medio** a:chi:petik. Ke:mah.</ANNOTATION_VALUE>
