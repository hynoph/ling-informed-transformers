        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
                <ANNOTATION_VALUE>Soh se: kilpilia wa:n yehwa ya yo:n tehwa:n ika tima:wiltia:yah, ne:, ne: ke:man pos ke:meh a:mo tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>ka:n nikihto:s neh *te:chtareahtia:yah**, n' te:chmakayah n' tomi:n mah, mah mi:miak niman, mah timokowili:ka:n teihsá:, ta: se: a:matsí:n yehwa sah, yehwa yo:n tehwa:n tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
                <ANNOTATION_VALUE>ika tima:wiltia:yah n' tehwa:n. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
