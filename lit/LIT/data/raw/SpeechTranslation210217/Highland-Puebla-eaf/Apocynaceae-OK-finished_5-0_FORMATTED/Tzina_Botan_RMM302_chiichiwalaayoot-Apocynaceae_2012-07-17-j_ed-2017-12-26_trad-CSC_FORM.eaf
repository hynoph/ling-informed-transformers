        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>ke:meh ka:mpa tiksowili:ti n' kowit, n' kowtsí:n yehwa yo:n nimitsilia, ne:n,</ANNOTATION_VALUE>
