                <ANNOTATION_VALUE>Neh nikmatik xa:, tak xa: ke:mah te:na:miki pero no: ke:meh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>no:, no: ki..., no: n' kokolis no: ta:taman kokolismeh *porque** onkak kokolis tein i:pa yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>ixwa sah se: kokot wa:n onkak kokolis, onkak kokot,</ANNOTATION_VALUE>
