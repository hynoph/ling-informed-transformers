            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
                <ANNOTATION_VALUE>ke:meh yehwa:n pos tikita ya ne: ke:man a:mo tahtowa:yah ke:meh a:xka:n a:man pi:pil tahtowah nikilia neh, mah tikihto:ka:n, *este**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>mah, mah niman ki..., niman tahtowah tahtaman wa:n ne:, ne: ke:man to..., towe:ita:twa:n semi motel....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
                <ANNOTATION_VALUE>Mah tikihto:ka:n mochipa:wka:nekiah, *siempre** mah tikihto:ka:n *porque** a:mo eliwis kamana:lowa:yah. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>*Es...**, se: *via...**, se:, sepa n'tatsi:ntokihtoya neh no: no..., *notío**, nikilia ke:yeh n' kiliah chi:chiwala:yo:t. *Porque** ki:sa kihtowa *que** mahyá: piltakwal *pues**, yehwa yo:n ika kiliah chi:chiwala:yo:t. Mmm. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
