        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>Chi:chi:ltik n' i..., n..., chi:..., *medio, medio, medio** chi:chi:ltik n' i..., n' iihtik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>Wa:n kipia n' iteyotsi:n chi:chi:ltik. Pisi:ltsitsí:n iteyotsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>*Pues** a:mo wel nimitskahkaya:was *porque** n' ikowyo neh niki:xehekowa a:it ox no: kwaltias para, nió:n para kowtati:l *porque** pané: ka:n ke:man xkita mah wa:ki kwaltsi:n, mah nochipa wa:..., nochipa, nochipa selistok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
