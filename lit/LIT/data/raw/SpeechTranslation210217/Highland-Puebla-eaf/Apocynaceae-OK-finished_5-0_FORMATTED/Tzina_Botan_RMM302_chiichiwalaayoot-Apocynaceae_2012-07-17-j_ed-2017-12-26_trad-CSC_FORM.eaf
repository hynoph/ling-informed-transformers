        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>ke:meh nikita seki kikwiah kipepechowa:yah, ika kichihchi:wayah, kichihchi:wayah *globos**,</ANNOTATION_VALUE>
