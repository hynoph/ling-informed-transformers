        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>¿Wa:n ka:nika ne:n se: kohkohsa ne:n yehwa i:n tikihtowa chi:chiwala:yo:t icho:kilo?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
                <ANNOTATION_VALUE>¿A:mo t'mati ke:yeh n' kiliah chi:chiwala:yo:t?</ANNOTATION_VALUE>
