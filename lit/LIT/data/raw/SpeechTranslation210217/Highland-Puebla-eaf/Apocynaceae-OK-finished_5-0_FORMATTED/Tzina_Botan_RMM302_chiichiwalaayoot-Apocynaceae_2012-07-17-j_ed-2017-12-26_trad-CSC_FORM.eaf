        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>pero eski tein i:pa i:xyo:li sah n' kokot, a:mo tein ke:meh yo:n moxokoliah.</ANNOTATION_VALUE>
