            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>Sa: e:wayohpihpixkito ke:meh seki kowtsitsí:n tikita n' teh yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>yo:n wi:tsi:kite:mpi:l tikihtowah tehwa:n no:, no: a:yoh, pero yo:n *siempre cuando** kwaltsi:n wa:ki a se: kita niman, niman wa:kipihpixki pero i:n a:mo ke:man tikitas teh mah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
