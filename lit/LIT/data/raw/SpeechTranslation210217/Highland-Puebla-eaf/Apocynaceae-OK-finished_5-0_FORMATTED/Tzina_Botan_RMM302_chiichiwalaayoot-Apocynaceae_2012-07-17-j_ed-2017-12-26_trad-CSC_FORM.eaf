        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>Pos pané: nochi a de i:n kowit, a:man sayoh moto:ka:y wa:n moxola:l.</ANNOTATION_VALUE>
