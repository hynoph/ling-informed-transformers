    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Bueno Ruben, pues ahora platicanos como es el chi:chiwala:yo:t, si es que lo conoces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>¿Como son sus hojas, como son sus flores?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>¿Y como son sus frutos?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>¿Y se ocupa ara algo o se come?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>¿Y no sabes si los animaless e comen los frutos?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>¿Y cuando se parte su cascara, como es por dentro?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>¿Y la madera sirve para algo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>¿Y el papalote lo puedes fabricar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Entonces platicanos como hacias el papalote y si es que usabas para pegamento (ese fruto).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>¿Y en que parte se le unta la resina del chi:chiwala:yo:kowit?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>¿No sabes por qué le dicen chi:chiwala:yo:t?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Pues parece que ya es todo lo de este árbol, nada más dime tu nombre y tu comunidad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Rubén Macario Martínez" PARTICIPANT="Rubén Macario Martínez" TIER_ID="RMM Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Pues yo conozco el árbol de chi:chiwala:yo:t desde que eramos pequeños,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>como siempre ha existido desde hace mucho tiempo, no voy a decir que ese árbol se va a extinguir, ese siempre abunda donde quiera que vayas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>hay en todas partes. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Sus hojas son alargadas y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>es de hojas verdes y un poco gruesas, sus flores son blancas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>son blancas parecidas como las</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>como las flores del ka:ka:lo:t,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>así tiene un parecido. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>Nada que digamos que es otro porque </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>tiene las hojas separadas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>y las hojas del ka:ka:lo:xo:chit se dan en racimos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>Asi tiene un parecido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Y su infrutescencia se ponen unos frutitos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>alargados y como puntiagudos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>Y los frutos salen desde las ramas por lo menos unos dos o tres.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>En las ramas se ponen tres frutos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>en las ramas del árbol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Pues como nosotros lo conocemos desde hace mucho pero tiempo pero nunca, nunca,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>se come porque no tiene algun sabor,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>lo que si veia hace tiempo es que lo ocupaban para pegamento,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>con eso pegaban cualquier tipo de papel,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>porque la resina es pegajosa y como anteriormente no conocian pegamento comercializdo como actualmente se conoce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Como hace tiempo, anteriormente solamente conociamos pegamento local, usabamos, nosotros usabamos... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>ya nuestros tios... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>A mi nunca me interesó hacer eso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>como veia que otros lo usaban, con eso pegaban los globos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>lo que ahora es el papel de</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>para hacerlo volar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>A mi nunca me gustó, nunca me interesó, pues yo nada más veia como recortaban (el papel) y con eso lo pegaban y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>ya lo soltaban.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Le echaban aire y lo soltaban.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>Pues nunca he visto que los pájaros se los esten comiendo como normalmente lo hacen con otros frutos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>donde hay frutos que se comen los pájaros, se pueden ver que ahí están sobrevolando...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>ahí se pueden ver muchos amontonados.Ahí solamente he visto mariposas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Cuando hay frutos maduros ahí se pueden ver muchas mariposas, las mariposas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>a lo mejor se lo comen, a lo mejor se comen lo dulce del fruto, porque a lo mejor es dulce cuando se madura, porque cuando se madura se ve bonito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>se pone de color amarillo y se parte por mitad, cuando ya se madura bien es cuando ya se coce</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>se parte su cascara.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Por adentro es un poco rojizo, es medio rojizo, es rojizo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Y tiene sus semillitas rojizas. Son semillas diminutas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Pues para que te voy a engañar, pienso que la madera tal vez no sirve ni para leña porque nunca se seca bien, parece que todo el tiempo es verde.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Si esta tirado en la tierra, esta verde.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Nunca lo he visto cortado (para leña).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Tampoco se ve desprendiendose su corteza por estar seco como se puede ver con otros tipos de leña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>la que conocemos como balletilla también concentra agua en la leña pero cuando ya se seca se ve luego porque se pela pero esta leña no es así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>a lo mejor se ha de ver pero muy pocas veces, pero casi nunca se ve así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>y tampoco ha de dar buenas brazas porque luego se ve que la leña es como bagazo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Hace mucho tiempo yo había visto con una persona, a la que fui a visitar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>y me estaba platicando que también sirve para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Y entonces pensé llevarlo a cabo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>tuve un grano el cuál nunca se podia curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Entonces él me sugirió que...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>le puse..., me sugirió buscar todos </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>los árboles que sueltan resina,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>como primer lugar usé de remedio el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>el chi:chiwala:yo:kowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Que con eso..., que le fuera a sacar su..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>se corta el fruto, ya sea en la base o en la punta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>y donde uno tiene un grano, ahí se le unta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Entonces hice todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Yo pensé que a lo mejor si hace remedio pero también es como,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>como hay diferentes tipos de enfermedades, porque hay enfermedades que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>nada más nace un grano y hay enfermedades, hay granos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>de los que nacen a partir de un golpe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Entonces yo pienso que a lo mejor cura los granos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>pero los granos que nacen por si solos, no de los que nacen a partir de un golpe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>El grano que nace a partir de un golpe, ese no se cura facilmente. Entonces yo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>lo que pensé es cortar (el fruto) y ponerle (la resina). </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Y le puse porque hacia de todo cuando me enseñaron cuales eran los remedios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Le puse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Lo que pasó es que cuando le uese por segunda vez o como por tercera vez, cuando le puse por tercera vez empezó a pelarse más. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Se peló más, y se extendieron </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>los granos. Y nacieron granitos pequeños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Entonces lo dejé así porque pense que ese remedio no era verdad...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>no es remedio porque el que si hace efecto luego se ve como se empieza a secar rápido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Entonces desde ahí yo no creo que eso es remedio, pero el que me lo habia recomendado es una persona que también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE> sabe un poco más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Pues como yo digo que no le voy a echar la culpa que no sirve, si ha de servir pero para otros tipos de enfermedades, a lo mejor es otro tipo de enfermedad lo que cura.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>No todo es remedio para las enfermedades. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Y también lo ocupan para pegar ese,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>le llaman papalote, ese que le ponen hilo y lo hacen volar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Ese lo pegan, también lo pegan con eso y le ponen</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>la caña de la mazorca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>La caña de la mazorca,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>lo labran y le amarran un hilo y le pegan con</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>este fruto del que estamos hablando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>También lo haciamos hace tiempo cuando eramos niños pero ahora ya no pensamos hacerlo porque ya nos avergonzamos. Porque de verás lo haciamos cuando eramos niños. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>SI.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Pues para hacer el papalote recortabamos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>recortabamos cuatro, cuatro..., como que lo recortabamos en cuatro lados...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>de una hoja sacabamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>dos pedazos no muy grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Lo recortabamos redondo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>y luego ya le poniamos lo que te digo, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>la caña de la mazorca, la caña de la mazorca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Lo cortabamos delgado y lo doblabamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>le oniamos dos, uno atravezado y doblado,como si fuera que con eso lo amarrabamos en ambos lados de la orilla.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Y entonces ya se le amarra el hilo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Se le amarra con un hilo para coser.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Nada mas se amarra y con eso ya jugabamos nosotros anteriormente porque no..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>pues no nos daban dinero en abundancia para comprar lo que nosotros quisieramos de juguetes sino que con un solo papelito... Eso es lo que...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>con eso jugabamos nosotros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Eso le vas a untar, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>por donde, por donde nada más vaya pegado al palito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>No le vas a untar, no le vas a untar a todo como está el papel, nada más se le unta muy angostamente, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>en la aprte donde le vas a poner la madera (caña de milpa), lo que te digo, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>la caña de mazorca, nada más donde lleva extendida la caña de mazorca oel bambú, como ahora que hay bambú pues ese se puede labrar delgado y angosto,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>ahí se le amarra y se le unta el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>aparte de untarle el pegamento, también se le amarra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>No nada más se le amarra y ya puede volar ese juguete, pues siemre es necesario amarrarlo con hilo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>porque pues se pega, se pega pero no, pero no tanto como... Se pega pero no como es tan seguro por eso se le amarra de este lado con el hilo y se pega con el...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Entonces ya se hace más resistente y no se junta en un solo lugar el papel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Porque si no se le pone el bambú o la caña de mazorca, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>el papel se junta en un solo lugar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Y nunca va a volar porque se dobla. Es lo que te digo que se dobla. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Pues no sé porque le llaman chi:chiwala:yo:t, yo pienso..., yo les escuchaba, les escuchaba... Porque les preguntaba a mis abuelos y nunca me dieron una respuesta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>porque como has de saber que nuestros antepasados con una pequeña palabra,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>que dijeramos nosotros, como que ellos, ellos eran como,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>nosotros no podiamos decir una mala palabra o albuhur, por eso nunca les pude preguntar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Pero ese le llaman así porque lo usaban... Porque sale </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>como la leche materna. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Por eso así le llaman,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>nada más que nuestros abuelos nunca nos descifraron cómo y por qué,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>como ya sabes que anteriiormente nno hablaban como ahora hablan los niños, como yo digo, como dijeramos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>ahora hablan diferente a como hablaban nuestros abuelos...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Podemos decir que hablaban más puro porque no hablaban con groserías o con albuhures.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Una ocasión le pregunte a mi tío que porque (a ese árbol) le llamaban chi:chiwala:yo:t y me dijo que porque le sale como leche materna. Por eso le llamaban chi:chiwala:yo:t. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>Yo me llamo Rubén Macario Martínez </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>vengo de Chilcuahuta y pertenezco a San Miguel. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
