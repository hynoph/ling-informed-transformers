        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>Neh a:mo ke:man nikwelitak, a:mo ke:man niknehnekik, pos neh soh nikitaya sah kitehtekiah wa:n kipepechowa:yah ika yo:n wa:n</ANNOTATION_VALUE>
