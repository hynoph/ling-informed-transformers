        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts166">
                <ANNOTATION_VALUE>Entó:s n' ompa yehwa yo:n neh a:mo nik..., a:mo no: nikye:kneltokak neh pero ne:ch..., ne:chilwihka se:, se: tokni:w tein no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
