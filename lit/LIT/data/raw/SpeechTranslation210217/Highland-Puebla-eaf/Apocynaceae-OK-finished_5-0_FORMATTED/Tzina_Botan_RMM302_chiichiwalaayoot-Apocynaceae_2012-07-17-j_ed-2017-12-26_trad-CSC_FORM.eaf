        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>o:me t'ta:liliah, se: tein tiki:xtapalta:liliah wa:n se: tein tikelpachowah tikpani..., tik..., ke:meh eskia ika tikihilpiliah ni:nipaka n' i..., ite:mpan.</ANNOTATION_VALUE>
