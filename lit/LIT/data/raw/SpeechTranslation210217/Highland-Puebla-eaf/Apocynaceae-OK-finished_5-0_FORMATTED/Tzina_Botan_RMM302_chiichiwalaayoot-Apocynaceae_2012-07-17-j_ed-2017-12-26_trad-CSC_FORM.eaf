            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>Ke:meh ne:ka *tiempo**, ne:ka to:nal tehwa:n tiki:xmatiah ma:se:waltapepecholo:ni *solamente** ne: tikwiah n' tehwa:n, kikwiah n' to...,</ANNOTATION_VALUE>
