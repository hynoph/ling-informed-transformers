        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts176">
                <ANNOTATION_VALUE>pa:pa:lo:t kiliah, ata yo:n ki..., kita:liliah *hilo** wa:n kilpilia, wa:n kitamo:tah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>Yo:n no: ki..., kipepechowah no: kipepechowah yehwa ika yo:n, kita:liliah, *este**, oh...,</ANNOTATION_VALUE>
