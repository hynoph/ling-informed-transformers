            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>a:p..., a:, no: taman, taman se: kiohsa ne:n tapepecholo:ni wa:n taman ok se: kilpia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
                <ANNOTATION_VALUE>A:mo sayoh *porque** se: kipepecho:ti:w wa:n mah iwki pata:ni a yo:n a:wil, ta: i:pa *siempre** tikihilpili:s ika n' *hilo**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
                <ANNOTATION_VALUE>*porque** pos mokwi, mokwi pero a:mo, a:mo semi, a:mo nikihto:ti semi kwaltsi:n kitsakwilia wa:n ika n' *hilo** tikilpilia nika:n wa:n t'pepechowa ika ne:...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts244">
                <ANNOTATION_VALUE>Entó:s mosempale:wia ya yehwa yo:n para a:mo mokel..., para a:mo mo..., moxolochowa ne:n a:mat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>*Porque** komo a:mo t'ta:lilih ne:n, yehwa nimitsilia ne:n ohtat oso ne:n owasin,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
                <ANNOTATION_VALUE>moololowa ne:n a:mat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>A:mo ke:m..., a:mo ke:man pata:nis *porque** ke:yeh mosen..., moah..., mo..., mokelpachowa. Mokelpachowa, yehwa ya nimitsilia neh. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>Mm, pos, ne:n, a:mo nikma..., a:mo nikmati ke:yeh n' kiliah chi:chiwala:yo:t, neh niki:xehekowa pos neh nik..., nikakilia:ni, nikakilia:ya *que**, nikintatsi:ntokia:ya nowe:ita:twa:n i:pa a:mo ke:man teh te:che:kilwihkeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
                <ANNOTATION_VALUE>*que** tikita ya n' towe:ita:twa:n yehwa:n ne: ke:man tepitsi:n ika se: tahto:ltsí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>tikihtowa:yah tehwa:n *como que** yehwa:n, mahyá: tikihtowah yehwa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
                <ANNOTATION_VALUE>se: kamana:ltahto:l a mah tikihto:ka:n tehwa:n, yeh ka a:mo ke:man wel tikintatsi:ntokihkeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
                <ANNOTATION_VALUE>Pero yo:n kiliah iwki *porque** kikwiah... Tikihto:ka:n ke:yeh ki:sa mahyá:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
