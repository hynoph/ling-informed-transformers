        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>Pos tehwa:n ihkó:n ke:meh de t..., ne:, ne: k..., ne: ke:man tiki:xmatih tehwa:n a:mo ke:man s..., a:mo ke:man,</ANNOTATION_VALUE>
