        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>Pa:pa:lo:meh tikitas teh komo oksitok pa:pa:lo:meh n' ompa ne: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>kikwah tak, yo:n no: kikwaliah eski n' itsope:kka tepitsi:n ta: a:chá: no: tsope:k eski ta: pos oksi, n' *cuando** oksi no: kwaltsi:n,</ANNOTATION_VALUE>
