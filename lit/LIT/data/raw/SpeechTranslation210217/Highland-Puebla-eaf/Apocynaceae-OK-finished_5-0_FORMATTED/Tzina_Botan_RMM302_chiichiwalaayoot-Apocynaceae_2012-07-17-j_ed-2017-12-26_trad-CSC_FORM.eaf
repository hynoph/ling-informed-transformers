        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
                <ANNOTATION_VALUE>Ompa ke:mah *mejor** nika:w iwki, nikihtoh pos a:mo neli n...,</ANNOTATION_VALUE>
