        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>Wa:n ompa ke:mah se: kilpilia ya n' *hilo**.</ANNOTATION_VALUE>
