        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>Pos yowi n' topopá:n ne: kowtah wa:n te:chtoktia:ya se: ta:tahko *morral** para 'tapepecho:skeh, t'sahsa:lowah ika a:mat.</ANNOTATION_VALUE>
