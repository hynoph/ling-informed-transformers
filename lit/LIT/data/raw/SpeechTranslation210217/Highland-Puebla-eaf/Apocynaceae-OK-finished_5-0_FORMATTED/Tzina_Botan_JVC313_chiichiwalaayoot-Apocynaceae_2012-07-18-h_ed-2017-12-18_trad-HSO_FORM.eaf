            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>chi:chiwala:yo:t tein nikahkwí:n mochi:wa ika 'tapepechowah.</ANNOTATION_VALUE>
