        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>Tikchi:wayah pa:pa:lo:t, ika tik..., [tik]tekiah n' owasin wa:n tikxakwalowilia:yah ne:n tikwa:tekiah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
