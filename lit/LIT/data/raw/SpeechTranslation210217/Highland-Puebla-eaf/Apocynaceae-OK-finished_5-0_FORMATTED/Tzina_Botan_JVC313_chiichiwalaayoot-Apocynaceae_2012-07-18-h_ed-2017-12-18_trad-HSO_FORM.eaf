        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts290" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>Yo:n tak a:mo kipia ne:n ma:se:walkopa n' ito:ka:y *porque** i:pa</ANNOTATION_VALUE>
