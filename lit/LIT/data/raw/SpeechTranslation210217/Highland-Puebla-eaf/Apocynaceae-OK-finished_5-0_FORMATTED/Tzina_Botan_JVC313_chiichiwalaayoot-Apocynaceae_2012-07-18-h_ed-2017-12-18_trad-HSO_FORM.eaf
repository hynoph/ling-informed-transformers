        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
                <ANNOTATION_VALUE>mah a:mo semi telpitstik san ke: wa:n mah tepitsi:n mah te:nkoya:wak para a:mo tata niman.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
                <ANNOTATION_VALUE>Komo te:mpitsaktik, te:nkopitstik niman tata. Monakasikata:lia wa:n tatak a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
                <ANNOTATION_VALUE>Yo:n telwehka yowi, t'chihchi:wah n' tehwa:n telwehka yowi yo:n iwki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
                <ANNOTATION_VALUE>Ke:mah. Onkak miak, ta: ekintsi:n miak taman kine:xtihkeh ya para yo:n, se: kichi:was yo:n a:mat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
                <ANNOTATION_VALUE>Kichihchi:wah ne: yo:n a:wilmeh *siquiera de** ma:kwi:l *ciento pliego o de** se: *mil**, o:me *mil pliego**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
                <ANNOTATION_VALUE>Yehwa yo:n, pero</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>neh kwali n'chihchi:wa soh *que** a:mo ika timokwitta:liah, pero nikchi:wa, niweli n'chihchi:wa, de tsikitsi:n nik..., [ni]weli, pos niweli n' tein we:i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts451">
                <ANNOTATION_VALUE>Ika yo:n ia:wiltsitsi:n kitsahik..,*ilujitos** kiliah yo:n ts..., i..., tsitsikiltik kita:liliah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts452" TIME_SLOT_REF2="ts454">
                <ANNOTATION_VALUE>Ekintsi:n onkak seki, seki</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
                <ANNOTATION_VALUE>*fotografías** ke:meh yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
                <ANNOTATION_VALUE>*o** tai:xkopi:n ne: kiliah, ka:mpa yetok yo:n chihchi:wtok yo:n a:mat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
                <ANNOTATION_VALUE>Soh moneki miak n' a:mat [mah]se: 'kowa para se: kichihchi:was yo:n. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
                <ANNOTATION_VALUE>Pero de tsikitsi:n niweli n'chihchi:wa neh, *porque** tehwa:n timoskaltihkeh t'chihchi:wayah n' a:mat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>Ke:mah, t'chihchi:wayah n' tehwa:n, t'tokatinemiah, ke:meh i:n *todos santos** yeh t'tokatinemiah nochipa ya. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
                <ANNOTATION_VALUE>Pos se: k..., para ahsi k..., ne:pa, para a:mo tatas se: kich..., se: kineki mah, mah, mah a:mo tata niman,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
                <ANNOTATION_VALUE>se: kichi:wa we:i n' ohtat, se: kiteh..., se: kixihxi:ma kanaktsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
                <ANNOTATION_VALUE>wa:n ompa t'ta:lia ne:n, yo:n *alambre**, i:pa onkaya i:pa n' *alambrito**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
                <ANNOTATION_VALUE>tikelpachowa:yah wa:n tikwa:..., [ti]kwa:postekiah tepitsi:n wa:n tikelpachowah, na:wi t'ta:liah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
                <ANNOTATION_VALUE>wa:n tikwa:kalakiliah ne:n *ibola** wa:n yehwa ya yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
                <ANNOTATION_VALUE>para a:mo tatas tepitsi:n te:nkoya:wak, we:i tikchi:wayah ne:n ikowyewal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
                <ANNOTATION_VALUE>Komo pitsaktik pos ti..., te:nkopitstik moka:wati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
                <ANNOTATION_VALUE>Wa:n para a:mo [...]pos tikwiah we:itsi:n para, para nejó:n kwali mopale:wia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
                <ANNOTATION_VALUE>Ke:mah, pero yo:n telte:mpitsaktik niman tata, monakasikata:lia wa:n tatak a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
                <ANNOTATION_VALUE>Iwki para tika:wiltia:yah, sake:ra ohpa e:xpa tikahka:wayah n' *toglobo**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
                <ANNOTATION_VALUE>Tikilia:yah lo:boh n' tikilia:yah. Wa:n ekintsi:n *globo** t'ta:lilihkeh pero koyo:tahtol ya, tikilia:yah lo:boh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
                <ANNOTATION_VALUE>Iwki n' tiki:xmatkeh tehwa:n de pe:wak timoskaltiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
                <ANNOTATION_VALUE>Kanah, ka:n, ika, i..., *bola** sah n' tikiliah porin ololtik sah, porin *bo:lahtik**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
                <ANNOTATION_VALUE>Yehwa yo:n tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
                <ANNOTATION_VALUE>seki t'chihchi:wah yehwaltik sah, seki, seki ololtik sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
                <ANNOTATION_VALUE>Tekochtik se: kichi:wa ihkó:n ka:mpa mota:li:s yo:n i..., y..., i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
                <ANNOTATION_VALUE>iyo:la:n se: kita:lilia n' tilmah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
                <ANNOTATION_VALUE>oso a:ya:t, yehwa ne:n tik..., tik..., ololtik sah n' kita:liah, kipankalakiah ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
                <ANNOTATION_VALUE>Pero seki t..., ki..., kwa:pitstik kita:liliah n' *alambre para** ompa ne: kikwa:kalakiliah yewaltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
                <ANNOTATION_VALUE>Ihkó:n a:mo powetsi no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
                <ANNOTATION_VALUE>Yehwa yo:n tikchi:wah, pero i:pa a:mo n'mati ke:n ito:ka:y de</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
                <ANNOTATION_VALUE>tikiliah *bola** n' tein yo:n t'ta:liliah, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
                <ANNOTATION_VALUE>tolo:boh wa:n yehwa ya yo:n. A:mo t'matih ke:ní:w ma:se:waltahto:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
                <ANNOTATION_VALUE>Pos a:kin kichihchi:wa ki:xehekohtok ton *tanto** kixi:ko:s *porque** telwe:i a:mo, a:mo kixi:kowa a:mo, a:mo mahokwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
                <ANNOTATION_VALUE>Yo:n se: kichihchi:wa ke:meh kina:mikis, se: ki:xeheko:s no: ke:meh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
                <ANNOTATION_VALUE>ke:meh kixi:ko:s sah *porque** tein, tein, soh tein, tein we:i a n' a:mat,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
                <ANNOTATION_VALUE>pos se: kita:lilia ye:kwe:i. Wa:n tein tsikitsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
                <ANNOTATION_VALUE>pos tsikitsi:n se: kichi:wa n' a:wiltsí:n sah wa:n se: kitate:kia ya, n..., 'te:kili n' *gas**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
                <ANNOTATION_VALUE>Wa:n yehwa se: kimattok kixi:kowa. Pero tein a:mo kixi:ko:s a:mo, komo we:i a:mo kixi:kowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
                <ANNOTATION_VALUE>Oso no: se: kita:lilia ne:n seki n..., yo:n kiliah n' *icandeleja** n' ite:yo ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
                <ANNOTATION_VALUE>toma:wak n' *alambre** a:mo kixi:kowa n' tein tsikitsi:n, *de cuatro** a:mo kixi:kowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
                <ANNOTATION_VALUE>Tehwa:n tik..., tikta:liah de na:wi pos</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
                <ANNOTATION_VALUE>pitsaktsí:n *alambrito**, pitsaktsí:n para kixi:kowa:ya kwali. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
                <ANNOTATION_VALUE>Pos neh niwa:le:w, nimono:tsa niErnesto Vázquez</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
                <ANNOTATION_VALUE>wa:n niwa:le:w nika:n San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
