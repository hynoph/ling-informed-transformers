        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
                <ANNOTATION_VALUE>Yo:n t'chihchi:wah sayoh melaktik o:me wa:n nikteki ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>niktehteki no: ne:n a:mat nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
