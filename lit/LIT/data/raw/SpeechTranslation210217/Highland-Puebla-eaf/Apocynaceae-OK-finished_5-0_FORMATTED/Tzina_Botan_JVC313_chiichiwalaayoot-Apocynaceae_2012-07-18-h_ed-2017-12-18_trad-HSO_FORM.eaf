        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts387">
                <ANNOTATION_VALUE>a:mat kipehpechowah, ¿tiweli n' teh n' tikchihchi:wa? ¿Kwali tite:chtapowi:s ke:ní:w yo:n se: kichihchi:wa?</ANNOTATION_VALUE>
