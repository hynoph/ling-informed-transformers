        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
                <ANNOTATION_VALUE>¿Wa:n yehwa yo:n ke:ní:w se: kimati, ne:n,</ANNOTATION_VALUE>
