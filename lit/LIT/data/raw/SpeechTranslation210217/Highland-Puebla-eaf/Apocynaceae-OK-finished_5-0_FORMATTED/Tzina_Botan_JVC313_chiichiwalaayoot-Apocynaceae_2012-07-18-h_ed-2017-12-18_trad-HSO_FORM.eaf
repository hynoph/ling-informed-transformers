        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
                <ANNOTATION_VALUE>Wa:n nejó:n,</ANNOTATION_VALUE>
