        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>Pero kowtah mochi:wa yo:n, mahyá: *cimarrón de** it...,</ANNOTATION_VALUE>
