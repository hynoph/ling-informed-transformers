        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
                <ANNOTATION_VALUE>Wa:n *de trompo** t'chihchi:wayah pos no: n'chihchi:waya *de trompo**.</ANNOTATION_VALUE>
