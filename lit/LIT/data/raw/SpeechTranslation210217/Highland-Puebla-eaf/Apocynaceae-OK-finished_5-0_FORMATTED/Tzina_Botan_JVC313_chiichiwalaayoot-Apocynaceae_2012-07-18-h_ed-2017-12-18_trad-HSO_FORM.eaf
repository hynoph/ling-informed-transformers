                <ANNOTATION_VALUE>Wa:n t'ta:liliah n' ite:yo wa:n t'ta:liliah m' *bola** wa:n yahki a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
                <ANNOTATION_VALUE>'Tsikwi:ntinemiah itech *Todos Santos** tikahka:wayah.</ANNOTATION_VALUE>
