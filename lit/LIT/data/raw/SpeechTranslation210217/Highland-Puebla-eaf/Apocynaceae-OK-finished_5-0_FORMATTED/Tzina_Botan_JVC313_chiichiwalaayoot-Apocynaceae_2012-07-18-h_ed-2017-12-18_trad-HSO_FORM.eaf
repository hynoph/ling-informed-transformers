        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>Achto t'chihchi:wayah tehwa:n toa:wil pa:pa:lo:t.</ANNOTATION_VALUE>
