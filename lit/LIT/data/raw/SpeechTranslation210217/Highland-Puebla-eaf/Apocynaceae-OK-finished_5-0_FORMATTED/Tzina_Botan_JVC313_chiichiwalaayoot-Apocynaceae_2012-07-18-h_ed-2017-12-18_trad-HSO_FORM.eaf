        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Decías hace rato que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>el chi:chiwala:yo:t que se usa para pegar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>con su savia se puede,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>usar para pegar. Para pegar ¿sólo se usan los frutos o también se puede usar la savia que sale del tallo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Y si dices que ocupaban los niños para pegar su sarampico, ¿y los alumnos que iban a clases también</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>ocupaban eso? Y ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>¿Y tú no sabes por qué le llaman chi:chiwala:yo:t?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Y nos platicas que se puede pegar papel, no sé si usted puede hacer también el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>juguete que hacen en todos santos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Ése juguete no tiene un nombre el nuestra lengua ma:se:wal porque siempre</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>creo que el nombre de globo es español.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>Y actualmente dices que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>para pegar papel, ¿usted puede hacer eso? ¿Puedes platicarnos cómo se hace?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a532" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>¿Y eso cómo se sabe este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a533" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>cómo es..., es..., de qué tanto puede ser la boca del globo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a545" ANNOTATION_REF="a277">
                <ANNOTATION_VALUE>Y el, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a546" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>que le llaman bola, ¿tampoco tiene nombre en lengua ma:se:wal?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a547" ANNOTATION_REF="a290">
                <ANNOTATION_VALUE>¿Y cómo se sabe la cantidad de tela que se debe ocupar para la bola?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a568" ANNOTATION_REF="a301">
                <ANNOTATION_VALUE>Pues parece que es todo lo que nos platicaste acerca del chi:chiwala:yo:t para qué</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a569" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>o se..., se puede ocupar la savia para pegar y nos platicaste qué</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a570" ANNOTATION_REF="a303">
                <ANNOTATION_VALUE>cuáles son los animales que se..., se alimentan de</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a571" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>estas semillas de chi:chiwala:yo:t. Ahora dínos tu nombre y del pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Ernesto Vázquez Chanico" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="JVC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>Mm. Como no, este ese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>el chi:chiwala:yo:t su..., el chi:chiwala:yo:t,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>hay dos tipos. Conozco el primero que conozco es el chi:chiwala:yo:t de por aquí, ese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>que su savia la usan para pegar. Sus frutos son amarillos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>sus frutos son amarillos y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>la savia lechosa se usa para pegar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>No sé si se puede pegar un ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>Antes hacíamos nosotros nuestro juguete que era el sarampico. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Hacíamos el sarampico, con..., cortábamos la caña del maíz, le cortábamos la punta y le echábamos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>y a la caña le echábamos la savia, hacíamos un</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>un pedazo de caña partida hacíamos un medio círculo, enseguida le echábamos la savia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Y le pegábamos al papel para nuestro sarampico, luego le amarrábamos un hilo y la echábamos a volar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Y no sa..., no se despega, no..., donde pega el papel ya no se despega.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Así hacíamos nosotros nuestro sarampico. La savia la usábamos para pegar y algo así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>o como en donde estudiábamos nos pedían que lleváramos algo para pegar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Llevábamos el chi:chiwala:yo:t, no lle..., no había como ahora los..., koyomeh</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>le llaman resistol o pegamento.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>Ahora ya hay muchos con diferentes nombres, ya tienen el que pega mejor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Nosotros nos piden pegamento pues llevábamos el chi:chiwala:yo:t.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Cuando hacíamos el adorno en las fiestas de septiembre</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>nos decía nuestro maestro que lleváramos este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>algo para pegar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Pues se va al campo nuestro padre y nos mandaba a cortar medio morral de chi:chiwala:yo:t para pegar, con eso pegábamos el papel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>Pegábamos las banderitas, tomábamos la savia y pegábamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>para pegar usábamos el chi:chiwala:yo:t.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>No usábamos el resistol que actualmente usan los koyomeh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>No, aho..., acualmente todo ha cambiado, pero nosotros usábamos esos frutos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Y pega muy bien la savia de esos frutos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Y su..., su ta..., tallo de este árbol de chi:chiwala:yo:t es..., blanco, es blanco el tallo del chi:chiwa:yo:t,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>sus hojas son un poco grandes y son lisas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Y su..., sus flores este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>son como unas cornetitas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>son un poco gruesos por donde tienen el pedúnculo, por dentro son de color amarillo, y son anchas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>En las puntas de las ramas brotan las flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Después de que se abren las flores pues..., se..., se caen al suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Y el kowchi:chiwala:yo:t, sus</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>flores no so..., no son iguales como el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a348" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>chi:chiwala:yo:t que se da por aquí y se usa la savia para pegar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Ese árbol tiene sus..., sus..., sus...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>flo..., flores un poco verdes, pero no son grandes, sus flores son pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Y cuando produce sus frutos tienen el pedúnculo largo para colgarse,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>son boludos los frutos y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>nunca llegan a tomar el color amarillo, los frutos siempre son verdes. Ese le llaman kowchi:chiwala:yo:t.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Pero se da en el bosque, sus frutos son como cimarrón, sus...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>digamos como si fuera la planta silvestre del chi:chiwala:yo:t que se usa para pergar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Porque cada fruto que es diferente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>tiene su compañero que es silvestre,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>como si fuera cimarrón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Yo conozco dos tipos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>El primero es kowchi:chiwala:yo:t  y segundo es el chi:chiwalayo:t que es bueno</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>sus..., sus frutos tienen un color amarillo bonito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Sí, y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>su..., sus frutos cuando maduran se abren partiéndose a la mitad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Y luego empiezan a caerse las semillas al suelo, si no se caen vienen los tucanes y las,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>primaveras para comerse a las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>y las semillas que caen al suelo se las levantan las palomas para alimentarse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Los pájaros ta..., también aprovechan las semillas para alimentarse. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Sí, se los comen, se los comen los pajaritos, los papá reales o </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>los tucanes, las primaveras o los nextikchiktehmeh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Los pájaros se alimentan de las semillas que hay arriba en.., las ramas y las que se les caen del pico </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>m..., ya se las levanta la palomita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Ése es el chi:chiwala:yo:t que conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>La savia se puede ocupar para pegar papel o alguna otra cosa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Sí, ojalá se pudiera otra vez s..., ahora otra vez </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>en todas las escuelas, les enseñen a usar para que no compren el </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>pegamento así como,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>el pegamento que usan los mestizos, que la..., que la traigan en el campo para pegar, la savia pega bien para el papel de china.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Sería muy bueno también que se..., volviera a usar otra vez.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Pero ahora ya no la usan los koyo:meh, ya nadie les hace caso esos frutos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Pero si también pega muy bien. Es todo lo que yo conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>También es pegajoso. También es pegajoso, sólo que no tiene el mismo color como el chichiwala:yo:t</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>chichiwala:yo:t, su..., la savia es de color blanca como leche,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>es el que pega. Y el otro también tiene su..., la savia que tiene es igual como,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>como la savia de otro chi.chiwala:yo:t, sólo que sus frutos siempre están verdes, nunca llegan a tener el color amarillo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Y son má boludos. Y el kowchi:chiwala:yo:t tiene sus hojas más pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>No es como el otro que tiene las hojas un poco más anchas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Sí, se da en el bosque el kowchi:chiwala:yo:t y este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>el árbol no crece muy alto, y..., es como si fuera un chi:chiwala:yo:t cimarrón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Sí, el otro chi:chiwala:yo:t que se usa su savia para pegar tiene las hojas más grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Tiene las hojas más grandes y el otro chi:chiwala:yo:t tiene las hojas más pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Es como el árbol de encino y el wi:tsi:la:mat que tiene las hojas pequeñas, es igual, igual este árbol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Es igual también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>También se abren. también se abren. Y también, también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>no sé si los pájaros se alimentan de esas semillas, pero las semillas del otro chi:chiwala:yo:t sí aprovechan los pájaros para alimentarse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Por acá hay cerca, vemos que cuando maduran los frutos se abren y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>después de abrirse vienen los pájaros para buscar las semillas y se </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>las comen, y las semillas que se les escapa caen al suelo y vuelve a levantarlas otro pajarito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Sí. Los pájaros se alimentan de las semillas de chi:chiwala:yo:t.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Como en este tiempo ha..., enero, febrero, hay frutos de chi:chiwala:yo:t,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>donde hay árboles de chi:chiwala:yot lo..., y las personas que pueden hacer varias cosas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>va a poner trampas debajo de los árboles de chi:chiwala:yo:t para atrapar a las palomitas, ponen la trampa que le llaman kechmekat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Por eso sé que los pájaros se alimentan de las semillas. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>También se puede usar para leña,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>sólo que tiene mucha agua, pero cuando se seca arde bonito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Y el tallo es un poco de color blanco y encima de la corteza tiene así como unos granos, así es el chi:chiwala:yo:t.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Sí, pero también se puede quemar, si es leña seca arde bien. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>También arde bien pero es un poco más corriente la madera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Los troncos son un poco gruesos y son muy...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>la corteza la tiene muy gruesa. Y el otro tiene la corteza más delgada y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>y cuando se seca, cuando está bien seca es liviana la madera del chi:chiwala:yo:t. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>No, la savia que se usa para pegar sólo se saca del fruto, se...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>si se..., los frutos se dan de a dos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>los dos frutos se despegan del pedúnculo y para no tirar la savia que sale de ahí, se toma el papel y se pega,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>y si..., ya usaste esa savia y se acabó pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>corta el fruto en la punta o en el costado, después de terminar en la punta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>se, en donde se corta el fruto, sale la savia como si sangrara y esa savia se aprovecha para pegar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>El papel se acerca nada más en el fruto con savia para untarle un poco y queda bien pegado, ya no se despega.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Sí, la savia es muy buen pegamento, es muy, es igual como el que venden el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>que le llaman resistol que se vende con botellas de plástico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Es mejor pegamento la savia que el pegamento que se vende. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Se ocupaba para ador...., adornar en la escuela como en las</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>fiestas de septiembre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Pues nos ordenaba nue..., nuestro maestro para que lleváramos pegamento, y llevábamos los frutos de chi:chiwala:yo:t</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>pegábamos el papel y empezábamos a poner el adorno para la escuela.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>E..., o las que les llaman banderitas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>el maestro cortaba el papel y nosotros pegábamos el papel de tres colores, blanco, verde y rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a443" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Le poníamos el hasta de madera y la pegábamos para ondear, andábamos llevando la bandera en la mano.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a444" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Pegábamos el hasta con la savia de chi:chiwala:yo:t, no usá..., no usábamos más harina, lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a445" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>lo pegan con harina. Actualmente se usa la harina si se quiere pegar el papel</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a446" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>nosotros sólo usábamos eso. Actualmente usan la ha..., harina o el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a447" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>ya la compran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Aa, pero el chi:chiwala:yo:t pega muy bien, tampoco se despega el papel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Pues no sé por qué le llaman así, le llaman chi:chiwala:yo:t porque,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>porque pega muy bien y la savia es blanca como si fuera leche.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a452" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Creo que por eso le llaman chi:chiwala:yo:t. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a453" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Sí puedo. Puedo hacer. Lo..., nosotros hacíamos cuando éramos niños. Ahora ya no lo hacemos porque ya somos viejitos, pero si hay papel por qué no lo vamos hacer, lo haremos todavía.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a454" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Yo puedo hacer cualquier juguete, como el papel corta..., podemos cortar el papel. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a455" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>Pues nosotros lo..., lo llamábamos lobo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a456" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Sí, nosotros le llamábamos lobo, lo..., lo elavábamos nuestro lobo con el humo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>Le poníamos una bola, le poníamos este, en esos años había petróleo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Ahora ya no hay petróleo, ya todos le ponen diesel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Pero en esos años había petróleo es..., Más antes dicen que había petróleo de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>Y después creo que lo pintaban, entonces el petróleo era morado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>Pero actualmente ya no, ya no hay ése.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>Actualmente es diferente, ahora es de color blanco, co..., como un poco amarillo el diesel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a463" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Ya no hay este petróleo. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>El petróleo era  de color morado como,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a465" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>como el color del copete que usaban las mujeres, era de color morado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a466" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Íbamos a traer con una botella y tenía un color morado bonito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a467" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>Y más, más antes era de color blanco como el refino.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a468" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Nosotros vimos todavía porque ocupábamos el candil, todas las casas se alumbraban con candil.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a469" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>Y últimamente vemos que ya no hay,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>si quieres so..., socarrar un cerdo para limpiar la carne de los pelos, como no hay soplete,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>se le echa gasolina, pero no, no, dan gasolina sino que venden el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>que le llaman diesel. Le echan al cerdo muerto en el exterior de su cuerpo para socarrar pero el olor se le queda a la carne.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Actualmente es lo que usan para socarrar al cerdo, pero,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>este ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>Pues los matanceros tienen sus herramientas, actualmente tienen el soplete para socarrar mejor al cerdo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>Sí, es de puro gas que lo..., que lo venden los koyo:meh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>Sí. Pero antes nosotros le llamábamos gas era el petróleo que vendían en Cuetzalan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>para subir del contenedor ocupaban un, con un</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>fierro de tubo para se..., sacar el petróleo de un contenedor a otro envase.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>Actualmente ya no lo concemos eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a205">
