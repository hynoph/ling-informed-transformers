        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>T'pehpepechowah yo:n *banderitas** tikwih, t'pehpepechowa:yah,</ANNOTATION_VALUE>
