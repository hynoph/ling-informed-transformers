            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
                <ANNOTATION_VALUE>T'pehpechowa:yah wa:n t'metskowyo:tiah wa:n 'ta:tayewalowah tepitsi:n, t'ma:ktinemih yehwa yo:n *bandera** ya.</ANNOTATION_VALUE>
