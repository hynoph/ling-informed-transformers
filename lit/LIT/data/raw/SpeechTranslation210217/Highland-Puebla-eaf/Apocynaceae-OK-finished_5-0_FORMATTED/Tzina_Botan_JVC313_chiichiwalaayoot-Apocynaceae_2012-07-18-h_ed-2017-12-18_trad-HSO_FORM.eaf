        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>Seki kiliah kowchi:chiwala:yo:t wa:n seki i:n chi:chiwala:yo:t tein kwali, tein</ANNOTATION_VALUE>
