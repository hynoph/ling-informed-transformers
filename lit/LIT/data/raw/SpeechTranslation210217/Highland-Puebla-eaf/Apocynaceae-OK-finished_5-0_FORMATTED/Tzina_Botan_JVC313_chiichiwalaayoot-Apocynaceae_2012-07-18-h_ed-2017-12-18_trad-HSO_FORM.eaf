        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
                <ANNOTATION_VALUE>ke:ní:w n..., k..., *este**, ke:ní:w ne:n ika we:i se: kite:nkoyo:ni:s?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
                <ANNOTATION_VALUE>Wa:n yehwa, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
                <ANNOTATION_VALUE>tein yo:n kiliah *bola**, ¿yo:n a:mo no: kipia ito:ka:y ne:n ma:se:walkopa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
                <ANNOTATION_VALUE>¿Wa:n ke:ní:w se: kimati ton achi we:i ne:n se: kichihchi:wa yo:n tilmah?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
                <ANNOTATION_VALUE>Pos pané: nochi a ne:n tein tite:chnohno:ts i:n chi:chiwala:yo:t toni ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
                <ANNOTATION_VALUE>kwali se: t..., kitatekiwtia n' icho:kilo wa:n nochi 'te:chtapowih toni, ne:n,</ANNOTATION_VALUE>
