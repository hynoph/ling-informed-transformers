        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Y el chi:chiwala:yo:t que se usa para pegar su...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
