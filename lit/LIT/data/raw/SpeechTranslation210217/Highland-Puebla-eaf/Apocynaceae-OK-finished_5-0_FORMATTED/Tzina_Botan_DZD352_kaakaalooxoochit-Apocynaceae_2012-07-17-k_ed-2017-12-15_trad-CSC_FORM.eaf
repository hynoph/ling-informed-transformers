        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>Wa:n yo:n kwali se: ka:ketsa, se kipohposteki n' .... Metswe:weyak.</ANNOTATION_VALUE>
