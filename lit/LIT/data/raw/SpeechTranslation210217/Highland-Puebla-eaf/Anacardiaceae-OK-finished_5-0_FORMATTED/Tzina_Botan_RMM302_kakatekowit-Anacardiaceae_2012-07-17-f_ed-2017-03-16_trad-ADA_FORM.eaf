            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n kitatekiwtia:yah, yehwa:n kwelitayah kit *porque** yo:n kowit, *este**, mah tikihto:ka:n takwa:wak.</ANNOTATION_VALUE>
