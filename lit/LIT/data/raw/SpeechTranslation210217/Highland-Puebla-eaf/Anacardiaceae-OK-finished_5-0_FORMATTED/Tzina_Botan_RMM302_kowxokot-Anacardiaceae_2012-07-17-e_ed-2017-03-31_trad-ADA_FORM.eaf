            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
                <ANNOTATION_VALUE>A:mo ke:meh ne:n kwowxokot yeh, kwowxokot itech n' i..., imahmaxaltsitsi:n ompa pe:wa xo:chiowa wa:n ompa mopahpampilowa. Mmm.</ANNOTATION_VALUE>
