        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>Wa:n, wa:n ompa yeh kitak *que** ne..., kineltokak *que** neli *porque** ke:mih pewa:k moskaltih m...,</ANNOTATION_VALUE>
