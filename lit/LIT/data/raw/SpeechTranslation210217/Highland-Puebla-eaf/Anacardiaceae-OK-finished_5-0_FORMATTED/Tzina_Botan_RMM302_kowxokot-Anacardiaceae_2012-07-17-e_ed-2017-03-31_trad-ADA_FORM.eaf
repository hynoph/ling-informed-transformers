        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>Neh nimitsilia *porque** ne: ka:mpa nikitak iwa:n, nika:n i:n,</ANNOTATION_VALUE>
