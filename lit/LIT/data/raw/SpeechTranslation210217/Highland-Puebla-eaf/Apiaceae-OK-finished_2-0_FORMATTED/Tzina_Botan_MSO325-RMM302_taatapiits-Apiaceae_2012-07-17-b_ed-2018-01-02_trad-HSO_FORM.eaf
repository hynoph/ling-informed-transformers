        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>cuando era pequeño, ahora también ya tengo,</ANNOTATION_VALUE>
