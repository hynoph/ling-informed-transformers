        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>Ne:, pos yehwa neh nimits..., nikmattok, [compadri]to.</ANNOTATION_VALUE>
