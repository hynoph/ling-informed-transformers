        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts155">
                <ANNOTATION_VALUE>mopihpilowa, *peor** ke:meh i:n xaxakachtik ne: pos*más** mopihpilowa, ne:n,</ANNOTATION_VALUE>
