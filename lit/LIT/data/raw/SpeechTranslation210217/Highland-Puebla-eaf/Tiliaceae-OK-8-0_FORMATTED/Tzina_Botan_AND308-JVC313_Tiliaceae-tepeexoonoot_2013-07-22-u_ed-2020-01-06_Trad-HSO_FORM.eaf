            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
                <ANNOTATION_VALUE>wa:n yehwa, nijó:n, ika tama:ma:yah.</ANNOTATION_VALUE>
