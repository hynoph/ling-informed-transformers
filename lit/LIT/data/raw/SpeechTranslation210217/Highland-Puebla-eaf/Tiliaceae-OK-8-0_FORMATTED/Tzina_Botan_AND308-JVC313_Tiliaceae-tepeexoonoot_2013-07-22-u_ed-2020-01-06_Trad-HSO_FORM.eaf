            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts235">
                <ANNOTATION_VALUE>Yo:n xo:no:t ke:masá: se: kitehteki ihkó:n kwaltsi:n se: 'ki:xtia ke:meh eskia *hilos** ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
