                <ANNOTATION_VALUE>Se: 'kwi:ltia:ya wa:n ke:mah se: kwa:lma:mahte:wa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>Se: ehko wa:n ne: se: kita:lia se: ikow.</ANNOTATION_VALUE>
