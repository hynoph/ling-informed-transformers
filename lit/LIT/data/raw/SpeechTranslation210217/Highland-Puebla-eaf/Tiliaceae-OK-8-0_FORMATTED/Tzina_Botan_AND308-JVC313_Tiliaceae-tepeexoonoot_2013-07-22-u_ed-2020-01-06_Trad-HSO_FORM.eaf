            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a587" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>busca la madera de &lt;i&gt;chi:kikis&lt;/i&gt; o del &lt;i&gt;tepe:xo:no:t&lt;/i&gt; y los tallos rectos los parte a la mitad para que alncancen dos, los que se pueden partir en dos,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a599" ANNOTATION_REF="a305">
                <ANNOTATION_VALUE>parte los tallos y cierra la pared amarrando los palos el señor Juan Medina, vi..., vivía a lado de nuestra casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a600" ANNOTATION_REF="a306">
                <ANNOTATION_VALUE>Hacía bonita la construcción de su casa, amarraba la madera con pura corteza de árbol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a601" ANNOTATION_REF="a307">
                <ANNOTATION_VALUE>Con pura corteza de árbol y lo amaraba cruzando el jonote con que amarraba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
