        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a579" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>usos que se le de solamente lo usamos para cerrar las paredes de la casa, nosotros le llamamos &lt;i&gt;tsi:ntsakwal&lt;/i&gt; usamos para eso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a580" ANNOTATION_REF="a297">
                <ANNOTATION_VALUE>usamos para cerrar. Le llamamos &lt;i&gt;tsi:ntsakwal&lt;/i&gt; para ce..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a581" ANNOTATION_REF="a298">
                <ANNOTATION_VALUE>los tallos que están un poco gruesos los parten a la mitad y lo..., lo amarran con eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a582" ANNOTATION_REF="a299">
                <ANNOTATION_VALUE>Y si no usan bejuco para amarrar pues se usa la corteza del </ANNOTATION_VALUE>
