        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a651" ANNOTATION_REF="a346">
                <ANNOTATION_VALUE>Ya tiene muchos años que haciamos para amarrar los palos, el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a652" ANNOTATION_REF="a347">
                <ANNOTATION_VALUE>&lt;i&gt;tepe:xo:no:e:wat&lt;/i&gt; y también sé que se puede usar para cerrar las paredes, este lo..., usábamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a653" ANNOTATION_REF="a350">
                <ANNOTATION_VALUE>También lo usábamos pero no puedo decir que se puede usar para </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a654" ANNOTATION_REF="a351">
                <ANNOTATION_VALUE>madera de la casa. No, solamente para cerrar las paredes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a655" ANNOTATION_REF="a355">
                <ANNOTATION_VALUE>A para leña no sirve porque no rinde, se quema rápido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a656" ANNOTATION_REF="a357">
                <ANNOTATION_VALUE>No arde bien. También del..., también sirven de..., las ramas del..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a657" ANNOTATION_REF="a359">
                <ANNOTATION_VALUE>Se cortan las varitas  también sirven.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a658" ANNOTATION_REF="a361">
                <ANNOTATION_VALUE>Pues  también sirve la madera de &lt;i&gt;tepe:xo:no:t&lt;/i&gt; que no está podrida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a659" ANNOTATION_REF="a362">
                <ANNOTATION_VALUE>el que todavía está un poco bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a660" ANNOTATION_REF="a363">
                <ANNOTATION_VALUE>También se quema si no se parte en grandes rajas, también se puede usar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a661" ANNOTATION_REF="a365">
                <ANNOTATION_VALUE>Pero si se parte en grandes rajas no sirve. No arde bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a662" ANNOTATION_REF="a367">
                <ANNOTATION_VALUE>O también si ya está muy podrida la madera, ya no prende.    </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a681" ANNOTATION_REF="a369">
                <ANNOTATION_VALUE>Ahí se meten los animalitos, creo que los conoces esos que les llaman comejenes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a682" ANNOTATION_REF="a370">
                <ANNOTATION_VALUE>Esos también cor..., cortan mucho la madera. Pero ahora no, casi no, parece que no los he visto. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a683" ANNOTATION_REF="a372">
                <ANNOTATION_VALUE>Esos animales son muy delgaditos y, por eso algunas veces lo lleva uno a</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a684" ANNOTATION_REF="a373">
                <ANNOTATION_VALUE>la casa para cerrar las paredes de la casa pues ya ahí se encuentran los animales y ya la cortan la,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a685" ANNOTATION_REF="a374">
                <ANNOTATION_VALUE>la madera de &lt;i&gt;xo:no:kowit&lt;/i&gt;, este, uno parte la madera pero todo està hueco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a686" ANNOTATION_REF="a375">
                <ANNOTATION_VALUE>Se quedaba hueco, le sacaban todo por dentro, creo que se la comen los</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a687" ANNOTATION_REF="a376">
                <ANNOTATION_VALUE>esos animales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a688" ANNOTATION_REF="a378">
                <ANNOTATION_VALUE>Esos animales lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a689" ANNOTATION_REF="a379">
                <ANNOTATION_VALUE>aunque se pone nuevas las,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a690" ANNOTATION_REF="a380">
                <ANNOTATION_VALUE>tablitas de palo de jonote, ya las coloca uno</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a691" ANNOTATION_REF="a381">
                <ANNOTATION_VALUE>se amarran las tablas y ve uno que ya la..., están cortando, en el suelo hay como polvo de madera.    </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a692" ANNOTATION_REF="a383">
                <ANNOTATION_VALUE>Sí, la madera de &lt;i&gt;tepe:xo:no:t&lt;/i&gt; se la comían, creo que porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a693" ANNOTATION_REF="a385">
                <ANNOTATION_VALUE>es suave. Por eso este, ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a694" ANNOTATION_REF="a387">
                <ANNOTATION_VALUE>Qué bueno que me..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a695" ANNOTATION_REF="a389">
                <ANNOTATION_VALUE>me estás platicando y también sabes del &lt;i&gt;tepe:xo:no:t&lt;/i&gt; pues es muy bonito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a696" ANNOTATION_REF="a391">
                <ANNOTATION_VALUE>Es bueno encontrarnos aquí en este camino en el bosque,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a697" ANNOTATION_REF="a393">
                <ANNOTATION_VALUE>pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a698" ANNOTATION_REF="a395">
                <ANNOTATION_VALUE>pues para muchas, sirve de mucho el &lt;i&gt;tepe:xo:no:t&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a699" ANNOTATION_REF="a398">
                <ANNOTATION_VALUE>de que lo pla..., platicamos todo bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a700" ANNOTATION_REF="a399">
                <ANNOTATION_VALUE>Pues todo vamos sabiendo, algunas cosas no lo sabemos todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a701" ANNOTATION_REF="a401">
                <ANNOTATION_VALUE>pero en este momento compartimos todo lo que sabemos, al encontrarnos acá y aquí es..., estamos pues estuvo bueno la forma en que me preguntaste y yo también te pregunté.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a702" ANNOTATION_REF="a403">
                <ANNOTATION_VALUE>pues es muy bonito, no hemos pla..., platicado de algo malo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a703" ANNOTATION_REF="a405">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a704" ANNOTATION_REF="a408">
                <ANNOTATION_VALUE>Pues yo me lla..., llamo Anastacio Nicolás Damián, vengo de San Miguel Tzinacapan.          </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a705" ANNOTATION_REF="a410">
                <ANNOTATION_VALUE>A bueno, gracias.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
