        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
                <ANNOTATION_VALUE>Wa:n ke:masá: *cuando** kelka:wayah de nijó:n kwa:it,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
                <ANNOTATION_VALUE>pos yehwa ya nimitsilia ne:wí:n wa:n a:mo teh se: ikowtsí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
                <ANNOTATION_VALUE>wa:n se: kita yo:n tepe:xo:no:t,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts307">
                <ANNOTATION_VALUE>pos se: kite:nteki wa:n se: 'ki:xtilia nijó:n xo:no:t wa:n se: ki..., kilpia ika se: ikow, se: wa:ltama:mahtiwi:ts a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
                <ANNOTATION_VALUE>A:mo te:i:xkwa:kokoh, nió:n no: koto:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts313">
                <ANNOTATION_VALUE>Nijó:n xo:no:t, tepe:xo:no:t miak, miak tapale:wia, nijó:n, sayoh *que**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
                <ANNOTATION_VALUE>no: tihtila:wak n' ie:wayo</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
                <ANNOTATION_VALUE>wa:n yo:n de, de pala:ni a, nijó:n, tepe:xo:no:t no:, no: semi ke:wa, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts321">
                <ANNOTATION_VALUE>nanakat, kiliah ne: xo:no:nanakat. Kiliah ne: xo:no:nanakat *porque** ompa ti..., itech e:wi ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
                <ANNOTATION_VALUE>tepe:xo:no:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
                <ANNOTATION_VALUE>Nijó:n, x..., kiliah xo:no:nanakat no: ke:wa seki n' alakcho ompa ne: *pero más** ke:wa ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts329">
                <ANNOTATION_VALUE>xo:no:nanakat. Nijó:n, xo:no:nanakat, ne:n, semi we:lik wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
                <ANNOTATION_VALUE>pos n' ie:wayo de nijí:n tepe:xo:no:t de n' chika:wak, nijó:n, seki tohtoma:wak,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
                <ANNOTATION_VALUE>pos no: tila:wak n' ie:wayo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
                <ANNOTATION_VALUE>Ti..., tila:wak n' ie:wayo wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts340">
                <ANNOTATION_VALUE>no: de pala:ni a nochi ki:sa. Yo:n no:, no: kikwih para tapala:n, nijó:n, ki..., kololta:liah, nijó:n, oso kitsi:nte:miliah ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
                <ANNOTATION_VALUE>kahfe:ntsi:n, pos yo:n no: tapala:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts346">
                <ANNOTATION_VALUE>No: tapala:n nijó:n tepe:xo:no:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts349">
                <ANNOTATION_VALUE>Ke:mah. Wa:n teh xa: kachi tikmatis teh para, nijó:n, tepe:xo:no:t xa: kachi tikmatis teh *que para, de** toni, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts353">
                <ANNOTATION_VALUE>*servi:rowa, para** toni kwaltia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts391">
                <ANNOTATION_VALUE>Pos yehwa, nijó:n, tepe:xo:no:t miak tapale:wia:ya pero</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts395">
                <ANNOTATION_VALUE>ki..., pos tehwa:n, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
                <ANNOTATION_VALUE>tota:tah katka no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts401">
                <ANNOTATION_VALUE>pos neh nikelna:miktok no: ne: ke:maniá:n ya *que** tikpiaya, nijó:n kaltsí:n nochi yehwa, nijó:n, xo:nokowtsí:n tikta:lilia:yah, tikwi:pa:nayah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
                <ANNOTATION_VALUE>*porque** tehwa:n katka ne:n kaltsí:n de, de owasakat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts409">
                <ANNOTATION_VALUE>Wa:n xa: tikelna:miki, owasakat nochi tikwi:pa:nayah ika yo:n tepe:xo:no:e:wat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts413">
                <ANNOTATION_VALUE>de yo:n selik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts417">
                <ANNOTATION_VALUE>A:mo pala:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts425">
                <ANNOTATION_VALUE>No: achto tikehketsayah achto yo:n kilia:yah tatili:nka:yo:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
                <ANNOTATION_VALUE>Ne:n ta:nka:yo:t nochi ne:n tik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>tikilpia:yah achto ke:mah ompa tiktekpa:nayah ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
                <ANNOTATION_VALUE>Tiktekpa:nayah yo:n kowtsitsí:n, ika titatsakwayah ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
                <ANNOTATION_VALUE>Wa:n ahko pos, ne:n, yehwa nijó:n ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
                <ANNOTATION_VALUE>owasakat katka ne:n kaltsí:n, tehwa:n tokaltsi:n katka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts441">
                <ANNOTATION_VALUE>Owasakat ne: ke:man ya. *Después** tikchi:wkah de, de kowxiwit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
                <ANNOTATION_VALUE>Neh no:pá:n nochiwelia nijó:n para ..., de kowxiwit wa:n yehwa yo:n tikwiah nochi yo:n tepe:xo:no:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>Wa:n pet..., peto:lkomekat, yo:n nochi, nochi yeh ne:n tikwiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts451">
                <ANNOTATION_VALUE>Pero más** tiktsahtsaya:nayah yehwa i:n tepe:xo:no:t, i:n semi, semi kwaltia, *más** takwa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
                <ANNOTATION_VALUE>Neh nikmattok kwali *porque** tehwa:n yeh n' tikwiah wa:n nikelna:miktok ne:n ne: ke:man ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
                <ANNOTATION_VALUE>Wehka:w ya, nijó:n, tikchi:wayah wa:n ika 'tawi:pa:nayah, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts459">
                <ANNOTATION_VALUE>tepe:xo:no:e:wat wa:n ika kwaltia nikmattok no: kwaltia para tatsakwil, nijó:n, tik..., tikwiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>No: tikwiah pero a:mo nikihto:s *que** kwaltias para teihsá: ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts467">
                <ANNOTATION_VALUE>kalkowit. A:mo, *solamente para** tatsakwil.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts475">
                <ANNOTATION_VALUE>A:, para kowtati:l a:mo kwaltia, chichinawi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts479">
                <ANNOTATION_VALUE>Chichinawi. No: de n..., no: kwaltia n' in..., n' imahma:yo de n...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts483">
                <ANNOTATION_VALUE>Se: kitehteki tako:tsitsí:n no: kwaltia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
                <ANNOTATION_VALUE>Pos no: kwaltia de n' a:mo semi palaktik ne:n tepe:xo:no:t,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts489">
                <ANNOTATION_VALUE>te:ntepitsi:n achi kwali ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts490" TIME_SLOT_REF2="ts493">
                <ANNOTATION_VALUE>No: tata mah a:mo semi telpa:pata:wak se: kitahtapa:na, no: kwaltia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts497">
                <ANNOTATION_VALUE>Pero komo se: kitahtapa:n wehwei, a:mo kwaltia. Chichinawi sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts501">
                <ANNOTATION_VALUE>*O** sepa ta:ká:n pano:tok a de pala:ntok nijó:n kowtsí:n, a:mo xo:ta ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
                <ANNOTATION_VALUE>Ompa mokalakiah yehwa yo:n kiliah yo:n okwiltsitsí:n a:chá: tikini:xmattok yo:n *comejenes**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts507">
                <ANNOTATION_VALUE>Yo:n semi ki..., kitehtekih yo:n, yo:n kowit no:. Pero ekintsi:n a:mo kachi ne:wí:n, pané: a:mo kachi nikinita.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
                <ANNOTATION_VALUE>Yo:n okwilimeh pihpitsaktikeh wa:n, *por eso** ke:masá: se: kwi:kaya ne:</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
                <ANNOTATION_VALUE>ka:mpa kali se:, se: kitsi:ntsakwaya se: ikaltsi:n pos ompa ne: aktokeh yo:n okwilimeh, 'kohkoyo:nia:yah, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
                <ANNOTATION_VALUE>xo:no:kowit, ne:n, se: kitahtapa:naya wa:n moka:waya sayoh kakawat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
                <ANNOTATION_VALUE>Kakawat moka:waya, nochi 'ki:xtilia:ya ne: tak 'kwa:yah nijó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
                <ANNOTATION_VALUE>yo:n okwilimeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
                <ANNOTATION_VALUE>Nijó:n, okwilimeh ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
                <ANNOTATION_VALUE>ma:ski, de a:mo k..., se: kita:lilia ya, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
                <ANNOTATION_VALUE>*xo:no:tablitas** ne:n se: kitekpa:na ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts529">
                <ANNOTATION_VALUE>se: tawi:pa:naya, se: ki:sati:w miak kite..., [ki]tektokeh, ta:lpan te:ntok ne:n tamomox.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts533">
                <ANNOTATION_VALUE>Ke:mah, ne:n tamomox, yo:n 'kwa:yah nijó:n tepe:xo:no:t tak porin</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts537">
                <ANNOTATION_VALUE>yema:nik. Yehwa ika, ne:n, ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts541">
                <ANNOTATION_VALUE>Pos no: kwali a *de que** tine:ch...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts545">
                <ANNOTATION_VALUE>tine:chilihtok wa:n no: tikmati ke:meh i:n tepe:xo:no:t pos kwaltsi:n no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts549">
                <ANNOTATION_VALUE>Kwaltsi:n de nika:n timahsikeh itech nijí:n ohti wa:n itech i:n kowtah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts553">
                <ANNOTATION_VALUE>pos,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
