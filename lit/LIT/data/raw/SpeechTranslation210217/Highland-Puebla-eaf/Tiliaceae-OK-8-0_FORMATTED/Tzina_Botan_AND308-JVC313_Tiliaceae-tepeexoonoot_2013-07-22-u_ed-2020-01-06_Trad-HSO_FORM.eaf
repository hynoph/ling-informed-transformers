            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts255">
                <ANNOTATION_VALUE>Ihkó:n ne: ke:man ti..., tipano:keh,</ANNOTATION_VALUE>
