        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts291">
                <ANNOTATION_VALUE>A:mo tiwelih ok wa:n ihwa:k miak weliah n' ta:tahmeh.</ANNOTATION_VALUE>
