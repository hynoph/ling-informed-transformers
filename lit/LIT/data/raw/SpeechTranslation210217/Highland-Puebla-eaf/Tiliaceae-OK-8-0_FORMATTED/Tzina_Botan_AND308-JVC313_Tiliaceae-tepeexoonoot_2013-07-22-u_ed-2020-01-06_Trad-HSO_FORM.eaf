        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts281">
                <ANNOTATION_VALUE>Kichi:wayah de xo:..., xo:no:kwa:it, nochi kichi:wayah ika ne:n tama:ma:yah n' tokni:wa:n.</ANNOTATION_VALUE>
