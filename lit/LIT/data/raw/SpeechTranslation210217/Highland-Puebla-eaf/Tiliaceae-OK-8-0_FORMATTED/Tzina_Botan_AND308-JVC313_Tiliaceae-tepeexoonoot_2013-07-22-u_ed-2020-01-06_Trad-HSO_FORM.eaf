        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a583" ANNOTATION_REF="a300">
                <ANNOTATION_VALUE>&lt;i&gt;tepe:xo:no:e:wat&lt;/i&gt;, se le extrae la corteza y se usa para amarrar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a584" ANNOTATION_REF="a301">
                <ANNOTATION_VALUE>Bueno lo amarraban nuestros abuelos, nosotros no lo hicimos, pero pues nosotros vivimos en otros tiempos pero antes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a585" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>todos los abuelos usaban eso para..., amarrar los palos, yo todavía vi al señor Medina que era nuestro vecino, vivía el finado Juan Medina,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a586" ANNOTATION_REF="a303">
