        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts285">
                <ANNOTATION_VALUE>No: ekintsi:n, ne:n, nochi ki..., n' oksé: taman no: kwa:it a pero n' oksé: taman kintsi:n onkak. Ikintsi:n ya..., yankwik ne:sik, nijó:n.</ANNOTATION_VALUE>
