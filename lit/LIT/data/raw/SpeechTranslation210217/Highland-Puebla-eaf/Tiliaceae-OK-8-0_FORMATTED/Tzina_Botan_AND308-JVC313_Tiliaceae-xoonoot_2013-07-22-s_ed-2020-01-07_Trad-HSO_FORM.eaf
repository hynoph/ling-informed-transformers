        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Y a veces la fibra del jonote blanco se dobla, si se puede se junta con el este</ANNOTATION_VALUE>
