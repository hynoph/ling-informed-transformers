        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>se: kaxto:l to:nal ke:mansá: soh se: *seman[ah]**.</ANNOTATION_VALUE>
