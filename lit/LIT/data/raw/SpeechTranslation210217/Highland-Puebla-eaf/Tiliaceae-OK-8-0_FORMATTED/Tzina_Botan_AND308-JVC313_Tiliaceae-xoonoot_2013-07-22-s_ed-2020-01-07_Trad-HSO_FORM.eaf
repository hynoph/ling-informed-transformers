            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Y pues eso es lo que se....</ANNOTATION_VALUE>
