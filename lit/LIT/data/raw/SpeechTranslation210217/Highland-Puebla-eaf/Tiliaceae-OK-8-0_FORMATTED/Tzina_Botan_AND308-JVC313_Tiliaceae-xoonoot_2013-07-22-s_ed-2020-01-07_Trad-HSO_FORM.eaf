            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>es importante tumbar el árbol y se le...,  desprende la corteza tirado en el suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Y el que se desprende fácilmente, ahí se le deprende erecto el árbol, se desprende la corteza hasta arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Y este, ya se tumba uno de los árboles en donde se mete  la corteza y se jala con fuerza para separar la fibra con la corteza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Este partimos a la mitad el tronco como nos..., tenemos que ver que nos facilite.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Y se labra un poquito para que quede como si tuviera filo en la esquina de la madera</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>y entonces se cor..., corta un pedazo de madera</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>como el tamaño (tres cuartas de largo) de un batidorcito y se..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>en el palo se enreda la corteza para jalarlo con fuerza, si se hace sólo con la manos no se puede porque está muy resbaloso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Y entonces se va jalando el palo. Luego se va cortando la..., la corteza,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Lo que se va jalando para acá es la fibra del jonote y el que va saliendo allá es la corteza dura que se va tirando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Se jala para acá y se le hace filo en la esquina de la madera para irlo jalando la..., así en..., se va jalando así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Y este va saliendo para allá lo que es la, la corteza,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>lo jalas y lo jalas, luego un po..., lo..., ya sale todo, lo..., sale todo este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>el que se desprende con facilidad lo jalas y se chispa la corteza hasta caerse para allá.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Luego ya lo enrollas tu..., el jonote, o de una vez lo..., lo vas acomodando, primero limpias todo y ya lo..., lo vas enrollando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>y lo..., lo echas en el agua, lo vas a sumergir en el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Y yo en donde voy a sumergir en el agua el jonote lo..., si no pongo unas hojas de plátano por debajo lo..., mejor lo meto en una bolsa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Pero lo meto aflojado, lo meto alfojado, no, no lo..., no lo enrollo así, lo...,   </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>lo enrollo para llevarlo y  otra vez lo desenrollo para que quede flojo dentro de la bolsa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>debe estar flojo para</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>para que se fermente bien. Y cuando yo lo meto en el agua lo amarro en un,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>lo amarro con lazo o con bejuco y lo aseguro en el tronco de un árbol porque a veces crece el arroyo y se lo lleva el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Y para que eso no pase pues yo lo..., echo en una bolsa y lo amarro con bejuco en un árbol,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>y hace unos veinte días para este, lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>ya lo voy a sacar, entonces se fermenta muy bien el jonote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Y cuando lo lavo no hay necesidad de ponerle cloro, sale la fibra de jonote blanca y muy blandita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Sí, pero de veras que, se debe sumergir en el agua en un lugar dónde se..., eh..., donde entran los rayos del sol, en un lugar que hay sombra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>No se fermenta muy bien porque este no se calienta el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Eso es lo que yo sé. No, se debe su..., sumergir en un lugar donde hace un poco de sol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Para que se fermente muy bien, se fermente muy bien. Yo lo hago así y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>a veces también lo..., me sale muy bien el jonote, pero yo he visto que otras personas venden el jonote pero no lo saben procesar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>tampoco pueden separar de la corteza porque sale la fibra muy dura.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>Y, y no sale su..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>este su savia o la baba del jonote que es lo resbaloso porque no se fermenta bien y lo lavan así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>las personas con tal de venderlo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>lo..., lo secan rápidamente y aunque ya se seque queda muy dura, pero queda muy dura porque no sale la baba, no se fermentó.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Y no lo..., no le va ayudar aunque le pongas cloro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>no lo va a suavizar ni lo va a blanquear, no lo..., no lo..., no le ayuda aunque uno lo lave con cloro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>aunque le pongas tantas veces, lo..., le vas a echar, lo vas a sumergir en el cloro pero no mejora.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>porque este, de que no se fermenta, de que no se fermenta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Cuando se fermenta bien no hay necesidad de que le eches mucho cloro, con un poquito que le eches queda muy blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>Sí, yo he lavado así la fibra del jo..., jonote, lo meto en el agua pero nunca le echo cloro</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>lo hago así y sale muy blanco el jonote. Y sale muy suavecito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Sí, pero otras personas veo que no pueden separar la corteza con la fibra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>pues así este lo, así lo extraen y lo lavan como pueden y no lo..., pues de que se seca ya queda muy dura y muy feo.   </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Sí queda muy dura. Y si uno lo lava sale lo resbaloso, sale lo resbaloso y no sale porque no se fermenta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>Así lo ponen a secar y aunque sea muy dura cuando lo venden, uno lo compra así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>Así no, no, no sale bien el jonote. No las personas que no lo pueden extraer. He visto que aunque los árboles de jonote sean delgadas, les extraen a los arbolitos así de del..., de ancho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>No sale la baba, lo traen así  y lo..., lo..., lo ponen a secar y lo venden </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Y es importante limpiarlo muy bien para no engañar a las personas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>para que tengan buena fibra y puedan trabajar bien o </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>hasta sus artesanías también salen muy blancos y tienen buena presentación, lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>dominan la fibra, pueden manejarlo como a ellos les guste, pueden torcer las hebras así parejas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>Pero el que está duro no se puede torcer porque lastima los dedos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a206">
                <ANNOTATION_VALUE>Sí así, sí también.    </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>Mm. Pero tarda más dentro del agua, tarda. Mmm. Ese no, uno no lo, así  nada más se desprende la corteza, al fermentarse se desprende.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a210">
                <ANNOTATION_VALUE>Mm. Pero cuan..., pero cuando el árbol es delgadito, el que está tierno, pero un árbol grande no, no se desprende porque la corteza es gruesa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>Sí. Primero se mete  la corteza y se jala con fuerza para que salga buena la fibra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>pero es cierto que se..., he visto que algunas personas venden la fibra pero la extraen de los árboles pequeños muy delgados y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>quien sabe si no lo pueden separar la fibra con la corteza o no sé cómo, porque he visto que la fibra está muy dura y muy delgada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Y yo extraigo la fibra de los árboles grandes, de que están grandes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a216">
                <ANNOTATION_VALUE>lo..., lo he extraído y sale muy bien la fibra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>Y sale muy lo resbaloso porque lo..., se fermenta muy bien y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>lo lavo muy bien y lo pongo a secar, sale la fibra muy suavecita y muy blanca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>Así se ve muy bien y hasta para vender es muy bonito y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>y no, no está dura para que lo trabajen, sale muy bien el jonote. Así es</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>Ya lo va cortando también, ya lo va cortando también</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>Sí. Sí. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>Sale muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a447" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>Sí. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>Sí. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>Esos se comen pero pues nose..., no lo..., se le puede extraer la fibra, se desprende la corteza del tallo y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>se pueden quedar ahí los gusanos, no estorban, se tumba y se,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>que ahí se quede tirado la madera. Sí yo..., ke..., los gusanos nada más se comen las hojas. Sí, sí, se comen las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>Mm. Sí.</ANNOTATION_VALUE>
