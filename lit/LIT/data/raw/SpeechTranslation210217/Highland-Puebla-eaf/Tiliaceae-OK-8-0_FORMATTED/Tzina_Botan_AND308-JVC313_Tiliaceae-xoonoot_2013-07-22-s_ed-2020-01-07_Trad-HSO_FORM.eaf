        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>*Porque** ta: a:mo komo se: kinehnepanowa ihkó:n</ANNOTATION_VALUE>
