        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts96" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Eh, kaxaltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts140" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Para, para xokoya. Ke:mah, para xokoya yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a117" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Kahkakaltik, kahkakaltik a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
                <ANNOTATION_VALUE>Ke:mah, pos neh de xo:no:t no: tepitsi:n n'matilia, no: nikehke:wani wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>nejó:n, se: ki..., ti..., onkak seki n...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
                <ANNOTATION_VALUE>se: n' chi:chi:lxo:no:t wa:n se: n' is..., ista:k xo:no:t kiliah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
                <ANNOTATION_VALUE>Pero neh *más** nikehke:wa yo:n ne:n ista:k xo:no:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts190">
                <ANNOTATION_VALUE>Ne: kowtahpa se: kahsi, kwaltsi:n kowtsí:n, mehmelaktsitsí:n wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>wa:n ne: yo:n *primero**, se:, komo se: kineki se: kehke:was s..., se: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
                <ANNOTATION_VALUE>se: kitsi:ntektiw n' kwomekat ne:n i..., n' ie:wayo wa:n se: kitila:ntiw ahko, se: kehke:wtiw *has...**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>se: kiteki wa:n se: kehke:wa, se: kita *hasta** ahko ne: ehke:wi ise:lti wa:n seki tein a:mo wel ehehke:wi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts198">
                <ANNOTATION_VALUE>se: kite:nteki *importa** n' kowit wa:n se: ki..., se: 'ki:xtilia iwetstoya:n, ne:n, ie:wayo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>Wa:n tein kwaltsi:n ehke:wi, ompa sah se:, iihkatoya:n se: 'ki:xtilia *hasta** ahko kihki:sa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts202">
                <ANNOTATION_VALUE>Wa:n, nejó:n, se: kite:nteki a n' kowtsí:n ka:mpa se: kitas kwali se: 'kowtsa:la:wi:s, yo:n tikiliah tikowtsa:la:wiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>Ne: tiktekih, tiktapa:nah ke:meh kwali ki..., tikitaskeh *que** te:chpale:wi:s.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>Wa:n se: kixi:ma tepitsi:n, mahyá:, mahyá: te:neh moka:wa ne:n kowit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
                <ANNOTATION_VALUE>wa:n ke:mah se: kit..., se: kiteki se: kowit ya se:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
                <ANNOTATION_VALUE>mahyá: se: tahmolotsi:n wa:n se: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>ika se: kiteki no: se: kitila:na, komo ika se: ima:y a:mo weli *porque** alaktik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts214" TIME_SLOT_REF2="ts216">
                <ANNOTATION_VALUE>Wa:n se: kitila:na n' kowit, se: kitila:ntiw. Ke:mah, se: kipostektiw n' k..., n' kowe:wat,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts218" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>Wa:n tein se: kitila:na para nika:mpa tein xo:no:t wa:n ne:pa ki:stiw tein, tein e:wat kakaltik wetstiw ne:wí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts223">
                <ANNOTATION_VALUE>Se: kitila:na para nika:mpa wa:n yo:n se: kite:ntia n' kowitpara se: kitila:ntiá:s tsi..., ihkó:n, 'nal..., se: kitila:ntiw ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts224" TIME_SLOT_REF2="ts226">
                <ANNOTATION_VALUE>Wa:n, nejó:n, ki:stiw ne:wí:n tein, tein kwowe:wat a,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>wa:n t'tila:na wa:n t'tila:na, ke:mah tepits..., tek..., tami ki:sa ya, ki..., tami ki:sa ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>tein kwaltsi:n ehke:wi t'tila:na wa:n kopi:ntiki:sa *hasta** ne: kalakiti ne:n kowe:wat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>Ke:mah, t'tetekwinowa mo..., moxo:no:w *o, o de una vez** tik..., tiktahta:lis se: wa:n, *primero** tiktamichipa:wa wa:n ke:mah tik..., t'tetekwinowa ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>wa:n tik..., tika:..., tika:te:mati *o** tika:pacho:ti a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
                <ANNOTATION_VALUE>Wa:n neh ka:mpa nika:pachowa xo:no:tsí:n nik..., koma:mo n'ta:lilia iswat tatampa nik..., *mejor nicostalketsa**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>Pero nikaxalte:ma no:, nikaxalte:ma, a:mo, a:mo nik..., a:mo niktetekwinowa ihkó:n, nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
                <ANNOTATION_VALUE>nikxiti:nia niktetekwinoh para nikwi:ka wa:n ke:mah nikaxa:lte:ma ya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
                <ANNOTATION_VALUE>wa:n mah kaxaltik para,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts244">
                <ANNOTATION_VALUE>para kwaltsi:n xokoya. Wa:n neh nika:pachowa nikte:mpilowa itech se:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>teihsá: itech kwowit ika *lazo o** kwomekat *porque** ke:masá: wi:tsa n' a:t we:ia wa:n 'kwitiki:sa, kwi:ka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts248" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>Wa:n para a:mo yo:n pos neh nik..., *nikbo:lsahketsa** wa:n nikte:mpilowa ika kwomekat,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
                <ANNOTATION_VALUE>wa:n kichi:wa se: *veinte días para**, nejó:n, nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>niki:xti:ti a, kwaltsi:n xokoya no: xo:no:tsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
                <ANNOTATION_VALUE>Wa:n nikpa:ka, a:mo moneki *cloro** kita:lili:skeh, kwaltsi:n pochiktsí:n ki:sa wa:n yehyemaxtik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>Ke:mah, pero neli mah, mah no: se: kapacho ka:mpa yo:n m..., eh..., ka:mpa yo:n kimá: to:nal ne:n a:t, ka:mpa yekawilah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
                <ANNOTATION_VALUE>A:mo ye:kxokoya niman *porque** ne: a:mo kawa:ni n' a:tsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts262" TIME_SLOT_REF2="ts264">
                <ANNOTATION_VALUE>Yehwa yo:n nikmattok. A:mo, moneki se: pa..., se: kia:pacho ka:mpa yo:n tepitsi:n to:na.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
                <ANNOTATION_VALUE>Para kwaltsi:n, ye:kkwaltsi:n xokoya. Iwki nikchi:wa neh no: wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
                <ANNOTATION_VALUE>niki:xtia kwah..., kwaltsi:n xo:no:t no: ke:masá:, pero neh nikita seki kinamakah ihkó:n xo:no:tsí:n 'ki:xtiah pero a:mo wel kiki:xtiah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
                <ANNOTATION_VALUE>no:, nió:n no: wel kikowtsa:la:wiah *porque** ye:kkahkakaltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>Wa:n, wa:n a:mo ki:sa de n' i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
                <ANNOTATION_VALUE>ne:n, icho:kilo *o** ne:n ialakyo ne:n xo:no:t *porque** a:mo xokoya *por eso**, wa:n iwki kipa:kah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>*con tal** kinamakaskeh n' tokni:wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>ki..., kwa:tstiwetsih ma:ski de wa:ki a kahkakaltia ya, pero yo:n kahkakaltik *porque** alakyoh, a:mo xokoyak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
                <ANNOTATION_VALUE>Wa:n a:mo teh ki..., a:mo kipale:wi:s *con que** tikta:lili:s *cloro**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
                <ANNOTATION_VALUE>a:mo kiyema:ni:s nió:n kipochi:nalti:s, a:mo kit..., a:mo ki..., a:mo kipale:wia n' *cloro** se: kita:lilia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
                <ANNOTATION_VALUE>ma:ski ka:nachi t'tete:kili:s, tik..., tikte:kili:s, tika:pacho:s ika *cloro** wa:n i:pa a:mo ki:sa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts286" TIME_SLOT_REF2="ts288">
                <ANNOTATION_VALUE>*porque**, nejó:n, de a:mo xokoya, de a:mo xokoya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
                <ANNOTATION_VALUE>*Cuando** xokoya a:mo moneki t'te:kili:s miak *cloro**, ika tepitsi:n wa:n pochi:niak ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>Ke:mah, neh nikpa:kani ihkó:n xo:..., xo:no:t, nika:pachowa:ni, a:mo ke:man n'te:kilia *cloro**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
                <ANNOTATION_VALUE>sanoke iwki sah wa:n ye:kkwaltsi:n ki:sa xo:no:t pochiktsí:n. Wa:n yemaxtik ki:sa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
                <ANNOTATION_VALUE>Ke:mah, pero seki nikita *que** a:mo wel 'kowtsa:la:wiah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
                <ANNOTATION_VALUE>pos iwki ne:, iwki 'ki:xtiah, kipa:kah ke:meh weli wa:n a:mo ye:k..., pos de, de wa:ki, wa:ki a pero kakaltia fie:roh ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
                <ANNOTATION_VALUE>Ke:mah, kakaltia. Wa:n de [ko]mo se: kipa:ktok alaki:sa wa:n alakki:sa wa:n a:mo ki:sa *porque** a:mo xokoya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
                <ANNOTATION_VALUE>Iwki kwa:tsah wa:n iwki se: 'kowa iwki te:namaki:ltiah ma:ski kahkakaltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts304" TIME_SLOT_REF2="ts306">
                <ANNOTATION_VALUE>Ihkó:n a:mo, a:mo, a:mo kwali ki:sa xo:no:t. A:mo, tein a:mo wel kehke:wah. Nikita ma:ski pihpitsaktik xo:no:tsí:n, xo:nokowtsitsí:n kehke:wah ihkwí:n pipih..., pa:pata:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
                <ANNOTATION_VALUE>Ka:n alakki:sa, ta: pos iwki 'kwitih wa:n ki..., ki..., kwa:tsatih wa:n ke:meh weli kinamakah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
                <ANNOTATION_VALUE>Wa:n moneki mah se: kichipa:wa kwaltsi:n para tokni:wa:n a:mo se: kinkaya:wa no:</ANNOTATION_VALUE>
