    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>A quieres saber al habernos encontrado en este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>en el camino o en el bosque y este lo..., vamos a buscar el jonote o vamos a ver cuál se le puede extraer la fibra, cuál es el que yo conozco también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>Pues yo también conozco el árbol de jonote, hay uno de color rojo y hay otro que es de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>El que es de color blanco son dos tipos, uno se le puede extraer la fibra y el otro tipo que no se puede desprender, se revienta en pedazos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Se le extrae, se le extrae así pero se va reventando y no se puede usar.      </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>Y el otro tipo que es blanco sale la fibra fácilmente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Es igual el de color rojo que también se le extraer sólo que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>se le..., se le extrae</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>y se le..., se parte el tronco a la mitad para hacerle una apertura, enseguida se mete  la corteza y se jala con fuerza para separar la fibra con la corteza y se...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Pues el de color rojo se le extrae la corteza y también sale de color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Ese es otro, otro tipo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>El de color rojo es todo rojo hasta su..., el tallo, a veces hasta este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>la madera que se corta también es rojo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Las semillas hasta arriba las hojas tiernas, todas sus ramas, las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>las semillas que se cuelgan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Pues también son de color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Y algunos se les extrae este el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>se revienta la fibra y otros que se pueden usar el jonote, sólo que la fibra sale de color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Por eso le llaman jonote rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Y el jonote blanco, algunos se le..., se les extrae la corteza que  también sale de color blanco hasta el tallo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>y este el jonote sale con un color blanco bonito y arriba pues todas las este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>hojas tiernas son de color blanco. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>El otro tipo de  árbol también se ve bonito pero la fibra se revienta mucho. También es de color blanco pero ese tampoco sirve</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Y el jonote que se..., se..., se extrae, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>se parte el tronco a la mitad para hacerle una apertura, enseguida ahí se mete  la corteza y se jala con fuerza para que salga la fibra por cachitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Al hacer eso hasta la fibra que se saca, sale muy blandita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Pero si se..., se mete la corteza completa y se jala hasta la punta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>la fibra sale muy dura.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Lo que se hace es ir cortando la corteza por cachitos así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>por pedacitos y se..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>se van tirando por ahí la corteza y la fibra sale en tiras largas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Después se doblan y se van acomodando por ahí, sólo que cuando está fresca es muy resbalosa por la baba. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Y es igual el de color blanco, se extrae de la misma forma,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>se mete  la corteza y se jala con fuerza para que salga la fibra, a veces salen en tiras largas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>También se va cortando en pedazos, también se puede si uno ve que este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>el palo..., este el tronco del árbol que se le extrae, también hay que saber partirlo a la mitad,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>toda debe ser angosta la apertura para ir jalando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>y para salga la fibra de calidad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a91">
