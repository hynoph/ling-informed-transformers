        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Muchas gracias y nada más dime tu nombre y de dónde vienes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
