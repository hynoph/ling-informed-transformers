        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts137">
                <ANNOTATION_VALUE>Mah a:mo se: kinehnepano, mah se: kito:tohtoma wa:n mah se: kipante:ma sah.</ANNOTATION_VALUE>
