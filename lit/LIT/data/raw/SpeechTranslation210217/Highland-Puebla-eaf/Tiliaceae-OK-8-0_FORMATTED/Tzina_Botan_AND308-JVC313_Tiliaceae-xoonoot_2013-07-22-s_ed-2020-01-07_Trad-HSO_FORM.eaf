        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>El jonote, si se sumerge en el agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a99">
