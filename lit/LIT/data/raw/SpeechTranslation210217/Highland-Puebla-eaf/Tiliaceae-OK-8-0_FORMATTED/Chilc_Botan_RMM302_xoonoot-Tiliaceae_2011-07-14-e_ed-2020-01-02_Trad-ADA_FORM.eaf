                <ANNOTATION_VALUE>ese, tiene las hojas redondas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>y son lisas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>y ese, este, el tronco, su semi..., la flor también, es diferente y su semilla, su semilla, ese da semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>El &lt;i&gt;tepe:xo:no:t&lt;/i&gt; da semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Y el &lt;i&gt;xo:no:kowit&lt;/i&gt; se ..., quizá ...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>También da semillas pero ese parece al</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>como decirlo, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>como la semilla del &lt;i&gt;kwaokwilkowit&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>el polen se esparece.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Y el otro que te digo, el &lt;i&gt;tepe:xo:no:t&lt;/i&gt;, ese no se cae el polen, ese, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>ese florece y ahí mismo sale la semilla.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Como si fueran unas bolitas, es ese el fruto que da.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Sí. Ese es diferente</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Este, la flor, así como vez el,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>cómo se llama, este, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>del que platicábamos hace dias, el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; pero la fibra es parecido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Es ahí, también salen en la superficie como si fueran ramas, ramas, sobre ...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>sus ramas, ¿Cómo decirlo? Sus ramitas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>ahí salen las flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Y cuando ya salen las semillas pues ya se caen las flores, la flor es blanca y se cae la flor,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Entonces ahí sale la semilla.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Su semilla se parece mucho a la semilla del &lt;itskwinpahwits&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Sí. Unos son un poco alargados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>La semilla del árbol que le llaman &lt;i&gt;tepe:xo:no:t&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Pues el &lt;i&gt;xo:no:kowit&lt;/i&gt; se puede usar como leña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Y también sirve como muros de una casa, pues donde decimos, pues donde no nos acompletamos  para comprar las tablas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>pues unos lo cortan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>y se parte y se le quita la corteza y con ellos se ponen los muros de la casa, también sirve para,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>nosotros decimos &lt;i&gt;xo:no:tatsakwil&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Y también se usa para leña, sólo que la lumbre no es tan fuerte, nosotros decimos, solamente sale para ceniza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>También, también arde bonito, cuando no hay leña pues con ello se puede hacer la leña, con ellos se puede hervir lo que comemos pero te digo que no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>digamos que no dura mucho tiempo (quemándose) porque arde muy rápido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>También arde muy rápido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>También el &lt;i&gt;chi:chi:lxo:no:kowit&lt;/i&gt;, también, ese es parecedo como el otro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>El tronco es un poco más resistente, si, el &lt;i&gt;tepe:xo:no:kowit&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>El &lt;i&gt;tepe:xo:no:kowit&lt;/i&gt; el tronco puede servir hasta para costruir una casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>¿Porqué? Porque el tronco es más resistente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Para leña, pues la lumbre es un poco más fuerte.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Y sirve hasta para el ..., digamos nosotros pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>usar para alfardas, o, o, para (construir) nuestra casa pues.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Entonces, ese jonote también sirve porque es más resistente el arbolito. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Ese le llaman &lt;i&gt;tepe:xo:no:kowit&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Hay bastante allá por San Miguel, más allá, allá por el monte.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Hay bastabte de ese árbol. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
