        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts227">
                <ANNOTATION_VALUE>se: tachihchi:wa. Ke:meh ekintsi:n wahkaltsitsí:n *o** teihsá: *cositas** se: kichi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>Se: tahtalpia yo:n semi *servi:rowa**, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts233">
                <ANNOTATION_VALUE>xo:no:tsi:n. Ke:mah pero yehwa, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts237">
                <ANNOTATION_VALUE>pos no: kwaltia n' chi:chi:lxo:no:t, no: kwaltia pero a:mo nochi, kohkoto:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts243">
                <ANNOTATION_VALUE>A:mo *igual**. Wa:n yo:n semi se: ka:ta:lia wa:n a:mo okachi kineki ki:s..., ki:sas n' alaktik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts247">
                <ANNOTATION_VALUE>Uhuh. Se: ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts251">
                <ANNOTATION_VALUE>Chi:chi:ltik *porque** i:pa ihkó:n, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts255">
                <ANNOTATION_VALUE>i:pa iwki, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>n' oksé:, n' oksé: taman ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts263">
                <ANNOTATION_VALUE>Ke:mah yehwa yo:n, ne:n, .... ¿Yehwa sah? *Compadrito** nik..., *compadrito**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts293">
                <ANNOTATION_VALUE>Mm, pos ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
                <ANNOTATION_VALUE>Pos, nijó:n, e:yi taman *de que** tiki:xmati *compadrito**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
                <ANNOTATION_VALUE>Nehwa niki:xmati na:wi taman *porque** yo:n nimitsilihtok oksé: xo:no:t ihkó:n achi pohpolokotik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
                <ANNOTATION_VALUE>Ahko, nijó:n, yowi ihkó:n wehkapania wa:n ahko mochi:wa, ne:n, *iramas** [mo]ma:ma:yo:tia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
                <ANNOTATION_VALUE>pero yo:n a:mo kwaltia. Yo:n i..., tsikitsitsi:n se: [ih]kó:n se: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
                <ANNOTATION_VALUE>kehke:wa kokotokatiw ihkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
                <ANNOTATION_VALUE>*Igual** ke:meh yo:n ne:n chi:chilxo:no:t no: *igualito**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n ahko ne: mochi:wa ya, nimitsilihtok pané:, kwaltsi:n pané: kipia *coronitas**, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
                <ANNOTATION_VALUE>ne:n, ixo:chio.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
                <ANNOTATION_VALUE>Yehwa ya kwi:kah ne:n chechelo:meh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts373">
                <ANNOTATION_VALUE>Kwi:kah para ne: ki[tatekiw]tia[h], wa:n yo:n okseki yo:n chi:chi:lxo:no:t,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
                <ANNOTATION_VALUE>yo:n mochi:wa [ih]kó:n ohololtik ne:n xo:chitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
                <ANNOTATION_VALUE>Ohololtik. Chihchi:chi:ltik ohololtik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
                <ANNOTATION_VALUE>Wa:n yo:n no:, no:, no: kwi:kah n' chechelo:meh, pero *más** kwelitah n' okseki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>Kwi:kah. A: pos tikmattok no: kwali *compadrito**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts385">
                <ANNOTATION_VALUE>Itech ka:mpa, ne:n, intapahsol ompa kita:liah, ompa tate:noh kite:mah n' ihkó:n imo:n..., se: *bola de n', de** n',</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts389">
                <ANNOTATION_VALUE>yehwa ya de n' xo:chit de n' tahsol. Wa:n yehwa yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
                <ANNOTATION_VALUE>ne:n chi:chi:lxo:no:t pos no: se: kehke:wa,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts395">
                <ANNOTATION_VALUE>pero ihkó:n de weyakaxtik wa:n koto:ni a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts399">
                <ANNOTATION_VALUE>Koto:ni a. Wa:n de n', de n' ista:k,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
