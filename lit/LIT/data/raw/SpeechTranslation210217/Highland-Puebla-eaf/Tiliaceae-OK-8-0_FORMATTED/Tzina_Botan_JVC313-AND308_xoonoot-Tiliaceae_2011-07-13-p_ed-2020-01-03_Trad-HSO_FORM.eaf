        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts48" TIME_SLOT_REF2="ts51">
                <ANNOTATION_VALUE>{O quizá quiso decir itsi:ntsakwil.}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts57">
                <ANNOTATION_VALUE>{Esta expresión es muy rara, lo más lógico sería "para se: kikehkechilia n' kali mah motsi:ntsakwa"}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Pues yo conozco compadrito, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>el, &lt;i&gt;chi:chi:lxo:no:t&lt;/i&gt;, &lt;i&gt;ista:k xo:no:t&lt;/i&gt; y el &lt;i&gt;tepe:xo:no:t&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Porque este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Cuatro tipos. Así  es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>El primero es el que tiene hojas pequeñas y al pie del tronco tiene varios nudos y pues ese no se puede usar para hacer algo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Se revienta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Y el segundo es el &lt;i&gt;ista:k xo:no:t&lt;/i&gt; que se se puede usar, este se le extrae la corteza, se mete en un tronco partido a la mitad, se jala con fuerza para separar la corteza con la fibra que es el jonote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>sale muy bien el jonote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>se puede usar para amarrar los palos en una cerca, esos son delgaditos y son cortos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Este sa..., sale junto con la corteza,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>y no se sumerge en el agua. Asì se usa para amarrar los palos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Y el &lt;i&gt;tepe:xo:no:t&lt;/i&gt; que es un árbol grande,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>ese no sirve, se usa pero solamente se parte el tronco para usar la madera en una cerca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Para ponerlos en forma vertical en las paredes de la casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Ese se puede partir el trozo, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>o bien lo cortan para sacar tablitas así. Porque algunos crecen grandes los árboles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Y sus frutos son así huecos, son redondos así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>y sus flores son de color morado. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Son moraditas y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>se dan en las puntas de las ramas así, en las ramas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>así son, se encuentran las ramas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Entonces desde el suelo se ven que algunas semillas se secan ahí arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Ya se caen al suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Y el &lt;i&gt;chi:chi:lxo:no:t&lt;/i&gt; se puede usar una parte.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>pero no todo, se revienta. El &lt;i&gt;chi:chi:lxo:no:t&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>El &lt;i&gt;chi:chi:lxo:no:t&lt;/i&gt; este, es bonito tiene así como si fuera este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>su..., sus semillas como si fueran moscas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Se dan así como si tuvieran coronita por aquí,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>y se ven así como con un color gris las flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Las ardillas a veces cortan las semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>se alimentan de esas y a veces las llevan a donde tienen su nido</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Pues las ardillas les gusta mucho alimentarse de las semillas, creo que las pelan y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>a donde se encuentra su nido,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>ahí se las llevan, a veces a la orilla o agunos pájaros también se alimentan de esas semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Eso es lo que yo co..., conozco compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Cortan las ramas delgadas y se las llevan ahí para hacer su nido. Y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>porque el otro tipo de jonote que ya no sirve,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>porque se tumba así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>y a veces retoña, retoña así pero de todos modos ya no sirve.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Lo..., quie..., ya se quiebra. Tiene varios nudos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Y el que sale bonito el jonote, el &lt;i&gt;ista:k xo:no:t&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>se saca así  en pedacitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>y salen las tiras de jonote muy bonitas y anchas. Es blanco el jonote, muy limpio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Ese se puede torcer así  muy bien, se tuerce y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>es bonito, después se estira y queda dura.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>No se revienta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Eso es lo que yo conozco compadrito, que ese jonote,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>sir..., sirve de mucho para hacer huacales o para amarrar algo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Allá..., allá en el bosque uno ve los árboles de jonote que son así pequeños y son rectos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Eso es lo que yo conozco que pues el &lt;i&gt;tepe:xo:no:t&lt;/i&gt; también se puede usar la corteza para amarrar palos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Y los árboles crecen grandes así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>y eso es lo que hacen otras personas, parten los trozos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>O se parten con machete los trozos delgados, también se pueden partir y se paran los palos para cerrar paredes de la casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>Para cerrar las paredes de la casa, o bien se le saca la corteza,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>y se usa la corteza para am..., am..., amarrar los palos. Se amarran así los palos, se le saca así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>se parten las cintas así en forma vertical.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Sí. Pues ese también se puede usar todo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>Eso es lo que yo sé, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>Sí y también puedes platicarme compadrito de que,. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>usted ta..., tal vez sabe más</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Sí y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>ese es el primero que.... No y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>pues es.... Es muy delgada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>Y el jonote blanco &lt;i&gt;ista:k xo:no:t&lt;/i&gt; pues ese se..., mete en el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Se sumerge en el agua, por debajo uno pone algunas hojas de planta y se coloca encima, luego</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>se le pone un palo pues se..., se fermenta rápidamente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a443" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>Después de que se fermenta se lava bonito, así  se hace, ya se va todo el agua, ya sale la baba, queda muy blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a448" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>Entonces ya se tienden las cintas para que se sequen y ya se usa para este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a449" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>hacer artesanías. Como actualmente se hacen huacales o se hacen otras cositas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Para amarrar, ese jonote sirve mucho, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a206">
                <ANNOTATION_VALUE>el jonotito. Sí eso es pero este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>pues también sirve el &lt;i&gt;chi:chi:lxo:no:t&lt;/i&gt;, también sirve pero no todo, se revienta.    </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a455" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>No es igual. Y ese se sumerge en el agua pero no puede sa..., salir la baba resbalosa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a456" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>Uhuh. Se: ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Es rojo porque siempre ha sido este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>siempre ha sido este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>ya es de otro tipo diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>Sí eso es, este, .... ¿Es todo? Compadrito lo..., compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Mm, pues ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>Pues tres tipos conoce usted compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a495" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>Yo conozco cuatro tipos porque como te platicaba que un &lt;i&gt;xo:no:t&lt;/i&gt; es el que tiene algunos nudos el tronco. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a515" ANNOTATION_REF="a269">
                <ANNOTATION_VALUE>Crece así hacia arriba y salen las ramas, crecen sus ramas así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a516" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>pero ese no sirve. Esos son pequeños su..., así se..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a517" ANNOTATION_REF="a271">
                <ANNOTATION_VALUE>le extrae la corteza así se va reventando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a518" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>Es igual como el &lt;i&gt;chi:chilxo:no:t &lt;/i&gt;, es igualito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a519" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>Y ese el que se da arriba del que te platico, son como unas coronitas las,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a520" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a521" ANNOTATION_REF="a275">
