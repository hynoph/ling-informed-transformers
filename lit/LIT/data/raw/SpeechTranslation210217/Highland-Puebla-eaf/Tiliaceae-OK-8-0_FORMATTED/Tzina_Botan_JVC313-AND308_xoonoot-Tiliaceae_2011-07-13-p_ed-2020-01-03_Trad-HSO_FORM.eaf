        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts447">
                <ANNOTATION_VALUE>A:mo, de n' tohtoma:wak yehwa yo:n kikwih para teihsá: [i]hkó:n de ti..., kitahtapa:nah wapaltsitsí:n oso</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
