        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
                <ANNOTATION_VALUE>Wa:n, pero yo:n a:mo kwaltia, ihkwí:n tsikitsitsi:n ne:n kohkoto:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
                <ANNOTATION_VALUE>Se:..., k..., ihkó:n se: ki..., kohkoto:ni niman.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n ke:meh ne:n tepe:xo:no:t pos yo:n i:pa a:mo,</ANNOTATION_VALUE>
