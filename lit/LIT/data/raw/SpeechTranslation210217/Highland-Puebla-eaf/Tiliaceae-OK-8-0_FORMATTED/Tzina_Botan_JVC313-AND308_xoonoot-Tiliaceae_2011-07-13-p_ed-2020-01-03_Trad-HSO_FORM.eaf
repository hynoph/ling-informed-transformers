                <ANNOTATION_VALUE>pos yo:n, nijó:n, ke:meh ne: se: kichi:wa wa:n se: k..., se: kiki:xtia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts407">
