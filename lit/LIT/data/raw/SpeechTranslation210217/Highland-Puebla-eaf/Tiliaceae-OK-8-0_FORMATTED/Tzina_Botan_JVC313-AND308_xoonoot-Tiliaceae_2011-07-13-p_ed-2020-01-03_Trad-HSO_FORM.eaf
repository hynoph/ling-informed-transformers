        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts439">
                <ANNOTATION_VALUE>a:mo kwaltia. Yo:n kwaltia *solamente** para se: tawi:pa:nas.</ANNOTATION_VALUE>
