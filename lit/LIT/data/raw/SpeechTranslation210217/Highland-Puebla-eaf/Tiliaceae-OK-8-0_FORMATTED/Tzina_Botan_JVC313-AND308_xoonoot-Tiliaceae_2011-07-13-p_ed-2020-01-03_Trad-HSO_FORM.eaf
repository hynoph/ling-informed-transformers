        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts205">
                <ANNOTATION_VALUE>yehwa yo:n se: k... A:mo wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts209">
                <ANNOTATION_VALUE>pos nij.... Kana:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>Wa:n yo:n xo:no:t de n' ista:k xo:no:t pos se: ki..., ka:ta:lia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>Se: ka:ta:lia, tata:mpa se: kita:lia teihsá: xiwit wa:n paniá:n ya se: kita:lia wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts217">
                <ANNOTATION_VALUE>se: kowtsí:n se: kita:lia, ne:n..., ne:nke:n xokoya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts221">
                <ANNOTATION_VALUE>De: xokoya pos se: kipa:ka, kwaltsi:n ihkó:n se: kichi:wa ya, nochi yowi ne:n a:t ya, ki:sa ya, kwaltsi:n moka:wa pochiktik ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>Ke:mah se: kipihpilowa ya wa:n se: kikwi a para, ne:n,</ANNOTATION_VALUE>
