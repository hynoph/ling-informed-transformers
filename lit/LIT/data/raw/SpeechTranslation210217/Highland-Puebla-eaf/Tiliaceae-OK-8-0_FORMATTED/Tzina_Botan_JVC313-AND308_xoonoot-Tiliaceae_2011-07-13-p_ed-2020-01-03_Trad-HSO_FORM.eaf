        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>Ke:mah wa:n no: kwali tine:chili:s *compadrito de que**,</ANNOTATION_VALUE>
