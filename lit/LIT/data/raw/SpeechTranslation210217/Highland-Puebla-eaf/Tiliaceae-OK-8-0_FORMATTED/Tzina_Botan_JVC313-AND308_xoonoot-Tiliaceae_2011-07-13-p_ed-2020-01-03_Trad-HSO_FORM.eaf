            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts201">
                <ANNOTATION_VALUE>Ke:mah wa:n,</ANNOTATION_VALUE>
