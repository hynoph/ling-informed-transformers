                <ANNOTATION_VALUE>Ese le llaman pitsa:xiwit y se extiende sobre el suelo, no crece alto. Se extiende sobre el suelo y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
