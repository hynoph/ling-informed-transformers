        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Ahí se pegan en las hojas de la milpa, en las hojas de la milpa.</ANNOTATION_VALUE>
