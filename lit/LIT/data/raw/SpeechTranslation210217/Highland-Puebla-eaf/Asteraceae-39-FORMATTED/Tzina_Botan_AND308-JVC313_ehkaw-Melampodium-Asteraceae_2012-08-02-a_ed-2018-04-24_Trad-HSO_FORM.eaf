        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Sí y es cierto que si uno se les da de comer a los animales como a las gallinas se comen las hojas.</ANNOTATION_VALUE>
