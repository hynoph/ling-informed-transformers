        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Dices que es medicinal, este nos dicen y de veras a veces hacemos la prueba cuando nos pica el borreguillo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
