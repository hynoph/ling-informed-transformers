        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
                <ANNOTATION_VALUE>Pos neh a:mo:, a:mo no: teh nikmati ok yehwa sah *de** n', *de** nimitsilih.</ANNOTATION_VALUE>
