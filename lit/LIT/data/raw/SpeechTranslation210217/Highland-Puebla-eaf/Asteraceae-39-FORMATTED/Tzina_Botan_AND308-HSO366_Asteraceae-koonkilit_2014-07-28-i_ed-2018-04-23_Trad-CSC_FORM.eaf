        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts187">
                <ANNOTATION_VALUE>Wa:n nimitsilwia neh n' mattok mahyá ki..., kipata:naltia ehekat neli wa:n kwi:ka wa:n para ixwa ya.</ANNOTATION_VALUE>
