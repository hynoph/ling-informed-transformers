        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>Pos nejó:n, komamo teh *más** tine:chnohno:tsas *de** yo:ni nejó:n, *o** taka..., *o** ta:ká:n teisá: tikelna:miki ok.</ANNOTATION_VALUE>
