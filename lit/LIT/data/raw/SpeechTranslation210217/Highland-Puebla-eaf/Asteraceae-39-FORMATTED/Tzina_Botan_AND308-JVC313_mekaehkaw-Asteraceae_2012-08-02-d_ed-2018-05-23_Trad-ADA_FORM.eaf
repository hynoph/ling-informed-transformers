        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>Ke:mah, yehwa yo:n nochi ti..., pos no: kwaltsi:n nika:n ti..., timotapowiah.</ANNOTATION_VALUE>
