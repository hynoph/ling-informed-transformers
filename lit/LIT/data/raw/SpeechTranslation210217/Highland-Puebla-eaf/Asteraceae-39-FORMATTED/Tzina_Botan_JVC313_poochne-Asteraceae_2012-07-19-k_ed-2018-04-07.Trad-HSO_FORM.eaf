        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>pexo:ntok n' iyo:lo. Wa:n *cuando** wa:ki</ANNOTATION_VALUE>
