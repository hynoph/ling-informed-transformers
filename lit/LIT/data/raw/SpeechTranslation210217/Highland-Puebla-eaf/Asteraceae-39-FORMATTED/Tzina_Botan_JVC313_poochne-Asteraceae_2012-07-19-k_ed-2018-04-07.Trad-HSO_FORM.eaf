        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>pos ehehke:wi n' ipanko, kwali se: ki:xtapa:na, ki:sa n' i..., ipane:wayo,</ANNOTATION_VALUE>
