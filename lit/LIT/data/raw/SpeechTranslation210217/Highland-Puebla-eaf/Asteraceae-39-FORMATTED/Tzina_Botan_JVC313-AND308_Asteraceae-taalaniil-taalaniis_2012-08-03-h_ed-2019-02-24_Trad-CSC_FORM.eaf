        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>A:mo onkak ok *porque** yehwa yo:n poliwik a *porque** kita:lihkeh nochi tet..., tet a kisohso:wkeh ka:mpa s..., ka:mpa onti.</ANNOTATION_VALUE>
