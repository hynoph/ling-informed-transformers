                <ANNOTATION_VALUE>Wa:n ekintsi:n titatame:wah ne: we:ikalte:noh pero a:mo teh nikita ok, ekintsi:n sakat nochi moi:xkwitok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>Xo:chiowa ya, i..., ixo:chionejó:n, ixo:chio ta:la:ni:l ista:k wa:n yo:la:nkohkostik n' iyo:la:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
