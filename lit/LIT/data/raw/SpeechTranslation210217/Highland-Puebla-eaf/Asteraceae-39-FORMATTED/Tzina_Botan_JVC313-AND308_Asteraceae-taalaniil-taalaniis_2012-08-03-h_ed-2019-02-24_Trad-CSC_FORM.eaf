    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="José Ernesto Vázquez Chanico" PARTICIPANT="José Ernesto Vázquez Chanico" TIER_ID="JVC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>A pues ese...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Si, conozco esa hierba, este, le dicen ta:l..., ta:la:ni:l. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Se da en la tierra y donde..., en este pueblo abundaba mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Pero de verás abundaba mucho..., antes nosotros estudiabamos en una escuela</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>y cuando no citaban a nuestros padres para que ellos limparan sino que nosotros limpiábamos en frente del palacio en donde está esa escuela.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Donde, hasta donde era la casa de Nachho López. Todo ahí este.., todo ahí limpiábamos nosotros, habia hierba de xo:no:ochpa:was y también ahí veíamos esa hierba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Ese de..., de hojas chiquitas y..., un poco de hojas alargadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Y, no tiene ramas, sus hoj..., sino que sus hojas se pegan en el tallo principal, ahí salen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>este, las hojas. Y son alargadas y angostas, alarga..., pero no son muy grandes, son largas. no, son chiquitas, chiquitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Y ese crece muy alto como, nada más, muy alto, muy alto como un, como un codo de alto, o menos, son chiquitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>No son muy grandes. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Si..., y este crece como un jeme, como un y medio de alto. Nada más así y así de este tamaño..., asi nada más de grande se da esa plantita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Y lo arrancaba uno..., lo arrancaba uno, nosotros lo dejábamos porque nos decía el que nos enseñaba que lo dejáramos porque lo podian ocupar si es que lo necesitaban para remedio, que abunde.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>En la orilla de la casa de la señora Ramón María ahí donde actualmente está, este, donde ahora está el señor Eulogio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Ese..., le..., ya mejoró esa casa pues sus muros eran de madera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Esa casa, si toda, toda era de madera sus muros de la casita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Ahí en la entrada de la casa todo..., ahora ya..., ya se cambió porque ya hay un muro alrededor, ya es puro losa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Pero nosotros estudiábamos todo en tierra de arena, en la entrada donde era la escuela, todo era arena, no... En una superficie de arena no como ahora que ya arreglaron y ya es de losa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Ya no hay esa hierba, se extinguió porque, había porque ahí todo estaba hierboso, ahí todo limpiábamos nosotros hasta junto a la casa del señor Nacho López finado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Nos..., todo limpiábamos, todo abundaba esa hierba que le llamamos ta:la:ni:l, por eso lo conocía, ahí había.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Pero a lo mejor en algún otro lugar también había, como nosotros los niños limpiábamos allá donde nos enseñabannada más ahí limpiábamos, no limpiábamos en el camino.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Por eso veíamos ese ta:la:ni:l y ahora aunque hubiera pero como todo ya lo..., ya cambiaron todo donde estaba la casita, ya todo le pusieron piedra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Lo arrancaron o lo..., lo escarbaron con esa maquina o con pico para ya poner esa calzada, para que no, no, para ya no chapear frecuentemente y...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Eso si, el camino quedó bien pero las plantas o hierbas que ocupaban para remedio o así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>nada más de ahí lo cortaban y pues ahora no, no, todo quedó de piedra, por eso pienso que se extinguió,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>porque anteriormente abundaba mucho en la..., atras de la iglesia todo abundaba ese ta:la:ni:l.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>El ta:la:ni:l, todo abundaba. Pues ese tiene rico aroma.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Tiene rico aroma, lo veo, no sabía si lo ocupaban para reme..., para remedio pero escuchábamos que..., que lo ocupaban los panaderos, lo..., lo buscaban.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Le ponian unos panes que luego preparan que son muy ricos en aroma, esos que son chuecos y rasposos encima, tienen un rico aroma como el a:ni:l. Si eso es aromatico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
