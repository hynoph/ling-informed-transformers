        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>Ompa kalte:noh katka nochi i..., ekintsi:n ta..., mopatak a *porque** nochi tepa:mit tayewalohtok, tei:xko nochi a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>Pero tehwa:n timomachtia:yah nochi texa:li:xko, yo:n kalte:noh ka:mpa kalnemachti:lo:ya:n katka, nochi katka texa:l, a:mo .... Texa:li:xko a:mo tei:xko ke:meh ekintsi:n tachihchi:wkeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>A:mo onkak ok yo:n xiwit, poliwik *porque** onkaya *porque** nochi katka xiwtah ompa nochi titame:wayah tehwa:n ne:n *hasta** i:n Nacho Lópezko kalte:noh katka.</ANNOTATION_VALUE>
