        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts140" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Ke:meh, ke:meh yo:n *manzanilla**, yo:n ne: ahkokopa kinamakah, iwki a ne: xo:chitsi:n, ke:meh *manzanilla**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
