        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>Yehwa:n ya ne:n kinohchi:wihkeh kwali para ne:nke:n tsi:tsikwi:niskeh pero, pero tein yo:n ke:meh pahxiwmeh, ke:meh poliw ixiwyo tikihtkeh wa:n ke:meh yehwa ta:la:ni:l a:mo onkak ok.</ANNOTATION_VALUE>
