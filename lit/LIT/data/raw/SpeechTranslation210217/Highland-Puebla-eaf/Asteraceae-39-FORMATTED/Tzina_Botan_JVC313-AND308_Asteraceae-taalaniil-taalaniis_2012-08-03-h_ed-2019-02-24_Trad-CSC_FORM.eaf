        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a129" TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>Ke..., wa:n nejó:n ke:meh se: *geme** mochi:wa, se: ke:meh wa:n tahko talwehkapan. Ihkwí:n sah wa:n sepa ihkwí:n sah ki..., iwki sah wehkapan mochi:wa ne:n kowtsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>Wa:n se:, se: kwiwit..., se: kwiwitaya, no: tehwa:n tika:wtia:yah *porque** te:chilia:ya a:kin te:chmachtia:ya mah tika:waka:n *porque** kikwiskeh para ta:ká:n kikwih para pahti, mah onka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>Ikalte:noh katka Ramón María na:nahtsi:n yo:n ne: ka:mpa n' ekintsi:n yetok, ne:n, ka:mpa yetok ekintsi:n [Eu]logio, ta:tahtsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>Yo:n ta..., kiye:k..., kiye:kchi:wak a yo:n kali ta: katka ne: de wapal itsi:ntsakka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>Yo:n kali, ke:mah nochi, nochi wapal katka n' itsi:ntsakka kaltsi:n.</ANNOTATION_VALUE>
