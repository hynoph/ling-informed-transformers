        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>Yo:n ma:..., ma:pisi:ltik wa:n ma:..., tepitsi:n ma:we:weyak.</ANNOTATION_VALUE>
