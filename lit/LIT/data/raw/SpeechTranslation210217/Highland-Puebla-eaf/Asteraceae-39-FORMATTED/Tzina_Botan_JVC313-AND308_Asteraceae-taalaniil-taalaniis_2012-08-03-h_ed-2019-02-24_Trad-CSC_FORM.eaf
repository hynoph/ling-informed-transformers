                <ANNOTATION_VALUE>ne:n, xiwit. Wa:n ma:pitsakweyak, ma:pitsak..., pero a:mo wehwei semi, we:weyak. Kanah pisi:ltik, pisi:ltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a126" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>Wa:n yo:n moskaltia semi wehkapan ke:meh, sayoh, telwehkapan, telwehkapan ke:meh se:, se: mo:lik telwehkapan, *menos** tskitistsi:n.</ANNOTATION_VALUE>
