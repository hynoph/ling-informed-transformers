        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>Timo..., nochi titame:wayah, nochi onkaya yo:n xiwit tikilia:h ta:la:ni:l, ika niki:xmattoya, ompa onkaya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts61">
                <ANNOTATION_VALUE>Pero ka:sá: ika tak no: onkaya, ke:meh tehwa:n titame:wayah sah tipi:piltsitsi:n ne: ka:mpa te:chmachtia:yah sah ompa titame:wahtehwa:n, a:mo ta..., a:mo 'tame:wayah ohti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>Ika tikitayah yo:n ta:la:ni:l wa:n ekintsi:n tak ma:ski onkaskia pero ke:meh i:n nochi ki..., kipatakeh ya, ka:mpa katka ta:ltsi:n sah nochi kita:lilihkeh tet ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts66" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>Kwiwitakeh *o** ki..., kichkwakeh ika yo:n tepos oso ika *pico** kichkwakeh para kita:lihkeh *calzada** ya, para a:mo, a:mo, para a:mo se: tame:was ok achi:chika wa:n ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
