        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts116" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>Iwki kichi:waya a:kin te:chmachtia:ya. Pos pané: ka:n ke:man nikita ok, nimitsilia poliwi ke:meh i:n tawehwelohkeh nochi ne:n tokni:wa:n wa:n tekiwa:nih kinemiliah mah nochi tei:xko ya ne:n ohti</ANNOTATION_VALUE>
