            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>Si es que lo ocupan para remedio (mejor) que abunde, porque la flor es muy aromática, que abunde.</ANNOTATION_VALUE>
