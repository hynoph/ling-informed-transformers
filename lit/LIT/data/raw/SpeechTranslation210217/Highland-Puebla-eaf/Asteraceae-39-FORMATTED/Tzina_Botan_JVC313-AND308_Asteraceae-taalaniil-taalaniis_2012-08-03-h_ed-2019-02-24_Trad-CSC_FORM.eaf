                <ANNOTATION_VALUE>Yeh ke:mah kwaltsi:n moka:wa ohti pero n' tato:kmeh *o** xiwmeh tein para pahti kikwiah *o** teisá: ihkó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
