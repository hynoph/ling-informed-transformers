            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Eso le ponían..., rico en aroma de esa hierba. Nada más era especifico a los que les ponían, nada más era específico, no a todos les ponían.  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a160">
