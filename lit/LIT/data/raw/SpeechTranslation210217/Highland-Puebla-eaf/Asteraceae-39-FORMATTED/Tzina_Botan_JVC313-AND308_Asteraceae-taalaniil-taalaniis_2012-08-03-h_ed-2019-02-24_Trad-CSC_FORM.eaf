        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>A:mo katka nexi:kol, a:mo katka te:chnawatih, "X'wiwitaka:n i:n, mah poliwi a". A:mo.</ANNOTATION_VALUE>
