        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>Wa:n, a:mo teh ima:kowyo, ima:y..., ima:xiwyo sanoke itech ikowyo mopepechowa:ya sah,kihki:sa,</ANNOTATION_VALUE>
