                <ANNOTATION_VALUE>wa:n ihwa:k a:mo kinino:tsayah tota:tahwa:n mah tame:waka:n sanoke tehwa:n titame:wayah ne: *palacio** kalte:noh ka:mpa yo:n *escuela**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a121" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>Ka:mpa, *hasta** ka:mpa Nacho López katka ikalte:noh. Nochi ompa tiwa:l..., nochi tima:tame:wayah tehwa:n, xo:no:ochpa:wa:syoh wa:n ompa tikitayah onkak yo:n xiwit.</ANNOTATION_VALUE>
