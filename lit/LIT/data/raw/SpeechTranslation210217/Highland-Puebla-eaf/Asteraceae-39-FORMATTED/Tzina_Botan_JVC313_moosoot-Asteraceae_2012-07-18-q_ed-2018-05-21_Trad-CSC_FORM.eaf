        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>Yehwa ika se: kimati *que** no: t..., no: taman, mo:so:t pero no: taman yo:ni.</ANNOTATION_VALUE>
