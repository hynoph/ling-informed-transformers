        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>Yehwa yo:n niki:xmattok wa:n i:n, i:n kwomo:so:t,</ANNOTATION_VALUE>
