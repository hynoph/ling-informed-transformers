        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>chika:waya, wa:ki, pampi:xowi n' xo:chit wa:n moka:wa ne:n iteyo ya,</ANNOTATION_VALUE>
