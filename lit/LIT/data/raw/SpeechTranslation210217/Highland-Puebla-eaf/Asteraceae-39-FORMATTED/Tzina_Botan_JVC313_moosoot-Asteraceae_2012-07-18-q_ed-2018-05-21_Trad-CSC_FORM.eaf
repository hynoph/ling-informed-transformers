            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>Pos ne:n mo:so:t, mo:so:t tein mi:lahmo:so:t,</ANNOTATION_VALUE>
