        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>Pos komohkó:n se: kinkwi:li:ti, ne:n, ehkaw ne:, ne: mi:lah mochi:wa kikwah, kikwa pitsot, kikwah piotsitsi:n, se: kinte:mili kikwah, kikwah n' ima:xiwyo.</ANNOTATION_VALUE>
