        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>Wa:n yeh chichi:k, yo:n a:..., yo:n a:mo tsohya:k, chichi:k.</ANNOTATION_VALUE>
