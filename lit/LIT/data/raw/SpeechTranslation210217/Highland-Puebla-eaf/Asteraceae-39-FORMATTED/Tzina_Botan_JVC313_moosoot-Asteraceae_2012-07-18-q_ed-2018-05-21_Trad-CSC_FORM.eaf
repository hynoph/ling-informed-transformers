            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>Pero mo:so:t a:mo kikwah *porque** we:weyakaxtik, yo:n a:mo, a:mo kikwah n' chiktehmeh. Ke:mah.</ANNOTATION_VALUE>
