        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>yehwa yo:n wa:n de sepa chika:waya yo:n mi:lahmo:so:t, de we:wehti a,</ANNOTATION_VALUE>
