        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>Yo:n para ki..., kitekih no: yo:n kwomo:so:t wa:n yehwa ne:n,</ANNOTATION_VALUE>
