        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>yeh chichi:k wa:n i:n se: a:mo chichi:k yeh. I:n seki tsohya:k ne:n kwomo:so:t.</ANNOTATION_VALUE>
