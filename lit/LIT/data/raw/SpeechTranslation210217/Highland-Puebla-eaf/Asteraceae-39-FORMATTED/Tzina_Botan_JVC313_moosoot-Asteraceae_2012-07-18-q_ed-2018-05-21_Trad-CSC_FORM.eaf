        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>ne: achi *más** kech..., ma:pisi:ltik wa:n ye:kma:tsitsikiltik *más** n' ima:te:mpan wa:n pisi:ltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>Wa:n ikowyo alaxtik. Alaxtik n' ikowyo wa:n wehka mowila:na.</ANNOTATION_VALUE>
