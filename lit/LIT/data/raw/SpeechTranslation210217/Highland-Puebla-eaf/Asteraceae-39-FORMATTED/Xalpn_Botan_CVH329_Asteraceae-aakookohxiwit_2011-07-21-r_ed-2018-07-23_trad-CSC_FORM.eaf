        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>Semi, semi *fuerte** yetok n' kokolis, na:wi *viaje** namopa:kaskeh ika yo:n pahti,</ANNOTATION_VALUE>
