    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Salazar Osollo" TIER_ID="MSO Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>¿Como señora, tu conoces como se riega esa flor,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>ese que le dicen sempowalxo:chit, cuando se riega (la semilla para que nazca).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>¿Y eso también lo limpian?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>A lo limpian.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>A lo limpian con las manos. ¿Y cuando le arreglan para regarlo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>también queman (la basura u hojarasca) o nada más así?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>así nada más lo..., le limpiamos y no se necesita quemar. Y sa..., sa..., sale bueno, hay que preparale como que, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>A, y entonces ya así, después ya nace. Ya nace.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Y entonces, ya así lo dejan de limpiar, ¿Y eso nada más lo limpian una sola vez?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>A lo limpian tres veces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>A pues no nada más una sola vez.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>A lo limpian tres veces. A pues es cierto y ya entonces es cuando después empieza a florecer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Así nada más hay pura flor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Si. Pues de verás, pues yo no sé eso, yo no, nunca he regado esa flor. Si, yo siempre lo riega mi madre pero</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>este, no, no sabía si se limpia tres veces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Antes también lo secan en el sol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Pero lo seca uno de nuevo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>A, ahí lo secamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>A ya lo guardas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Y ya es lo que riegan. A pues es verdad. Si, yo no sabía si es que también lo limpia uno, este tres veces. Yo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>yo es..., yo sé que de por si lo riegan pero no  sé como es eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Si y, si porque... Si es trabajoso pues de que también lo riegan y de verás que hay que limpiarlo, si, no se da por si solo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>No. Si. Se va a dar pero pues hay que..., también hay que limpiarlo. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Son bonitas las flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Y eso cuando lo cortan lo cortan todo o también lo van seleccionando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>A, es lo único que cortan, ya lo seleccionan ahí. A pues es verdad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Si pues no..., de verás que yo no sabía eso como es, este, lo corta uno, si lo selecciona uno todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>A lo selecciona uno y ya es lo que se ocupa para adornar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Así se van siguiendo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Y entonces lo..., ya lo amarran. Y eso lo amarran solo o también con alguna otra hierba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>A ya con eso lo amarran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Y entonces, ya es así como terminan de adornar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>A ese día.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>A adornan de neuvo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Ya es lo que ponen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>A pues es verdad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>A pues yo no sabía como es entonces que ustedes adornan.... A pues con eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>A otra vez adornan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Si, todo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>A pues adornan tres veces. tres veces. Aja. Si. Y siempre van escogiendo todas las flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Todo lo escogen. Por eso mucho, este, lo cortan y pues es grande..., es grande el lugar donde le arreglan para que alcance.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>A ya en la entrada de la casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>¿Pues este ustedes no ocupan eso que le llaman palo del altar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Aja. Y con el otro adornan. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>A, ya en la entrada de la casa. A pues es verdad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>A pues es verdad. ¿Ya es así? ¿Ya es así?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>Pues eso es todo señora lo que te estaba preguntando, muchas gracias por lo que me dijiste. Yo no sabía como es que se hace esa flor unos..., lo riega uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Muchas gracias si. Yo me llamo María Salazar Osollo, vengo de San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Aja. Este, yo vengo de Xalpanztingo, me llamo María Guadalupe Vázquez.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Guadalupe Vázquez" PARTICIPANT="María Guadalupe Vázquez" TIER_ID="MGV Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>Pues el sempowalxo:chit, este, según..., yo, por allá nosotros lo regamos por allá nosotros...,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>nue..., donde..., Dios nos tiene, este, nosotros lo regamos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>en, el día de San Juan cuando es su fiesta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Es cuando lo..., lo..., le adornamos ese mero, justo ese día.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Cuando es su fiesta cuando le adornamos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>para lo..., lo..., ya lo regamos, así lo desmoronamos bien con las manos la flor, lo hace uno polvito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>del que está seco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>De ahí, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>lo ponemos este como, como debe de ser le arreglamos lo..., para</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>para ocuparlo en todos santos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Ahora en todos santos, lo cortamos, este, lo..., como que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>no en el mero día, sino que lo cortamos este..., digamos que al día siguiente cortamos la flor,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>y entonces, cuando le dicen vigilia pues ya arreglamos. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Ahora lo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>ya es cuando si es que digamos que, este, florece.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Pero nosotros,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>nosotros lo limpiamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Lo limpiamos cuando ya es así la flor,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>lo..., lo limpia uno todo, lo limpia uno con las manos no con herramienta, con azadón, con machete, por allá nosotros lo limpiamos con las manos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Lo limpiamos con las manos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Si. Por allá nosotros,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Y entnces ya lo riegan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>hay que prepararle así como que, como si fuera ese, como siembra esa jicama.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Aja. Hay que prepararselo así, como que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>le hacemos tierrita como si fuera, como que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>tierra verdad, como que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>así, le hacemos así y ahí..., lo desmorona uno así esa flor. Ya nace. Es bo..., ya nace bonito, ya nace así bonito, crece bonito si es que lo cuida uno bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Que no lo toque el animalito, que no se lo coma. Y entonces cuando ya lo vemos que ya tiene hojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>las hierbas ya son de este tamaño, el mo:so:t o ese,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>cualquier hierba, le decimos ehkawxo:chitsi:n, ehkawxiwtsi:n todo lo..., lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>bonito lo..., lo..., le limpia uno todo bien, que tenga..., ese así donde..., donde pisa uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Aja, se limpia dos o tres veces nosotros le limpiamos para que no este hierboso, este..., Aja, para que no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>como que, que no esté hierboso como que va a florecer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>No, pues nosotros lo..., tres veces lo limpiamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Si. Si. De ahí, cuando ya florece bien, como que ya no esta hierboso...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Aja, nada más hay pura flor si es que le limpia uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Aja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Si, se limpia tres veces y de que está seco esa flor lo hace uno en polvo así si..., lo va uno poniendo así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Si, pues eso es seco, pero ese no..., lo guardamos cuando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>ya descompone uno en nuestro altar guarda uno la flor</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>y lo..., lo seca uno. Como yo tengo adonde secarlo, lo tiendo encima de la casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
