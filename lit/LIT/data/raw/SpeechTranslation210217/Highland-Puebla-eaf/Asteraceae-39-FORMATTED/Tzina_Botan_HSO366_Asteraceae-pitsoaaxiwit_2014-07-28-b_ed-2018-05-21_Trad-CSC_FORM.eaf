        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>ma:ehewaltik wa:n pos a:mo telma:pa:pata..., ke:meh yo:n</ANNOTATION_VALUE>
