                <ANNOTATION_VALUE>nokahfe:ntah m'pia nika:n San Miguel ne:paka sah, yahkah i:n tokni:wa:n 'kwitoh seki xiwit, ompa no: onkak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
