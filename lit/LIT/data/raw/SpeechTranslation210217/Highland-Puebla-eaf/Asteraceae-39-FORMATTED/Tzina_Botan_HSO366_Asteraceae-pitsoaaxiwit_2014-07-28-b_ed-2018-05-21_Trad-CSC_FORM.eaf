        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts168" TIME_SLOT_REF2="ts170">
                <ANNOTATION_VALUE>A:h.</ANNOTATION_VALUE>
