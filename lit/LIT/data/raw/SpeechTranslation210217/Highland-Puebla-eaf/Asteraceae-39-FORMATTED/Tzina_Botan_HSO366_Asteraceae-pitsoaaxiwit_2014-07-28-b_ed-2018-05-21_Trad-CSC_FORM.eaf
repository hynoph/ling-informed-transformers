    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Hermelindo Salazar Osollo" PARTICIPANT="Hermelindo Salazar Osollo" TIER_ID="HSO Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>Aja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>A ese pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>No sé de verás porque así le dicen pero</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>cuando yo crecí lo veía porque yo preguntaba, porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>así..., yo trabajaba en el campo en aquel tiempo, ahce tiempo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>y limpiaba en los cafetales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Y cuando limpia uno en los cafetales, este, también se da ese pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Pero ese pitsoa:xiwit se apriete mucho (en la tierra) se entierra mucho. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Donde hay,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>parece que endurece..., endurece mucho la tierra porque este...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>se llena de esa hierba y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>y este se...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>se enraiza pero tiene muy juntitas sus</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>sus juntas con lo que se enraiza pues parece que..., parece que se amarra en la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Pues es muy dificil..., para limpiar, si quiere uno arrancar el pitsoa:xiwit se..., nada más se rompe al ras del suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Y pues había otras hierbas, ese que le dicen gachupin, pues ese se jala (hacia arriba) y ya se arranca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>Pues preguntaba ¿Por qué..., como se llama esta hierba, por qué es así? Y me decía mi papá, no pues ese es el pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Pero no sé porque le dicen pitsoa:xiwit porque, este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>ese no, no voy a decir que se lo come el cerdo o</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>o algún animal que se lo coma,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>ni tampoco sirve para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Ese nada màs es pura hierba que se da, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>yo he visto que ese pitsoa:xiwit se da en donde,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>donde es tierra dura, donde este..., y donde este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>se da más en los bordos de tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>A lo mejor es porque se entierra mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Si. Y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>y de verás que donde se da el pitsoa:xiwit es muy...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>abunda encimándose como si fuera..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>se encuentran entre si..., se..., se entre cruzan y..., la misma hierba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Y de ahí..., por eso hace endurecer la tierra donde abunda.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Pero de verás siempre hay, abunda más donde le llaman tierra fuerte</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>porque donde hay tierra suelta o muy pura (muy fertil),</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>en tierra blanda no, no se da.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Si. A pues este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>tengo mi cafetal un poco hacía allá de San Miguel, habían ido estas personas a traer unas hierbas, ahí también hay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Y de verás que hace endurecer mucho la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Si, este, y...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Ese pitsoa:xiwit se..., se extiende como si fuera que se extiende sobre el suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Y no, no crece alto, este, y sus flores también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>es parecido como, este, las flores del ehkaw.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>parece que nada más... parece que todo el tiempo esta floreciendo porque ahora está en flor. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Y este es de hojas redondas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Este..., este...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>es de hojas redondas y pues no es de hojas ancha... Como el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>sus hojas son parecidas como ese que le dicen hierba buena en español le dicen hierba buena, tiene un parecido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Pero, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>y sus tallos..., este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>sus tallos son delgados y parece que son morados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Y pues ese no se siembra, a lo mejor nace por si solo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Yo pienso que da semillas y si no da semillas el mismo... Pero es muy probable que da semillas porque a veces en algún lugar... Allá en mi cafetal no había nada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Y quien sabe de donde vino la semilla y o sea pos yo veo que abunda.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Y antes, antes yo limpiaba allá en el cafetal porque cuando yo crecí me enseñaba mi papá..., limpiabamos pero así como le llaman limpiar a mano, arrancando las hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Ahora como, este, dicen que </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>limpiar a mano este, se acaba la tierra,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>se la..., se lava, cuan..., cuando viene la lluvia..., va barriendo mel agua(lavando).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Entonces en la actualidad dicen que es mejor limpiar pero sòlo chapeando un poco alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Pues de que se limpia un poco alto la hierba crece más rápido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Si. Y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Pues eso es todo. Yo no sé porque le dicen pitsoa:xiwit, es..., nunca lo vi que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>cuando crecí le trajeramos un animal,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>para un cerdo, porque a veces teniamos los cerdos, no, nunca. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Y quien sabe por qué le dicen pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>pero de verás este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>pues se da por si sola no se necesita sembrarlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Y se da con..., un poco..., se da en los cafetales y en algunas orillas de caminos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>donde abunda con diferentes tipos de hierbas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Si. Y de verás que se extiende en el suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Si. Pues no, parece que ya no sé nada de eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>SI:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Aja, a:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Aaa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>A pues a lo mejor es por eso. Aaa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>A lo mejor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>No. No sé y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>este, pues de verás..., así como..., vivimos en diferentes lugares,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>en cada pueblo nombramos de diferente manera las hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Aquí nosotros también hay una hierba que le decimos a:xiwit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>pero ese es diferente, es otro tipo. Crece un poco y ese se lo comen los guajolotes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>me acuerdo de verás que..., cuando, pero es otro tipo de hierba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Ahí..., si es que se da quien sabe como le llaman pero de verás que tiene que ver de acuerdo adonde vivimos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Si, nombramos de diferente manera a las hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Pues mi nombre es Hermelindo Salazar y vengo de San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>A pues gracias que ya platicamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Ceferino Salgado Castañeda" PARTICIPANT="Ceferino Salgado Castañeda" TIER_ID="CSC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Hermelindo, ahora que aquí nos encontramos este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>quería preguntarte, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>escuché el otro día que decías, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>esa hierba hay por allá y lo puede ver uno </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>como dices con flores de color amarillo, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>el pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Y yo quería preguntarte como es el que ustedes así le dicen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Si. Yo, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>lo..., el otro día escuché que así le dicen. Ese yo lo conozco por a:xiwit. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>A:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Si y, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>yo veo por allá donde</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>en lugares pantanosos o donde baja agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>ahí se da en, si es que hay un caño</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>ahí abunda mucho y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>crece así de alto, parece que hasta se da de muy buena calidad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Y de verás que como dices, parece que todo el tiempo esta floreciendo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Si, pero yo, ya ahce mucho tiempo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>me acuerdo que cuando veía eso en algun lugar, si abundaba bonito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>ahí llevaba el cerdo, lo iba jalando hasta allá y ahí lo amarraba,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>peroel cerdo se lo come.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Se lo come. Si. Pero pienso que a lo mejor por eso ustedes le dicen pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Pero nosotros este... Yo nunca lo cortaba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Pero nosotros por allá le decimos a:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Aja. pero si se lo come el cerdo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Este, y asi te digo que yo veo que nada más por allá, este crece donde..., donde...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>pasa el agua, pero no en los arroyos grandes sino que donde</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>baja muy poca agua, ahí abunda mucho y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>no he puesto atención si de verás que hace endurecer la tierra, pero también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>también he visto que hay por allá.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Si, y eso pense preguntarte, este ese, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>pero me dices que no sabes por qué, como, por qué asi le dicen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Si. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Aja. Si, pues eso es todo lo que te quería preguntar, este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>si ya no sabes nada más, me puedes decir tu nombre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Si. Yo me llamo Ceferino Salgado Castañeda y vengo de Tacuapan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
