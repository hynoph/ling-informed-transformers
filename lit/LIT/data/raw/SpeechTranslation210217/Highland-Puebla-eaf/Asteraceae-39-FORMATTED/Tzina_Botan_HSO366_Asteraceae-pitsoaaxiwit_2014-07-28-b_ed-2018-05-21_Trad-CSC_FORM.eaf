        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>Pero neli nochipa onkak, *más** mochi:wa ka:mpa yo:n kiliah chika:wakta:l</ANNOTATION_VALUE>
