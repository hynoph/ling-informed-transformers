        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>Ke:meh se: *semana**, o:me *semana** kikwa:s te:tewatsi:n sah.</ANNOTATION_VALUE>
