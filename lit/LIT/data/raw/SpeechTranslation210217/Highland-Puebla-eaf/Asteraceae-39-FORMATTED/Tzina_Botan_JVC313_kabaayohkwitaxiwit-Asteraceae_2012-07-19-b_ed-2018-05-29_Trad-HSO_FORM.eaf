    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Ahora dinos cómo es el</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>kaba:yohkwitaxiwit, en donde se da, cómo son sus hojas, su tallo, sus flores, cómo son sus semillas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>y si sabes este, si lo usan para curar pues también platícanos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>¿Cómo son sus flores cuando brotan y no sabes en que tiempo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>¿Y las hojas no se usan para alimentar a los animales? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Y este, bueno, uno escucha que dicen que las plantas del kaba:yohkwitaxiwit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>nacen en el potrero, si lo amarraron ahí este, como un,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>caballo ¿es cierto eso, no lo sabes?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Entonces por eso le llaman así. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Bueno pues e..., para que es todo este nos..., nos, platicaste de esa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>hierba, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>dices que no es fácil que se pierda, nos platicaste todo cómo son sus..., sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Pues ahora sólo dinos tu nombre</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>y del pueblo de donde vienes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Ernesto Vázquez Chanico" PARTICIPANT="Ernesto Vázquez Chanico" TIER_ID="JVC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Sí el kaba:yohkwitaxiwit lo conozco, se da en el potrero, en algunas partes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>y en donde abunda, en el potrero, tapa al zacate y lo acaba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>Las matas de esta planta tapan al zacate, sólo que no, no, se seca, se da sólo en determinados tiempos también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Hay un tiempo que no hay porque se secan las matas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Y cua..., cuando vuelve a retoñar se da en matas grandes y se extiende, entonces las matas tapan al..., al zacate.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Y las hojas de la planta también tienen una aroma como te platico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a99" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Y su..., el tallo tiene un color un poco morado, en las puntas de la planta tienen un color morado en donde</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>van a brotar las flores, es la que se..., crece, crece</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a101" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>hasta en la pun..., punta, ahí brotan las flores, ahí se dan las flores, ya no crece más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>Después de que ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Y sus hojas son pubescentes, son pubescentes y tienen una aroma las hojas, del kaba:yohkwitaxiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>Y se da en matas grandes que se extienden, cuando se arranca la planta, sus raíces traen mucha tierra y no se esca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>Cuando se arranca la planta, se agarra con la mano y se azota en el suelo, pero no fácilmente suelta la tierra porque tiene muchas raíces que se encuentran pegadas con mucha tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Y la planta no se seca fácilmente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Pero llega el día cuando la planta llega a su maduréz, después brotan sus flores y ya produce semillas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>se..., sus semillas son muy chiquitas como si fueran unas basuritas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Y enseguida se caen las semillas, de..., después de que se secan sus..., sus..., sus semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>entonces ya se seca la mata, hasta acabarse, se acaban todas las este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>sus hojas. Se secan todas como si se quemaran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Y vuelve un tiempo, viene, viene otra vez,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a113" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>cuando empieza a retoñar o nacen nuevas plantas en donde se dan, para volver a a crecer y dar semillas. Esa planta se da sólo en tiempos determinados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a114" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Sólo en algunos tiempos, no se da en todo el año esa planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>Sí, aunque uno dice que la planta no se chiquea pero se da sólo en tiempos determinados. Y cuando se da, se extienden mucho las matas y tapan mucho al zacate en los potreros. Sí, eso es,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>así es esa hierba, pero cuando maduran las semillitas, florea la planta y maduran las semillas, entonces ya se..., con eso ya se seca la mata.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>Se seca como si se quemara. Pero otras hierbas no se secan, así se..., como la que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>le llaman pitsoa:xiwit no se seca nunca,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>siempre, se da en todo el tiempo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Pero el kaba:yohkwitaxiwit se da en determinados tiempos nada más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Pues no sé en qué tiempo se da, pero he visto que se da, pero, pero no sé en qué tiempo florece, bueno sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Y esa planta crece y florece, al  terminar de crecer se..., se abren sus flores, y sus flores</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>se..., como si..., no tienen punta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>bueno su tallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Lueg se abren las flores. Y sus flores tienen una aroma agradable y son pubescentes en su...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>son como muy..., las florecitas como si tuvieran algodón y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>son pubescentes en las puntas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>As..., su..., se dan así redondas, como que, como si fuera un rollo, por rollo y son pequeñitas las florecitas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>Así es como se..., como florece el kaba:yohkwitaxiwt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Pero no sé si es medicinal esa planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Pero de que tiene una aroma, sí es aromática, pero no sé si es medicinal, sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Su..., los animales no se comen, con la planta de kaba:yohkwitaxiwit no se alimentan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>No se lo comen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Por eso las personas que tienen potreros no quieren a esa planta porque tapa al zacate hasta acabarlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Esa hierba no es comestible para los animales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Los animales se comen a la hierba del pitsoa:xiwit, pero el kaba:yohkwitaxiwit no se lo comen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>E..., donde defeca el caballo, ahí nacen las plantas, quien sabe cómo se hace eso, de…, donde vienen las semillas, pero</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>es cierto que en donde defeca el animal ahí nacen las hierbas por…, así por ruedas nacen muchas plantas en el suelo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Eso es, esa hierba, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>si amarran a un toro no es así, pero en donde se amarra el caballo nacen esas plantas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>así es, nacen las plantas quien sabe cómo hace el caballo, en algunos lugares se come las hierbas y ahí tira las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Sí es cierto que en donde defeca el caballo ahí nacen las plantas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Por eso le..., por eso le llaman kaba:yohkwitaxiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Sí, porque se da en donde hay estiércol de caballo, ahí nace la planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>A pues yo me llamo Ernesto Vázquez</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>yo soy de San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
