        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>Na:wi *esquina** wa:n semi te:kwihkwi ne: ka:mpa ...</ANNOTATION_VALUE>
