                <ANNOTATION_VALUE>Pos kwaltsi:n se: motahtania ke:meh i:n tik..., timona:mikih itech i:n ohti pos nijó:n se:, se: molia wa:n se: kimattiw.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
