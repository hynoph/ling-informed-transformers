        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>No: tikilia ko..., kwomo:so:t *porque** no: *igual** ke:meh ne: oksé: mo:so:t.</ANNOTATION_VALUE>
