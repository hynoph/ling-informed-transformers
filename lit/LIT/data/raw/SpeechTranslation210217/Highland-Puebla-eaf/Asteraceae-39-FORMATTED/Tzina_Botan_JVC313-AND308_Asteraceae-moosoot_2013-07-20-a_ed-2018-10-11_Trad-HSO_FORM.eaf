        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts412" TIME_SLOT_REF2="ts414">
                <ANNOTATION_VALUE>Kikohkoto:ntiowih wa:n *hasta** kitamiah ya.</ANNOTATION_VALUE>
