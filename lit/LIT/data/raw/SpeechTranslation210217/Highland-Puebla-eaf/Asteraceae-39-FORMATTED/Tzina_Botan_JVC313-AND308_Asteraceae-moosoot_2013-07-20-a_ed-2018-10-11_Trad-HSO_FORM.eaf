        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Yeh. A:, yo:n mowi:wila:na itech kahfe:n xiwma:ko.</ANNOTATION_VALUE>
