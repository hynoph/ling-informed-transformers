            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>Wa:n de pe:wa pala:ni ompa mokepa ya n' a..., n' ta:labo:noh ya no: para n' tatok:tsí:n.</ANNOTATION_VALUE>
