        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>To:chimeh kikwah wa:n kikwah no:, ne:n, kwa:kowehmeh</ANNOTATION_VALUE>
