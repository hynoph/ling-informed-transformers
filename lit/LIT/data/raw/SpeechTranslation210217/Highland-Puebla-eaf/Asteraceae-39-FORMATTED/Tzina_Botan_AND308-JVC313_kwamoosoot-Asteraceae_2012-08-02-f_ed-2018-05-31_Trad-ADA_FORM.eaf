        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>Yehwa yo:n a:ko:kohxiwit ne: kita:lia:yah pero de yo:n de n' selik.</ANNOTATION_VALUE>
