        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>Yehwa yo:n a:mo, de sepa ki:sa ya pos,</ANNOTATION_VALUE>
