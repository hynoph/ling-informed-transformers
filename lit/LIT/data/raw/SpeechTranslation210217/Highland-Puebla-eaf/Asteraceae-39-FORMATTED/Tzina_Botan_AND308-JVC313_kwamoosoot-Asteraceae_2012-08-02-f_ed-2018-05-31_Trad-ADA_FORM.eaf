        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n okseki ne:n, yehwa yo:n tikihtowa, ne:n, nikneltoka ne: kalanemi:lis,</ANNOTATION_VALUE>
