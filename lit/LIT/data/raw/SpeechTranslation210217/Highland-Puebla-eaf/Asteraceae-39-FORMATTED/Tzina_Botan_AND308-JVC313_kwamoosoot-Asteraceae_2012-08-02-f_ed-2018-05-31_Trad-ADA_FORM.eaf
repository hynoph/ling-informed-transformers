        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>'Te:tehpa:ntiowih ihkó:n kinmahmagah para mah, mah taneki:sa nexwitil.</ANNOTATION_VALUE>
