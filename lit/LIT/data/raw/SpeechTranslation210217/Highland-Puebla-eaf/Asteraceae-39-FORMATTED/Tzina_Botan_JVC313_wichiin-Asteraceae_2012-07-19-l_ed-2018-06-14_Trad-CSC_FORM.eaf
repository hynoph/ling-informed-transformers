        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>I:pa semi nikita kikwih para, para ke:meh i:n teihsá: mo..., motekih wa:n ki...,</ANNOTATION_VALUE>
