        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>Wa:n achi pané: *para:rayado** ne:n i..., ikowyo tein *cuando** selik ok.</ANNOTATION_VALUE>
