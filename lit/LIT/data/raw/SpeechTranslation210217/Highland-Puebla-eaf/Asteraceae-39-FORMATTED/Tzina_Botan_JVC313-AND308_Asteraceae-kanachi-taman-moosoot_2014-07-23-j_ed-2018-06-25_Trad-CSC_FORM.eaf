        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts85">
                <ANNOTATION_VALUE>{Aquí quizá cabría "neli ata" pero dice simplemente "ta".}</ANNOTATION_VALUE>
