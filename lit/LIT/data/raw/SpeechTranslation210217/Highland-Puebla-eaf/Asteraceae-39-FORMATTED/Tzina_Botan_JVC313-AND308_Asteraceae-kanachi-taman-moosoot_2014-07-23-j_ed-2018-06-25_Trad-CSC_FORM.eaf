        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>A quieres sa..., saber ya que aquí nos encontramos en este monte.</ANNOTATION_VALUE>
