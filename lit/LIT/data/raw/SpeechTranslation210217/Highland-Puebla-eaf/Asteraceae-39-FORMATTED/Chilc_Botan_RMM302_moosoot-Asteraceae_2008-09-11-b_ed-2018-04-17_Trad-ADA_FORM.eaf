    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Jonathan D Amith" PARTICIPANT="Jonathan D Amith" TIER_ID="JDA Traducción">
        <ANNOTATION>
