        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Quizá, quizá solamente les gusta porque la flor es limpia, solamente ala ven y vuelan sobre ella. Pero ....</ANNOTATION_VALUE>
