        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Crece con muchas ramas y, también florece. Sus flores se ven muy bonitas pero no se pueden cortar con las manos.</ANNOTATION_VALUE>
