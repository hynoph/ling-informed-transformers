        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Pero es de color gris por ser tan pubescente, digamos que tiene mucha pubescencia.</ANNOTATION_VALUE>
