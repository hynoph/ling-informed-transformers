        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>Yo:n kahkalaki se: itech a komohkó:n wa:kik a.</ANNOTATION_VALUE>
