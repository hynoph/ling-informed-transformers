        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n se: kimowilia, a:mo se: kiteki.</ANNOTATION_VALUE>
