    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="Eleuterio Gorostiza Salazar">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>*Bueno**, pos ekintsi:n mah timonohno:tsaka:n yo:n xiwit yo:n ixta:wat mo...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>mochi:wa, neh a:mo n'mati ke:n mono:tsa, ata kowyohtihti:ltik wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>no: xo:chiowa ke:meh yo:n *kaba:yohkwitaxiwit**, soh achi pané: *mohmorado** ata ne:n ixo:chio.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>No:, no: i:ksá: mochi:wa ohte:nakas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>Wa:n yo:n seki tein ne: xola:lpampa yo:n ta:lpan mopa:pacha:nia, ata no: iwki kito:ka:ytiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>Pero yo:n tak no: pahti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>Ke:mah, pos yo:n seki, yo:n tein ixta:wat mochi:wa, yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>t'to:ka:ytia ne:, a:xokoxiwit tak, *este**, xa: porin yehwa yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>ato:l ika kichi:wah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts101">
                <ANNOTATION_VALUE>I:pa kanah, tehwa:n, neh *que** nimihto:tia:ya wa:n tia:yah *mayordomohko**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>Pos pané: yehwa sah ne: i:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>o:me taman xiwit ika timonohno:tskeh, neli yehwa ne:n tein yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>tihti:ltik n' ikowyo ne:n teh tikto:ka:ytia a:xokoxiwit wa:n yehwa yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>tein ta:lpan mopa:pacha:nia nika:wí:n seki no: kiliah a:xokoxiwit wa:n seki:n kiliah tsope:likxiwit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Wa:n, *este**, ekintsi:n sayoh moto:ka:y wa:n moxo:la:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="Ernesto Vázquez Chanico" TIER_ID="Ernesto Vázquez Chanico">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>Ke:mah. Niki:xmattok no: yo:n xiwit, ne: semi takwa:wak pané: *alambre** ne:n ikowyo wa:n tihti:ltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>Wa:n ahalaxtik wa:n yo:n xiwit ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>nejó:n, no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ka:n semi telma:wehwei, pero i:xahalaxtik nochi n' i..., ixiwyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>Wa:n ixo:chio ke:meh, tamati n' *kaba:yohkwitaxiwit no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>I..., pan..., *como que** mahyá: kwa:pammoloxtik, ne:n, ixo:chio.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>Wa:n i..., ik..., ikwa:pan kipia no: n' i..., xiwit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>Wa:n yo:n kihtowah kikwih para a:..., a:xokot kichi:wah nih..., tehwa:n nika:n a:mo tiki:xmatih yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>Kichi:wah nikahkwí:n, mah tikihto:ka:n kwesalte:kakopa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>Tehwa:n a:mo tiki:xmatih, a:mo, a:mo tik.., tikpiah yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>*costumbre** para tik..., para kichi:waskeh n' ka:mpa tehwa:n tinemih, nika:n San Miguel a:mo tikpiah *costumbre para** yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>de kichi:waskeh yo:n a:xokot kiliah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>*Porque** nikita tehwa:n ke:masá: ompa mihto:ti:tih mihto:tia:nih wa:n te:cheko:ltiah pané: a:mo se: kwe:lilia de a:mo se: momati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>Tehwa:n tikwe:liliah kahfe:ntsi:n wa:n oso ato:ltsí:n te:makah ke:meh i:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ka:sá: *mayordomohko, pero** yo:n a:xokot a:mo, a:mo k..., a:mo tikwih nika:n tehwa:n, a:mo *tocostumbre**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>*Costumbre** nehkwí:n tokni:wa:n seki:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>Ke:mah, *porque** ompa semi kitatekiwtiah yo:n xiwit tikihtowa ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>a:..., a:xokoxiwit. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>Wa:n ahwia:k ata tepitsi:n *pero casi** taman sah yo:n xiwit pero, nejó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>ixta:wat mochi:wa, yo:n a:mo kito:kah, mochi:wa sah. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>Mochi:wa ohtipan. Mochi:wa nikahkwí:n, nika:n i:n *campo para** ne:paka nochi mochi:wa n' ixta:wat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>Pero neli a:mo tiktatekiwtiah nika:n, ompa,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>ompa moa:wilowa xiwit de a:mo t'tatekiwtiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>Pero yeh kiliah ne: tsope:likxiwit *porque** tsope:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>Yo:n *cuando**, yo:n ki..., kimanah komo se: kineki se: tai:s,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>seki tein yo:n mopahtihtokeh, de ke..., ke:meh yo:n mokoyo:pahtiah de kwesala:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ne: ki..., kinawatia mah tai:ka:n *té**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>yehwa yo:n kikwitih xiwit, a:mo kita:li..., a:mo kita:liliah *azúcar**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>kimanah yehwa yo:n xiwtsí:n wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>kimolo:ntiah wa:n yehwa n' taih, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>xiwtsí:n wa:n a:mo kitsope:liah, tsope:ya ika n' xiwit *porque** xiwit semi tsope:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>Yehwa yo:n kichi:wah seki. Taih yo:n tokni:wa:n de, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>yo:n tsope:likxiwit, pero neli tsope:k. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>No: pahti, no: pahti *porque** ne..., nejó:n, pero yo:n mochi:wa sah, onkak ka:sá: ohte:noh se: kita ata.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>Onkak sah yo:n, a:mo, a:mo se: kikowa, nika:n sah mochi:wa n' tehwa:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>Ta: yehwa ika kito:ka:ytiah iwki por a:xokot kichi:wah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>Ke:mah, pero tehwa:n nika:n neli a:mo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>a:mo, a:mo tikpiah *costumbre para** tikchihchi:waskeh yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>yo:n ato:ltsí:n. *Porque cad..., cada** xola:l kipia n' i..., *icostumbre**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts100" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>Ihwa:k teh timoskaltih i:pa ka:n kichi:wayah n' a:xokot nika:n xola:lpan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>ne:, te:chwa:ntiah kahfe:ntsi:n sah, pero a:mo, a:mo a:xokot kichi:wayah, a:mo ke:man niki:xmatik neh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>Wa:n i..., ke:masá: ne:chyo:le:wah, nia:ya i..., tia:yah ne:wí:n seko, kwesalte:kakopa timihto:ti:tih,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>tik..., ka:mpa *mayordomohko** te:chwa:ntiah ika a:xokot pero tehwa:n a:mo tikwe:liliahpos</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>tika:wilchi:wah sah, a:mo 'tai:yah tehwa:n tipi:pilmeh *cuando** tipiltamatiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>Pero nika:n tehwa:n ne: a:mo, a:mo tikitah ke:man yo:n te:chwa:ntih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>Achto ne:, ke:meh i:n *mayordomos**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>*cerahkwiti** wa:n kino:tsah mihto:tia:nih, komohkó:n we:i, we:ichi:wkeh ne:n tahpixkeh ompa kipiah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>kino:tsah mihto:tia:nih wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>*ticerahkwitih, pero** soh *ticerahkwitih** sah a:mo te:chtamakayah ti...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>te:chwa:ntiah kahfe:ntsi:n sah ika *pantsi:n**. Yehwa sah yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>Wa:n *ticerahka:watih** ihwa:k n' te:tamakah ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>Pero ekintsi:n a:kin ..., ekintsi:n mopatati sepa n' *costumbre porque** ekintsi:n kitelne:nta:lihkeh ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>*cada** se: *mayordomo, importa** te:tamakas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>Ma:ski *caldito** sah *o** chi:lposo:ntsí:n sah pero te:tamakas *importa**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>Wa:n sepa *cuando** se: *cerahka:wati** a ke:mah wi:tsa *mole** ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>Ke:mah, te:tamakah ohpa ekintsi:n kitelchi:waltiah n' *costumbre** kipatakeh ya, porque** achto a:mo te:tamakayah n' *cuando** se: *cerahkwiti**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>Ekintsi:n ke:mah se: ..., te:tamakah *cerahkwitih** wa:n sepa *cerahka:watih** sepa te:tamakah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Iwki ekintsi:n, mo..., mopatak n' *costumbre** nikitstok ekintsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>Yo:n a:mo *mal**, te:tamakah ohpa oso e:xpa a:mo *mal. Mal** komo a:mo te:tamakakeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>Pos tehwa:n tiki:xmatih tsope:likxiwit yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>Pos neh nimono:tsa niErnesto Vázquez wa:n noxola:l San Miguel Tzinacapan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Bueno pues ahhora hay que platicar de esa hierba, de esa hierba que en los potreros...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>se da, yo no sé como se llama, es de tallos negros y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>también florece como el kaba:yohkwitaxo:chit, nada más que sus flores son un poco moradas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>A veces también se da en las orillas de caminos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>Y el otro que allá en el pueblo hay, ese que se extiende sobre el suelo también así le llaman verdad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>Pero ese también es remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>Si, pues el otro, ese que se da en los potreros, ese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>lo nombramos este, a:xokkoxiwit, este, a lo mejor es por eso </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>que con eso preparan el atole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>De por si no, nosotros, yo que bailaba en una danza e ibamos con el mayordomo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Pues parece que ya es todo de esto,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>nos platicamos de dos tipos de hierba, de verás que es del que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>el que es de tallos negros es el que tu lo nombras a:xokoxiwit y el que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>por acá se extiende en el suelo algunos le dicen a:xokoxiwit y otros le dicen tsope:likxiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Y pues ahora nada más tu nombre y tu pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Ernesto Vázquez Chanico" PARTICIPANT="Ernesto Vázquez Chanico" TIER_ID="JVC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Si. Conozco también esa hierba, sus tallos son negros y muy duros como alambre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a99" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>Y son lisos y esa hierba, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>este también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a101" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>no es de hojas muy grandes, pero sus hojas todas son lisas en el haz.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Y sus flores son como el, también se parecen al kaba:yohkwitaxo:chit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Su..., en..., como que en las puntas de las flores son blandas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Y..., en las puntas también tiene hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>Y dicen que eso lo ocupan para..., para hacer atole no..., nosotros acá no conocemos eso. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>Lo hacen por acá, digamos que por las comunidades mas Cuetzaltecas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>Nosotros no lo concoemos, no, no lo..., no tenemos eso</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>costumbre de..., para que lo preparen donde nosotros vivimos, aquí en San Miguel no tenemos esa costumbre para eso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>de preparar ese que le llaman a:xokot.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>Porque yo he visto que a veces allá van a danzar los danzantes y nos dan a probar pero como que no nos gusta de que no estamos acostumbrados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Nosotros nos gusta el cafecito o el atolito cuando nos dan donde como,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a113" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>con algún mayordomo pero ese a:xokot no, no..., no lo ocupamos nosotros, acá no tenemos esa costumbre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a114" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>Esa costumbre es de otras gentes de por allá.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>Si porque dices que allá ocupan mucho esa hierba,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>el a:xokoxiwit. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>Y tiene un aroma medio diferente esa hierba pero, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>se da en los potreros, ese no lo siembran, se da por si sola. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Se da en los caminos. Se da por acá, por el campo hacía allá todo se da en los ppotreros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>Pero de verás que no lo ocupamos acá, allá,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>ahí se echa a perder esa hierba de que no la ocupamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>Pero ese le dicen tsope:likxiwit porque es dulce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Cuando ese, ese..., lo hierven si es que uno quiere tomarlo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>algunos de los que están en tratamiento, de que..., como tienen tratamiento médico de patente de Cuetzalan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>este..., les indican que tomen te,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>y van a atraer esa hierba, no le po..., y no le ponen azucar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>hierven esa hierba y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>lo hierven y ya eso es lo que toman, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>esa hierba y no lo endulzan, se endulza con la hierba porque esa hierba es muy dulce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Eso es lo que unos hacen. Se lo toman las personas de, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>ese tsope:likxiwit es muy dulce. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>También es remedio, también es remedio porque este...este, pero ese se da por si solo, se puede ver que hay en las orillas de los camiinos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Ese nada más hay, no, no lo compra uno, aquí nosotros nada más se da.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>Pues por eso lo llaman así porque con eso preparan el a:xokot.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Si, pero de verás que por aquí nosotros no,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>no, nno tenemos la costumbre de preparar ese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>ese atolito. Porque cad..., cada pueblo tiene..., su costumbre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Cuando tu creciste de por si no hacían el a:xokkot acá en el pueblo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>este, solamente nos daban cafecito, pero no, pero el a:xookot no lo preparaban, yo nunca lo conocí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Y..., a veces me invitan, iba..., ibamos por allá en algún lugar, íbamos a bailar por las comunidades de Cuetzalan, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>lo..., con el mayordomo nos daban el a:xokot pero nosotros no nos gustaba pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>lo echabamos a perder, nosotros los niños no lo tomábamos porque aún eramos unos niños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Pero aquí nosotros este no, nunca vemos que nos den eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Anteriormente con los mayordomos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>iban por la cera y les invitabana a las danzas, si es que es grande, si es que tienen una imagen patronal,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>les invitaban las danzas e</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>ibamos por la cera, pero nada más íbamos por la cera no nos daban de comer i..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>nada más nos daban cafecito con pan. Nada más eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Y cuando ya ibamos a dejar la cera ya es cuando dan de comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Pero actualmente el que..., actualmente ya se cambió la costumbre porque ahora ya lo inventaron mucho,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>cada mayordomo tiene que dar de comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Aunque sea con caldito o chilposonte pero es importante que tiene que dar de comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Y otra vez cuando van a dejar cera ya es cuando dan mole.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Si, actualmente ya dan de comer dos veces, ya hacen mucho por esa costumbre, ya lo cambaron porque antes no daban de comer cuando iban a traer la cera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Ahora si..., dan de comer cuando van por la cera y otra vez dan de comer cuando ya la van a dejar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Ahora es así, se cambió la costumbre, es lo que veo yo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Eso no es mal, que den de comer dos o tres veces no es mal. Está mal si no dieron de comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Pues ese nosotros lo conocemos como tsope:likxiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Pues yo me llamo Ernesto Vázquez Chanico y mi pueblo es San Miguel Tzinacapan. s</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
