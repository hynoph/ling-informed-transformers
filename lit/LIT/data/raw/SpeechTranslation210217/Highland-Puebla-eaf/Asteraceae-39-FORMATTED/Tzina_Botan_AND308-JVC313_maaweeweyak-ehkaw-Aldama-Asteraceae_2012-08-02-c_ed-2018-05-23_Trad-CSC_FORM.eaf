    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Comentarios" PARTICIPANT="Comments" TIER_ID="Comments">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts41">
                <ANNOTATION_VALUE>{Aquí quiso decir wa:n yo:n}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts85">
                <ANNOTATION_VALUE>{Hubiera dicho mah tikihto:ka:n}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts195">
                <ANNOTATION_VALUE>{Así aunque se escucha con la segunda /a/ larga}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
