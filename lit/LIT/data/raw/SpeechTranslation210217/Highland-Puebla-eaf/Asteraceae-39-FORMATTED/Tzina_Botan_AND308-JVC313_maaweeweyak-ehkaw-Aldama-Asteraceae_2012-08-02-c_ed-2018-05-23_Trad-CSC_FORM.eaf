        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Pues eso es todo de lo que nos platicamos, dime como te llamas y de donde, de donde vienes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
