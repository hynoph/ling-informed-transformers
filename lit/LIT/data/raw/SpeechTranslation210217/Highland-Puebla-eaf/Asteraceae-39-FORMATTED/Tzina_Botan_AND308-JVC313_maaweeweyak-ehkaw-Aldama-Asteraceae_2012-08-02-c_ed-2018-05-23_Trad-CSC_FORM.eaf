        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts181">
                <ANNOTATION_VALUE>Pos yehwa sah yo:n, nika:n, nika:n timona:mikih nimitstahtania ox no: tiki:xmattok *porque** neli tiki:xmattokeh yo:n pero ...</ANNOTATION_VALUE>
