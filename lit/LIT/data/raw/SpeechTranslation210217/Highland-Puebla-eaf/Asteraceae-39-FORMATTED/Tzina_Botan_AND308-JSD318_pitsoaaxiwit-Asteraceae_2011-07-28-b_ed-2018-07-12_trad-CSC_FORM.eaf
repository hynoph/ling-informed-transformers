        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
                <ANNOTATION_VALUE>Pero yehwa yo:n, neh no: nikmattok *de que**,</ANNOTATION_VALUE>
