        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
                <ANNOTATION_VALUE>Wa:n ke:masá: nikita neh i:pa xo:chiohtok ya. I:pa xo:chiohtok ya, n' ima:ko se:wtok ya ika ne:n xo:chitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts340">
                <ANNOTATION_VALUE>Pero a:mo ke:man nikita, ne:n, tsikitsitsi:n mah,mah e:wto ihkó:n tsikitsitsi:n *porque**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
                <ANNOTATION_VALUE>ihkó:n xo:chimeh seki se: kita pe:wa, nijó:n, moskaltihtiw ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
                <ANNOTATION_VALUE>I:n neh ke:masá: nikita pero i:pa, i:pa xo:chiohtok ya.</ANNOTATION_VALUE>
