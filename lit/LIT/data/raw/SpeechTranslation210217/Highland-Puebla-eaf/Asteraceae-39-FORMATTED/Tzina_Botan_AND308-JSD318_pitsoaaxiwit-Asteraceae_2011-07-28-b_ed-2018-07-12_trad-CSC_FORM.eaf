        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
                <ANNOTATION_VALUE>E:ktila:wtok, pero a:mo nikita ke:maniá:n *mero**</ANNOTATION_VALUE>
