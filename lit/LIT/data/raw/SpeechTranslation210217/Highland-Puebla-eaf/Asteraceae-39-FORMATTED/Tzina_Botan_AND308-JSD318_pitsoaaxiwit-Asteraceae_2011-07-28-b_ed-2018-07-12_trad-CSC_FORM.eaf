        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>Pues yo lo..., te dije también de que también lo..., sé, este,</ANNOTATION_VALUE>
