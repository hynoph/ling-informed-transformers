        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts346">
                <ANNOTATION_VALUE>I:pa yetok ya nochi xo:chioh ya, ne:n, ne:stok, eh, ne:n</ANNOTATION_VALUE>
