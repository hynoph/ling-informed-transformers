            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>También son amarillas sus flores y</ANNOTATION_VALUE>
