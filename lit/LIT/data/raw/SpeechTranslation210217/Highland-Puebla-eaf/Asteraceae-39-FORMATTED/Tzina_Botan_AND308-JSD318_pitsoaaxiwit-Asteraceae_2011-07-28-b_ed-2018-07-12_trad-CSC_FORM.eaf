        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>se hacen como unos capulines y nada más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Si, son amarillos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Pues todas las plantas tienen nombre diferente. Hay muchas hierbas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>y sus nombres son diferentes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>lo que hay aquí en la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Hay hierbas unos para remedio,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>y otros son nada más simples hierbas y otros sirven para</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>ayudar a un animal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>o algo le va aservir o nos va ayudar hasta nosotros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Para comer también solo está señalado cual. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>No vamos a comer lo que no..., lo que no nos dejaron enseñado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>este nuestros antepasados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Ese pitsoa:xiwit nunca le he escuchado a alguién,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>que lo..., lo cortan para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Lo que si, de verás lo cortan con asadón,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>o lo arrancan y quisieran que ya no se reproduzca</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>porque es muy dificil arrancarlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Y no..., no voy a decir que vamos a chapear con machete y vamos a traer un gancho,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>y con eso lo vamos a chapear porque no lo lleva.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>Si limpias con azadón, tal vez lo puedes arrancar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Pero si lo limpias a mano,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>se te van a acabar las uñas porque se va reventando..., su raiz, su tallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>Pues si. Uno de nosotros, cada uno de nosotros, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>lo conocemos con diferente nombre cada hierba que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a463" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>se da en esta tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>Una pers..., la gente lo ve así, una persona lo ve así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a465" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>una hierba que hay</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a466" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>y lo nombran con otro nombre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a467" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>Y otro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a468" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>alguién también lo va aver y le pone, le pone un nombre como lo vino escuchando en aquel, en aquel tiempo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a469" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>Y pues así aprendimos esos nombres de</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>nombres de plantas vamos a ver y nos dicen como se llama,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>unos que sirven, otros que no sirven.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>Unos le andamos teniendo miedo, unos no les tenemosw miedo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>porque unos son urticantes y otros no son urticantes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>Pero lo..., tienen nombres diferentes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Y nos enseñaron de hace tiempo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a489" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>y nos lo nombraron como se llama y eso es lo que nosotros lo..., lo conocemos hasta ahora.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>Pues yo me llamo Juan de los Santos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a491" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>Y eso conocí, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>esa siembra, esa hierba que nace, nace por si sola, ese nadie lo siembra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a493" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>Nace por si sola en la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a494" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>Y empieza acrecer y eso me enseñaron en aquel tiempo, en aquel tiempo lo que mis padres vivían.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a495" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>Donde trabajabamos pues luego dicen, ¿"Porque no hay, todavía no haces nada y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a496" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>ya tiene mucho rato que veniste?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a497" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Pero hay todo de este pitsoa:xiwit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a498" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>y no se puede arrancar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a499" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>Pero pues es muy..., ya tiene rato que veniste pero, pues si. Pues ahora que ya llegaste, pues ya ayudame también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a500" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>"Ya date cuenta porque..., n..., porque nno puedo avanzar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a501" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>Porque no puedo hacer gran trabajo y pues de verás ya tiene rato que vine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>Ya es medio día. Ahora ya ayudame.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a503" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>Para que ya veas como se trabaja porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>pues esto es muy dificil arrancar este pitsoa:xiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a505" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>Eso es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a506" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>Pues yo ya te informé con esto de</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a507" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>esta hierba del que nace. Y eso es todo lo que le conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
