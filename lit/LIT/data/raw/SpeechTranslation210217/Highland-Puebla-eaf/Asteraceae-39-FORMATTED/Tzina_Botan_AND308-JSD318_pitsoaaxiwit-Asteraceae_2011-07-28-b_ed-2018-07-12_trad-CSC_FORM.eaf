        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>pues igual tampoco sé si es que sabe rico o como o que tipo de pájaros, pájaros que se lo comen.</ANNOTATION_VALUE>
