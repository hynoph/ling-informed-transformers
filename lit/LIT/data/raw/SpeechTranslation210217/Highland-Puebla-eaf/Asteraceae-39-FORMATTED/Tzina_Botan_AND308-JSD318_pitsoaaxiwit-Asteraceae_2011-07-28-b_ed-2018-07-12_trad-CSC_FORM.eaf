        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>En algún lugar los ve uno así de chiquititos.</ANNOTATION_VALUE>
