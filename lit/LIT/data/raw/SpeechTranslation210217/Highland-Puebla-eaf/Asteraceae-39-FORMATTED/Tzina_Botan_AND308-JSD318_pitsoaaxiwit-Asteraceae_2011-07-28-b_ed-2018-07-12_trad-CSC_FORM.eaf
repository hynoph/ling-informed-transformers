        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
                <ANNOTATION_VALUE>katí:n, katí:n to:nal pe:wa xo:chiowa.</ANNOTATION_VALUE>
