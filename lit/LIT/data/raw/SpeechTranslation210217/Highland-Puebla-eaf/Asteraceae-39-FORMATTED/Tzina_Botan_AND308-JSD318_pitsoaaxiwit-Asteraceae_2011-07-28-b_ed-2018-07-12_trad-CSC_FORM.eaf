        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
                <ANNOTATION_VALUE>No: se: kihtowa pos nika:n i:n onkak i:n a:pitsoxiwit.</ANNOTATION_VALUE>
