        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>así nues..., nues..., con eso nos curaban nuestros padres, para nues...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a101">
