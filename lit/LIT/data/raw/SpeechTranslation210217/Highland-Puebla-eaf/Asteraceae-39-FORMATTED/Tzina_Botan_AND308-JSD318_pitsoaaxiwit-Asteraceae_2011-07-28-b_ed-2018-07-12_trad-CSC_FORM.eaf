        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
                <ANNOTATION_VALUE>Wa:n ixo:chio pos yeh, nijó:n, kohkostik, n' ixo:chio pero</ANNOTATION_VALUE>
