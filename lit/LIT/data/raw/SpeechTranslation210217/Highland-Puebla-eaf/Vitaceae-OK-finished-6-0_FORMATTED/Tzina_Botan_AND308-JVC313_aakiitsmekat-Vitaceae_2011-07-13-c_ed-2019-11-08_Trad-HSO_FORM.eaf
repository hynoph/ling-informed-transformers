            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Y no se seca si uno lo..., lo..., Como usted me platica que no se seca. Uno lo enreda así o lo cuelga uno por ahí,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
