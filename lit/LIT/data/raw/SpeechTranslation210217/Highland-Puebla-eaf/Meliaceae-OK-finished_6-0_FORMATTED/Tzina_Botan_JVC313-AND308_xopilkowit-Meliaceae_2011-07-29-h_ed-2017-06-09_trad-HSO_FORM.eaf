        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>Tikmimilowah para, para nih..., ihkó:n *de que** ixwa ya,</ANNOTATION_VALUE>
