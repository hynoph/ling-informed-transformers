        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>O:n de ne:n xina:ch, ihkó:n momehmela:wa ya.</ANNOTATION_VALUE>
