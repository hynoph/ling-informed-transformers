        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Ne: tikiliah yo:n xopiltet, nijó:n tik..., tikma:n..., tikma:nelowah ya.</ANNOTATION_VALUE>
