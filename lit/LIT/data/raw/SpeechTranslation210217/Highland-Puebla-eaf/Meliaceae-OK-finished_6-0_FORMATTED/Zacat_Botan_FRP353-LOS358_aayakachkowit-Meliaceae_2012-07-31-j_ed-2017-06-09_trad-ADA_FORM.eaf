        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>A:, es un tipo de pintura. A: es así pues.</ANNOTATION_VALUE>
