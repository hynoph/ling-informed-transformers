            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>Mm</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>¿Para que se usa? Pues del tronco del ayakach se puede sacar tablones.</ANNOTATION_VALUE>
