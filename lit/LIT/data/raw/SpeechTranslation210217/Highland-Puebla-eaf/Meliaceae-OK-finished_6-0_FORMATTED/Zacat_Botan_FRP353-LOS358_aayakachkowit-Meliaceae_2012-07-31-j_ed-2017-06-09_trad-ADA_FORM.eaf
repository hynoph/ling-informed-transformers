        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>¿Y cómo son las hojas, son anchas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Ah, son pequeñas y las hojas son alargadas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>A:, no tanto. ¿Y cómo son las hojas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>Las hojas salen en forma de hileras a lo largo de la rama</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>o ¿solamente las hojas son anchas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>Ah, van saliendo en forma paralela, así como salen las hojas del pesma (helecho).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>A:, y las semillas que produce,</ANNOTATION_VALUE>
