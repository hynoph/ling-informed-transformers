        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a444" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>y luego al tumbar el árbol</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a445" ANNOTATION_REF="a258">
                <ANNOTATION_VALUE>sacan los tablones y las ramas las cortan para hacer leña y quemarla.</ANNOTATION_VALUE>
