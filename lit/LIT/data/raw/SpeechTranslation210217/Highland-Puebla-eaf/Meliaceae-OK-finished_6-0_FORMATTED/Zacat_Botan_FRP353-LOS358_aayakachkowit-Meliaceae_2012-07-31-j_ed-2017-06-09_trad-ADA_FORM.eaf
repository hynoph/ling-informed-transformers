        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>¿Sirve para curar alguna enfermedad?</ANNOTATION_VALUE>
