        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>Hace tiempo, los señores,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a442" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>lo aserraban con la sierra para sacar los tablones y luego los vendían.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a443" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>Para eso lo ocupaban</ANNOTATION_VALUE>
