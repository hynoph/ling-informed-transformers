        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>pues imagina que la pintura que le añadian a la prenda.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>Entonces señora, solamente eso quería preguntarte.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>¿Y ahí donde vives, también hay?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>Ah, también hay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>Ah, es así pues.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>También allá donde vivo, también hay como unos, no tantos, quizá como unos tres árboles,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>y no, no hay tantos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>Yo digo que tampoco dejamos a que crezca la planta y tampoco nos preocupamos para sembrar más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>Y el tronco de ese árbol es muy macizo, se parece mucho al ti:ltika:wa:t. El tronco del ti:ltika:wa:t tambíen es muy duro, muy macizo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>(Después de aserrar la madera) es necesario construir luego, luego la casa porque si se deja a que se seque, ya no se entierran los clavos. Ya no, si, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Bueno, muchísimas gracias señora.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>Nos veremos pronto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>Ah, pues ya me voy.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Señora, discúlpame, otra vez quiero..., ya me había despedido de tí y otra vez me he regresado por me acordé (para preguntarte)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>Una vez que se tumba el árbol, la madera que se saca del tronco para qué se usa?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>¿Para que lo usan?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>A, para tablones.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>Ah, solamente para eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>Mm, para cocinar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>Ah, (la leña) también sirve para cocinar, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a450" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>A:, es así pues.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>Pues está bien, ahora que me has informado, porsteriormente, quizá tumbe uno que tengo allá en mi terreno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a452" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>Entonces por lo menos eso me he enterado, se usa para la construcción de una casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a454" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>Y también puede servir para cercar una casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a455" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>A:, bueno. Entonces, si algún dia vas a visitarme señora</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a456" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>y no me reconoces, yo me llamo Francisca Rivera Pérez.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a275">
                <ANNOTATION_VALUE>¿Y usted cuál es su nombre?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>Ah, en Tecoltepec, yo en Tepango tengo mi casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>Allá en Zacatipan, un poco más allá de Zacatipan. Aha.más allá de Zacatipan. Aha, si acaso algún día pasas por allá pues preguntas por mí, con el nombre que te he dicho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a463" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>Aha. Entonces señora nos vemos a la próxima, solamente eso se me había olvidado preguntarte por eso regresé para que informes bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>Ahora si ya me voy.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Leonor Segura Osollo" PARTICIPANT="Leonor Segura Osollo" TIER_ID="LSO Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Pues yo lo conozco, es un árbol que crece grande y de un buen tanto de grosor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Es un árbol grueso con hojas redondas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>También, todo el tronco es muy duro, macizo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Mm, es muy resistente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Y las varas de las ramas también..., al tumbar el árbol, se cortan las ramas para usar como leña, es muy bueno, arde muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Rinde mucho por la brasa que genera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Si, la lumbre es muy fuerte.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Es muy buena madera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Es muy resistente (el tronco de ese árbol).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Si es cierto, sirve (para construir una casa)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Ya no se puede, pues ese es muy duro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Y...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Pues, las hojas son lisas y también florea pero no sé, no recuerdo en qué momento florea, pero sé que los frutos se maduran en marzo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Los frutos se caen. Los frutos se parecen como las mazorcas, tiene una cubierta (como conchas que cubren las semillas)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>El centro del fruto es cilíndrico y ahí salen las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Ehe, ahí salen las semillas, se parece a la mazorca, del que nos alimentamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Las conchas que protegen a las semillas se parece a una mazorca y en el interior, las semillas se forman en capas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Las semillas son pequeñas que se desprenden del tallo del fruto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Son pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Eso es lo que yo conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>¿Eh?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Son grandes, son grandes, pues se hacen grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>pues sirve para..., uno puede recoger ahí donde caen (debajo del árbol) y poner al sol, extendiéndolo para que se seque y después ocuparlo para hacer tortillas, (como leña, para cocinar).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Si, sirve para..., sirve para y yo digo que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>También genera buena lumbre, arde muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>La flor de la caoba arde muy bien (la cáscara que cubre las semillas)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Se puede recoger.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>Mm, (cuando el fruto se madura), se parte o se abre, se caen las conchas que cubren las semillas, como cascarón. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>Una vez que se caen las conchas o la cáscara, caen otras más delgadas (estas son las semillas).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Son esas, que cubren las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Después cae la capa que hay debajo de las conchas, esa capa es donde están las semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Como si fuera...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Son pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Son pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>No tanto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Ah, no tanto..., esas hojas no son tan alargadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>No, las hojas salen en forma paralela.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>Se van formando en forma de paralela, van bien formadas, ehe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Salen bien formaditas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>No, esa (semilla) no sirve como medicina, solo se usa para teñir telas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>Las que tejen, la ocupan para teñir las telas, por ejemplo para teñir al que le llaman koyo:ma:mal, le echan el extracto de la caoba por eso toma el color de koyo:tik.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>Lo hervían con una cubeta y ahí se quedaba todo el extracto, muy espesa, pero hervían la corteza del árbol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>Pero ocupaban la corteza del árbol.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>Mm, solamente la corteza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>Y sale muy espesa, como la melaza y cuando ya echan sobre la prenda a teñir </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>Mm, ya le echan sobre la prenda tejida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a388" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>Ya hacen el chal o reboso para cargar un bebé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a389" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Y la prenda ya toma el color a koyo:tik, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a206">
                <ANNOTATION_VALUE>Porque allá donde yo vivo, conocí a gente que se dedicó al tejido,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>elaboraban unos tejidos que le llamaban pa:palte:lmeh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>Elaboraban los pa:palte:lmeh y todos eran pintados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>Ya no los elaboran</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Pero hace tiempo cuando yo era joven, elaboraban los pa:palte:lmeh, koyo:ma:malmeh y ocupaban el algodón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>Si, sale muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>Y los pilma:malmeh salían muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a222">
