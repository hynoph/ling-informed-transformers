        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a104" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>kwowtsapot. Iwkitisneki a, sayoh *que** ne: iwe..., weyakaxtik sah, tepitsi:n weyak mahyá: ayakach,</ANNOTATION_VALUE>
