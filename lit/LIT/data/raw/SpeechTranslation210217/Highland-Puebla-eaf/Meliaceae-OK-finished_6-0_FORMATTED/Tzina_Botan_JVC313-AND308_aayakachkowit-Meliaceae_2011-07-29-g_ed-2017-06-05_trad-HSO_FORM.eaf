            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>ehehke:wi a n' iteyotsitsi:n wa:n kipata:naltia ya n' ehekat *cuando** eheka. Yehwa yo:n kiliah ayakachkwowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
