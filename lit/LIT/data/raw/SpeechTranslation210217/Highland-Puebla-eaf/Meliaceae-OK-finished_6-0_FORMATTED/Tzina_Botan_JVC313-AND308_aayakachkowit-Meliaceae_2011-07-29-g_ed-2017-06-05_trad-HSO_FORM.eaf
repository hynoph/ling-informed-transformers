        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>Kostik ne:wí:n wetsiti a,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
                <ANNOTATION_VALUE>wa:n ka:nsik..., ka:nsika nikita ne:,</ANNOTATION_VALUE>
