                <ANNOTATION_VALUE>Wa:n na:..., na:wi ki:sa n' tapa:ni, *como que** na:wi n' tap..., i..., iwki a n' ita:kka ke:meh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
