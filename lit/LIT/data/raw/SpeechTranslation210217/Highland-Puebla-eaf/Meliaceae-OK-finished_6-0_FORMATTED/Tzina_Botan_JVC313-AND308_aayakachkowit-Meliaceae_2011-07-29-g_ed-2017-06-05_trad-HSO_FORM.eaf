        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>pos seki no: se: kwiwita,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
                <ANNOTATION_VALUE>wa:n komo se: kinehneki se: kito:kas pos se: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts243">
                <ANNOTATION_VALUE>mochi:wa wa:n se: kito:ka ne:wí:n. Pero yo:n pos no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts247">
                <ANNOTATION_VALUE>no: yo:li:k para moskaltia *compadrito**. Yo:n a:mo nikihto:s *de que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>moskalti:ti niman. Yo:n wehka:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>Wehka:wa, nijó:n, ka:nsika tikitstinemih yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
                <ANNOTATION_VALUE>kwowtsitsí:n wehwei,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>pero a:mo tikmatih ke:maniá:n, nijó:n, ixwak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
                <ANNOTATION_VALUE>A:mo ke:man, *bueno** a:mo ke:man se: kitas, neh nikitstinemi,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
                <ANNOTATION_VALUE>ka:nsika ihkó:n weh..., wehweikowit ya, ihkó:n wehwei,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
                <ANNOTATION_VALUE>*que** a:mo ke:man nikita mah, ihkó:n mah ...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
                <ANNOTATION_VALUE>*porque** yo:n yo:li:k, yo:n a:mo k..., nikihto:s ke:meh teihsá: ihkó:n *plantas** moskaltia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts273">
                <ANNOTATION_VALUE>Nijó:n *siempre** wehka:wa, x..., 'mati ka:nachi, ka:nachi xiwmeh ne: kipia para,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>para moskaltia nijó:n kowit, yo:n ayakachkwowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>Yo:n *lo más** kiliah ayakachkwowit *porque**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
                <ANNOTATION_VALUE>*hasta** o:me taman, yo:n no: kiliah a:y...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
                <ANNOTATION_VALUE>yayakach yo:n se: kima:a:wiltia *cuando** yo:n se: kichi:wa, ne:wí:n se: mihto:tia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
                <ANNOTATION_VALUE>Wa:n no: yo:n, yo:n kiliah, yo:n a:chá: tikimat...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts287">
                <ANNOTATION_VALUE>tiki:xmati seki chiktehtsitsi:n, yo:n no: kiliah i:ya:..., i:ya:kachmeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts288" TIME_SLOT_REF2="ts291">
                <ANNOTATION_VALUE>Yo:n seki pankwi:kwiltikeh, yo:n iya:kach no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
                <ANNOTATION_VALUE>Tehtekolotikeh. A:, pos no: tiki:xmati *compadrito.**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
                <ANNOTATION_VALUE>Yehwa yo:n no: *mismo de** yo:n kowit, no:, no: ni...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
                <ANNOTATION_VALUE>ik..., iwki mono:tsa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts301">
                <ANNOTATION_VALUE>*Cuando** yehwa ihkó:n neh nik..., nikmattok nijó:n i:ya:kachkowit pos kiliah checar iya:kachkowit *porque**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
                <ANNOTATION_VALUE>mopihpilowa n' ite:mpan, pero .... Wa:n ixo:chio pos neh a:mo no: nikta:lihtok *cuidado** ki:ní:w.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
                <ANNOTATION_VALUE>Kox yo:n, kox nijó:n nik..., ke:mah, a:mo ke:man nikitstok nijó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
                <ANNOTATION_VALUE>mah nik..., nikte:mo, nijó:n mah nikita nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
                <ANNOTATION_VALUE>ki:ní:n yetok ne:n xo:chit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
                <ANNOTATION_VALUE>Kox chi:chi:ltik oso kostik oso *morado**. A:mo nikitstok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
                <ANNOTATION_VALUE>A:mo nikita ki:ní:w, sayoh nikita yeh yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
                <ANNOTATION_VALUE>tahtapa:ni wa:n ki:sa ne:n ie:wayotsi:n wa:n pata:ni a yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
                <ANNOTATION_VALUE>yo:n ihkwí:n ke:meh n' iahtapal ne:n, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts321">
                <ANNOTATION_VALUE>pa:pa:lot. Ke:meh tsi:kat n' i..., n' iato..., n' iahtapal wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
                <ANNOTATION_VALUE>pos ne:wí:n wehwetsiti, ihkwi:kwí:n de we:we:yaktsitsi:n, a:chá: no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts327">
                <ANNOTATION_VALUE>a:chá: no: tiki:xmattok *compadrito**, yo:n nochi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
                <ANNOTATION_VALUE>Pos yehwa yo:n neh a:mo nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts361">
                <ANNOTATION_VALUE>ni..., nikitstok de n' ie:kapan ki:ní:n yetok pero,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
                <ANNOTATION_VALUE>Neh nikita sah nijó:n wa:n pata:ni wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
                <ANNOTATION_VALUE>pos yehwa ne:n ik..., n' ikowyotsi:n pos yehwa kwaltia para nochi ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
                <ANNOTATION_VALUE>nochi n' towapalwa:n, ihkó:n ke:masá: ne: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts371">
                <ANNOTATION_VALUE>kitekih ihkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
                <ANNOTATION_VALUE>Achi no: tepitsi:n, yo:n alaxtik moka:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts377">
                <ANNOTATION_VALUE>Alaxtik, pero no: seki ka:mpa kipia n' ii:x, pos no: xixipochtik moka:wa *porque** takwa:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts381">
                <ANNOTATION_VALUE>Yehwa yo:n nochi k..., kikwih ke:masá: pos no:, ke:masá: kwa:tsi:ke:wi, pero a:mo nochi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
                <ANNOTATION_VALUE>Seki n..., kwa:tsi:ke:wi, pos, ne:n, de n' tsi:ke:wi pos no: ne:wí:n ke:masá: ki..., kisoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
