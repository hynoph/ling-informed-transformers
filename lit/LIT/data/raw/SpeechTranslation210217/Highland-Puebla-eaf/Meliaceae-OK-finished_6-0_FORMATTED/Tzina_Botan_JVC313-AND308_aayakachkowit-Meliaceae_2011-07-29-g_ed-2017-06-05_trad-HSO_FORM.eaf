        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts190">
                <ANNOTATION_VALUE>Ixwa ka:nsika ihkwi:ntsitsí:n *matitas**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>wa:n ixwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
                <ANNOTATION_VALUE>Pero yo:n no: taman ne:n i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>n' it..., n' iteyo. Yo:n no:, yo:n kiliah a:mo ahwia:k, yo:n achi tsohya:k,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts198">
                <ANNOTATION_VALUE>*porque** ke:yeh, nijó:n ka:nsika se:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>ihkó:n se: kihnekwi,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts202">
                <ANNOTATION_VALUE>pos niman se: kihtowa, nika:n yehwa i:n kowit, i:n ayakachkowit *porque** ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>Pos yo:n a:mo nikihto:s *de que** tik..., tikihto:tih tehsá: chikt...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>chiktehtsitsí:n kikwa:tih, ta: yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts209">
                <ANNOTATION_VALUE>pos i:pa para nijó:n teih..., teihsá: kaltsí:n ihkó:n kichi:wah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>wa:n yo:n i..., iya:kach kiliah *porque** pos yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>kwaltsi:n no: tak kakisti, tak de wa:ki,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
                <ANNOTATION_VALUE>*o** porin pihpilkak ihkó:n ima:te:mpan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>N' ima:te:mpan wa:n tahtapa:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
                <ANNOTATION_VALUE>Nikneltoka ki:sa na..., na:wi, na:wi taman, na:wi, de nika:n se: 'ki:xtia na:wi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
                <ANNOTATION_VALUE>*Después** tak de chika:waya, pos ki:sa ya n' iteyo wa:n ne:wí:n kwi:ka n' ehekat, pata:ni,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>ka:nsika *hasta** ihkó:n se:, yetok itech se: xiwma:ko ihkó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>ompa yetok yo:n i..., n' i..., n' ix..., n' ixo:chiyotsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>wa:n yo:n tak n' iteyo ne:wí:n wetsiti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>Ne:wí:n wetsiti ka:nsika tak yo:n, tak ox a:it ke:ní:w mochi:wa *porque** ka:nsika se: kita,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
                <ANNOTATION_VALUE>miakka:n ixwatok ihko:ntsitsi:n, ne:n, *matitas** wa:n</ANNOTATION_VALUE>
