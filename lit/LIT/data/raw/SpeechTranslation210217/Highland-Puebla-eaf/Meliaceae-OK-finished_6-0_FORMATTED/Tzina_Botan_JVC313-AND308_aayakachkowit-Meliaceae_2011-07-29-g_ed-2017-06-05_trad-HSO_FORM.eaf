        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
                <ANNOTATION_VALUE>ompa ne: xi:ntok wa:n ixwa.</ANNOTATION_VALUE>
