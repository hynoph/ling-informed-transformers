        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Con eso se cura uno. Mmm. Y poco a poco, uno se le olvida los síntomas de esa enfermedad, porque uno se siente muy mal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Se quita el dolor (olvidando la enfermedad)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>No, pues es muy buena medicina. Yo sé que es muy buena medicina porque con eso nos curábamos hace tiempo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Y la persona quien nos curaba, pues ella nos decía que las hojas del (tio:kowit) es medicinal y esta es muy buena medicina, yo lo conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Él nos decía por eso sabemos que ciertamente es medicinal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Mm, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>No nos cura, mmm. (Nos curamos) solamente con las hierbas, uno se cura con las plantas medicinales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Mm. Pues uno se enferma repentinamente y no se da uno cuenta en qué momento fuimos embrujados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Uno no se entera, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Quiza sea por eso. O quizá ya es la mala suerte de que uno se enferme.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Ah, de esa enfermedad nos ataca en cualquier momento, puede ser en el trayecto de un camino, cuando vamos a alguna parte, en ese momento nos sopla el (mal) aire.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Mm, por eso nos enfermamos, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Mm, si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Si. Si, que se bañe uno con (el gua hervida de) esas hojas, mm, mmm. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Que se hiervan (las hojas) y luego ya se baña uno, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Esas, las flores del tio:kowit, ..., las hojas, mmm. El cedro rojo y el blanco o quien sabe cual es, porque uno se da cuenta que es rojo o blanco después de haber cortado, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Si, mmm. Se despinta, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>Así te llamas, bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Yo me llamo Leonor Osollo Segura, vengo de Tecoltepec.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
