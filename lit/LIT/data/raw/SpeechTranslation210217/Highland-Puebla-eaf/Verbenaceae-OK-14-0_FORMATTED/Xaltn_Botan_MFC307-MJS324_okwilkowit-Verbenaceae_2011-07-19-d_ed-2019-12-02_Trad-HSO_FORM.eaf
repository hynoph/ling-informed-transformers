        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>lo.., le damos uso ¿Por qué? porque lo usamos para curar a nuestro bebé</ANNOTATION_VALUE>
