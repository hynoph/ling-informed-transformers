        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>Tikwi xoxowik wa:n tiki:xtilia n' *imatecayotsi:n**,</ANNOTATION_VALUE>
