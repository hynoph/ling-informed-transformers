        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Y al hincharse es como le..., si le va hacer efecto cuando le aplicas la manteca de ese gusano, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>entonces todo se va a desprender. Se va a despprender.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Como lo vayas aplicando, debe de quedarse en la tela, como si lo fuera cor..., cortando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Lo..., lo va cortando lo afectado</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>y entonces lo va desprendiendo, lo va desprendiendo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Entonces usted lo sigue limpiando con mucho cuidado, sigues limpiando con cuidado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Y se..., una vez que ya sale todo lo..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>nada más lo revisas como va quedando y si el niño todavía le dan de mamar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>entonces ya le das de mamar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>para ver que ya puede mamar bien, ya toma su leche,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>pues es que ya se ha limpiado dentro de su boca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Así los cura uno.</ANNOTATION_VALUE>
