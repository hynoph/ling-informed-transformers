        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>se: 'ki:xtilia n' *ipuntita** wa:n ke:mah se: kite:kilia n' a:tsí:n,</ANNOTATION_VALUE>
