        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>mi madrina puede platicarnos cómo lo sabe porque</ANNOTATION_VALUE>
