        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Y si nos hace efecto pues ya nos sentimos muy a gusto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Sí, si este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>de verdad si nos hace efecto pues mucho más las..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>buscamos más de que..., para seguir tomando si vemos que nos da resultados de lo que ya hemos tomado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>entonces buscamos más para este..., volver a hervirlas y seguir tomando.</ANNOTATION_VALUE>
