        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>a veces</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>si te..., te..., tienes m..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>un fuerte dolor y tienes diarrea. Pues a veces es buen..., bueno tomar para la,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>para curar la diarrea,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>también es muy buen remedio para curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Que hiervan las hojas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>y que le den de tomar a uno, deben esperar que reduzca el agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>debe reducir en el momento que este hirviendo y le dan de tomar a uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Uno debe tomarlo. Y después de tomar, si uno siente que se calma el dolor estomacal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>o si ya se te quitó el dolor pues este..., es cierto que ya te estás aliviando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Pero si no se calma el dolor es porque no te está haciendo efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Pero luego vuelven a preparar, preparan pero vuelven a juntar más hierbas todavía,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>las vuelven a hervir como si las tostaran, y después de eso lo...,  las hierven hasta que reduzca el agua decimos nosotras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Eso es y luego le..., le da..., le dan al paciente para que se la tome. O si te da este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>este la muje..., enfermedad de las mujeres es más</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>a veces te enfermas de repente, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>a nosotras las mujeres decimos que se detiene nuestra regla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>entonces esa planta también la usan para curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>La..., las hierven y le dan de tomar a uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Y la empiezan a dar un poco de masajes a uno para que, para que ablande un poco nues..., nuestro abdomen, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>porque a veces también se detiene con eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Le hace efecto a uno. Le hace efecto a uno. Y pues acá venimos, acá he..., hemos venido pero ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Pues algunas se..., decimos que nos da un poco de pena,</ANNOTATION_VALUE>
