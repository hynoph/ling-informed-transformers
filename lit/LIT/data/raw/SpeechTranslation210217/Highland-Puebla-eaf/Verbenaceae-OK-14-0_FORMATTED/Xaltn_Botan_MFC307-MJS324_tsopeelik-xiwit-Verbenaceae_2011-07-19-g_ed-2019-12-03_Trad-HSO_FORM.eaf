            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>como las personas que se encuentran acá, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>también quieren saber cuáles son las plantas que utilizamos para curarnos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Solamente los mestizos pues ellos usan otras medicinas diferentes, pero también quieren saber acá nosotros los &lt;i&gt;ma:se:walmeh&lt;/i&gt; con qué nos curarnos cuando nos enfermamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Pues acá nosotros hacemos uso de las plantas. La..., hervimos un,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a87">
