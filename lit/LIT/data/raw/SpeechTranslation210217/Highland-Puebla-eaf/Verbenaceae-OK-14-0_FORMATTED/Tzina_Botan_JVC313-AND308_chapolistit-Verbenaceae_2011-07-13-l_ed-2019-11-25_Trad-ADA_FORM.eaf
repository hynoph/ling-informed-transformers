        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts295">
                <ANNOTATION_VALUE>¿*porque** ke:yeh? a:mo k..., a:mo, a:mo molo:ni. *Bueno** a:mo panowa itech n.... A:mo.</ANNOTATION_VALUE>
