        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts301">
                <ANNOTATION_VALUE>Pos moneki mah se: kixahxama:ni kwaltsi:n, kwaltsi:n.</ANNOTATION_VALUE>
