        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>a veces, ese,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Nosotros le llamamos mal de orín, mal de orín.</ANNOTATION_VALUE>
