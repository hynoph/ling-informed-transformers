            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Una vez que queda muy poco, ya lo bebe uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
