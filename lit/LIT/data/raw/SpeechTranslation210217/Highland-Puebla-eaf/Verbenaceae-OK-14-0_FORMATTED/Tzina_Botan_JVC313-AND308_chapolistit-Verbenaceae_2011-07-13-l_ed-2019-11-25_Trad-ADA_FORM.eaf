        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>chapolin, pues cómo le llaman, este, también es bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Es bueno y algunos no lo sabemos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>Ah, también, pues hay tres tipos. Yo solamente lo estoy viendo de esa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>Muchos me preguntan, ¿porqué le llaman chapolistit?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>Le llamamos chapolistit porque tiene las flores dispersas y las tiene así, así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>Por eso le llamamos chapolistit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>Este, pero ese es bueno, este, se parece al masa:owat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>Pues también, este, nos cura.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>Eso, muchas personas no lo sabes y muchas sí saben.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>Sí, muchas sí saben cómo hacerlo, este, es muy buena medicina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>Porque el masa:owat se parece a la caña, las hojas son muy bonitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>Las hojas no, no sirven, de ese ocupan la base de los tallos, los más recios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>El más recio porque el tierno no sirve.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>No sirve porque es tierno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a216">
                <ANNOTATION_VALUE>El que es recio, a veces lo corto el más recio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>De este tanto de grueso y lo corto y lo machaco así,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a410" ANNOTATION_REF="a218">
                <ANNOTATION_VALUE>Lo machaco y luego ya paro sobre ...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>Ya lo paran y ..., a veces yo lo hago, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>Pues ese es medicinal, algunos no lo sabemos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>Tambié algunos ..., he visto que algunos lo paran sobre,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>pero así enteros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>Y si son enteros no, no sirve.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>¿Porqué? no, no, no hierve, no pasa en el ..., no.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>Y es eso es lo que ahora ...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>Pues es necesario machacarlo muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>Que lo apachurre muy bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Pues es eso lo que ahora estamos platicando compradrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>Pues así está bién, nos damos cuenta cómo lo vimos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Cómo es nuestro remedio sobre nuestra medicina</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>que nosotros trabajamos el campo. Pues todo lo sabemos cómo, como este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>al que le llaman chapolistit. Y muchos no lo conocen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Muchos no lo conocen. Unos dicen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>"¿Cuál es el chapolistit?" Yo no lo conozco ...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>Ellos conocen los chapulines, este, este, los corren, las uñas de los chapulines.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Están vivos. Y no, pues es una hierbita, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>así, este, esta es una hierbita, al que le llamamos chapolistit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>Entonces ese es muy bueno. Es el que te estoy diciendo para esa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>pero que se use para otra cosa, que yo diga que es comestible, que uno lo va a hervir, no es comestible.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>Sí, eso es posible, compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>Solamente eso. Bueno compadrito.</ANNOTATION_VALUE>
