            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Y les digo pues cuando yo lo tengo, este,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a158">
