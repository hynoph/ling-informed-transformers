        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts291">
                <ANNOTATION_VALUE>Wa:n yo:n ahahsitok a:mo, a:mo kwaltia.</ANNOTATION_VALUE>
