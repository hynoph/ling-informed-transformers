        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>Ke:mah, pero a:mo nikmati ki:ni:n, teh xa: tik..., [ti]ki:xmattos *más**</ANNOTATION_VALUE>
