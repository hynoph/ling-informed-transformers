        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts130" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>Yehwa yo:n ti..., nika:n nimitstahtania neh, nijó:n, yehwa yo:n nikmati para, nijó:n, semi kwali para ne:n *remedio**.</ANNOTATION_VALUE>
