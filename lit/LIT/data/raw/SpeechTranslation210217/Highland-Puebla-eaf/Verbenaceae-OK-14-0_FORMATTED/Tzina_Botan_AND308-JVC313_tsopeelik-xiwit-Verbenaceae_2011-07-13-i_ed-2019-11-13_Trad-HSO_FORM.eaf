        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>Ne: chi:chi:ltik n' ixo:chio, achi chi:chi:ltik.</ANNOTATION_VALUE>
