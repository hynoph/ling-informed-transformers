        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Nada más para el mal de boca, se hierve y se </ANNOTATION_VALUE>
