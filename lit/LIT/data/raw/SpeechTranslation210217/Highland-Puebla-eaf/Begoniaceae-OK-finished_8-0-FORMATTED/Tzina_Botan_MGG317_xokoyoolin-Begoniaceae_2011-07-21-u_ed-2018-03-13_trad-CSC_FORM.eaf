        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>El xokoyo:lin solo es agrio. Si esos son los que yo conozco.</ANNOTATION_VALUE>
