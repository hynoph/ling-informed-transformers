        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a119" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>Yeh, nejé:n, a:mo no:, a:mo teh kipia tei.</ANNOTATION_VALUE>
