        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Si es que uno quiere tambié se puede comer pero no es común que se consuma.</ANNOTATION_VALUE>
