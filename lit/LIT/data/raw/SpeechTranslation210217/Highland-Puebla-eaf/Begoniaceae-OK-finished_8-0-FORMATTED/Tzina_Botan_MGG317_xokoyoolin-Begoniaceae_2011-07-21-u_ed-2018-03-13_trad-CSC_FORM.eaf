            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>no es pubescente en los tallos. Y el pe:sohxokoyo:lin es muy pubescente de los tallos.</ANNOTATION_VALUE>
