        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>¿Ke:ní:w se: ki:xmati ne:n pesoh..., eh, pe:sohxokoyo:lin wa:n teko:seh?</ANNOTATION_VALUE>
