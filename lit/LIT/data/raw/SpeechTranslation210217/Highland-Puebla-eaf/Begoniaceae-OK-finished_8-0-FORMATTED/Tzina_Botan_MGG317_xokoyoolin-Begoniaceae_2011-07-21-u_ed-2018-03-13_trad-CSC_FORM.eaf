        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Como del que hablamos hace rato, el que se da en el suelo no se come.</ANNOTATION_VALUE>
