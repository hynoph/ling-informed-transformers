        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>Yeh i:pa ihko:ntsitsi:n n' ima:..., ima:kwowyo ka:mpa</ANNOTATION_VALUE>
