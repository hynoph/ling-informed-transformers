        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Si es que uno quiere se corta una hoja y se puede comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Con uno es suficiente, no se necesitan muchas. Si pero no sabe a nada,  no tiene nada (de sabor).</ANNOTATION_VALUE>
