        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Se puede encontrar por ahí en las orillas de caminnos o en los potreros.</ANNOTATION_VALUE>
