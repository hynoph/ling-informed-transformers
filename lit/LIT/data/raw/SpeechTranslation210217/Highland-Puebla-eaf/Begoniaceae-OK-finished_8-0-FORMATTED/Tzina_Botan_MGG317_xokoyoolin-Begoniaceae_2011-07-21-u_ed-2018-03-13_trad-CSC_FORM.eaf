        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Wa:n yehwa, ka:n kipia, ka:n kipia oksé: taman *más**. Ke:mah.</ANNOTATION_VALUE>
