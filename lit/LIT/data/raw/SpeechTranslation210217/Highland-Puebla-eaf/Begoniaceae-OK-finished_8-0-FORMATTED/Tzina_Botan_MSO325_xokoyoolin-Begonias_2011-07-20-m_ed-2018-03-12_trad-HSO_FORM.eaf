    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Amelia Domínguez Alcántara" PARTICIPANT="Amelia Domínguez Alcántara" TIER_ID="ADA Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Hace rato platicábamos y me hablaste de muchas cosas, este me platicaste.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Este ahora quiero que me platiques si cono...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>si conoces varios tipos de xokoyo:...,  o que haya varios tipos de xokoyo:lin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Este xokoyo:lin cómo se come o cómo se prepara para hacer la comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>No el xokoyo:lin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>¿Y entonces el xokoyo:lin se echa antes?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>El xokoyo:lin siempre la compran, no se da allá en donde tu vives.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>¿Y el teko:seh también se prepara igual como este ...?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Se prepara diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>¿Y sólo se usa la ce..., ceniza para sacarle lo ácido o se le puede sacar de otra forma?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>De estos dos que me dices que los conoces y el otro k..., siempre los haz consumido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>A mi me platican que hay uno que se llama kiowtehxo..., kiowteyo:xokoyo:lin no sé si usted lo conoce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Y hay otro también, también lo..., me..., me dicen que hay otro que le llaman tohmiyoh xokoyo:lin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Y hay otro que dicen que se llama xo:xokoyo:lin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Que es lo que se hierve, las hojas o el tallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Yo pienso que también lo haz de conocer y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>mm, quizás también se consuma con uno que le llaman esquina xokoyo:lin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Este no se come, no se usa para preparar comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Pues si hay varios tipos de xokoyo:l..., xoko..., xokoyo:lin, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>otro que he escuchado que se llama pe:sohx..., pe:soh xokoyo:lin, no sé si hay también ahí por donde vives.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Sí. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>¿Y lo conoces?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Y alguien te platicó que si se come.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>¿Y cómo son sus hojas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>¿Cómo a qué se parecen sus hojas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>pues este no todos se consumen. Ni todos se pueden usar para curar, sólo se usa para curar el que le llamas xo:xokoyo:lin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Y el esquina xokoyo:lin también se usa un poco para curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Pues me gustaron mucho tus...,  pensamientos que me platicaste.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>El xokoyo:lin si hay varios tipos, he visto algunos que parece que florecen nada más,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>pero no sé si de verdad son comestibles. Se da en varios lugares y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>el teko:seh también hay en donde yo vivo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>pero no sabía cómo se le saca lo ácido que tiene.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>A mí siempre me han convidado, he consumido pero ya está prepar..., preparado, nunca la he preparado para mí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Sí este..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Muchas gracias por haberme aclarado mis dudas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Ahora quiero que me digas cómo te llamas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>¿De donde vienes?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Salazar Osollo" PARTICIPANT="María Salazar Osollo" TIER_ID="MSO Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Yo conozco el que le llaman teko:seh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Y del otro xokoyo:lin que te hablaba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>Sí. Hay uno que acá nosotros casi no se da, lo traen mucho en Cuetzalan, ese si hay más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Ese xokoyo:lin siempre se compra. Pero el teko:seh lo conozco porque se da en el cafetal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>¿De ese teko:seh?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>A ese se puede, también es igual se..., primero se para la olla con frijoles para que empiece a hervir, el frijol negro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>también se debe hervir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Y cuando ya se empieza a cocer pues ya se tuesta el ajonjolí</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>se muele, que quede bien liso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>También se le agrega chile verde.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Y enseguida ya se..., se le echa agua el ajonjolí molido,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>y se le echa a los frijoles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>En seguida se le echan las hojas de nakastekilit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>De esa hojas no sé cómo, creo que siempre lo han llamado así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>No, antes le llamábamos nakasihwiyo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Nakasihwiyo. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Esa hojas también le agregamos a la comida,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>si se le echa muchas hojas a la comida para que adquiera una aroma agradable. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>E..., sí. cuando este, cuando ya se cuecen los frijoles se le echa el xokoyo:lin para que en seguida se le eche el ajonjolí,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>se muele el ajonjolí, se le agrega agua y se echa a la olla junto con el xokoyo:lin,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>enseguida s..., también se le echan las hojas de nakas..., nakasihwiyo, yo le llamo nakasihwiyo, siempre le llamamos nakasihwiyo. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Eso es lo que le ponemos y después de que empieza a hervir pues ya la sacamos del fogón que huele con un sabor agradable. Si uno le agrega muchas hojas del que le llamamos nakasihwiyo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>la comida sale con un buen sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Mm. Pero se deben agregar muchas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>También hay que moler el chile verde para echarle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Sí, se puede moler para agregarle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>El del otro siempre lo hemos comprado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Pero el teko:seh se da en el cafetal. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>No el teko:seh es diferente porque es más blando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Eso es lo que dije que se calienta poquito el agua con ceniza,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>se entibia nada más y cuando se siente que ya está tibio se echa en la olla</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>porque si se llegua a calentar bien, el xokoyo:lin se deshace fácilmente,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>y así mejor se..., se empieza a batir y se..., se va probando si ya va saliendo lo ácido del xokoyo:lin,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>para que se..., que después ya se prapare la comida. Si ya salió lo ácido pues ya se empieza a preparar también. Se hace igual, el teko:seh se echa en la olla y también se le agrega el nakasihwiyo. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>No, sólo se usa la ceniza. Mm, sólo se le quita con esa. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Mm, sí, siempre hemos preparado para la comida. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Sí lo conozco, pero de ese nunca he preparado para comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Sí lo conozco, sí. También se da, se da hasta en las orillas de los caminos, las varas de xokoyo:lin se dan así largas y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>sus hojas son parecidas a las hojas de teko:seh. Pero de ese nunca he preparado para comida, no sé si es sabroso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Sí, nunca la hemos consumido. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Sí, ese también se da en el cafetal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>También lo conozco, pero tampoco sé si es sabroso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Ese sí lo conozco también, es pubescente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Mm, no es igual como el teko:seh y otros xokoyo:lin, las demás varas de xokoyo:lin son lisas y el tohmiyoh xokoyo:lin es pubescente, este también se da en el cafetal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Xo:xokoyo:lin es el que también conozco, sus hojas se parecen a las hojas de teko:seh, también son bonitas sus ho..., pero ese,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>en el centro de las hojas tiene unas rayitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Tiene una rayitas de color rojo. Dicen que también es buen remedio, pero se</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>dicen que hierven las hojas, se usan para curar las aftas. Si uno padece de aftas bucales hay que lavarse la boca con el agua de esas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Sí, esas hojas son buenas pero para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Las hojas, las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Sí. Se hierven las hojas, se espera que se enfrie y en seguida se lava la boca. Hay que hervirlas en una olla pequeña. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Sí. Ese si lo conozco, ese, es..., se da con varas largas, así es,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Es..., dicen que ese también es bueno masticar el tallo si uno tiene mu..., muchas agruras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Es bueno masticar el tallo y tragar el jugo y se quitan las agruras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Sí, porque si uno sufre de acidéz hay que masticar el tallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Si es medicinal porque el tallo es ácido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>No.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Te dije que ese xokoyo:lin se come pero solamente se prepara con quelite, cuando se hierve el soyokilit para comida se le puede agregar dos cogollos. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Sí debe haber pero no lo conozco, ese no lo conozco. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Mm, y hay otro por allá en donde vivimos, por allá por donde lo conocen como kali:ka:mpa si hay,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>también es xo:xokoyo:lin, dicen que también es comestible pero no me acuerdo cómo se llama, esos son mas delgadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Mm. Sí. Pero no me acuerdo cómo se llama, cómo le dicen pero también es xokoyo:lin, dicen que también es sabroso, también es bue..., bueno para comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Pero las varas son más delgadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Y...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Sí lo conozco, si se da allá por donde se conoce como kali:ka:mpa. Sí lo conozco. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Pero este, dicen que también es bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Sí..., sí pero cuando yo crecí parece que nunca vi que mi madre preparara para comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Sí. Sólo me acuerdo que me decía que es comestible pero nuna lo preparaba. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>También es de hojas pequeñas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>también es de hojas pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Casi se parecen a las hojas de teko:seh pero son más pequeñas y se ve que tiene hojas más delgadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Y el teko:seh tiene las hojas más gruesas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Pues es cierto como dices que hay varios tipos de xokoyo:lin y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>No. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Sí. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>María Salazar Osollo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>De San Miguel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
