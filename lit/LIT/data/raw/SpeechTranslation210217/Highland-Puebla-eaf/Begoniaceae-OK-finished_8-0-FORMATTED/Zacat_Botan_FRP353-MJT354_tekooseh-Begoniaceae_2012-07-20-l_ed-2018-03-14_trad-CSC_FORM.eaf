                <ANNOTATION_VALUE>son de color de rosa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Si ha de ser eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Si, sus flores son de color rosa. Si, sus hojas también son bonitas. Si, pues tiene mucho parecido al xokoyo:lin normal nada más que tiene las hojas más chiquitas. Si, donde terminan las hojas son rojizas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Si, así es eso. Donde empiezan sus hojas son rojizas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Ya es eso. Si, es eso. A pues si es cierto porque cada quien lo conocemos con nombre diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Conocemos de diferente manera nuestras plantas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Pues siempre es así, pero así también sabemos como preparar nuestras comidas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>SI.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>También lo conozco pero ese se deshace si es que se hierve mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>No quiere servir muy bien y a veces lo encuentra uno muy amargo y este...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Si, que sea muy...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>si y también se necesita lavarlo bien para que no absorba la ceniza y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>se pone en agua por un rato y posteriormente ya se le agrega a los frijoles. Ese también se deshace mucho, se deshace mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Pues esto es lo que ya usamos como para variar nuestras comidas. También variamos de comida al hacerlo en guisado con eso ya estamos variando la comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Si, hace daño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
