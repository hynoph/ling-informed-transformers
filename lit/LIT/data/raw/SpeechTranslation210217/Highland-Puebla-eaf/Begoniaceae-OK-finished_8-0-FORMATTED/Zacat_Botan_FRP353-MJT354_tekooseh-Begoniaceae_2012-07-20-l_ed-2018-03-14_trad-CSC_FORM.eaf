                <ANNOTATION_VALUE>Entó:s no:, no: mahyá: no: uhki a n' tein ke:meh neh niki:xmati i:n ta...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts150" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>i:n tapalo:l. N' ta: i:n, ta: yeha i:n totapalo:l teha:n. Neli. Pero, *este**, ka..., xa: kachi kwali a, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>nochi se: kimahse:wa *puro**, nejó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts156" TIME_SLOT_REF2="ts158">
                <ANNOTATION_VALUE>ke:meh yo:n *ajolí, porque** komohkó:n nochi *manteca** a:xá: no: te:chi:wili:s *mal**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts160" TIME_SLOT_REF2="ts162">
                <ANNOTATION_VALUE>Ajá. Pos, ta: yeha n' toma:se:walemo:l, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts164" TIME_SLOT_REF2="ts166">
                <ANNOTATION_VALUE>tikiliah n' teha:n *ajolí** kwi:ka. ¿Wa:n no: ankita:liliah n' tekilit?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts170" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>A:, neli os.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts174" TIME_SLOT_REF2="ts176">
                <ANNOTATION_VALUE>Entó:s kwali etok mohkó:n nikilia neh *siquiera** tine:chtapowih, tine:chyo:lmela:wak ka ta:ká:n a:mo yeha, ne:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>Tein n' teh tiki:xmattok wa:n tein neh niki:xmattok, ta:ká:n no:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts180" TIME_SLOT_REF2="ts182">
                <ANNOTATION_VALUE>chi:chiko ne:n i..., n' i..., n' ito:ka:ywa:n xiwtsitsí:n. Ta: no: mahyá: xiwtsí:n sah pané: pero,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts184" TIME_SLOT_REF2="ts186">
                <ANNOTATION_VALUE>ta:taman tikto:ka:yi:xmatih. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts188" TIME_SLOT_REF2="ts190">
                <ANNOTATION_VALUE>¿Wa:n no: ankikwah os? Mmm. Ta: tel..., tel..., mahyá: telwe:lik. ¿No: taman ahwia:k *que** xokoyo:lin? Mmm. No: tamantik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>Entó:s i:n, i:n, uhki no: nikahsika:mati n' teh tein tikmattok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts194" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>Yeha n' tikilia n' teh teko:skat wa:n neh nikilia *tekeski:kirijó:n. Ajá**. Wa:n yeha sah na:no yo:n nimitstahtania ta: nimolia neh ta:ká:n ke:masá: se: ke:meh i:n se: kimattok kahka:ni onkak, [...]oso sepa ta:ká:n se: kite:mowa. Neli. Ajá. Entó:s, *este**, ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts198" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>Ka:n teihsá:. Ahum.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts202" TIME_SLOT_REF2="ts204">
                <ANNOTATION_VALUE>Timoka:wah uhki. Niow.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
