                <ANNOTATION_VALUE>Es más sano preparar comida regional. Si eso es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Si pues la verdad eso es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Si le ponemos eso porque allá nosotros abunda mucho en las superficies de las piedras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Si, este si pues...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>en verdad de Dios que es así, pues parece </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Los conocemos con nombre diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>También lo comemos. También lo comemos pues decimos que como que es muy aromatica, es diferente porque el que se vende en Cuetzalan es diferente, es diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Si y pues como que la comida sale muy rica. Si pues tiene dos nombres diferentes. Si. A bueno. Se pregunta uno. Si de verás, pues muchas gracias.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
