    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Francisca Rivera Pérez" PARTICIPANT="Francisca Rivera Pérez" TIER_ID="FRP Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Buenos días.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>A pues parece que no lo conozco por el nombre del que me estas hablando pero este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>a lo mejor ya es lo mismo que yo conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>nosotros, o más bien yo lo connozco como tekeski:kirijo:n, así lo conozco yo como tekeski:kirijo:n</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>porque el otro lo conocemos como xokoyo:lin</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>de verás que es el xokoyo:lin, y allá nosotros también es como el xokoyo:lin pero</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>es parecido como el xokoyo:lin pero nosotros lo conocemos como tekeski:kirijo:n porque nace aunque sea, aunque sea en</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>si aunque sea en las bases de las rocas o en las superficies de las mismas rocas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>también se da en la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>Aja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Y no lo hierven con otra cosa más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>¿Pero que le ponen?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>El agua de ceniza lo colamos con sedazo para que no lleve pedazos de carbón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Entonces es igual como yo lo preparo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Si, también lo hago de la misma manera porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>yo primero hiervo el agua con ceniza y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>ya se lo echo fuera de (la olla con frijoles).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>lo tapo con su tapadera para que se le salga lo agrio</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>y posteriormente ya lo lavo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Lo lavo y entonces ya está hirviendo la comida</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>pues ya lo...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>ya le echamos ahí para que no se deshaga mucho porque si se hierve mucho se deshace. Pero a lo mejor cuando florea es cuando se riegan sus semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Sus flores parece que son</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>si es que dices que es el teko:skat yo...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>a lo mejor es lo que yo le llamo tekeski:kirijo:n pero...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Si, sus flores son de color rosa y yo como que sus hojas son aserradas y puntiaguadas. Y en el tallo del xokoyo:lin son como rojizas. Como que son, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Yo digo que como si fuera que el xokoyo:lin es pubescente pero su pubescencia es rojiza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Si, es lo mismo que yo conozco, nada más que tu dices conocerlo como teko:skat y nosotros lo conocemos como tekeski:kirijo:n. Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Pues lo conocemos de diferente manera en cada, en cada...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Si, de verás que también sabemos así como nos fueron enseñando nuestros padres.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Pero este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>pues aunque sea xokoyo:lin pero es del otro tipo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>es muy agrio, ¿tu conoces el xokoyo:lin?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Pues se necesita despedazar mucho los que son chiquitos y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>nada más hay que enjuagarlo con agua de ceniza hirviendo, eso es lo que se le pone.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Ese también se deshace mucho, se deshace.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Entonces ya es casi igual al que yo conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>la comida. Pues esa es la comida de nosotros. Si pero a lo mejor es mucho mejor</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>comer todo de eso (natural).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>como el ajonjolí porque si todo es (preparado) con manteca a lo mejor provoca algún mal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Si pues eso es nuestra comida regional.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>nosotros le ponemos ajonjolí. Y ustedes también le ponen el tekilit?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>A es verdad entonces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Entonces esta bien como digo yo tan siquiera ya me platicaste, ya me informaste si a lo mejor no es el mismo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>el que tu conoces y el que yo tambièn conozco</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>que son diferentes los nombres de las plantas pero</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Si. Los conocemos con diferente nombre. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>¿Y entonces también lo comen? Pues parece que es muy rico. ¿Tiene aroma diferente que el xokoyo:lin? Si. Tiene aroma diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Entonces así ya me informè bien de como lo conoces tu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Es lo que tu conoces como teko:seh y yo lo conozco como tekeski:kirijo:n. Y pues es todo lo que te pregunto señora, pues pienso que a lo mejor uno sabe donde hay y a veces lo busca uno. Si. Aja. Entonces este...  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>No hay de que.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Aquí nos despedimos. Ya me voy. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
