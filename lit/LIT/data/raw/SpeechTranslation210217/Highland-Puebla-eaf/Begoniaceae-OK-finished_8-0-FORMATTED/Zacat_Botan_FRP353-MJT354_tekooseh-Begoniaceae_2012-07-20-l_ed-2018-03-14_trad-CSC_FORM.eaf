    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María de Jesús Tecuaco" PARTICIPANT="María de Jesús Tecuaco" TIER_ID="MJT Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Buenos días señora. Ya que aquí estamos juntos platicame como preparas eso que le llaman teko:seh, nosotros allá en Yhualichan lo estamos cultivando y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>sus hojas son redondas y un poco grisáceos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Y se adapta aunque sea en la tierra...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>pues ahí nace orque ahí florece y ahí mismo vuelan sus semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>sus flores son de color rosa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>A tu lo conoces con ese nombre. Y nosotros</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>A ustedes es así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>Aunque necesita muchos cuidados pero se da.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>También se da muy bien donde hay nakastekilit abundan juntos y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>ya es cuando nosotros lo cortamos, allá nosotros tenemos el nakastekilit, abunda en las superficies de las piedras y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>entonces es ese xokoyo:lin que también hay, pues a lo mejor se adapta por allá y por eso se da</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>si pues cuando nosotros queremos comer eso, lo vamos a cortar y lo preparamos hirviéndolo con agua de ceniza y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>ahí estamos haciendo el trabajo de pelarlo, bueno, primero paramos al fuego los frijoles para que ya esten hirviendo y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>cuando ya tenemos el xokoyo:lin pelado, lo lavamos y ya lo agregamos con los frijoles hervidos y también molemos el ajonjolí</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Lo hervimos con olla de barro y agua de ceniza</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>A pues este el agua de ceniza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>A pues a lo mejor lo haces de la misma manera...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Si, se le sale lo agrio, sale lo agrio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Si pues, si...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Ya le echamos (a la olla).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Y ya le echamos. Pero si se deshace mucho ya no se puede comer bien porque la comida se hace muy espesa. Ya es cuando se da en los cafetales. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
