        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts61">
                <ANNOTATION_VALUE>A:, n' kwahnexa:t. A:, Ajá.</ANNOTATION_VALUE>
