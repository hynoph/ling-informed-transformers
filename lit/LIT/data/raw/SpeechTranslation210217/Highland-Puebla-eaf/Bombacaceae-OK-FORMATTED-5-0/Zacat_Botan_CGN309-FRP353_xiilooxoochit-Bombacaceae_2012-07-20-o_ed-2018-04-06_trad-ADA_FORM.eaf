        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts124" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>Mm. Ka:n nikmati neh yo:ni. Wa:n teh a:mo, a:mo tikmatik os no: kwal....</ANNOTATION_VALUE>
