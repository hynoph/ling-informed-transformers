        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>A:, n' tikihtowa. A:, no: uhki.</ANNOTATION_VALUE>
