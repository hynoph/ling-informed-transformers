            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Sí, y eso es lo que yo pensaba si acaso sabes que sea medicinal el xi:lo:kapixxo:chit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Así es. Yo jugaba con esa flores, pero es cierto ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Pues yo pensaba como tu eres de</ANNOTATION_VALUE>
