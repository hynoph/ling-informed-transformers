        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts135">
                <ANNOTATION_VALUE>I:pa tika:wiltia:yah ne: ka:mpa no..., nowe:ita:t no: tak *que** telonkaya yeha yo:ni,</ANNOTATION_VALUE>
