        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts132" TIME_SLOT_REF2="ts133">
                <ANNOTATION_VALUE>Neh niki:xmati por xi:lo:kapix, a:mo n'mati yo:ni para toni yo:ni.</ANNOTATION_VALUE>
