    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Celina González Nazario" PARTICIPANT="Celina González Nazario" TIER_ID="CGN Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Bueno señora, una vez más nos hemos encontrado aquí, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>que platiquemos sobre el xi:lo:xo:chit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>Yo lo conozco como xi:lo:xo:chit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>y hay allá por tierras bajas, lo utilizan como linderos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>y también se ocupa para horcón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Y la flor, pues se da en el mes de mayo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>los niños lo recogen y jugamos con ellas, jugábamos con ella, yo también las jugaba cuando aún era pequeña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>Pero no sé si sepas que tenga algún uso medicinal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Aha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Sí, ya se abren.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Sí, pues eso también sé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Que sirva para medicina</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Pues es eso lo que yo te pregunto, por si acaso sabes que sirve para medicina porque nosotros solamente lo conocemos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>(como) xi:lo:xo:chitsi:n.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>También lo conocemos como xi:lo:xo:chit y xi:lo:kapix, también así le llamamos nosotros.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Y ese, cuando se seca, sirve, pues se ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>uno lo recoge para leña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Y pues sirve, donde hay árboles grandes lo tumban,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>sirve para lindero, con ello se hace corrales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Son grandes, sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Es una madera muy resistente. Así es, así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Arde bien, sí, se quema, si acaso ..., eso es lo que yo quisiera saber si acaso sirve para medicina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Tampoco se muy bien. Pues tampoco sé.</ANNOTATION_VALUE>
