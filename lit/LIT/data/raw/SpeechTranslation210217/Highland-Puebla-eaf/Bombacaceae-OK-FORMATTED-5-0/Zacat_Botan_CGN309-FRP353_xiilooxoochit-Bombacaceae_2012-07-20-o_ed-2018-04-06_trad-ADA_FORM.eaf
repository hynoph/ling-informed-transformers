        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>A:, n' ika *tacorraltiah**.</ANNOTATION_VALUE>
