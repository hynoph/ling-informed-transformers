        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>No sé si es medicinal. Sí, eso es ...,</ANNOTATION_VALUE>
