        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts128" TIME_SLOT_REF2="ts131">
                <ANNOTATION_VALUE>No: yeha n' ika tine:chtahtania:ya. Mm, pero neh a:mo no: nikmati.</ANNOTATION_VALUE>
