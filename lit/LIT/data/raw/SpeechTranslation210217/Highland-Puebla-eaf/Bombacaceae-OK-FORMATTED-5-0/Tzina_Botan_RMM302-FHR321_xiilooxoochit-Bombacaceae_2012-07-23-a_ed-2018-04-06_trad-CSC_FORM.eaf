            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>A:, ¿ne:n ikowyotsi:n? *Este**, kwaltia para tatsakwil.</ANNOTATION_VALUE>
