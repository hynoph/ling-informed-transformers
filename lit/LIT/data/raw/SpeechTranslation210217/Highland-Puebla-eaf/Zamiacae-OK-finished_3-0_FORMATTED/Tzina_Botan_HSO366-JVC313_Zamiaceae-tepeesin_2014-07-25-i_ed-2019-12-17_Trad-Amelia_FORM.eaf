                <ANNOTATION_VALUE>I..., moyewalo:ltia ne:n iteyo ihkó:n, ne:n, yo:n kowta:kilo:t ihkwí:n, mahyá: kowelo:t,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
