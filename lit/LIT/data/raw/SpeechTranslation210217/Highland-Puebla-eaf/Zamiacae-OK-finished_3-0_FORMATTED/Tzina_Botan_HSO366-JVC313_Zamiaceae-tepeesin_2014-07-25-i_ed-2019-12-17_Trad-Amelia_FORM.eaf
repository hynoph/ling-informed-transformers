                <ANNOTATION_VALUE>yehyewaltik ihkwí:n wa:n achi me..., *color, color** ke:meh, *color** ke:meh se: achi nextik sah n' *color**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
