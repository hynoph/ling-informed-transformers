        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
                <ANNOTATION_VALUE>Patachtik, patachtik ne:n, ne:n, ne:n kowtet wa:n ye:ktakwaktik.</ANNOTATION_VALUE>
