                <ANNOTATION_VALUE>Ne:, ne: mochi:wa tehtepe:te:n, ka:mpa owihka:n wa:n yo:n ixwa ne: teke:..., te..., itech n' tepe:t,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
