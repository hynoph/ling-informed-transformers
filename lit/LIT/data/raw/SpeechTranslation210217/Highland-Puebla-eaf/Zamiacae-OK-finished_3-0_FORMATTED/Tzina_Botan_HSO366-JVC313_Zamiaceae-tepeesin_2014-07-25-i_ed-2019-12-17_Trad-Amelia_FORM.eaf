                <ANNOTATION_VALUE>wa:n moskaltia, ne:n, i..., ki:sa n' ima:xiwyo, ye:k..., me..., m..., te:..., *cuando** pilimeh ok tsikitsi:n n' ima:xiwyo, *después** moskaltia, ke:meskia wei:xtiw, wei:xtiw</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
