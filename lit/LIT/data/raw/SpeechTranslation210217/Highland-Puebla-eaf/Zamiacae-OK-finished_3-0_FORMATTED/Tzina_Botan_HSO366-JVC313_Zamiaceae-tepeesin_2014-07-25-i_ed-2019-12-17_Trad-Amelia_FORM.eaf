        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>Ye:kwitsyoh ma:ski ne: xiwit a neli kwa:lkwih witsyoh no:, se: ... te:witswih ata. Pero *más** witsyoh n' ima:tsi:ntan, ka:mpa e:wa ne:n *más** witsyoh.</ANNOTATION_VALUE>
