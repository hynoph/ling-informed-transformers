        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>Ye:kwitsyoh ihkó:n, ihkwí:n, achka kipia n' iwitsyo.</ANNOTATION_VALUE>
