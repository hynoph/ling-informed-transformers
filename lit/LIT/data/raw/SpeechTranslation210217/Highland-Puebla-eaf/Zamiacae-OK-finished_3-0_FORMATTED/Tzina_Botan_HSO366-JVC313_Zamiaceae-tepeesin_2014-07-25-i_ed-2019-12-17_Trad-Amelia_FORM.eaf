        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>panki:sa, ne:n, i..., ima:tsa:lan se: ..., ihkwintsi:n mochi:wa sah ihkwintsi:n ke:meh se: *ge...,** se: *geme o** se: *cuarta de** we:i mochi:wa yo:n iyo:lxo:chio mochi:wa ya.</ANNOTATION_VALUE>
