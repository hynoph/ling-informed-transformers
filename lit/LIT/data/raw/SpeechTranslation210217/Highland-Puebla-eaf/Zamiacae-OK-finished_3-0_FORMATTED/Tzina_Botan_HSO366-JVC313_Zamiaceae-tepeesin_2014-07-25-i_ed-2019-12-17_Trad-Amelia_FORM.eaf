        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
                <ANNOTATION_VALUE>Ihkwikwí:n, ne:n, ihkwikwí:n yehyewaltik tepitsi:n, pahpatachtik,</ANNOTATION_VALUE>
