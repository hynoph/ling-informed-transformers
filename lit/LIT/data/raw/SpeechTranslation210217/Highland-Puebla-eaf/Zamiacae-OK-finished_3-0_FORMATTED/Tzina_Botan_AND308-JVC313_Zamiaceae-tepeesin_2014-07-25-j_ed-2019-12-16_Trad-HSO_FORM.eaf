        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
                <ANNOTATION_VALUE>a:mo, a:mo ahko *porque** wehkapan.</ANNOTATION_VALUE>
