        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts66" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>Ompa mota:lia ya n' iteyo.</ANNOTATION_VALUE>
