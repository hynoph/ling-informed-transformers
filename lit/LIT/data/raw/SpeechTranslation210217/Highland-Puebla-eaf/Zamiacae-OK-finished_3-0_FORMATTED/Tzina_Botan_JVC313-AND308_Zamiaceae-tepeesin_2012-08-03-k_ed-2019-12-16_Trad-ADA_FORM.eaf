        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Sí pues el &lt;i&gt; tepe:sin&lt;/i&gt; lo conozco, ehe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>El &lt;i&gt; tepe:sin&lt;/i&gt; se da en los riscos, abunda mucho acá por A:tpoliwi. </ANNOTATION_VALUE>
