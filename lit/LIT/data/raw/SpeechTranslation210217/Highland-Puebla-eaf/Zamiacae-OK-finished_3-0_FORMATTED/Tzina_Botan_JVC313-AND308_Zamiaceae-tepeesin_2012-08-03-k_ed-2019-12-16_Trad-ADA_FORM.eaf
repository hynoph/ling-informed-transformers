            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Esas las cortan nada más donde empiezan las hojas y el pedúnculo lo dejan ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Y este, no, no tiene su..., su tallo, nada, nada, ahí salen las hojas y quien la va a cortar, aquella persona que las corta, pues las corta desde arriba</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
