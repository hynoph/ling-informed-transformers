        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts110" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>Wa:n wehwei, ma:pa:pata:..., ma:we:weyak.</ANNOTATION_VALUE>
