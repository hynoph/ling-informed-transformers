                <ANNOTATION_VALUE>En el koyo..., Koyo:xo:chitepe:t abunda mucho,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>este, se da en la superficie de las piedras y también se da sobre las piedras y al pie de un risco, ahí en la orilla de la entrada de la cueva también se da, ahí al pie..., pie..., pie de un risco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
