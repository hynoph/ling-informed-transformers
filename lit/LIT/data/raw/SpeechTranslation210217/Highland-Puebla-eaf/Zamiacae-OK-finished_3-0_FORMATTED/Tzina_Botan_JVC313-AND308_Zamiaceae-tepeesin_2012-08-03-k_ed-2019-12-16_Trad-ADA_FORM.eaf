        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a129" TIME_SLOT_REF1="ts88" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>A:mo, a:mo, a:mo mihmimiltik, pahpatachtik sah.</ANNOTATION_VALUE>
