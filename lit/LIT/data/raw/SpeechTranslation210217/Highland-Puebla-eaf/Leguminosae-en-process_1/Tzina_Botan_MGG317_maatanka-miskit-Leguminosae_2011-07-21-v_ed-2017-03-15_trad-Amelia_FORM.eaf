        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Se parece mucho pero hay una pequeña diferenca, las hojas son un poco..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>las hojas tienen tendecia a color amarillo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Si, y las hojas del ma:tanka son muy verdes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Si, las hojas son muy verdes. Si. Por eso se reconoce que el ma:tanka. Uhuh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Miguel Gorostiza Gabrioto y soy de San Miguel Tzinacapan.</ANNOTATION_VALUE>
