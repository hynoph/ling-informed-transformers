            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
                <ANNOTATION_VALUE>neh a:mo wel name:chili:ti *que** niki:xmattok na:wi, ma:kwil *o** chikwase:n</ANNOTATION_VALUE>
