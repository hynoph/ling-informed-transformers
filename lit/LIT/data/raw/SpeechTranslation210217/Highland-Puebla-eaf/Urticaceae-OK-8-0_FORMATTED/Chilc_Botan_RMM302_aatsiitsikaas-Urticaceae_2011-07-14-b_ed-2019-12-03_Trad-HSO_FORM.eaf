        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
                <ANNOTATION_VALUE>A:mo kachi onkak, *porque** yo:n nimitsilia neh poliwi, yo:n onkak ke:meh</ANNOTATION_VALUE>
