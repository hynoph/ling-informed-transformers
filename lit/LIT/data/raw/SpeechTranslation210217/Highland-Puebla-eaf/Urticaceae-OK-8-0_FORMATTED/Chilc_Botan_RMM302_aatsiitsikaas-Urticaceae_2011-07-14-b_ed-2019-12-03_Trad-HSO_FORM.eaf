        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
                <ANNOTATION_VALUE>Yo:n tikmatis ka:n n' onkak, nika:n ka:mpa, ne:n, *bachillerato** de n', de San Miguel,</ANNOTATION_VALUE>
