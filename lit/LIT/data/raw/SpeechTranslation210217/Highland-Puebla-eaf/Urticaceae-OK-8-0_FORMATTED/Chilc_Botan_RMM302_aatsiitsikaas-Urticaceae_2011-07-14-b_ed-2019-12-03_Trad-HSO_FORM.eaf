            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
                <ANNOTATION_VALUE>onkak wa:n sepa tikitas a:mo tei ok.</ANNOTATION_VALUE>
