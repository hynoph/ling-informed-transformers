        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
                <ANNOTATION_VALUE>Ne: ke:man moi:xmatia nochi yehwa yo:n xiwtsí:n kikwiah.</ANNOTATION_VALUE>
