        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
                <ANNOTATION_VALUE>Pero yo:n okseki tein te:tepi:nia, yo:n ne..., semi, semi nehmach para tikahsis yo:n.</ANNOTATION_VALUE>
