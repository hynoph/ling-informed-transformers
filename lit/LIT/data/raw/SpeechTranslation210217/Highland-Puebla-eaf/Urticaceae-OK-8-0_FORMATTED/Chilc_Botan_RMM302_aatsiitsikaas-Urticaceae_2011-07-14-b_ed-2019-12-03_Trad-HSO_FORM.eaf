        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>Kwa:kwehmeh sah *más** nikita ika motekipanowah.</ANNOTATION_VALUE>
