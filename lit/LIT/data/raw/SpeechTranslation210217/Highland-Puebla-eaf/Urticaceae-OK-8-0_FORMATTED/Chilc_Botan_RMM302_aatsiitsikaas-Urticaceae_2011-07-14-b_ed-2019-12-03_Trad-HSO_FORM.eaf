        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>A:tsi:tsika:s tein yo:n kwomeka..., ta:lpan a:tsi:tsika:s.</ANNOTATION_VALUE>
