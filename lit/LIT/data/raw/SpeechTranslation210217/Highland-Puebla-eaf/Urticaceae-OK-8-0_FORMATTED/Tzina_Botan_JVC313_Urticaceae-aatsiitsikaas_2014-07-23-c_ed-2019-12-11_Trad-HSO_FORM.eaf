            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Y el otro tipo de ach..., de &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; son como, como largos como cabello, se cuelgan así como la cola de caballo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>esas este se..., a..., se..., se cuelgan sus semillas, y si uno mueve las semillas vuela el..., el polvo que tienen este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que se usan las hojas para envolver carne de re..., Esa tiene hojas redondas y no pica. Y el otro</ANNOTATION_VALUE>
            </REF_ANNOTATION>
