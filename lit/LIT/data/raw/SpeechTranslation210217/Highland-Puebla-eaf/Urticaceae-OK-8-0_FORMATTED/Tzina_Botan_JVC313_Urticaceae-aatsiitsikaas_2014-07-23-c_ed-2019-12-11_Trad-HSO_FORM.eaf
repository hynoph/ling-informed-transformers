        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts148" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>A: pos neli porke ka:sa ika nikita neh pero a:mo ke:man nimomakaya *cuenta** ke:yeh yo:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
