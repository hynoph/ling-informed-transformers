        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>&lt;I&gt;itskwinpahwits&lt;/i&gt; lo haz de conocer el &lt;I&gt;itskwinpahwits&lt;/i&gt; que también hay muchos tipos, el &lt;I&gt;itskwinpahwits&lt;/i&gt; se da en el potrero.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>se..., se extiende en el suelo y sus frutos son unas bolitas así de color amarillo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a348" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Y el otro tipo de &lt;I&gt;itskwinpahwits&lt;/i&gt; crecen grandes las matas y son altas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>sus hojas son anchas como las hojas de &lt;i&gt;po:chne&lt;/i&gt; y son muy..., todas tienen muchas espinas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>y su..., al pie del pedúnculo de las hojas tienen espinas y son pubescentes desde el  tallo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>sus frutos se cuelgan por racimo y tienen un color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Y el otro tipo de  &lt;I&gt;itskwinpahwits&lt;/i&gt;. Sí y el otro, sí y el otro tipo de &lt;I&gt;itskwinpahwits&lt;/i&gt; la planta es erecta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Y sus flores son muy alargadas de color morado, así son sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Ese se..., pero ese es el &lt;I&gt;itskwinpahwits&lt;/i&gt;. Juntan todas con el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt;, las juntan todas para preparar le medicina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Eso es. I..., ak..., ka..., yak..., la usan para bañar, bañan a las personas que se encuentran enfermas. Eso es i..., ak..., ka...,  yak...,las bañan con eso</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Sí. Pues hay cuatro tipos de &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que yo conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Pues el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; se da acá por &lt;i&gt;A:tekohkomol&lt;/i&gt;, hay el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que es de color rojo todo..., las hojas usaban para envolver.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Y hay el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; de hojas largas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Ese se da en matas grandes, aquí en Pawa:pan hay de ese &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que se ven en la orilla del camino,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>de una vez que nacen las matas. Uno tumba las matas y retoñan nuevamente. Pero el otro &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que tiene hojas redondas que se usaban para env..., envolver carne.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Ese no, no se..., no retoña mucho, crecen los troncos gruesos y grandes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>si uno tumba la mata retoña pero poquito nada más y este otro crece la mata muy grande si lo haz visto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Crece en matas grandes y retoña para extenderse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Esas más crecen en matas grandes y el otro tipo se..., no, no, no retoña mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>El que tiene hojas redondas usaban las hojas para envolver.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Y el que tiene las hojas del..., delgadaas esas no. No la usan para envolver pero si crecen grandes las matas y retoñan mucho, ese se da a orillas del camino.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
