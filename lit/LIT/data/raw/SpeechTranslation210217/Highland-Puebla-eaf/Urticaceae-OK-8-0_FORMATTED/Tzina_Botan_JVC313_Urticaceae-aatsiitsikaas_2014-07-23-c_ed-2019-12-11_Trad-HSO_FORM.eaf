        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a453" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>S..., sí. Le llaman &lt;i&gt;tanechiko:lxiwit&lt;/i&gt; porque de veras que son muchas hierbas diferentes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a454" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>Uhuh. Juntan muchas hierbas, buscan las que tienen espinas para que..., buscan para las mujeres que se ponen descoloridas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
