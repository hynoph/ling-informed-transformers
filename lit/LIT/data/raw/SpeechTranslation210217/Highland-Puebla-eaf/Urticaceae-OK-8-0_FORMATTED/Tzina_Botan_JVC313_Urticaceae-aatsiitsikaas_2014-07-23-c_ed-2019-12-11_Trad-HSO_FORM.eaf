        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>Wa:n mochi:wa toma:wak [si]ke:ra ihkwí:n toma:wak wa:n moketsa sikera se: ma:kwi:l *metro** de weh..., wehkapan yo:n a:tsi:tsika:s.</ANNOTATION_VALUE>
