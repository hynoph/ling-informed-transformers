        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Y el otro tipo de &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; se extiende en el suelo que le llaman &lt;i&gt;ta:lpana:tsi:tsika:s&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Ese crece de altura nada más como el tamaño del &lt;i&gt;kaba:yohkwitaxiwit&lt;/i&gt;, crece muy alto como dos cuartas 40 cms. de altura</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Ese también es muy..., ese &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; pica.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Pero ese también es buen remedio cuando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>la usan para bañar las, las que..., personas que se enferman las usan para bañar. Pero no se usa sóla, según se juntan muchas plantas que tienen espinas y que pican.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Sí m..., juntan muchas plantas para preparar la..., El &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que es pequeña la usan junto con otras para ha..., preparar y bañar al paciente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Eso es pero los otros tipos que son grandes no se usan para curar, uno es el que pica y el otro pues se usaban las hojas para</ANNOTATION_VALUE>
            </REF_ANNOTATION>
