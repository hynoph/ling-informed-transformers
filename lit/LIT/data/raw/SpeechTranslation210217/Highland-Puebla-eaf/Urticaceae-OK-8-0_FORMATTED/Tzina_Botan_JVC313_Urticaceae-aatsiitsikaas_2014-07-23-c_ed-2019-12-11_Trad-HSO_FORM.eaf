        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts53">
                <ANNOTATION_VALUE>Yeh mochi:wa wehkapantik ke:meh yo:n kaba:yohkwitaxiwitsah mochi:wa, semi wehkapan ke:meh se: o:me *cuarta** de wehkapan sah mochi:wa.</ANNOTATION_VALUE>
