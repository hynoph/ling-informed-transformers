        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Sí, hay cuatro tipos de &lt;i&gt;a:tsi:tsika:s&lt;/i&gt;, tres tipos son los que crecen altos y uno es el que se extiende en el suelo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a409" ANNOTATION_REF="a183">
