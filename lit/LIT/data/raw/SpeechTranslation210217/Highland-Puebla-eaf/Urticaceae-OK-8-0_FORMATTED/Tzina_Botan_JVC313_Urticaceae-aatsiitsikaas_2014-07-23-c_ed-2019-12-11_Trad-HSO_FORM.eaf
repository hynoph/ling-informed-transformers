                <ANNOTATION_VALUE>Acá por Tatampa y Pa:wapan abunda mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Ese se da..., se da sóla esa planta, se da  sóla y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>el otro &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que pica,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>en algunas partes la usan para corral para .... El corral, construyen el corral para trampa, para que no pase uno al pie del corral para que le pique a uno, para que uno respete el corral.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Por eso usan el a:tsi..., &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que pica.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Eso es lo que ponen. En algunas partes hacen corral y entierran las estacas en las orillas de camino, les gusta mucho porque ...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Para que no se..., no camine uno al pie del corral porque si no, te rozas el hombro con las hojas y duele la urticaria que provocan, entonces uno no pasa. Las hojas provocan urticaria.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Por eso usan esa planta para el corral. La esposa de don Perdo Martín en frente de su casa, tiene un corral construido con toda esa planta que llega hasta el terreno de don Chucho Payno</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>para que no se roce uno, no se.., Esa planta se respeta porque pro..., provoca urticaria.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>pica.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>Sí no se puede pasar al pie del corral porque se..., se le tiene miedo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
