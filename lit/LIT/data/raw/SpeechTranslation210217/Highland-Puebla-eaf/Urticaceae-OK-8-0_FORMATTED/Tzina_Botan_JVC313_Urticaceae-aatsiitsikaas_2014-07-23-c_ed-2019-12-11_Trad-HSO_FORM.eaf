        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a104" TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>Tein ika kipi:kih nakat tikihtowa.</ANNOTATION_VALUE>
