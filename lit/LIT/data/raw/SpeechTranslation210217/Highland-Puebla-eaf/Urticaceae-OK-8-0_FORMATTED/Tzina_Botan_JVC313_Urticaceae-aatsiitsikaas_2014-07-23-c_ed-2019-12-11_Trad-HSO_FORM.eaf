        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>*Bueno**, le..., este: nika:n timoahsi nik..., wa:n este nikneki nimitstahtani:s ne: ox tiki:mattok yo:n a:tsi:tsika:s, ka:nachi taman onkak.</ANNOTATION_VALUE>
