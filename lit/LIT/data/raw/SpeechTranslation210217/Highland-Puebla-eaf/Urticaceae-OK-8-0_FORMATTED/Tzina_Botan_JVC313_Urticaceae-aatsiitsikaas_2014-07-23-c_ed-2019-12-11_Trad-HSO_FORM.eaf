            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>ese se seca, pero llega una temporada que no hay toda está seca. Y hay meses que la planta se encuentra con hojas verdes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Pues ese se da a orillas de camino. Se da a orillas de camino. Como se da esa ..., he visto que algunas personas la buscan junto a las casas, buscan el &lt;i&gt;a:tsi:tsika:s&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a191">
