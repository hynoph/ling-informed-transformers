                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>Nochi yo:n mochi:wa sah a:mo, a:mo se: kito:ka, a:mo .... Ke:mah ta.</ANNOTATION_VALUE>
