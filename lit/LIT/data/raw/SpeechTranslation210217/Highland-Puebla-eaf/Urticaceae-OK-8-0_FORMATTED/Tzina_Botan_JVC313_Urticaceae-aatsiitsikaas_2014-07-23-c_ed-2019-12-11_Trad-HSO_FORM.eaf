        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>Wa:n se: taman a:tsi:tsika:s mosowa ta:lpan, ta:lpana:tsi:tsika:s kiliah.</ANNOTATION_VALUE>
