            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>Ke:mah m..., miak taman tanelo:loh para kichi:wah n.... Yo:n a:tsi:tsika:s pisi:ltik tewa:n kikwih no: para ki..., kichihchi:wah tehsá:, para ika ma:ltiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
