            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Que, un..., hay un &lt;i&gt;a:tsi:tsika:s&lt;/i&gt; que tiene las hojas redondas gran..., grandes y redondas que usaban para envolver, antes usaban para envo..., envolver carne que vendían en las matanzas ahí en Cuetzalan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Son redondas y el pedúnculo ..., el pedúnculo de las hojas es de color rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Y las semillas se..., se cuelgan como, como bejuquitos así de largos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>y las emillas son de color rojo. Son largos y así se cuelgan hacia abajo su..., sus semillas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>las semillas y las flores. Son largas así. Se cuelgan hacia abajo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Y, y tiene hojas redondas que se pueden cortar para, para envolver carne.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Esas, esas no te..., no te..., no pican y hay otro tipo que tiene las hojas redondas también</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a98">
