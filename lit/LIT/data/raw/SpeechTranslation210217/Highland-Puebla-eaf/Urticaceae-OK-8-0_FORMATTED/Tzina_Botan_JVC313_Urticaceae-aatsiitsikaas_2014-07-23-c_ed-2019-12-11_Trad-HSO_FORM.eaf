        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>Wa:n onkak seki a:tsi:tsika:s no: ma:we:weyak. Yeh ma:we:weyak a:mo teh *servi:rowa** para tei ma:we:weyak sah ke:meh *más** wehwei ke kahbe:xiwit ma:yekapampihpitsaktik.</ANNOTATION_VALUE>
