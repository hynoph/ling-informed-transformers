        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>To:ni n' kipahtia tein tikihtowa tapahtia, kihtowa.</ANNOTATION_VALUE>
