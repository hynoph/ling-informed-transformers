        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a452" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Sí pues les..., les tendían en donde dormían, yo también se que les tendían y con esas las tendían desde la cabecera hasta a los pies de los pacientes, las tendían todas y ....</ANNOTATION_VALUE>
