            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a445" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>ya le va a dar anemia, algunas personas dicen que es porque el paciente tiene susto pero no se sabe, a veces se cae uno y de  ahí proviene la anemia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a451" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>Y para que eso no pase, pero yo no sé si algunos pacientes les dan de tomar.</ANNOTATION_VALUE>
