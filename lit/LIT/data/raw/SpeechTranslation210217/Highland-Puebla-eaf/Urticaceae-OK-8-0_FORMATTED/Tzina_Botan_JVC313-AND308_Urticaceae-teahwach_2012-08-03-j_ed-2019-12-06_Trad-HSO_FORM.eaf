        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>Y cuando uno trabaja en algún lugar pues también se van dejando las plantas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a282">
                <ANNOTATION_VALUE>Luego dice uno, voy a dejar esta hierbita porque es medicinal, me..., vendré a traerla para que me curen o con esta lo vamos a curar a un ni..., niño.</ANNOTATION_VALUE>
