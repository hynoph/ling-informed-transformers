        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts86" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>Para a:mo kimoya:was.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts92" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>Kitamo:ta.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>A:, sayoh sah yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts102" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>A:yoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts108" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>Tihtila:wak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts112" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>Pos sese:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts116" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>Pos neh no: nikmati tepitsi:n de yo:n teahwach kiliah, teahwach, ne:n, *a veces** tek..., teke:span mopilowa wa:n ka:nsika, ne:n, ihkó:n se: kita miakka:n ihihkatok no: ka:mpa, ka:mpa tetah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>Pero yo:n a:mo nikihto:s ne: ka:nsika itech ta:ltsi:n e:wi yo:n nik..., san [...]nikita itech n' tet.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>Wa:n yo:n nikneltoka de ke ne:chilihtok yo:n kone:meh kimpechtiah oso yehwa yo:n ma:ski tehwa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>yo:n tikochtokeh ihko:ni wa:n tiye:kmi:to:nihtokeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>Wa:n yo:n kihtowa:yah de ke ihkwí:n se: kima:xakwalowa:yah wa:n te:i:xkwa:ta:lilia:yah no: wa:n se: iyo:lpan wa:n kachi miak ne: te:pechtia:yah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Yo:n kihtowah *cuando** yo:n te..., te:kwiti teisá: ekintsi:n se: kochisneki oso tatsiwi ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>Yo:n cha:wis kihtowah yo:n seki, ne:n, momachtiah pi:piltsitsi:n oso se: yehwa se: kostia se: moyo:kolia,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>niman kihtowah ne: 'kwitih cha:wis ne: kone:t *o** se: yehwa ne: ta:tahtsi:n 'kwiti cha:wis *porque**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>pos yehwa yo:n kostitok, ekintsi:n tikwitih ne:n, ne: xiwtsi:n ne: teahwach tikwitih wa:n tikpechti:tih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>Pos yehwa yo:n 'kwiah, ne:n, ye:kmiak ihkó:n kite:te:mayah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>wa:n ompa paniá:n ya, ne:n, se:, se: te:te:kayah, komo, komo se: kone:t pos ompa kite:kayah ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>wa:n komo se: yehwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>Entó:s kwaltsi:n se: mi:to:nia:ya pos ki:saya, nijó:n, te:ki:xtilia:ya yo:n, *porque** yo:n kihtowah seki de nemowtil.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>Pero a:mo se: kimati, seki kihtowa:yah de se: mo..., moyo:..., [mo]yolwai:to:nia, de cha:wis te:kwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>Wa:n no: *igual hasta** i:n tehwa:n komo a:mo timopahtiah sioh para no: se: mikis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts162" TIME_SLOT_REF2="ts164">
                <ANNOTATION_VALUE>Se: mikis *porque** de ke komo te:kwik yo:n kokolis a:mo no: se: takwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>Se: to:ntohkwi wa:n pos yehwa yo:n kihtowah *hasta** se: sehsekwi pero ika yo:n xi:wtsi:n, ne:n, teahwach</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts170" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>yo:n semi kwali. Yo:n semi kwali sayoh ke a:mo nikmati neh ke:ni:n, ne:n, ixo:chio, kox chi:chi:ltik oso ista:k, neh nikitani sayoh, ne:n, yehwa ya, ne:n, xiwtsi:n sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts174" TIME_SLOT_REF2="ts176">
                <ANNOTATION_VALUE>A:mo ke:man no: tikita, nijó:n, ixo:chio kox chi:chi:ltik oso ista:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts178" TIME_SLOT_REF2="ts180">
                <ANNOTATION_VALUE>Pos neh a:mo no: ke:man nikita m....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts182" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>Pos achi nextik nijó:n xiwtsi:n, achi a:ista:k, a:mo semi telxoxoktik wa:n kwaltsi:n ma:pisi:ltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
                <ANNOTATION_VALUE>Wa:n yo:n, nijó:n, a:mo, ne: ke:man ma:ski a:mo, nikita ma:ski teke:span ihkó:n pero tsikitsitsi:n pero a:mo ke:man nikita iteyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts188" TIME_SLOT_REF2="ts190">
                <ANNOTATION_VALUE>Yo:n tak kipias tsikitsi:n iteyo wa:n pos yo:n tak wetsi n' tetsi:n ike:span de n' tet wa:n ikwa:pan de n' tet pos ompa ne: onkak tepitsi:n m..., yo:[n]tei ihkó:n kin..., nalwats..., nalwat tepitsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
                <ANNOTATION_VALUE>Wa:n ompa mi:xto:ka ya wa:n ke:mah moskaltia ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>Pos yo:n no: kwaltia, no: se: kitekiti pero mah se: kikohkoto:na sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts198" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>Pero komo se:, ihkó:n se: kahkotila:na, tamiwiwiti *porque** itsi:ntan semi yema:nik. Witsa ika n' ta:ltsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts204" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>Pos poliwi a no:. Poliwi a, komo se: kwiwita ne:wí:n se: kitamo:ta pos yeh a:mo wa:ki niman.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts210" TIME_SLOT_REF2="ts213">
                <ANNOTATION_VALUE>Pero se: kahchi:wa ya ka:mpa tetsi:n, de n' ta:lpan a:mo, a:mo no: ...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts218">
