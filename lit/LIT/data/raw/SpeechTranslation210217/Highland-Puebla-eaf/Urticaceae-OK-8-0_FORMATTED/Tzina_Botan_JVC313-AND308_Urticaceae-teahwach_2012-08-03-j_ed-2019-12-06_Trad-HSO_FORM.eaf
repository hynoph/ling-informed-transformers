        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>Cuando uno despierta está sudando mucho, eso es ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Eso es lo que dicen. luego dicen pues aquel señor o aquel niño le..., le vamos a tender hojas de &lt;i&gt;teahwach&lt;/i&gt; porque sino le va a dar anemia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
