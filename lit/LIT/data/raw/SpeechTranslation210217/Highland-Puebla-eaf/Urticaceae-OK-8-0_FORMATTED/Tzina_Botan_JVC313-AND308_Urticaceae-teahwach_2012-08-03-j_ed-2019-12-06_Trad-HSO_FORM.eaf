        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>Y eso es que cuando uno se le quitaba la enfermedad, en el momento que descansaba uno ya no sudaba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>Pues eso es lo que dicen que en la espalda de nuestra camisa se moja todo.</ANNOTATION_VALUE>
