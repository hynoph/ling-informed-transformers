        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>Y pues esas son las que se cortan como te platico, las puntas de la planta porque también se ramifica.</ANNOTATION_VALUE>
