    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Pues aquí nos encontramos otra vez, aquí estamos, pues puedes decirme si conoces el &lt;i&gt;teahwach&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>a donde se da el &lt;i&gt;teahwach&lt;/i&gt;, cómo son sus flores y que tanto de altura crece,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>también me puedes platicar para qué se usa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Estamos sudando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>A está cubierto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Encima.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>También es enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Para que uno no duer....,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Para que no las tire en varias partes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Las tira.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a348" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Aa nada más eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Contienen agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Son gruesas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Pues es fría.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Pues yo también sé un poquito del &lt;i&gt;teahwach&lt;/i&gt; le llaman &lt;i&gt;teahwach&lt;/i&gt; este, a veces germinan las semillas en la superficie de las piedras y otros lugares donde hay piedras también se encuentran esas planttas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Pero esa planta no puedo decir que nazcan sus semillas en el suelo, yo lo..., he visto que se da sobre las piedras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Y yo lo creo como me estás platicando que esa hierba lo ponen debajo del tapete  en donde duermen los niños o a nosotros los adultos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>eso es cuando estamos durmiendo y sudamos mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>Y decían de que las hojas las machacaban y le ponían a uno en la frente y en el pecho y les tendìan muchas hojas en el tapete a los pacientes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Eso dicen que cuando uno se..., a uno le va a dar alguna enfermedad que tienes sueño o tienes así como flojera</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Dicen que es anemia cuando un niño o una persona adulta, de repente se pone descolorido,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>luego dicen "aquel niño o un adulto se va a enfermar de anemia porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>se está poniendo todo amarillo, ahora mismo vamos a conseguir hierbas de &lt;i&gt;teahwach&lt;/i&gt; y las vamos a tender debajo de su tapete..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Pues esa hojas ocupaban, tendían muchas hierbas en el tapete</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>y encima este, se acostaba si, si era un niño pues ahí lo acostaban,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>o a uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Entonces al sudar mucho pues salía la enfermedad porque decían que esa enfemedad provenía del susto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Pero uno no sabe, otras personas decían que uno se..., su..., suda por las noches porque uno tiene anemia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>Y hasta a nosotros si no nos curamos, igual podemos morirnos con esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>Puede uno morirse porque si a uno lo ataca esa enfermedad pues no tiene ganas de comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Uno se debilita y pues dicen algunas personas que siente uno escalofríos pero con esa hierba del &lt;i&gt;teahwach&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>es muy buen remedio. Ese es muy bueno, el problema es que yo no sé cómo son sus flores, si son de color rojo o son blancas, yo he visto sólo la plantita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Nunca las haz visto sus flores si son rojas o son blancas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Pues yo igual, nunca las veo m....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>Pues es un poco de color gris la plantita, esa tiene un color bajo, no tiene color verde fuerte y tiene las hojas pequeñas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>Y ese este no, hace muchos años aunque no, he visto que en la superficie de las piedras nacen así pequeñitas pero nunca veo sus semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>Creo que tiene las semillas muy pequeñas y se caen en la superficie de las piedras y ahí sobre las piedras se encuentran algunas plantas q..., así con las..., unas pocas raíces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>Y ahí se enraíza y ya crece.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>Pues así también se pueden cortar pero hay que cortar el tallo nada más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>Pero si uno lo arranca jalando hacia arriba se arranca toda la mata porque el tallo es muy suave. Viene con todo y tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>Pues ya se acaba la mata. Se acaba si uno lo arranca y lo tira por ahí pues no se seca luego.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a205">
                <ANNOTATION_VALUE>Pero al quitarla de las piedras porque en el suelo no, no, tampoco</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>En la..., en el suelo ya no se enraíza, si eso es cuando uno realiza alguna actividad, cuando uno limpia el suelo pues ya lo tira uno por ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
