        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>Pues dicen que las hojas se secaban cuando uno se acostaba sobre esas.</ANNOTATION_VALUE>
