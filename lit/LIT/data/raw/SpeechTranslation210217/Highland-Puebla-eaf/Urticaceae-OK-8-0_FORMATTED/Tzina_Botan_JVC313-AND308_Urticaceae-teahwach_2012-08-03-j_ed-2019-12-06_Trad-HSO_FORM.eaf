        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>Pues para mí, eso es todo lo que sé de esta plantita, este también, también hace efecto. Ya nada más eso sé del &lt;i&gt;teahwach&lt;/i&gt;. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
