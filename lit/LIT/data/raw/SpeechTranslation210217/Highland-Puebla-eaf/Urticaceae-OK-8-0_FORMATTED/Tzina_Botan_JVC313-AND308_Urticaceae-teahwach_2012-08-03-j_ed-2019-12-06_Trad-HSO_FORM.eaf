        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>La anemia, significa que es la anemia de color amarillo.</ANNOTATION_VALUE>
