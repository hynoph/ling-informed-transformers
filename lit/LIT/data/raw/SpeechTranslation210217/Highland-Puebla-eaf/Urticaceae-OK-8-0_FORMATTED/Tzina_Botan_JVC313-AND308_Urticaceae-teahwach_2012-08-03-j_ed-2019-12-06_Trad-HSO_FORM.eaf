        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>Se pone uno amarillo tanto en la cara como en las manos. Se pone uno amarillo.</ANNOTATION_VALUE>
