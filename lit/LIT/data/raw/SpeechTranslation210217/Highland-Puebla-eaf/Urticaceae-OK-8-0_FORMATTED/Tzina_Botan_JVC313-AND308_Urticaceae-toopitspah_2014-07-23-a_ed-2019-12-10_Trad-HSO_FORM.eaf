    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Transcripción" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="Anastacio Nicolás Damián">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>¿A: no: tikneki tik..., tikmatis?.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>Pos no: kwalia ke nika:n ti..., timahsikeh nika:n i:n kwowtah wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>pos no: niki:xmati neh, no: kwali para, nijó:n, to:pitspah, kiliah to:pitspah wa:n to..., to:pitsxiwit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts21">
                <ANNOTATION_VALUE>Ne:wí:n neh no: nikahsi, ne:wí:n kahfe:ntah, ka:mpa ko:nkahkahfe:ntah onkak</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>moso:sowa. Wa:n yo:n semi kwali se: ki:..., para to:pitspah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>Kilia porke nik..., semi kwali se: kima:xakwalowa wa:n se: kita:lia ka:mpa yo:n se: moto:pitstia de te:koko..., para se: kokot.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts29">
                <ANNOTATION_VALUE>Pero yo:n kokot, ma:ahchi:wa ne:n to:pits.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>Seko se: yetok kokot wa:n ke:mah se: ki...., okseko mahchi:wa, nijó:n, to:pits,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>pero, nijó:n, tikwitih, nijó:n, xiwtsi:n, to:pitsxo:chit, ne:, xiwit para, nijó:n, se: ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>kima:xakwalowa wa:n ke:mah se: kita:lilia ka:mpa ne:n, mote:mpitstia, ne:n, kokot.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>Ompa se: kita:lilia ke:mah, nijó:n, kah..., kaxa:ni a ne: pitsi:ni a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts41">
                <ANNOTATION_VALUE>Pitsi:ni a, kaxa:ni a, *despues** patsa:waya ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>Wa:n, pos yehwa, nijó:n, xiwtsi:n no: ki..., te:chna:miki wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>no: mo..., mowi:wila:na. Kwaltsi:n mohmoloxtik</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>imahma:ko wa:n no: kipia n' iteyo, ne:n, seki, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>n' i..., kwaltsi:n no: mo..., mopihpilowa tepitsi:n, kiliah ma:mohmoloxtik kwaltsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n se: 'kwiti ne:n, se: ki..., [ki]ma:xakwalowa kwaltsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a101" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>wa:n yo:n kip..., ne:n, a:tsi:n kipia ke:meskia cho:kil,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts57">
                <ANNOTATION_VALUE>wa:n se: ki..., se: mota:lilia ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a104" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>Yo:n se: mota:lilia porke, nijó:n, to:pits, se: kokot e:wi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>wa:n mosowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>Yowi seko wa:n seko moto:pitsti:tia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts67">
                <ANNOTATION_VALUE>Pero ika, nijó:n, xiwtsi:n yo:n to:pits, kiliah to:pitsxiwit, to:pits, to:pitspah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>Pat'ta:liliah ya pos nijó:n kaxa:ni tepitsi:n, patsa:waya, ta: no: ke:mansá: no: titi:ka.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts74" TIME_SLOT_REF2="ts77">
                <ANNOTATION_VALUE>No: titi:ka wa:n *despues** de se: kta:lilia ya, ne:n, xiwtsi:n se: kma:xakwalowa, n' a:tsi:n tak kikwia wa:n pahti a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts81">
                <ANNOTATION_VALUE>Wa:n no: kwali tine:chili:s teh xa: kachi tikmati, ne:n, ke:ní:w, ne:n, xiwtsí:n kox no:, no: tiki:xmati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts123">
                <ANNOTATION_VALUE>A:n os no: tik..., no: tikmattok, pos yehwa yo:n kwaltsi:n de ke nika:n timona:mikkeh itech, niji:n, ohti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts129">
                <ANNOTATION_VALUE>A:mo wehkapania, wa:n yehwa yo:n nik...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>no: nikita ne:wí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>Pos neh a:mo ke:man nikita kox wa:ki ihko:ni nikita tatampa, ne:n, kowtampa, ne:n, yetok pero a:mo wehkapania wa:n pos no: seki, ne:n, tikitstinemih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts137">
                <ANNOTATION_VALUE>Pos ne:wí:n kowtah a:mo tikahsih, kó:nkowtah tikahsih pero ne: kahfe:ntah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>Kahfe:ntah wa:n neh a:mo ke:man nik..., a:mo ke:man nikita kox wa:ki, neh nikita nochipa kó:nselistok, ma:mohmoloxtik wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts144" TIME_SLOT_REF2="ts147">
                <ANNOTATION_VALUE>yeh n' iteyo tsikilitsitsi:n wa:n neh a:mo ke:man nikita kox kikwah chiktehmeh oso ki:ni:n neh nikmattok *solamente** kikwih para n' pahti. Pero kikwih ne:n ixiwyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>N' ima:xiwyo, ne:n, kikwih wa:n kikwih sike:ra ka:no:me, kikwih wa:n kima:we:ik...,wa:n kima:xakwalowah nio..., n' iselo no:, ke pané: kipia n' iselo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts154" TIME_SLOT_REF2="ts157">
                <ANNOTATION_VALUE>Ihkwí:n n' ima:y mohmoloxtik wa:n se: kima:xakwalowa kwaltsi:n wa:n yehwa ya se: kita:lilia ne:n kokot. Se: kpacha:nilia wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts161">
                <ANNOTATION_VALUE>pos ompa ya ne: i:xwa:ktiw ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
                <ANNOTATION_VALUE>Pero yo:n kokot, ne:n, komo sepa te:kwi ne:n, .... Pos nochi ne:nemi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts167">
                <ANNOTATION_VALUE>ne:nemi wa:n te:kokoh *hasta** ke:masá: komo se: ima:ko te:kwi pos te:kokoh *hasta** se: ise:katan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts171">
                <ANNOTATION_VALUE>Wa:n yo:n to:pitsmeh mota:liah sike:ra ka:n e:yi oso na:wi. Pero ompa se: kita:lilia yo:n pahti pos k...,kaxa:ni a, no: ke:masá: *hasta** te:kwi yo:n toto:nik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts175">
                <ANNOTATION_VALUE>Toto:nik te:kwi wa:n pos de kaxa:ni a nochi pos te:..., kise:wia ya a:mo ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts193">
                <ANNOTATION_VALUE>Ke:meh eskia yo:n mokehketsah sah se: i..., iika:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts197">
                <ANNOTATION_VALUE>Wa:n yo:n kisowiliah, nikita pané: seki sayoh 'pepechowiliah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts201">
                <ANNOTATION_VALUE>Pos neh no: nik..., ne:, ke:man nikitaka, ne:n, mah se: kitalili *mismo** ne:n xiwtsi:n yo:n mohmoloxtik mah se: k[i]pepechowili.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts205">
                <ANNOTATION_VALUE>Ni:nipaka mah se: kipepechowili wa:n no:, no: kina:miki no: *casi** kitsakwilia ya, yo:n para:mo se: ki..., para:mo wetsis, ne:n, de se: kima:xakwalowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts209">
                <ANNOTATION_VALUE>Koma:mo se: kita:lilih, ne:n, teisá: pos wetsi. Wetsi wa:n a:mo tena:miki ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
                <ANNOTATION_VALUE>Pos yehwa yo:n *hasta** titi:ka se: ikechko komohko:n, ne:n, te:kwik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>Wa:n yo:n de pe:wa kihtowah itech se: imetsko komohko:n, ne:n, se: imetsko e:wi, nijó:n, kokot.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts227">
                <ANNOTATION_VALUE>Yo:n kokot kihtowah ka:mpa, de se: wetsi wa:n se: metstsaya:na,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>wa:n ompa ya ki:sa yo:n kokot.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts235">
                <ANNOTATION_VALUE>Ke:meh eskia chas.... Ke:meh eskia cha:wis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts241">
                <ANNOTATION_VALUE>Pos, nijó:n, *sereno** wetsi *cuando** yo:n a:mo kiowi. *Cuando** tachipa:wya:nwa:n *cuando** kwaltsi:n tachipa:waxtok,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts245">
                <ANNOTATION_VALUE>ihkwa:k wetsi, nijó:n, *sereno**, yo:n a:tsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts251">
                <ANNOTATION_VALUE>Kite:malo:tia wa:n yehwa yo:n te:kokoh n' te:mal. Ika yo:n xiwtsí:n se: ke..., ne: to:pitsxiwit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts255">
                <ANNOTATION_VALUE>to:pitspah se: kita:lilia, pos ne:nke:n 'ki:xtia. *Despues** kaxa:ni a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts259">
                <ANNOTATION_VALUE>Kaxa:ni a, patsa:waya ya nochi ne:n kokot oso ne:n to:pits. Pero koma:mo se: kita:lilih yo:n ke:masá: no: te:kwi toto:nik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts263">
                <ANNOTATION_VALUE>Toto:nik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts267">
                <ANNOTATION_VALUE>Yehwa, nijó:n, te:kokoh semi. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>Pos seki tikpanowihtinemih seki xiwtsitsi:n ihkó:n de ke a:mo tikitah ne:, kox kwali pahti, pero, nijó:n, semi kwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts279">
                <ANNOTATION_VALUE>Yo:n semi kwali para n' to:pits. To:pits, kiliah to:pitspah porke yehwa ne:n topah para tik..., tik..., tikwih, tikma:xakwalowah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts283">
                <ANNOTATION_VALUE>Wa:n kó:nneh nikita ne:wí:n a:mo ke:man nikita mah wehkapania, nochi tsikitsitsi:n kó:n ke:meh eskia mosowa wa:n mohmoloxtik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts284" TIME_SLOT_REF2="ts287">
                <ANNOTATION_VALUE>Yo:n kiliah ma:mohmoloxtik porke kwaltsi:n kó:n kipia pané: n' i..., imahma:yo ihko:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
                <ANNOTATION_VALUE>Wa:n *por eso** tikiliah ma:mohmolox, ma:mohmolox to:..., to:pitspah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts293">
                <ANNOTATION_VALUE>Entó:s yo:n to:pitspah n' a:mo tikitas ne:wí:n we:ikowtah, ne: tikitas ompa ne: kahfe:ntah ka:mpa, ne:n, kó:n, kó:n tehtetah no: onkak, pero neh</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts297">
                <ANNOTATION_VALUE>a:mo ke:man nikita ne: mah wa:ki. Neh nikita, nikita nochima:selistok. Ma:selistok wa:n n' iteyo ye:kkwaltsi:n, ne:n, tsikitsitsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
                <ANNOTATION_VALUE>pero neh a:mo ke:man kox kikwah chiktehtsitsi:n. Nikita sayoh ke tak, ne:n, .... Wa:n yo:n xi:ni</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts303">
                <ANNOTATION_VALUE>wa:n tatampa ya ne: ixwa. Ixwa wa:n ko:n moso:sowa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts307">
                <ANNOTATION_VALUE>Moso:sowa ya, nijó:n, wa:n mowe:ita:lia wa:n yehwa [e]kintsí:n nochi tiknekiskiah mah nochi kimatika:n, ne:n, tokniwa:n katí:n pahti te:chna:mikis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts311">
                <ANNOTATION_VALUE>Porke miakeh a:mo tikmatih, kox kwali, nijó:n, pahti yo:n to:pitsxiwtsí:n, nijó:n, to:pitspah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts316">
                <ANNOTATION_VALUE>Seki tikwitih seki xiwit pero a:mo tikmatih. Ne:pa nochi nik..., ke:meh [e]kintsí:n nika:n t[i]mona:mikkeh wa:n nochi ti..., timo..., timolihtokeh</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts318" TIME_SLOT_REF2="ts320">
                <ANNOTATION_VALUE>pos no: kwalia ka:nsika tikitaskeh ne: wa:n timoli:skeh *o** tikili:skeh se: tokni:w yehwa i:n kwali para n' to:pitspah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts324">
                <ANNOTATION_VALUE>[En]tos pos no: kwali 'kwiti:w o kwali tikwiti:wih wa:n tikmakaskeh *o** tikchihchi:wili:skeh ki:ni:n,ne:n, se: kima:xakwalo:s. Se: kima:xakwalo:skia wa:n ki:ni:n, kwali se: kili:s, kwali se: kita:lili:s ne:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts326" TIME_SLOT_REF2="ts330">
                <ANNOTATION_VALUE>kokot ka:mpa yetok, para mah mahchi:waya n' to:pitsmeh, ke yo:n to:pitsmeh mota:liah sike:ra ma:kwi:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts332" TIME_SLOT_REF2="ts335">
                <ANNOTATION_VALUE>Ma:kwi:l *o** e:yi oso sike:ra ma:kwi:l. [En]to:s mote:tekpa:nah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts339">
                <ANNOTATION_VALUE>*bien** se: k..., ise:katan mota:lia *o bien**, nijó:n, nochi se: i..., se: imetsko. [En]to:s yo:n de moso:sowa ya n' to:pitsmeh yehwa ya, ne:n, kokot yehwa kichi:wa mah te:..., te:kokoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
                <ANNOTATION_VALUE>Wa:n de se: kita:lilia, nijó:n, se: kipechowilia, kwaltsi:n nochi kaxa:ni a, *hasta** se: yehwa ta: yo:n no: te:kwi toto:nik wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts345">
                <ANNOTATION_VALUE>pos no: ke:masá: hasta te:..., se:, se: wetsi. Mm, se: wetsi a. Yo:n sese:k, nijó:n, xiwit porke, nijó:n, kokot</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts349">
                <ANNOTATION_VALUE>Ke:mah toto:nik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts353">
                <ANNOTATION_VALUE>Ke:mah. Pos yehwa yo:n nehwa nimi..., nimitsilih de ke ki:ni:n ta:ká:n ka:nsika se: tokni:w mitstahtani:s ka:n onkak yo:n to:pitsxiwit, to:pitspah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
                <ANNOTATION_VALUE>pos kwali tikili:s ke:meh i:n ka:nsika timona:miktinemih iwa:n seki tokniwa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
