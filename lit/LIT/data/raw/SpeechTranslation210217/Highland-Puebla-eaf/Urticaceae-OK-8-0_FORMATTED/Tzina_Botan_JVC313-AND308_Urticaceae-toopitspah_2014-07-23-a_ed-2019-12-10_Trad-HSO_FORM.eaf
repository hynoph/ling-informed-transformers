                <ANNOTATION_VALUE>ka:ni yetok yo:n pahti, xa: tikna:..., xa: tik..., xa: tikita yo:n kiliah seki:n to:pits....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
