    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>¿A quieres, qui..., saberlo también?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Pues qué bueno que aquí nos..., nos encontramos en el campo y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>pues yo también la conozco que el &lt;i&gt;to:pitspah&lt;/i&gt; es medicinal, le llaman &lt;i&gt;to:pitspah&lt;/i&gt; y to..., &lt;i&gt;to:pitsxiwit&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>También la he encontrado en el cafetal, en donde hay matas de café abunda esta planta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>se extiende la mata. Y esa es muy buena para la..., curar la enfermedad de los ganglios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Le dicen porque la..., es muy buena para curar los ganlios o granos si uno tiene el dol..., machacan las hojas y lo aplican.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Pero el grano de los ganglios cambia de lugar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>A uno le sale el grano y luego se..., cambia de lugar el ganglio,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>pero este se va a traer la hierba del &lt;i&gt;to:pitsxo:chit&lt;/i&gt;, las hojas para este, se..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>las machaca uno y se aplica en el lugar donde se encuentra el pico del grano.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Ahí se le pone, luego este se..., se desinflama ya se rompe el grano.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Después de romperse se desinflama.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Y pues esa hierbita también nos..., nos hace efecto y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>también se..., es extiende. Son pubescentes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>las hojas y algunas  también tienen semillas este, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>su..., también son bonitas se..., se cuelgan un poco, dicen que sus hojas son bonitas y pubescentes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Y esas son las que se van a traer este, se..., se machacan muy bien</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>y la que tie..., el jugo que contienen como si fuera savia,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>y se le..., se aplica uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Se aplica uno porque cuando, uno tiene enfermedad de los ganglios aparace un grano </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>y se extiende.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Se cambia de lugar y ahí se siente el dolor de ganglios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Pero con esas hojas de &lt;i&gt;to:pits&lt;/i&gt;, le llaman &lt;i&gt;to:pitsxiwit&lt;/i&gt;, &lt;i&gt;to:pits&lt;/i&gt;, &lt;i&gt;to:pitspah&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>De una vez que le aplicas pues ya se desinflama un poquito, se desinflama, porque a veces también se hincha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>También se hincha y después de aplicarle las hojas machacadas, el jugo de las hojas le llega al grano y se quita la enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Y usted también me puede platicar tal vez conoce más cómo se usa la hierbita si usted también la conoce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>A entonces también lo..., lo sabe, pues eso es bueno de habernos encontrado en el, en este camino.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>No crece alto, y eso es lo que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>También la veo por ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Pues yo nunca veo si se seca, la veo así en la sombra, se encuentra en la sombra de los árboles, pero no crece alto y pues la he visto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Pues por allá en el campo no la vas a encontrar, se encuentra en donde hay árboles pero en el cafetal.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>En el cafetal y yo nunca la..., nunca la veo si se seca, yo siempre la he visto así de color verde que tiene las hojas pubescentes y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>sus semillas son muy pequeñitas, y yo nunca veo que e esas semillas se alimenten los pájaros o, yo sé que solamente se usan las hojas para curar. Pero se usan las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Usan las hojas, este, toman siquiera dos hojas, toman las hojas y las..., las machacan su..., también las hojas tiernas que tiene, parece que tiene hojas tiernas..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>así son sus hojas, son pubescentes, se machacan muy bien y se le aplica al grano. Se le echan las hojas machacadas y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>entonces ya empieza a sanar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Pero el grano de una vez que lo ataca a uno este, .... Pues se anda cambiando de lugar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>anda cambiando de lugar hasta, si a uno le duele la mano llega el dolor hasta en las axilas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Y los ganglios aparecen siquiera tres o cuatro en el cuerpo. Pero ahí se aplica el medicamento y entonces se va..., ya se va desinflamando, a veces hasta le da a uno fiebre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>A uno le da fiebre y cuando se desinflama pues ya se..., ya se le quita a uno, no ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>Como si se pararan en la..., espalda.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Y entonces le tienden , he visto que algunos les pegan nada más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Pues yo también lo..., hace muchos años también lo vi, que hay que ponerle esa hierbita que es pubescente, hay que pegarle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Hay que ponerle en cada lado y también, también le hace efecto, lo sostiene para que no se..., caigan las hojas que se machacan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Si uno no le pone algo para que lo sostenga pues se cae. Se cae y ya no hace efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Pues eso es,  se incha el cuello de uno cuando ataca esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Y entonces dicen que empieza el dolor en el pie si uno tiene un grano.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Dicen que el grano nace cuando se cae uno y se lastima el pie</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>y de ahí nace el grano.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE>Como si fuera chas..., Como si fuera una enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Pues el sereno cae cuando no llueve. Cuando no hay nubes y cuando todo está despejado,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>es cuando cae el sereno, el aguita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>Lo hace infectar y eso es lo que duele cuando tiene pus. Con esa hierba se..., el &lt;i&gt;to:pitsxiwit&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a386" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>se le pone el &lt;i&gt;to:pitsxiwit&lt;/i&gt; pues lo hace calmar. Después ya se desinflama.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a387" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>Se desinflama, se desinflama todo el grano o el ganglio. Pero si uno no le pone a veces. a uno le da fiebre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>La fiebre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>Es lo que duele mucho. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>Pues andamos pasando donde hay hierbas así de que no sabemos si es buen remedio, pero es muy buena para medicina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a209">
                <ANNOTATION_VALUE>Esa planta es muy buena para los ganglios. Le llaman &lt;i&gt;to:pits&lt;/i&gt;, &lt;i&gt;to:pitspah&lt;/i&gt; porque es nuestra medicina para que la..., la..., machacarlas cuando se usan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>Y así lo he visto yo que nunca crece alta la mata, todas son bajitas como si se extendieran y sus hojas son pubescentes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>Le llaman pubescentes  porque así tiene las hojas bonitas como si..., así son sus hojas. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>Y por eso decimos que tiene las hojas pubescentes, pubescentes to..., &lt;i&gt;to:pitspah&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Entonces el &lt;i&gt;to:pitspah&lt;/i&gt; no lo vas a ver en el bosque, lo puedes ver en el cafetal donde hay piedras también, ahí si abunda pero yo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>nunca veo que se seque la planta. Yo la veo, la veo siempre con sus hojas verdes. Con hojas verdes y sus semillas son pequeñitas y muy bonitas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>pero nunca veo que con las semillas se alimenten los pájaros. Veo nada más que este, .... Y esas se riegan en el suelo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>y germinan debajo de otras plantas. Nacen nuevas plantas y se extienden.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a411" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>Se extienden las matas y ya crecen las matas, ahora todos quisiéramos que lo sepan las personas cuáles son las plantas que curan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a412" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>Porque muchos no sabemos si es buena para curar el &lt;i&gt;to:pitsxiwtsí:n&lt;/i&gt;, el &lt;i&gt;to:pitspah&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a413" ANNOTATION_REF="a226">
                <ANNOTATION_VALUE>Algunos vamos a traer las plantas pero no sabemos si es medicinal. Ahora todo lo..., como ahorita aquí nos encontramos y todo lo..., lo..., estamos platicando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a414" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>pues está bien lo veremos en alguna parte y lo platicaremos o le diremos a una persona que esta planta que se llama &lt;i&gt;to:pitspah&lt;/i&gt; es buena para curar los ganglios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>Entonces también lo puede ir a traer o podemos ir a traerla nosotros, se las vamos a machacar para prepararle. Se las vamos a machacar y le vamos a decir cómo lo va a aplicar al</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>grano en donde se encuentre para que se le quiten los ganglios, porque a veces aparecen siquiera en cinco partes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>Cinco, tres o siquiera unos cinco. Entonces se forman,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>bien en las axilas o bien este en el pie. Entonces de que se extienden los ganglios pero es el grano que provoca que sien..., sienta uno el dolor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>Y de que se le aplica, este, se pega bien y ya se desinflama, hasta uno se siente bien porque también le da a uno fiebre,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>pues a veces hasta llega un..., uno a caer. Mm, se cae uno. Esta planta es fría porque el grano es </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>Sí es caliente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a422" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Sí. Pues eso es lo que yo te..., te platiqué cómo, si en algún lugar te pregunta una persona en donde se da el &lt;i&gt;to:pitsxiwit&lt;/i&gt;, &lt;i&gt;to:pitspah&lt;/i&gt;,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>pues puedes decirle así como nos andamos encontrando con otras personas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>cuando venimos acá en el pueblo o andamos por ahí por el campo pues andamos viendo qué plantas nos pueden curar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a425" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>pues podemos decirle a una persona que..., que vaya a traer la planta para su hijo si te lo pide</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>en donde se da esa planta medicinal, quizás lo..., quizás lo veas el topis....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>Le vas a decir, "Yo sé muy bien que abunda ahí" Pues lo vas a traer y se lo..., preparas, lo machacas bien para que quede como masa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>Depués de quedarse como masa se aplica alrededor del grano.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>Le..., le hace efecto. Sí, eso es todo lo que..., sé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>A Ernesto Vázquez. Yo me llamo Anastacio Nicolás Damián, también vengo del pueblo de San Miguel Tzinacapan. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Ernesto Vásquez Chanico" PARTICIPANT="Ernesto Vásquez Chanico" TIER_ID="JVC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>Pues ahora que aquí nos encontramos compadrito, yo quiero preguntarte ¿si conoces una planta que le llaman &lt;i&gt;to:pitspah&lt;/i&gt;?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Esa hierba que se da por acá en el centro del pueblo o en algunas partes del campo en..., en donde hay humedad se da</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>yo pienso que usted la conoce también, y si también la conoce que se puede usar para curar los ganglios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Quería preguntarle a usted si también la conoce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Sí. Se desinflama, lo hace desinflamar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Sí. Pues.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Sí pues esa hierba también la conocemos, lo..., se.... Bueno de que uno no se comunica con la gente, uno no sabe si es medicinal la hierba que la estamos pisando, porque esa hierba es muy buena para ..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>a veces tiene uno, es..., uno se lastima el pie con un poquito y si esa herida le entra el sereno cuano va al campo y le entra el sereno,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>se infecta y se tapa el grano, si uno, si uno se corta un poquito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Entonces después de taparse, al no poder respirar, pues este se,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>se infecta y si no tiene respiración entonces eso..., los gan..., aparecen los ganglios y se infectan, se infectan más este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>en su..., en el lugar donde se encuentra la herida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Y esa hierba es muy buena, se..., se busca esa hierbita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Esa no se escasea, se encuentra en cua..., cualquier lugar donde hay humedad, al pie de las paredes de la casa, en la superficie de las pie..., piedras, sobre las piedras o en el cafetal, pero donde hay sombra </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>se da, esa planta abunda en donde hay sombra, ahí se adapta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>en donde no es..., en lugares donde no hay sombra de árboles no se da esa planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Esas se..., se cortan y se macha..., todo con el tallo, con todas las hojas y sus flores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Y sus flores son un poco verdes, las flores y son muy...., y una mata tiene muchas flores en su..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>su..., dirán su..., su..., su...., sus semillas donde se..., en donde tiene sus ramitas, en el racimo, las flores brotan en el centro de las ramas, en el centro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>se ramifica y en el cent..., en la punta de la planta su..., se encuentran las flores</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>para este, y las semillas son muy pequeñitas como las semillas de amaranto su..., su..., sus florecitas son muy pequeñas, pequeñas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>se machacan juntas con el tallo, como son mu..., muy blanditas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Su ta..., el tallo de esta planta tiene un color poco rojo y este muy liso como el &lt;i&gt;xokoyo:lin&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Se ve así hasta transparente el tallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Esa hierba se corta y después de machacarse se aplica al lugar afectado para que no aparezcan los ganglios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Sí conozco esa, conozco esa hierbita. Y no se..., no crece alto, crece de alto un..., de altura,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>crece como una cuarta y media 30 cms. de altura. No crece muy alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>No crece alto. Es bajita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>En los cafetales, donde hay mucha sombra. Siempre es de color verde, siempre es de color verde.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Son muy pequeñas sus semillas. Nada más eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Sí. Se le echa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Sí. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Sí, eso es, due.... Se desinflama.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a348" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Sí. Ya se calma.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Y también hay unos ganglios que les llaman cuando uno..., está, está, algunos nos enfermamos o ya estamos en la gravedad, se encuentra grave el enfermo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>este a veces le duele el cuello, le llaman ganglios en el cue..., cue..., le llaman ganglios en el cuello que aparecen en la parte del cuello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Y uno se..., ya se encuentra uno grave aparecen ganglios en el..., en el cuello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Y esa planta es buen remedio, la..., la buscan, machacan las hojas y le echan en el cuello, le ponen como emplasto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Le ponen xa..., un pape..., en un papel le..., le...., las hojas machacadas las ponen sobre el papel y enseguida le ponen como emplasto en el cuello, le amarran con un pedazo de tela para que ahí se..., para que así queden pegados en el cuello.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>Esos también, esos también se, también les llaman ganglos que aparecen en el cuello na..., bueno no, no nacen sino que duelen como si...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>las venas son las que..., se endurecen  y esos son los que provocan el dolor también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Cuando uno está enfermo de gravedad. Entonces acá en el cuello [...], el enfermo hasta se..., ya tiene ganglios en el cuello, le duele en varias partes, ya no puede mover el cuello, entonces esa hierba es muy efectiva para esa enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Sí, le tienden con un papelito y le amarran con un pedazo de tela en el cuello para que  lo sostenga, así le hace efecto al paciente y se le quita el dolor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Sí. Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>le hace efecto. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Sí eso es. Se cae, se cae. No.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>Sí ese se..., lo..., se le ponen las hojas en el cuello al..., paciente que padece de ganglios.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>Las hojas se tuestan ahí, así como contienen mucha agua se tuestan ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>Y a veces si haceb efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
