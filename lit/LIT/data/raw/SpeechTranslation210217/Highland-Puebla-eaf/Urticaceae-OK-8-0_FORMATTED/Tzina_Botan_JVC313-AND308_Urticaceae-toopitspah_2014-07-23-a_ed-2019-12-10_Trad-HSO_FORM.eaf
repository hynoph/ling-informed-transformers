                <ANNOTATION_VALUE>ke:meh nika:n xola:l tiwi:tseh oso ne:wí:n kowtah tinentinemih pos tikitstinemih katí:n xiwit te:chna:mikis,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts361">
