        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts165">
                <ANNOTATION_VALUE>Pos no: kwali a ke nika:n timona:mikkeh wa:n timo..., timoliah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>Se: tokni:w koma:mo kimati pos kwali tikili:skeh, porke *hasta** i:n tehwa:n neh nikaktok wa:n nikita.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts171">
                <ANNOTATION_VALUE>Pos ke:meh yo:n seki semi se: mo..., se: te:... Se: mi:to:nia de yowak *hasta** i:n tehwa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts175">
                <ANNOTATION_VALUE>pos kihtowah yehwa yo:n cha:wis te:kwi yo:n semi se: kos..., kostia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>*Hasta** n' pi:piltsitsi:n kó:n seki ma:ski chika:wkeh katkah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts180">
                <ANNOTATION_VALUE>Pero kinkwi yo:n kihtowah de k..., kostia *o** ki:ni:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
                <ANNOTATION_VALUE>yo:n de nemowtil. Momowtiah wa:n a:mo kintaliah yo:n xiwtsí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts185">
                <ANNOTATION_VALUE>Pos mose:wiah ya, kochi ya pero ta:, nochi mi:to:nihtokeh wa:lihsah nochi, nochi n' i:n...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts189">
                <ANNOTATION_VALUE>n' inpanko, n' intsontekonko, n' inmetsko nochi mito:nihtokeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts193">
                <ANNOTATION_VALUE>Nochi a:paliwih wa:n a:mo, a:mo, nijó:n, a:mo kimatih toni ta: seki a:mo tikmatih toni, pero [e]kintsi:n nika:n timonohno:tstokeh ta:ká:n a:ksá: mitstahtania</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts197">
                <ANNOTATION_VALUE>Pos kwali tikili:s, ne:n, kati:ni n' pahti de n' te:ch..., ika te:chpahtia:ya, ne:n, tota:tahwa:n wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>*Hasta** [e]kintsi:n pos kwali ti..., timoli:skeh, kwali tikitaskeh yo:n xiwtsí:n, yo:n semi kwali, yo:n a:mo nikihto:s semi tel wehkapania *o** tehsá: kwaltia para teisá:</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts203">
                <ANNOTATION_VALUE>kowtati:l yo:n, a:mo yo:n *solamente** para pahti. Wa:n a:mo e:wi itech i:n ta:ltsi:n ta: teke:span</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts207">
                <ANNOTATION_VALUE>ka:mpa miak tet, tet [ih]kó:n ohololtik pos ompa n' ikwa:ko mo, mos..., mokehketsa, nijó:n, xiwtsí:n pero a:mo wehkapania.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
                <ANNOTATION_VALUE>Tsikilitsitsi:n ompa momahmaxalowa sah wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts213">
                <ANNOTATION_VALUE>pos neh nikita n' iteyo pané: semi tsikitsitsi:n. Pisi:ltik n' iteyo. Pisi:ltik n' iteyo wa:n nochi pané: yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts217">
                <ANNOTATION_VALUE>moma:..., moma:sohsowa ihkó:n mah..., mo..., mota:lia ihkó:n *irramitas** ihkó:n imahma:yo wa:n kwaltsi:n ko:n mo..., mokehketsa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts221">
                <ANNOTATION_VALUE>Yo:n momahmaxalowa, pos yehwa yo:n mah se: kikechtekiti ihkó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts225">
                <ANNOTATION_VALUE>wa:n a:mo no: se: kwiwita. [Por]ke komo se: kwiwita pos se: kiki..., ki..., ka:wilowa ya. Wa:n yo:n no: pané: [Ke:]masá: semi itsmoli:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts229">
                <ANNOTATION_VALUE>Itsmoli:ni, nijó:n, wa:n sepa se: kikwi a. Sepa se: 'kwiti para se: kinta:lilia ne:n kone:meh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts233">
                <ANNOTATION_VALUE>Pero komo nochi se: kiwiwita ihkó:n se: kipolowa ya. Se: kipolowa ya wa:n ne: a:mo ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>Owih ya para ixwa. Ka:nsikase: kita tsikitsitsi:n itech n' ohti se: ki..., se: kita [i]hkó:n ixwatok,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts240" TIME_SLOT_REF2="ts243">
                <ANNOTATION_VALUE>itech i:n tet, tsikilitsitsi:n. Pero ka:mpa ne: n' teke:span [i]hkó:n seki wehwei ihkó:n mohmoskaltia ya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts247">
                <ANNOTATION_VALUE>wa:n momahmaxalowa sah e..., ihkó:n de, wehwei ihkó:n momahmaxalowa pero a:mo wehkapania.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>Ihkó:n ke:meh eskia yo:n mosahsa:lowa. Ihkó:n momahmaxalowa ihkó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
                <ANNOTATION_VALUE>sike:ra ma:kwi:l, ne:n, i..., n' ima:yo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts255">
                <ANNOTATION_VALUE>Ento:s ompa mokehketsa pero yo:n a:mo ke:man neh nikita mah, mah wehwei n' ixiwyo. Yo:n tsikitsitsi:n pisi:ltik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts261">
                <ANNOTATION_VALUE>Xoxoktik wa:n kwaltsi:n mo:..., moke motahta:lilia. Pero a:moke:man nikita de wehwei, nijó:n, yeh..., nika:n timonohno:tstokeh xa:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts265">
                <ANNOTATION_VALUE>xa: tikitani teh xa: wehwei n' ima:xiwyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
                <ANNOTATION_VALUE>Pisi:ltik. Wa:n ne:n, nikitani a:mo ke:man wa:ki, neh nikita pané: nochipa selistok [i]hkó:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts273">
                <ANNOTATION_VALUE>Sayoh ke *cuando** chika:waya, nijó:n, wa:ki a n' ima:yo wa:n ma:xi:ni tepitsi:n wehwetsi. Wehwetsi pero sepa itsmoli:ni ihkó:n. Wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>sepa ihkó:n mochi:wtiki:sa wa:n yeh nimitsilia, ne:n, tehwa:n no: ihkwi tik..., tiktekiah [i]kó:n *o** k[i]tekiah, ne:n, ta:tahmeh, a:mo kwiwitayah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>Sayoh 'kechtekiah ihkó:n para, nijó:n, sepa mah itsmoli:ni, para sepa tikwitih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts281">
                <ANNOTATION_VALUE>Pero komo tikwiwitah [i]hko:n nochi poliwi a. Poliwi a n' ma:ta</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts285">
                <ANNOTATION_VALUE>*[des]pues** owih ya para sepa ne:wí:n se: kite:mohtinemi. Wa:n yo:n nochi e:wi ka:mpa tehteyoh, a:mo nikihto:s itech kowit e:wi oso ka:nsika, ne:n, [ih]kó:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts289">
                <ANNOTATION_VALUE>yo:n nochi itech i:n teke:span ka:mpa, ne:n, kisa:lowah, ne:n, tet.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>*O, o** [i]hko:ni yetoki:n toh..., n' tet we:i, tela:jah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
                <ANNOTATION_VALUE>pos ompa ne: yeto[k], ompa ne: mochi:wa yowaltik n' tet n' ike:span ya mochi:wa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts297">
                <ANNOTATION_VALUE>Wa:n koma:mo. Ke:mah ka:mpa, nijó:n, pachyoh ihkó:n ompa n' ike:span mopepechowa. Yo:n pepechiwtok sah. Mopepechiwtok ko:n ika m' pachti ika, ne:n, mo..., mopepechowa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
                <ANNOTATION_VALUE>wa:n ompa ke:meh eskia yo:n kiyo:litihtok, nijó:n, tet.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts303">
                <ANNOTATION_VALUE>Kiyo:litihtok, nijó:n, tet pos ompa n' ike:span, ne:n, moskaltia. Yo:n a:mo itech i:n ta:ltsi:n nika:n moskaltia yo:n ike:span</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts307">
                <ANNOTATION_VALUE>tak yehwa ya n' kiskaltia, ne:n, tepach. Tepach ihkó:n yeh kiyo:li..., kiyo:litia ya. Ke:mah yehwa yo:n neh nikmattok wa:n kwaltsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
                <ANNOTATION_VALUE>timonohno:tsah wa:n kwaltsi:n tikin..., [tikin]iliskeh n' tokniwa:n ta:ká:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
                <ANNOTATION_VALUE>a:mo kimatih pero nika:n tehwa:n tepitsi:n tik..., tikitah i:n tein tikita tota:tahwa:n pos, nijó:n, ekintsi:n mah ti..., mah tikilika:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts315">
                <ANNOTATION_VALUE>Ke:masá: se: kone:tsi:n kihto:s kwali mitstahtani:skeh xa: to:n, to:n n' kina:mikis nika:n nopili porke, nijó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
                <ANNOTATION_VALUE>moyowali:to:nia. Entos pos yehwa, nijí:n, teahwach xkwiti wa:n sik..., xiksohsowili</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts321">
                <ANNOTATION_VALUE>'ta:lili se: tilmahtsi:n tatampawa:n paniá:n x'ta:lia, ne:n, pahti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts322" TIME_SLOT_REF2="ts324">
                <ANNOTATION_VALUE>Nijí:n, semi kwali, niji:n, pahti itech n' ikwa:tapech wa:n nochi, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts327">
                <ANNOTATION_VALUE>pos nochi mah kisohsowili wa:n kina:mikis. Yo:n nochi de mopechia nochi ki:sa ya n' a:tsi:n ke:meh eskia yo:n cho:kil</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts331">
                <ANNOTATION_VALUE>Ke:meh eskia cho:kil ki:sa yo:n a:tsi:n pos yehwa ya m' pahti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts335">
                <ANNOTATION_VALUE>Kikwia ne:n kone:t ki..., itech n' *ilomo**, itech n' ipankonochi nika:n wa:n itech n' imetsko *o** itech n' itsontekon</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts336" TIME_SLOT_REF2="ts339">
                <ANNOTATION_VALUE>pos yehwa ya ne:n kikwih para, ne:n, pahti kikwia itech n' i, n'i, n'i..., nika:n nochi itech n' inakayo</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
                <ANNOTATION_VALUE>itech n' ipanko, itech n' inakayo, itech n' iomio,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts345">
                <ANNOTATION_VALUE>pos nochi yeh kikwi a. Wa:n yehwa yo:n neh nimitstahtani:sneki xa: kachi *más** tikmati *o**, ox para se: tai *o** para,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
                <ANNOTATION_VALUE>para ki:ni:n nehwa neh s..., neh ihkó:n nikmattok para n' pahti ihkó:n se: mo..., se: mota:[li]lia no se:ki:n kihtowah ke ika te:a:ltiah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts351">
                <ANNOTATION_VALUE>Neh, nijó:n, kihtowah seki kimolo:ntiah. Pos neh, nijó:n, no: nik..., tepitsi:n nikmati no: pero,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
                <ANNOTATION_VALUE>Pos miak ki..., kichi:wah no: seki para netati:l pero yo:n kima:nelowah. Pero [ek]intsi:n nikmattok yehwa ne:, de ne: xiwtsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts357">
                <ANNOTATION_VALUE>yehwa yo:n te:sowiliah. Porke yo:n ke:masá: *hasta** i:n tehwa:n tiwehwei:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
                <ANNOTATION_VALUE>De tikotok..., tikochtokeh wa:n toi:xko te:temo:tok, nijó:n, a:tsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
                <ANNOTATION_VALUE>yo:n a:tsi:n de ne:to:n. De ne:to:n a:mo porke a:t, ne:n, a:t de ne:to:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts365">
                <ANNOTATION_VALUE>wa:n yehwa yo:n ma:ski tehwa:n [e]kintsi:n tepitsi:n tichika:wkeh o ki:ni:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts366" TIME_SLOT_REF2="ts368">
                <ANNOTATION_VALUE>pero komo te:kwik, nijó:n, ta..., tatsiwi:lis, se: tatsiwi, se: kochisneki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
                <ANNOTATION_VALUE>Yehwa yo:n te:kwitok ke:meh eskia se: nemowtil.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts373">
                <ANNOTATION_VALUE>Pos se:, se: kostia *o** ki:ni:nse:, *o** ki:ni:n se: kimati porke se: tatsiwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts374" TIME_SLOT_REF2="ts376">
                <ANNOTATION_VALUE>Se: tatsiwi wa:n yehwa yo:n te:chi:wilih *mal**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts379">
                <ANNOTATION_VALUE>Porke s..., komo se: kochi wa:n se: mi:to:nihtok te:chi:wilih, ne:n, *mal** yehwa ya, nijó:n, se: kokolis pe:wa ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>Se: kokolis pe:wa ya yehwa ya tiki..., te..., se:, se: mi:to:nia yo:n semi *mal** a:mo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
                <ANNOTATION_VALUE>a:mo, nijó:n, kwaltsi:n se: yetok ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts387">
                <ANNOTATION_VALUE>*Igual** i:n kone:meh pos seki ika, ne:, ika xi:kawih, porke a:mo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts391">
                <ANNOTATION_VALUE>a:mo kimpahtiah. Pos no: yowih tapahtilo:ya:n pero koma:mo yehwa, nijí:n, pahti, nijí:n, xiwtsí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts395">
                <ANNOTATION_VALUE>Semi tel..., semi telte:na:miki. Nijí:n xiwtsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
                <ANNOTATION_VALUE>no: kwali a nika:n ti..., timona:mikkeh nika:n itech i:n ohti pos ....</ANNOTATION_VALUE>
