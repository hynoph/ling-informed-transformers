        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a390" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Se mojan todo y no, no este, no saben con qué porque algunos no saben qué es, pero ahora que estamos platicando acá y si alguien te pregunta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a391" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>Pues puedes decirle con qué medicinas nos..., usaban para curar nuetsros abuelos y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a392" ANNOTATION_REF="a186">
