            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a426" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>Entonces ahí se encuentran las plantas pero yo nunca veo que tenga hojas grandes. Son pequeñas, muy pequeñas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>Son verdes y se..., son bonitas sus ramas. Pero nunca veo que sean grandes, este es..., aquí estamos platicando tal vez</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a217">
                <ANNOTATION_VALUE>usted la haya visto que tenga hojas grandes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a429" ANNOTATION_REF="a219">
                <ANNOTATION_VALUE>Son pequeñas. Y yo he visto que nunca se secan las matas, yo siempre he visto que las plantas son verdes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a430" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>Sólo que cuando se maduran, este se secan sus ramas y se caen las hojas un poquito. Se caen pero la planta vuelve a retoñar y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a431" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>otra vez se ramifica y como te platico este, que nosotros también las..., las cortábamos así o cortaban los ancianos pues no las arrancaban.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a432" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>Sólo cortaban las puntas para este, que vuelva a retoñar para volver a cortarlas nuevamente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>Porque si la arrancamos pues ya se acaba. Se pierde la mata</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>después cuesta trabajo andar buscando por ahí. Y esas plantas se dan en donde hay piedras, no se da en el tronco de un árbol oen alguna otra parte así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
