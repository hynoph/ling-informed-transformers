        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>A también lo quieres saber. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Pues qué bueno que nos encontramos en este camino.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>pues siempre nos andamos encontrando y ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Pues el &lt;i&gt;teahwach&lt;/i&gt; también, también la conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>También la conozco la co..., también es bueno para remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Cuando los niños se..., sudan mucho cuando duermen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>sudan cuando duermen y en toda su cara baja el agua, el agua, el sudor, o hasta nosotros los adultos también nos...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>sudamos cuando está cerca de que nos va dar alguna enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Eso es lo que..., uno empieza a sudar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Entonces van a traer el &lt;i&gt;teahwach&lt;/i&gt; y lo..., lo tienden debajo de la sábana,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>lo tienden debajo de donde duerme uno</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>ahí tienden las hojas y otras personas dicen que también se pueden usar para que lo bañen a uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Pero más lo ve uno que las..., las tienden en la almohada o en la  espalda.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>La tienden en todo el tapete el &lt;i&gt;teahwach&lt;/i&gt; y yo he visto que esa planta no se da en el suelo, sino que se da en la superficie de las piedras,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>en lugares donde hay piedras ahí abunda esa planta y también, también se ramifica.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Esa no crece alto, es muy pequeña y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>se dan muy bajitas no puedo decir que se dan arriba, en el tronco de un árbol o en el suelo. Esa planta se da en la superficie de las piedras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>donde se encuentra una..., t..., así una piedra redonda.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Ahí en la superficie de la piedra se encuentra. Y desde ahí se trae, a veces se arranca o nada más se corta porque es..., esa este se deja porque es muy buen remedio, es muy buen remedio.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Ese remedio la tienden hasta para nosotros si nos..., si uno tiene sueño porque a los niños </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>les da sueño y eso es, este,a veces están sudando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Aunque duerman en su tapete durante el día pero están sudando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a344" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Y algunos en la noche cuando duermen sudan y entonces van a traer este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a345" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>las hojas de &lt;i&gt;teahwach&lt;/i&gt; y se las tienden</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a346" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>hasta se secan las hojas ahí y entonces, es cuando les hace efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a347" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Les hace efecto porque les quiere dar como si fuera  anemia, una enfermedadque es la anemia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a348" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Cuando uno suda al dormir significa que uno tiene esa enfermedad. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Si sudas en la noche al dormir y cuando despiertas se te está bajando el sudor en la cara</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a350" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>pues eso es lo que hace daño y ya se..., enferma uno. Pero si uno se cura a tiempo, se consiguen este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>el &lt;i&gt;teahwach&lt;/i&gt; pues se cura uno hasta a nosotros. Y eso es lo que yo también quiero preguntarte</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a352" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>tal vez usted lo sabe más, si nada más se usan esas hojas para curarse este de..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>cuando uno suda por las noches al dormir, tal vez se toma algo o cómo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>o, o a dónde se da tal vez haya en el bosque o alguna otra parte que sea lejos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Pues esta se da lejos en donde hay piedras pero uno no sabe. Eso es lo que yo también quiero preguntarte, tal vez conoce más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a161">
