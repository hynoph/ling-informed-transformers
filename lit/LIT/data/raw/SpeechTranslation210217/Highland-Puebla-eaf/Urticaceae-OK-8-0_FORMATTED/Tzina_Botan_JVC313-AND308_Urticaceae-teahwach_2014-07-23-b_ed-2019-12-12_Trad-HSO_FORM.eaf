        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts413">
                <ANNOTATION_VALUE>Ne: ke:man neh nik..., nikitaya miak n' tokniwa:n te:chka:wte:wkeh *o** kone:meh ke a:mo kimatih i:n xiwtsí:n kox semi kwali. Teahwach.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts417">
                <ANNOTATION_VALUE>I:n semi kwali nijí:n pahti. A:mo *igual** tapahtilo:ya:n ne:wí:n.</ANNOTATION_VALUE>
