            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Pues ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Pues qué bueno que nos encontramos en este lugar y lo..., platicamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Una persona si no sabe pues podemos decirle, porque hasta nosotros que estoy escuchando y lo veo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a383" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>Pues como algunos nos..., uno se.... Uno suda por las noches hasta nosotros los adultos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a384" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>pues dicen que cuando uno padece de anemia y se pone uno muy ama..., amarillo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a385" ANNOTATION_REF="a175">
