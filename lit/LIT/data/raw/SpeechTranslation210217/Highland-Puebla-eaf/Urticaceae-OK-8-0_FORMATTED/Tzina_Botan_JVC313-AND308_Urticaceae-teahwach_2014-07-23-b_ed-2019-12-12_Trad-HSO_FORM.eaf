            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a421" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>Cuesta para que germine de nuevo. En algunas partes en el camino, lo ve..., ve uno que están germinando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
