        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>Ekintsi:n nika:n timo..., nika:n timolihtokeh ke a:ksá: mitstahtania ihkó:n se: tokni:w *o** se: na:nahtsi:n *o** se: ta:tahtsi:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
