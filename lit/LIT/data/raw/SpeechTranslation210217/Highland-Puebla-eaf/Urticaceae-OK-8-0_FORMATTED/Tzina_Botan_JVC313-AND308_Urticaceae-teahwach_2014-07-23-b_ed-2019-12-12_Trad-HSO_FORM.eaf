        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts401">
                <ANNOTATION_VALUE>Semi kwaltsi:n nika:n timonohno:tstinemih wa:n nochi tik..., tikix..., tikits..., tikitstinemih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts405">
                <ANNOTATION_VALUE>Ton.....</ANNOTATION_VALUE>
