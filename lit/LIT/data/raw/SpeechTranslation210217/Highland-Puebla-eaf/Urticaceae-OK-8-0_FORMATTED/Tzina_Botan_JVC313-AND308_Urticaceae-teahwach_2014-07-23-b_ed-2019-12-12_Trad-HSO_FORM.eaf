        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts425">
                <ANNOTATION_VALUE>Miak a:mo tiki..., tiki..., tikitah sayoh xiw..., xiwtsí:n ne: yetok ne:n teahwach ike:span tet.</ANNOTATION_VALUE>
