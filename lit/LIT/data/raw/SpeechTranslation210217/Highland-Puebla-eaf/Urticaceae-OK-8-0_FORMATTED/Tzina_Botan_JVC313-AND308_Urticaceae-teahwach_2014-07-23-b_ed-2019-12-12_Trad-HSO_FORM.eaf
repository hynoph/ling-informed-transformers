        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a423" ANNOTATION_REF="a208">
                <ANNOTATION_VALUE>y se ramifican e..., así son de grandes que se ramifican pero no crecen alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a424" ANNOTATION_REF="a210">
