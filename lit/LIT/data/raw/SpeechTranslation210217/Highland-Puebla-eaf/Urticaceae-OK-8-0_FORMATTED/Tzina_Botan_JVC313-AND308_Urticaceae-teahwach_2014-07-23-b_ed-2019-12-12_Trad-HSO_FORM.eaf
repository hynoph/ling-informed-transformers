        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts421">
                <ANNOTATION_VALUE>Itech oksiki pahti de ne:pa nijí:n, kwali nijí:n no.... Wa:n miak a:mo tikmatih.</ANNOTATION_VALUE>
