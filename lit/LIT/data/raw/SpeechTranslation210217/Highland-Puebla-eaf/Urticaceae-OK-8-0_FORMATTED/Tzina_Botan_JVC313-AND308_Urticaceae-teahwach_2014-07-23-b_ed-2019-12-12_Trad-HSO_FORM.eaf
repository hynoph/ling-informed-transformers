            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Le está dando vida la piedra, y pues ahí en la superficie crece. Esa no se da en el suelo sino que encima de las piedras</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a238">
