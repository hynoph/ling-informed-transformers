        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>Wa:n yo:n kihtowah ne: kita:lilia:yah sikie:ra o:me ihkó:n, ne:n, ne: ka:m[pa] koyoktik, we:noh 'koyo:nia:yah ohka:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
