            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
                <ANNOTATION_VALUE>ka:mpa kite:ntekiah yo:n we:i..., wehweikowit, yo:n wehweikowit mochi:wa.</ANNOTATION_VALUE>
