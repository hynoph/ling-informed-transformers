        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts428" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>Ompa konki:xtilia:yah ne:n e:wat oso ka:mpa ka:nsika ihkatok pos ki..., ka:mpa a:mo semi wehkapan pos ma:ahsiah pos 'ki:xtilia:yah yo:n e:wat pata:wak.</ANNOTATION_VALUE>
