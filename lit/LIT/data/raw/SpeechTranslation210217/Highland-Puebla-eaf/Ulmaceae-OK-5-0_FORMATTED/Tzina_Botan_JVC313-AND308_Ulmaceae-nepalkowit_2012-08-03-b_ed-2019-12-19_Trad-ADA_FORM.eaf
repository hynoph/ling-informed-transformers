        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
                <ANNOTATION_VALUE>Wa:n *después** te:chi:ilia:ya wa:n neh nikitak ok.</ANNOTATION_VALUE>
