            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>Konkwiah wa:n kichi:wayah. Wehka:w ya wa:n yehwa yo:n ki... nan..., kixita:nia:yah wa:n kikwiah ya yo:n *hilo**.</ANNOTATION_VALUE>
