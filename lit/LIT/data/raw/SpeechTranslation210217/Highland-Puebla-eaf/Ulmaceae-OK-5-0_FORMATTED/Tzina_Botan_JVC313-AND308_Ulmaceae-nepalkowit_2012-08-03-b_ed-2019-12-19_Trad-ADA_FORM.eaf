        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
                <ANNOTATION_VALUE>Pero n' de yo:n nijí:n okseki, i:n ekintsi:n de kwa:koweh ne:sik aya:mo teh katka.</ANNOTATION_VALUE>
