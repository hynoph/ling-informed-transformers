        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
                <ANNOTATION_VALUE>Kitehtekiah wa:n kikohkoyo:nia:yah pero pos kihtowah kikoyo:nia:yah ika oksé:, n'mati ika toni yo:n 'koyo:nia:yah pero pos yo:n a:mo wel kichini..., kichichino:wa:yah *porque** de xohxowik a:mo tata.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
