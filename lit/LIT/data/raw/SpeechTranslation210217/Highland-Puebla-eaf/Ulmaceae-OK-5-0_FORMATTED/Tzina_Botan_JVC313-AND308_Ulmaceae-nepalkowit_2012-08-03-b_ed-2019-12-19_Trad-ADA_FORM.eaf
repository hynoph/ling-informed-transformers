            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
                <ANNOTATION_VALUE>Seki, seki, ne:n, *hule**, achi ne: kipia, nijó:n, o:me n' i..., *esquina** nika:n, nika:n no:</ANNOTATION_VALUE>
