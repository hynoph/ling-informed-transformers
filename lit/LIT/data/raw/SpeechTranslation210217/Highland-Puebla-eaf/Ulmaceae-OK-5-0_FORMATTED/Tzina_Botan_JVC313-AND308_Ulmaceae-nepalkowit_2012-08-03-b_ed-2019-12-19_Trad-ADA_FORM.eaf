                <ANNOTATION_VALUE>A:mo onkaya wa:n pos ihwa:k, ne:n, a:mo teh onkaya de, nijó:n, para se: mota:lilia:ya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
