        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
                <ANNOTATION_VALUE>Entó:s 'kwa:'ilpia:yah wa:n yehwa yo:n kita:lilia:yah.</ANNOTATION_VALUE>
