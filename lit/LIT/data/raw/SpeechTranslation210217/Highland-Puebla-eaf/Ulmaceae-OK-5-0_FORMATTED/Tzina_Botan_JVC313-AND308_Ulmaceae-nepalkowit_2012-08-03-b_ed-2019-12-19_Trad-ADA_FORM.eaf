        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts416" TIME_SLOT_REF2="ts418">
                <ANNOTATION_VALUE>A:mo teh, a:mo teh onkaya de, nijó:n, tekak de n' ke:meh ekintsi:n, ne:n, miak taman onkak de i:n tekak te:ch..., te:chtehtekiliah wa:n ....</ANNOTATION_VALUE>
