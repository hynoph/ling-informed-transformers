        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Bueno, pues yo me llamo Hermelindo Salazar, también vengo de San Miguel Tzinacapan. Sí.</ANNOTATION_VALUE>
