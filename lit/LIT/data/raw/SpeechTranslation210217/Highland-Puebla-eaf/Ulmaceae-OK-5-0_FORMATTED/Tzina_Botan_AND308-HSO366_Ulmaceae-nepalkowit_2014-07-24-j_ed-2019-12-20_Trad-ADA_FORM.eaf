        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>este, si acaso sirve para algo o también sepas cuándo florece, dónde crece</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>y pues, es eso, para qué se usa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Si.</ANNOTATION_VALUE>
