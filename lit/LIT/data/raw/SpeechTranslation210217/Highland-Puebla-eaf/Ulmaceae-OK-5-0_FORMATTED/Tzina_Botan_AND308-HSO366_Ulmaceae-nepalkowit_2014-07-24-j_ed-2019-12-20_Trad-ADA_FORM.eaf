        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>Pues este, si acaso quieres contarme algo más sobre el &lt;i&gt;nepalkowit&lt;/i&gt; o este...,  pues yo conozco solamente lo que te he dicho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
