        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Si y solamente eso. El árbol no crece muy alto, no crece muy alto, crece en los cafetales o crece en alguna parte del monte.</ANNOTATION_VALUE>
