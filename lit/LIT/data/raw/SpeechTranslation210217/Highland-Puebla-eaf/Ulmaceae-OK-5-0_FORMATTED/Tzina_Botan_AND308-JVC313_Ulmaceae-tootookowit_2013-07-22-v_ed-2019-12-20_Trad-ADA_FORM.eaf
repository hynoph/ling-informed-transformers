        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts37">
                <ANNOTATION_VALUE>{Ikwa:y es ikwa:y mekapal, la parte del lazo del mecapal que va por la frente del quien carga}</ANNOTATION_VALUE>
