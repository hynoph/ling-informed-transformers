        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts249">
                <ANNOTATION_VALUE>M..., *o machete**, a:mo moto:ka.</ANNOTATION_VALUE>
