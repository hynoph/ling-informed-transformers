        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>wa:n m[o]mahma:itia, mo..., ye:kmahmaxaleh, ihkó:n mochi:wa ke:meh *palma** wa:n ompa ne: ompa ta:ki a, ka:mpa yo:n chika:wak kowit pos ompa ta:ki kwaltsi:n, ompa mochi:wa ika *sarta**, ke:meh kahfe:n.</ANNOTATION_VALUE>
