                <ANNOTATION_VALUE>Kowset..., a:mo tekoloh pero kwaltsi:n xo:ta.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>Wa:n nejó:n yehwa sah yo:ni niki:xmattok no: wa:n neli ne:n ima:y ma:we:weyakaxtik wa:n ma:..., ma:tsitsikiltik ima:yekapan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>Ke:mah wa:n yehwa ya. Ka:n semi wehkapania kowit, a:mo semi wehkapania, mochi:wa nika:n kahbe:ntah *o** ka:sá: ika kowtah mochi:wa yo:n.</ANNOTATION_VALUE>
