                <ANNOTATION_VALUE>wa:n no: se: kitsahtsaya:na</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>para no: yeh se: ika se: tawi:pa:na, se: tahtalpia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>Wa:n sepa no: *igual de que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>pos se: kikwi para kale:walmeh *o para** taihtiyo:meh de se: ikaltsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>Yo:n no: kwaltia, sayoh *que de** wehka:wa ya mochihkolowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts33">
                <ANNOTATION_VALUE>Mochihkolowa ya wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>pos yo:n i..., n' iteyo no:, no: semi pisi:ltik wa:n tihti:ltik,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
                <ANNOTATION_VALUE>wa:n kikwah ne:n chiktehmeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts43">
                <ANNOTATION_VALUE>Chiktehmeh kikwah. Yo:n koyoltsitsi:n oso yo:n seki n' yo:n kini[li]ah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts47">
                <ANNOTATION_VALUE>ne:, e:lo:to:tomeh, nochi kikwah yo:n seki. Tein eski chiktehmeh ki..., kikwah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>Ke:mah kikwah nochi kipanxi:niahta:lpa:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>Wa:n yo:n sepa e:wi. Ixwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts59">
                <ANNOTATION_VALUE>Wa:n sepa moskaltia sepa mochi:wa mehmela:wak. Yo:n mehmela:wak</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts63">
                <ANNOTATION_VALUE>mochi:wa kwaltia para kalkowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>Ta:ká:n tiknekih tiketsaskeh tokaltsi:n pos tikte:ntekitih,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>*[Por]que** yo:n onkak nowiá:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts71">
                <ANNOTATION_VALUE>Onkak nika:wí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>To:sa:n, nika:wí:n no: ohte:noh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>Ka:nsika se: kita *que** seki mochi:wa wehwei kowit ihkó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>para yo:n a:mo kwaltia seki para kali,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>*sólo** para kowtati:l.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a95" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts87">
                <ANNOTATION_VALUE>Ke:mah pero n' ie:wayo yeh kwaltia para se: tawi:pa:na. *Antes** i:pa tikwiah se: tama:mal ihkó:n de,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>para ika tiktsahtsaya.... T'tehtekiah ihko:ni,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>ika mache:teh wa:n tiki:xtia:yah ihkó:n, ke:meh eskia yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>ke:meh eskia yo:n mekapal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>Entó:s ika titawi:pa:nayah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a101" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
                <ANNOTATION_VALUE>Pero yema:nik no:, *en lo**.... Wa:n ekintsi:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a103" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>pos a:mo kachi tikwih ok, pero tikixti:liah n' e:wat *cuando** ke:meh i:n kali tikchi:wasnekih</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a104" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>para a:mo okwilowas pos tiki:xtiliah n' e:wat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
                <ANNOTATION_VALUE>Para a:mo chihkoltia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts113">
                <ANNOTATION_VALUE>Kichihkolowa ya wa:n pos a:mo kwaltsi:n, ke:masá: niman pala:ni wa:n *mejor** ne: se: 'ki:xtilia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n neh nikmattok *de que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>pos i:n de que panxi:n[i]n' iteyotsitsí:n wa:n ixwa miak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts121">
                <ANNOTATION_VALUE>Ka:nsika se: kita ye:kmiak kipia pero nochi mehmelaktsitsí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts125">
                <ANNOTATION_VALUE>Wa:n yo:n no: ki:sa n' ie:wayo pero de n' achi selik ok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts129">
                <ANNOTATION_VALUE>Pero de n..., de n' ihkó:n tohtoma:wak chika:wak, a:mo ki:sa ok, kohkoto:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>Kohkoto:ni ne:n ipane:wayo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Yehwa yo:n neh nikmattok *compadrito que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a121" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>pos ne:, nijó:n, no: kwali tine:chilis</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>ki:ni:n n' teh xa: kachi tikmati.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a126" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts151">
                <ANNOTATION_VALUE>Pipi:nik.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts155">
                <ANNOTATION_VALUE>A:mo eti:k yo:n se: ki..., tein a:mo semi tohtoma:wak ke:meh ne:n se: kixi:kowa o:me.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts159">
                <ANNOTATION_VALUE>Wa:n okseki ne:n etik. Wa:n i:n a:mo etik i:n kowtsí:n de wa:ki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts163">
                <ANNOTATION_VALUE>Wa:n no: taxi:kowa, sayoh *que** ke:masá: 'kohkoyo:niah yo:n ok..., okwilimeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>N' okwiltsitsí:n kalakih ompa ne: wa:n 'kohkoyo:niah pos ompa posteki a. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts170" TIME_SLOT_REF2="ts173">
                <ANNOTATION_VALUE>Wa:n, pos, pos i:n, nijó:n, iteyo tehwa:n a:mo, a:mo tikwah nió:n tei.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts177">
                <ANNOTATION_VALUE>Kikwah *solamente chiktehtsitsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts181">
                <ANNOTATION_VALUE>Chikteh[meh]kikwah nochi ne:n, *bueno** neh nikitani yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>Miak, tein a:mo chiktehtsitsi:n ihkó:n mo..., mopi:pilowah wa:n kipanxi:niah n' iteyo wa:n *después** nochi ahko, nochi sentakwi a ke:masá:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts187">
                <ANNOTATION_VALUE>Ihkó:n ixwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts191">
                <ANNOTATION_VALUE>Wa:n seki, se: kita ihkó:n *plantitas**, miak ixwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
                <ANNOTATION_VALUE>Wa:n yo:n miak ka:nsika tame:wah ihkó:n 'ka:wah *porque** yo:n kwaltsi:n para kalkowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts197">
                <ANNOTATION_VALUE>Ompa se: kitekiti para, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts201">
                <ANNOTATION_VALUE>kalkowit. Komo se: 'ki:xtilia n' ie:wayo yeh ika se: tawi:pa:na.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>Ke:meh yo:n se: kihilpia, ne:n, kowxiwit n' i..., n' ixiwyo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
                <ANNOTATION_VALUE>entó:s se: kihilpia pos kwaltsi:n no:.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts211">
                <ANNOTATION_VALUE>Se: kichi:wa ihkó:n, ne:n, se: tahtalpia yo:n semi yema:nik. Mmm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts225">
                <ANNOTATION_VALUE>Pos [i]hkó:n kihtowah, no: nite:kakilia *de que**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts237">
                <ANNOTATION_VALUE>Pos [i]hkó:n se: te:kakilia, pero a:mo, a:mo tikmatih.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts241">
                <ANNOTATION_VALUE>Pero pos chiktehtsitsi:n a:mo mikih. Yehwa: kachi *más**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts245">
                <ANNOTATION_VALUE>mo..., mo:chihchika:wah ta: ....</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts249">
                <ANNOTATION_VALUE>ika motekipanowah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts253">
                <ANNOTATION_VALUE>Eki:ntsi:n a:mo kineki mah kachi se: kite:nxi:ma yo:n kowtsitsí:n *porque** yo:n ompa motekipanowah ne:n chiktehmeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts257">
                <ANNOTATION_VALUE>Ompa motekipanowah n' chiktehmeh. Ke:meh i:n tehwa:n ka:nsika tiowih pos,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts261">
                <ANNOTATION_VALUE>teihsá: timahxiliah, *este**, pahpatatsi:n pos tikwah ya, *igual** se: chiktehtsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
                <ANNOTATION_VALUE>Ompa nochi motate:moliah ya wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
                <ANNOTATION_VALUE>ihkó:n no: i:xpanowah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts273">
                <ANNOTATION_VALUE>Ke:mah yo:n kowtetsí:n. Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts279">
                <ANNOTATION_VALUE>A: *bueno** Ekintsi:n ti..., tikmatik no: ya *de que** ki:ni:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts283">
                <ANNOTATION_VALUE>ti..., tik..., tikitah.</ANNOTATION_VALUE>
