        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Eso es todo compadrito y yo he escuchado que otros le llaman   matacaballo, así le llaman en español.</ANNOTATION_VALUE>
