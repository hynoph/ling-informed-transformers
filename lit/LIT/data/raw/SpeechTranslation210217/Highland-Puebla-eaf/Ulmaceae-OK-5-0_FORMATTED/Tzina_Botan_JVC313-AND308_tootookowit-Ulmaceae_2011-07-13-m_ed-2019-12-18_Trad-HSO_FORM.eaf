        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Sí, pero dicen que es cierto que es veneno si el caballo se come las hojas de esta planta.</ANNOTATION_VALUE>
