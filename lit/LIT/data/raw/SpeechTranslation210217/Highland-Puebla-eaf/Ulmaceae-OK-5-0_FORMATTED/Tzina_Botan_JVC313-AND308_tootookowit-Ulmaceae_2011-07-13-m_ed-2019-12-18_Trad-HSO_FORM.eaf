    <TIER DEFAULT_LOCALE="us" LINGUISTIC_TYPE_REF="Comentarios" PARTICIPANT="Comments" TIER_ID="Comments">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts55">
                <ANNOTATION_VALUE>{Nicolás Damián alarga la /a/ de pan pero se escribe corta para seguir la morfologia. Notese que en algunos nahuatl se alarga una vocal antes de dos consonantes.}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts137">
                <ANNOTATION_VALUE>{Otra vez Nicolás Damián alarga la /a/ de pan-}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>{Aquí se equivocó al pluralizar porque para la mayoría de los hablantes sería "kowtekinih"}</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traduccion" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>A el &lt;i&gt;to:to:kowit&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Pues ese tiene dos nombres compadrito, ese se llama</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>también se llama &lt;i&gt;kwetaxkowit&lt;/i&gt;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>y &lt;i&gt;to:to:kowit&lt;/i&gt;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Pues el &lt;i&gt;kwetaxkowit&lt;/i&gt; también se..., se le sacasu...,  la corteza</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>y también se rompe</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>se puede ocupar para amarrar palos en un corral.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Y también es igual de que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>se puede usar para alfardas o para tirantes en nuestra casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Ese también sirve nada más cuando ya tarda se encorva la madera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Ya se encorva y,</ANNOTATION_VALUE>
