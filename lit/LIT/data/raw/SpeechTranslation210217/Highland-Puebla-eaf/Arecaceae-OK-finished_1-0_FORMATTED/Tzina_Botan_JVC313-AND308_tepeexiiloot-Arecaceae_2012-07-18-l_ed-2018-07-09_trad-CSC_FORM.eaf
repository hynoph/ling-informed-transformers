        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>Yo:n, nejó:n, no:, no:, no: *cuando** a:mo onkak tepe:xi:lo:t tein kwali pos se: kikwi ma:ski yehwa.</ANNOTATION_VALUE>
