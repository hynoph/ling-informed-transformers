        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>Wa:n ima:y telkwe:chtik ki:sa n' i..., im..., ima:..., ima:xiwyo *mo que** telkwe:chtik ki:sa n' ima:ko, mahyá: *palma**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>Ye:kkwe:chtik n' ima:y wa:n, nejó:n, a:mo wehkapania. Sayoh ma:tokotstik, para se: tachihchi:was a:mo, a:mo se: kikwi pero,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
