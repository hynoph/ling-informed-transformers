        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>Si dejan la mata por ejemplo en el bosque si crece y es..., abundante.</ANNOTATION_VALUE>
