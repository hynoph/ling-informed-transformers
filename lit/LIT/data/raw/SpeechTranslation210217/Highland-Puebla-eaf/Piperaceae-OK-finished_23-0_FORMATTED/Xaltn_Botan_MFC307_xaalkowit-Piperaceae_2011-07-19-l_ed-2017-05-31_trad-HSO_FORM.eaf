    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Eleuterio Gorostiza Salazar" PARTICIPANT="Eleuterio Gorostiza Salazar" TIER_ID="EGS Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Bueno pues señora, ahora platícanos de éste,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>los diferentes tipos de xa:lkowit que usted conoce. Platícanos todas las diferencias que usted conoce, qué parte de la planta se usa, cómo son las hojas, el tallo y si crece un árbol grande.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Bueno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>El que dices que se pueden usar los frutos para atole este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>también le llamas xa:lkowit, ¿cómo son sus frutos cuando maduran, son rojos o son de color negro?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Ahora el que dices que, lo usan este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>es pequeño y usan para e..., sembrar yuca, ¿cómo lo hacen, juntan con esa planta o siembran junto con la yuca? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>¿Si no usan el xa:lkowit para hacer los hoyos no se dan bien los camotes?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Y el que dices que se usa para curar el empacho, ¿es sólo para curar el empacho, no se usa para curar otra enfermedad?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Parece que ya nos platicaste todo de los  tres tipos de xa:kowit que conoces, ahora dinos, este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>tu nombre o si sabes algo más del xa:lkowit nos puedes decir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Bueno pues ahora dínos tu nombre y el pueblo de donde vienes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="María Ocotlán Fermín Cabrera" PARTICIPANT="María Ocotlán Fermín" TIER_ID="MFC Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a21">
