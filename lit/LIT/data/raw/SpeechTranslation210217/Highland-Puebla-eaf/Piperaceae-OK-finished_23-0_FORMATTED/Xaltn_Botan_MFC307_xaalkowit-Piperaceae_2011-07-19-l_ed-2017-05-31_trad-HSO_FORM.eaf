        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>es el que se usa para sembrar yuca, es el que se llama xa:lkowit. Y el xa..., el otro,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
