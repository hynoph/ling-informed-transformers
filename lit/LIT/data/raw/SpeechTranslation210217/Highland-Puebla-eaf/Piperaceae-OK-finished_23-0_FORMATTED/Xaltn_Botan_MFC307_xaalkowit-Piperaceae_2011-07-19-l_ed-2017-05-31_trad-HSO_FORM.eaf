        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>como una lombríz de tierra. Y también maduran.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Y también son sabrosas las semillas, también son dulces. Mmm. Y,</ANNOTATION_VALUE>
