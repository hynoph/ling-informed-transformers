            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>Se da por aquí y los frutos se usan para preparar atolito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Si preparas atole y lo hierves, y lo..., haces, lo...,</ANNOTATION_VALUE>
