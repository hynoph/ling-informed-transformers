        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts153">
                <ANNOTATION_VALUE>Entó:s mah se: kintai:lti ne: xohxowik, ke:meskia pero mah se: kinimaka mah ki..., mah kitsonkwahkwa:ka:n wa:n koma:mo ne: mah se: kima:xakwalo xiwit wa:n mah se: kintailti a:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
                <ANNOTATION_VALUE>¿Wa:n yo:n no: onkak nika:wí:n oso kanah ika onkak *más**?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts161">
                <ANNOTATION_VALUE>Ma:ski ohti. ¿Wa:n tein ista:k no: onkak? ¿Wa:n tein ista:k ne: kachi *más** wehwekampantia oso ka..., katí:n yeha *más** tein wehkapan, tein chi:chi:ltik *o** tein ista:k?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts167">
