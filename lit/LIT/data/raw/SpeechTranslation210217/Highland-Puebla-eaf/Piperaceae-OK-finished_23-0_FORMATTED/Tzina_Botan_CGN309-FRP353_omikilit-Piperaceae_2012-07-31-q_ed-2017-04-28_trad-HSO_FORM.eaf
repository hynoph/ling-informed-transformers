            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>No:, no: weli, no: weli, mmm. Aha, koma:mo teh kipia pilixmeh. Xtai wa:n, wa:n ta:mo ika ximo..., ximo..., ximota:lili se:, se: ika a:toto:n xmokechili de n' ke:man tikochiti a wa:n ....</ANNOTATION_VALUE>
