        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts185">
                <ANNOTATION_VALUE>Mm, tein chi:chi:ltik pané: se: monana.... A:ha:.</ANNOTATION_VALUE>
