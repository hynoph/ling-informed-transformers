        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts189">
                <ANNOTATION_VALUE>Pero tein yo:n nimitsilia chi:chi:l..., chi:chi:lo:mekilit *más, más** mone:neki. A:mo moskaltia semi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts195">
                <ANNOTATION_VALUE>A:, neli os, pos kwali yetok nika:n de ke timonohno:tskeh ika i:n o:mekilit komohkó:n tiki:xmati, *este**, pos neh ni..., niwa:le:wa ne: nocha:yohpan ne: Tepango, Zacatipan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts199">
                <ANNOTATION_VALUE>Ta:ka:n sentahman, ne: ke:masá: tik..., tikneki, tikih..., tikye:kma:tsi:ntokas, i:n ke:ní:w, para toni pahti, pos ompa nietok.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts203">
                <ANNOTATION_VALUE>Ne: ompa ne:ch..., tatsi:ntoka *por** no..., noto:ka:y, nimono:tsa niFrancisca Rivera Pérez.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
