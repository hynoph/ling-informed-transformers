        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>A bueno, entonces muchas gracias. Nos vemos otro día señora, ya me voy.</ANNOTATION_VALUE>
