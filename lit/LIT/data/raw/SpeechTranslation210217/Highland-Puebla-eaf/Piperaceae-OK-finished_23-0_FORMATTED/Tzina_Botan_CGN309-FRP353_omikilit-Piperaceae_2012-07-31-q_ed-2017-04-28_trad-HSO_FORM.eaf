    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Francisca Rivera Pérez" PARTICIPANT="Francisca Rivera Pérez" TIER_ID="FRP Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Señora aquí nos..., vamos a platicar acerca de una planta que se llama o:mekilt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Quiero pre..., preguntarle a usted, este, cómo ve, este el o:mekilit si sabe ¿para qué sirve?.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>Aa, para curar, mmm.¿Y, y qué enfermedad cura?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>Para mí lo hago igual como usted me platica, de, cuando uno ya se alivia, yo sé que hace muchos años cuando ya te alivias después de que nace el bebé.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Ya vas a traer el o:mekilit y este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>y en lugar de que..., usar una tela o algo, un, un pedazo de lazo que lo uses como estropajo para tallar, lo que se usa para..., para enjabonar, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>ya no uses esas cosas, mejor ve a traer hojas de o:mekilit y úsala para enjabonarte y para tallar tu cuerpo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Úsalas cuando te bañas. Así hojas verdes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Mm, así usa las hojas verdes como si fueran tu estropajo, debes usarlas siempre cuando te bañas, y tus hijos también debes bañarlos, debes hacerlo de esa forma para que los niños no le tengan asco a los alimentos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>Que no..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Aa, hierven todas. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Sí porque que..., dicen que, este cuando, nosotros después de nuestro nacimiento, traemos un olor fuerte a xo:kihya:k</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Y entonces para qui..., quitar el olor a xi..., xi..., xo:kihya:k entonces nos tallan con esa hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Yo us..., usé siempre cuando tu..., tuve a mis hijos, como cuando es.., me aliviaba, apenas pasaban unos días de haber nacido mi bebé, porque me..., me aconsejaron que bañe a mis hijos con esas hierbas y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>y parece que es verdad porque no..., ninguno de mis hijos se enfermó.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Todos usábamos el o:mekilit, bañaba a mis hijos con esas hojas y yo también usaba para bañarme. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>Y nunca este, se enfermaron mis niños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>¿Y cuántos tipos conoces, este, ...?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Sólo dos tipos, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Aa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Entonces sólo conoces dos tipos. Aa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>¿Y no se puede usar el o:mekilit para curar otras enfermedades? ¿Para que otra cosa más? ¿Sólo se usa para bañar a los niños?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Aa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Pero las hojas tiernas se usan para tlayoyos o para tamales.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Aha, usan las hojas para envolver pero ahí se queda la fragancia de las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Aa también le agregan las hojas tiernas. Mmm. Aha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Pues eso es lo que yo sé, este conozco el o:mekilit y sé que también se puede usar hasta para curar a las mujeres que tienen interés de embarazarse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>las que no pue..., pueden tener hijos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Entonces pueden tomar el té y que se..., que se..., que se bañem con el agua caliente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>También, también se puede, también se puede, mmm. Aha, si no tienes hijos. Toma el té, y si no ba..., ba..., báñate con..., con el agua caliente antes de ir a dormir y ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Al termina..., ter..., al terminar de bañarte, te abrigas bien y ya te vas a dormir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Pero con las hojas de o:mekilit. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Aha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Mm, mmm. también es muy..., también es muy..., también es muy bueno curar con o:mekilit a los niños que le tienen asco a los alimentos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>entonces deben de tomar las hojas verdes, como si fuera, hay que darle al niño que la..., que mastique la hoja y si no hay que exprimirla y darle de tomar el jugo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>¿Y esa planta se da por aquí o en otras partes se da más?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Aunque sea orilla de camino. ¿Y el de color blanco también se da? Y el de color blanco crece la mata más alta o ca..., ¿cuál es el que crece más? ¿el de color rojo o el blanco?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Pues yo conozco, este, si es así .... Quizá sea otro porque yo conozco que el rojo no crece muy alto. Uhuh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>No son altas las matas que se dan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Y el de color blanco crece más alto, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Pero parece que es el de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Mm, el rojo parece que se..., aha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Pero del que yo te platico que es el o:mekilit roj..., rojo no se da en cualquier parte, escasea la planta. No crece muy alto</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Aa si es cierto, pues está bien aquí platicamos del o:mekilit por la forma en que conocemos, este pues yo ve..., vengo de mi pueblo de allá de Tepango, Zacatipan. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Si alguna vez te..., quie..., quieres saber cómo se usa para remedio esta planta pues ahí te espero.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Ahí me..., perguntas por mi..., mi nombre, me llamo Francisca Rivera Pérez.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Aa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
