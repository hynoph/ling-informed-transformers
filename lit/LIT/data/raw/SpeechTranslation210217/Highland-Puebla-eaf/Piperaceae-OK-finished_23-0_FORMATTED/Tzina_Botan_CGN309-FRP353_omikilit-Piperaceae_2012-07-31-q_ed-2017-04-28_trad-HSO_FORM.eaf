        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a129" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts171">
                <ANNOTATION_VALUE>Pos neh niki:xmattok, *este**, komohkó:n .... Tak xa: no: se: *porque** neh niki:xmattok ne: tein chi:chi:ltik a:mo semi moskaltia. Uhuh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts174">
                <ANNOTATION_VALUE>Ki:sa nejó:n mahyá: tsa:tsapalo:tikeh sah kowmeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts177">
                <ANNOTATION_VALUE>Wa:n tein ista:k kachi *más** moskaltia, mmm.</ANNOTATION_VALUE>
