    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Celina González Nazario" PARTICIPANT="Celina González Nazario" TIER_ID="CGN Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Aa, sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Pues tiene varios usos, se usa para curar esa plantita, mmm. Es muy..., es muy buena para curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Pues cuando se acerca el, el parto, juntan muchas hierbas y con esas se ba..., lo..., bueno se baña uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>Consiguen las hojas de las plantas, las hierven y se baña uno, hasta los bebés los bañan también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Las señoras dicen que el hermano del recién nacido,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>también es importante bañarlo con esas plantas para que no le pase nada, para que no le de el te:te:milis.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>Eso es lo que yo sé que se usa para curar y también es bueno curarse con esa planta cuando uno le tiene mucho asco a los alimentos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>Se corta la hoja tierna, la mastica uno y lo traga uno la hoja masticada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Así es, no se usted cómo la usa para curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Así las hojas verdes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>No, pues nosotras las hervimos para usar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Sï, pues nosotras usamos las plantas pero las hervimos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Bañan a los niños pero hervidas las plantas. Así es. Y también usan así las hojas verdes para tallar el cuerpo cuando los bañan, hacen eso para no rascar el cuerpo con las uñas y de esa forma se quita la mugre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>usan las hojas para tallar el cuerpo y así sale la mugre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Es cierto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Sí, son buenas para remedio esas hojitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Con esa planta. Sólo con hojas de esa los curábamos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>No pues, si es muy buen remedio esa plantita.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Pues yo conozco nada más dos tipos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Sí, conozco el de color rojo y otro que es blanco, y sus flores se dan así como unas velitas paradas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Pero no conozco cómo son sus semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Sí, nunca he puesto atención cómo son su..., sus semillitas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Sólo dos tipos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Pues se, se, parece que se escucha que, por ahí quien sabe donde, si es para arriba, las hojas tiernas se usan para ponerle a la comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Eso, dicen que las hojas usan para preparar tlayoyos y para la comida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Y las hojas tiernas usan para ponerle la comida. Sí nosotras todavía no las usamos pero no me acuerdo en donde me convidaron la comida preparada con hojas de o:mekilit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Aa, también es bueno que tomen té las mujeres que no pueden concebir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Mm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Aa, con esas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Pues también sé que algunas mujeres de allá de mi pueblo usan las raíces. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Se hierven las raíces, se espera que reduzca y luego toman el té para este, ¿cómo le llaman?, cuando uno come huevo y como que hace.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Eso es. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Pues nosotras allá en mi pueblo, sé que se les da la hoja para que la mastiquen y que la traguen, así es, y con eso se les quita el asco a los niños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Hay hasta en las orillas de los caminos, hay plantas a orillas de camino, junto a mi casa también hay. Hay plantas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Pues parece que veo, que todos los dos crecen alto y el tallo también se puede usar para leña. Su tallo también crece un poco grueso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Y cuando se seca se puede cortar para leña.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Así es, todas las plantas que tienen tallo leñoso se pueden usar. No crecen muy alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Sí crece mucho. Pues no sé si es el de color blanco del que te platico porque éste crece muy alto, si nadie lo tumba crece hasta arriba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Sí, debe ser ése. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Y es el que te digo que su tallo se puede usar para leña, cuando se seca arde muy bien como si fuera totomoxtle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>No se da en cualquier lugar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Creo que sí es verdad, sí, el que crece más es el de color blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Sí, yo sé que se puede usar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Pues yo también, vengo de San Miguel Tzinacapan, me llamo Celina Gonzáles Nazario.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Por nada.</ANNOTATION_VALUE>
