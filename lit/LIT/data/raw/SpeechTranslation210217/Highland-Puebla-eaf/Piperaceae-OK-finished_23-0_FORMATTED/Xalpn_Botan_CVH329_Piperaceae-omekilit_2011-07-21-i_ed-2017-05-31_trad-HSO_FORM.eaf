    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Cristina Vázquez Hernández" PARTICIPANT="Cristina Vázquez Hernández" TIER_ID="CVH Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Esa planta se llama omekilit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Este yo te puedo decir que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>cuando las mujeres se enferman de..., esa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>enfermedad que les da cada mes (menstruación)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>y si ya pasaron los días en que se iban a mejorar pero siguen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Entonces como que siguen sin mejorar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>cortas cuatro hojitas, cuatro hojitas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>cortas cuatro hojitas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Y las... así las exprimes bien,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>y enseguida la cuelas en una tela.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Y luego le,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>le das a la muchacha que se la tome.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>Si va mejorando con una, con una medida. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>Con esa nada más.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>Y si así este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>si ya va mejorando poco a poco. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Y vuelve a recaer, nuevamente le das una medida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Mm. Otra vez cortas cua..., cuatro hojitas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>las preparas así las..., las..., las exprimes así</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>y la cuelas con la tela.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>Y se la vuelves a dar para que se la tome, mmm. Y con eso, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>no hay necesidad de que vaya a la clínica. Uhuh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Se hierven junto con hojas de wi:tsikite:mpi:l,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>y el tsope:likxiwit, tres tipos de hierbas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Pues yo sé que se usan para curar esa enfermedad y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>y este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>se usan para curar hinchazones en el pie te:te:mih.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Si este, es cierto como cuando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>si pasó por el lugar donde lavaron la ropa de una mujer que apenas tuvo un hijo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>y metió los pies en el agua. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Hacia arriba del arroyo están lavando y por abajo pasó esa persona</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>y metió los pies en el agua, y después de unos días se hinchan sus pies te:te:mi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>También puede tomar. Y debe bañarse pero con hojas verdes sin hervir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Que las hojas las machaquen y enseguida que se bañe el paciente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>y también puede tomar un poquito de agua pero sin hervir</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>que se la tome.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Con eso se le va a quitar la enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Ya no hay necesidad de que vaya con doctores.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Eso es lo que yo sé de esa planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Alla en el pueblo de donde yo vengo, usamos esas hojas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>ehe, se usan esas hojas para curar las dos enfermedades.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Este si hay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Esa planta no se escasea. Mmm. Hay por ahí,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>se da en el cafetal o en la milpa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Hay uno de color rojo que es más chiquito, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>tiene las hojas pequeñas y sul tallo es rojo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Y éste otro es blanco, las matas crecen más grandes, así de tamaño crecen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Y el de color rojo es más chiquito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>y sus tallos son mas delgados. Eheh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>También es medicinal, es medicinal pero ahora no se da mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Hace muchos años había mucho, tenía muchas plantas junto a mi casa.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Pero actualmente no hay mucho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Si hay, pero las matas son escasas, yo vi que hay sólo como dos matas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>en el cafetal pero últimamente ya no he ido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>cura la misma enfemedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>La misma enfermedad, uhuh. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Las mismas dos enfermedades, con esas hojas se curan. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Si florea, mm, florea.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Sus flores son alargadas de color blanco. Eheh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Pero no puedo decirte cómo son sus semillas. Eheh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Este, pues he visto que florea, pero nunca me he fijado cómo son sus semillas y cuando maduran. Eheh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Le llaman te:te:mih, se enferman de asco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Mm, porque ya no tienen ganas de comer la comida de frijoles,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>si les dan un caldito no quieren comer. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Eheh o les..., tienen ganas de vomitar, les dan vómitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>En lugar de comer no quiere nada sino que le dan vómitos, así hemos visto nosotras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Eheh. Y para que no pase eso este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>puedes tomar el agua, mm, pero las hojas deben ser verdes, no hervidas. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Pero es la misma enfermedad de la que te estoy platicando.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Porque el netati:l dicen,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>a veces como algunas de nosotras, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>lo..., no tenemos a nadie que cuide a nuestro hijo más grandecito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>ahora aca..., acabo de dar a luz a un bebé,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>y el otro más grandecito al que nosotros los ma:se:walmeh le llamamos tsipit </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>nos va a alcanzar a nuestra cama donde se encuentra el bebé</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>su hermano. Entonces el niño más grande se le hinchan sus pies te:te:mih.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Eheh. Y para que no, para que no le de esa enfermedad hay que curarlo a tiempo, eheh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Aunque se acerque al lugar donde se encuetra el bebé no le va a pasar nada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Eheh, antes de que se enferme, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>luego hay que bañarlo con estas hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Hay que machacarlas así verdes y bañar al niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Y puede tomar un poquito de agua de las hierbas machacadas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Se hinchan también.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Se hichan los pies y si este no lo tomaste en serio,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>empiezan a colgarse, se cuelgan así como si fueran uno jitomates pequeños,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>salen ampollas y se vuelven de color negro. Eheh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Y le da así en toda la piel, le da en todo el cuerpo  si no supiste atacar la enfermedad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>Y  se muere con eso, si ya no se pudo curar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Yo no sabía antes, yo vi a una cuñada que así le pasó hasta morir su niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Cuando nació el bebé y aquél otro, el hermano del bebé</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>y como ya no vivía su suegra, ya se había muerto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Entonces no hubo alguna persona que cuidara al niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Y yo vivía en otro lugar en donde llegué a ser nuera de una familia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Y mi suegra no podía ir a ver más continuamente, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>pasó eso, se murió su niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Era un niño que se murió. Pero en todo su cuerpo salieron pequeñas ampollas y se rompieron,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>se hacen bolas así de éste tamaño, como las bolitas que tiene el cuello de una pava o guajolote (itomaw).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>Mm. Se incha la piel, se inchó en el pie así parejo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>En todo el cuerpo. Y des..., después ya escuché que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>le pasó eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>Pero como yo era joven todavía no entendía que pasaba.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Eheh. Yo acababa de llegar ahí como nuera de esa familia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a318" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Mm. Todavía no tenía ni un hijo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>No si esa enfermedad si salen como ampollas en la piel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Se debilitan, se debiltan. Si ya no va a comer, tiene vómitos y no come ni un alimento.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>Mm. Todo lo que le dan de comer dice que sabe a xo..., xo:kihyak.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>No quiere comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Mm Y para que no pase eso,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>luego hay que machacar las hojas de o:mekilit y hay que bañarlo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>Y darle de tomar un poquito de agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>Si el bebé es muy pequeño. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>Nunca olviden esto y di..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>dile a tus vecinos para que lo sepan. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>Sólo que ahí tienes dos tipos de hierba, falta otro que es el tsope:likxiwit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>quizá la tengan por ahí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>Yo me llamo Cristina Vázquez Hernández,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>de Xalpantzingo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Amelia Domínguez Alcántara" PARTICIPANT="Amelia Domínguez Alcántara" TIER_ID="ADA Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Bueno señora e..., esta hierbita que volviste a traerla para mostrarme, la vez pasada me estabas platicando que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>cuando me platicaste de la otra planta que se llama wi:tsikite:mpi:l</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>y me platicaste de esta hierbita pero se me olvidó cómo se llama.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>ahora quiero que me platiques si el o:mekilit se usa para curar otras enfermedades</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>o nada más se usa para curar esas enfermedades de las que me platicaste la vez pasada.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>¿Usas solas esas hojas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Y sólo se usan las hojas para curar esa enfermedad?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>¿Sólo se usa para curar esa enfermedad cura?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>¿Y esta planta donde se da, es escasa o es abundante?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>¿Sólo hay un tipo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Como un..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>¿Y en de color rojo también es medicinal?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Y si se usan esas hojas ¿para qué enfermedad se cura?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>¿Y esta planta de o:mekilit tambien florea y produce semillas?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Nunca haz visto que produzca semillas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Bueno señora esa enfermedad me decías que este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>les da a todas las personas pueden ser niños o adultos este, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>como si se les hichan los pies si se..., acercan a una mujer que acaba de dar a luz</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>¿cómo le..., le llaman esa enfermedad?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Bueno pues yo he escuchado que le llaman este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>algunas personas le llaman netati:l escarlatina, pero yo no la conozco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Entonces cuando les da el netati:l también se hinchan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Pues fíjese que yo no sabía de esa enfermedad si</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>salen en la piel como pequeñas ámpulas, había escuchado pero no sabía cómo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>¿Y también se debilitan?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>Sí señora muchas gracias. La verdad ya no me acordaba pero ahora ya me quedó claro que esta plantita se llama o:mekilit. Sí. Pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>Sí parece que también hay por donde vivimos nosotros, también hay plantas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a187">
                <ANNOTATION_VALUE> se da. Pues muchas gracias señora, ahora dime tu nombre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>Y yo también,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>yo me llamo Amelia Domínguez y vengo de un lugar que queda al sur de Xaltipan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
