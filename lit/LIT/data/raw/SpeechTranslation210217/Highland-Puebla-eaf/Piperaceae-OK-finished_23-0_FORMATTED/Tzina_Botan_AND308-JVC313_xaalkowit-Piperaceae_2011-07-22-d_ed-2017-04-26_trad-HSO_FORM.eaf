                <ANNOTATION_VALUE>Wa:n yo:n xo:ta, mah kwali xo:ta mochi:wa, xo:ta mahyá tekol ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
                <ANNOTATION_VALUE>ke:mah, ki..., kwali, kwali xo:tatok *mientras**, ne:n, tokni:w a:kin, a:kin kichi:wati pahti,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
                <ANNOTATION_VALUE>kikwi yo:n xiwit ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
                <ANNOTATION_VALUE>kimomotsowa wa:n kima:xakwalowa *fuerte** ihkón wa:n kite:ka se:..., a:t ihkón sake:ra se: o:me, o:me xi:wah sake:ra, ekintsi:n onkak yo:n *plástico**, mah pexo:ni o:me,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>kima:xakwalowa *fuerte** ihkón kima:xakwalowa wa:n ke:mah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
                <ANNOTATION_VALUE>ka..., kin..., ke:mah *una vez** kipisi:loh ya, kikwi itech n' a:..., a:..., kia:te:mak a wa:n kima:xakwaloh ya, ihkón kima:xakwalowa,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
                <ANNOTATION_VALUE>de kima:xakwalowa *hasta** xoxoktsí:n moka:wa, ne:n, a:tsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
                <ANNOTATION_VALUE>wa:n xoxoktia n' a:tsí:n nochi mahyá tomakila:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>Wa:n ke:mah de ih..., kwali nochi kima:xakwaloh yo:n xiwit kixohxokolih ya, ahwia:yak a xiwtsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
                <ANNOTATION_VALUE>ke:mah nejó:n kiki:xtia ya yo:n ika teihsá ne:n, ne:n yo:n tapalkat tein kixo:taltihtok,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
                <ANNOTATION_VALUE>kipana:ihsawia, tehtsoyokatiw se:..., se:wi *porque** pos de ne:, ne: sese:k yo:n a:t.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
                <ANNOTATION_VALUE>Sepa se: kiki:xtia, sake:ra se: mahtak oso *más**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
                <ANNOTATION_VALUE>ke:mah *hasta** kawa:ni a ne:n, yo:n *de que** kawa:ni a ne:n a:t momoloka ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
                <ANNOTATION_VALUE>momoloka ika ya n..., ika ne:n, ke:meh xo:tatok ne:n koma:l, de n' koma:ltepalkat oso *tejatapalkat**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts244">
                <ANNOTATION_VALUE>*de que** miak a, miak a n' a:ihsawih yo:n n' tapalkat,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
                <ANNOTATION_VALUE>kawa:ni a n' a:t, ke:mah momoloka ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts249">
                <ANNOTATION_VALUE>Moka:wa posok n' tai:xko, *cuando** moh..., mochi:w posok a n' tai:xko, yo:n kitak poso:nik a, *es que** mochi:wati *remedio**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
                <ANNOTATION_VALUE>Yo:n ki..., kihto:sneki *que** mochi:wati pahti. Ke:mah de poso:nik a wa:n, wa:n momoloka kwali,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>ke:mah ne: 'ki:xte:kah itech se: ih..., tehwa:n tikiliah xola:soh mejika:noh, pero</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
                <ANNOTATION_VALUE>koyo:tahtok kiliah *coladera**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
                <ANNOTATION_VALUE>Ne: kite:kah yo:n xola:soh, kite:kah, ne:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
                <ANNOTATION_VALUE>ne:n, pos ihwa:k a:mo kikwiah xola:soh, pero tilmahtsí:n, yo:n pitsa:waktilmah kiliah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
                <ANNOTATION_VALUE>ompa kite:kah ya n..., ika n..., ika se:, ika se: ta..., se: *tacita**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
                <ANNOTATION_VALUE>kichih..., ki:xte:kah n' a:tsí:n para a:mo pachyoh iwa:n eski, eski pachyoh ne: ya:s *porque** xiwpach moka:wa miak,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
                <ANNOTATION_VALUE>para tai:s a:tsí:n sah ne:n kokoxkeh. Tai se: kwali *pocillo**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
                <ANNOTATION_VALUE>mokahka:wilia wa:n ke:mah yowi kalanemi:lis yo:n, yo:n para kalanemi:lis yo:n se: tai. Yo:n pahti yo:n, yehwa ne:n ista:k xa:lkowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
                <ANNOTATION_VALUE>Wa:n i:n tein nimitsilia ti:ltik xa:lkowit,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
                <ANNOTATION_VALUE>yeh pos ne: kwali pahti 'te:kakiliah para n...,para m' pilimeh ke:meh i:n kone:meh ok,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>kikwah teihsá, ke:meh kikwah nakatsí:n kikwah *pantsi:n o galleta**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
                <ANNOTATION_VALUE>mopepechowa ne: yo:n takwalis i..., inpoxnakastan wa:n a:mo motapa:tiliah, ke:meh a:mo teh kichi:wah *más** i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
                <ANNOTATION_VALUE>teihsá chi:walis ke:meh pilimeh ok,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts283">
                <ANNOTATION_VALUE>mopepechowa n' intakwal i..., impoxnakastan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
                <ANNOTATION_VALUE>Wa:n de pox..., mopepechowa impoxnakastan ke:mah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
                <ANNOTATION_VALUE>no: ki..., tsahtsih a m' pilimeh, *después** a:mo teh kinekih ok, elmoya:wih ya. I:ksá kimakah teihsá,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
                <ANNOTATION_VALUE>e:lmoya:wi *porque** tahyalkwitok *porque** e:..., kipia nexwitil.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>Wa:n yo:n niman kitah m' pili nexwitil,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
                <ANNOTATION_VALUE>komohkón mokala..., mokalawia pané: nexa:yo:t eski moxwitihtok m' pili.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
                <ANNOTATION_VALUE>Pos ika yo:n nejó:n, kikwitih ya yo:n xa:lkowit, ti:ltik xa:lkowit,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
                <ANNOTATION_VALUE>Yeh mochi:wa pisi:ltik n' ima:y, ke:meh *corazoncitos**, pero *más** e:kapihpitsaktik wa:n ye:ktsohya:k xiwit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
                <ANNOTATION_VALUE>Mochi:wa ka:mpa, nikahkwí:n onkak n' i:n...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
                <ANNOTATION_VALUE>Tate:mpan *o** ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
                <ANNOTATION_VALUE>ne: Tu:sanko semi onkak, ompakakwí:n tehtetsi:ntan mochi:wa yo:n *por rollo**,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
                <ANNOTATION_VALUE>yo:n tako:t sah mochi:wa yo:n tikihtowa xiwit, a:mo wehkapania.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts309">
                <ANNOTATION_VALUE>Wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts313">
                <ANNOTATION_VALUE>ye:ktahtakwaktik n' ikowyo, ye:kta:wa:k ata n' ikowyo ata. Yo:n teltakwa:wak, ke:meh tekowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
                <ANNOTATION_VALUE>Wa:n nejó:n yo:n kikwitih yehwa n' ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
                <ANNOTATION_VALUE>no: yeh, no: ki..., yeh ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
                <ANNOTATION_VALUE>kima:xakwalowah oso kixkah koma:lko,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
                <ANNOTATION_VALUE>wa:n kwaltsi:n kima:xakwalowah yo:n mahyá,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts325">
                <ANNOTATION_VALUE>ke:..., ki..., mahyá kipa:ta de una vez ta ixkal ya, pos kipa:tah uan kema:h kikwitih ne: a:mat, se: pana:mat *o** se: *periódico**, ekintsi:n onkak *periódico**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
                <ANNOTATION_VALUE>Ki..., kip..., kita:liliah, ne:n, kita:liliah ompa ne:n xiwit tama:xakwalo:l ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
                <ANNOTATION_VALUE>pero taixkal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
                <ANNOTATION_VALUE>Wa:n ke:mah tamo..., kisowah ya nika:n ne:n i..., xiw..., xiwit tein xiwpach ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
                <ANNOTATION_VALUE>wa:n ke:mah ki:x..., kite:miliah *carbonato**, koma:mo *carbonato** iwa:n tekixtit wa:n iwa:n *aceite**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
                <ANNOTATION_VALUE>Yo:n kita:liliah, ke:mah kininpepechowiliah n' impoxnakastan pilimeh nika:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
                <ANNOTATION_VALUE>Wa:n ki..., kinilpiliah ika tilmahtsí:n wa:n yehwa yo:n ki...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts341">
                <ANNOTATION_VALUE>kika:xanilia n' nexwitil *porque** tsohya:k yo:n, ne:n xa:lkowit teltsohya:k,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
                <ANNOTATION_VALUE>kikaxa:n...., yo:n xa:lkowit tikiliah,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts347">
                <ANNOTATION_VALUE>i..., tsohya:k semi, ki..., nexwitiltsohya:k semi yo:n xiwit *compadrito**. Nexwitiltsohya:k. Wa:n yehwa yo:n kin..., kitaweliah de kita:liliah pos ne:,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
                <ANNOTATION_VALUE>Kixiti:nia n..., ika n' *ifuerzas**, ahwia:kka panowa, tak a:it ke:ní:w yo:n, ke:ní:w n' tietokeh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
                <ANNOTATION_VALUE>panowa kinima..., kima:yawi a nexwitil wa:n tepitsi:n kite:ntia tsikitsi:n a:tsí:n ne:n pili, ia:yotsi:n wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts355">
                <ANNOTATION_VALUE>ki:sa nexwitil ke:mah ki.... *Cuando** xiti:ni nexwitil,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts359">
                <ANNOTATION_VALUE>kichihchi:wah *hasta** pohpoxkawtok ne:n ki:sa ne:n *cachitos**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
                <ANNOTATION_VALUE>n' in..., itakwal mopepechowa nika:n *porquería**, mopepechowa ihkón kixi:ti:nia nexwitil.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
                <ANNOTATION_VALUE>Yehwa n' tikiliah *que** i:pa nexwitilpah yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
                <ANNOTATION_VALUE>Ke:mah, iwa:n *aceite** kita:liah para nejó:n yema:nia wa:n kichi:wa *remedio** n' ka nexwitil, para pilimeh pero.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
                <ANNOTATION_VALUE>Wa:n i:n seki pahti para, para tiwehwei:n, para kalanemi:lis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
                <ANNOTATION_VALUE>Yehwa yo:n kwali pahti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
                <ANNOTATION_VALUE>Wa:n i:n seki onkak ne: yo:n xa:lkowit, yo:n wehwei xa:lkowit wehwei *mata** mochi:wa no:, itsmoli:ni wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
                <ANNOTATION_VALUE>chihchikoltik mochi:wa n' iitsmo..., *casi** ka:mpa i..., i..., ima:y ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
                <ANNOTATION_VALUE>mochihkolowa ihkón mahyá pohpostektiw,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
                <ANNOTATION_VALUE>wa:n no: *igual** nejó:n yeh ma:yehyewaltik tepitsi:n wa:n ye:ki:xtsihtsikiltik no: mahyá ma:...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>ma:ta..., maya..., ma..., mahyá *rayado** n' ima:ko,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts385">
                <ANNOTATION_VALUE>wa:n no: ekapihpitsaktik ke:meh *corazoncitos** n' ima:y, wehwei achi,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
                <ANNOTATION_VALUE>mahyá *corazoncitos**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
                <ANNOTATION_VALUE>Wa:n i:n seki neh nimitsilia ne:n ti:ltik xa:lkowit yeh no: ke:meh *corazoncitos** pero tsikitsitsi:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts393">
                <ANNOTATION_VALUE>Wa:n i:n seki mawe:weyakxa:lkowit, ye:kma:we:weyak, ma:we:weyakxa:lkowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
                <ANNOTATION_VALUE>Wa:n i..., ke:meh kahfe:nxiwit tamati, pané: mochi:wa tepitsi:n ma:ihista:k, yo:n kahfe:nxiwit *hasta** xoxoktik n' ima:y.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
                <ANNOTATION_VALUE>Wa:n nejó:n i:n ma:yehyewaltik ke:meh *corazón, más** wehwei n' ima:y *hasta** ihkwí:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
                <ANNOTATION_VALUE>wa:n yekapihpitsaktik ke:meh *corazoncitos**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
                <ANNOTATION_VALUE>Wa:n no: iwki a ne: iteyo ke:meh i:n seki xa:lkowit ista:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a352" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts405">
                <ANNOTATION_VALUE>No: kit yo:n wewe:yak ki:sa ihkón, mopahpampilowa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
                <ANNOTATION_VALUE>No: ista:k n' ixo:chio wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
                <ANNOTATION_VALUE>wa:n nejó:n yeh, no:, no: pahti yeh pero a:mo *para personas**, sayoh pahti para</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts413">
                <ANNOTATION_VALUE>*para planta** ke:meh i:n kowkamoh se: kito:ka, tein</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
                <ANNOTATION_VALUE>i..., kito:kah kowkamoh, *bueno** tehwa:n iwki tikchi:wayah *porque noabuelito** kito:kaya kowkamoh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
                <ANNOTATION_VALUE>wa:n nochi te:chne:xtilia:ya toni m' pahti, toni n' kitawelia ika.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
                <ANNOTATION_VALUE>Yehwa ne: kow..., yehwa yo:n kikwi ne: yo:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
                <ANNOTATION_VALUE>yo:n xa:lkowit kitekiti a, xoxowik kitemo:ti ne:wí:n kowtah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
                <ANNOTATION_VALUE>Kitekiti a, ke:mah kitachkwilia n' kamoh, ki..., ta..., tamole:wa wa:n kipankehketsa ya n' kowit de n' kowkamoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
                <ANNOTATION_VALUE>Wa:n ke:mah de mochi:wa ya yo:n, moskaltia yo:n kamoh wa:n *cuando** ki..., kichkwati a,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
                <ANNOTATION_VALUE>kichkwati a nejó:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
                <ANNOTATION_VALUE>pos kit..., i..., kitawelih ya yo:n kowtsí:n wa:n, wa:n yo:n kitawelia porin *cuando** wa:ki ata yo:n xa:lkowit,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
                <ANNOTATION_VALUE>mo..., mo..., mahyá ke:kepo:ni ihkón, mahyá *estrella** moka:wa n' kowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts435">
                <ANNOTATION_VALUE>Tsa:tsaya:ni, nochi tsa:tsaya:ni *parejo** n' ipanko, wehwei n' tsa:tsaya:ni. Tahtapowi n' *cuando** wa:ki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
                <ANNOTATION_VALUE>Wa:n kitaweliah yo:n kowkamoh *cuando** kimanah pos nejó:n kwaltsi:n tsope:kkalaki wa:n</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts441">
                <ANNOTATION_VALUE>ta:tap..., yo:n tatapa:ni para kalaki n' tsope:k, tsope:kka n' iihtik yo:n. Ke:mah yehwa yo:n mochi:wa yo:n wa:n koma:mo se: kitawelih yo:n, yo:n kwahkamoh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
                <ANNOTATION_VALUE>ki:sa *ye:kmamacizo** wa:n a:mo tsope:kkalaki, se: kikehtsoma ihtipochiktik n' kamoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts447">
                <ANNOTATION_VALUE>A:mo tsope:yak. Payán sah n' tsope:ya wa:n taihtik takwaktik, a:mo tsope:ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n tehwa:n tikitayah kitawelia:ya *noabuelito** yo:n *semilla para cuando** yeh kichkwati a pos e:..., i:pa kitawelia, *cuando** kimana ya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
                <ANNOTATION_VALUE>kekepo:ni kwaltsi:n wa:n kwaltsi:n tsope:kkalaki n' kamoh, *hasta** iyo:lkowyo nochi kwaltsi:n tsope:ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
                <ANNOTATION_VALUE>Ke:mah, *cuando** yo:n kit..., ne: kitaweliah, ne:n, ika yo:n kowit.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts457">
                <ANNOTATION_VALUE>Wa:n no: tikiliah xa:lkowit *porque**</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
                <ANNOTATION_VALUE>komohkón wa:kik wa:n sake:ra tepitsi:n a:paliw, xokoya, ke:ke:spixki a,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
                <ANNOTATION_VALUE>pawe:tsi n' ie:wayo, wehwei ki:sa ne:n ie:wayo,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>wa:n, wa:n pané: *medio** we:weyak tepitsi:n kipia ihkón ii:xko.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
                <ANNOTATION_VALUE>Wa:n ke:mah se: kikwiti yo:n, xa:lyoh n' ii:xko n' e:wat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
                <ANNOTATION_VALUE>Yehwa yo:n tikiliah, kiliah *que** xa:lkowit kito:ka:ytiah ika,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
                <ANNOTATION_VALUE>*porque** pané: kipia xa:l ata.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
                <ANNOTATION_VALUE>E:, pané: xa:lyoh, yehwa yo:n niki:xmati ika yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts477">
                <ANNOTATION_VALUE>No: pahti *o para planta** ika se: kitawelia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts481">
                <ANNOTATION_VALUE>Ke:mah, nochi pahti yo:n e:yi taman. Pero, ke:mah o:me taman *para personas** wa:n, wa:n se: taman *para planta**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts489">
                <ANNOTATION_VALUE>Tato:k, ke:mah, ke:meh kamoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts501">
                <ANNOTATION_VALUE>Kihtowa se: metstsa:tsa..., metsa:tsaya:ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a405" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts511">
                <ANNOTATION_VALUE>Kowkamoh ke:mah n' kihtowah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts515">
                <ANNOTATION_VALUE>Ke:mah, ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts519">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n se: kitawelia ika yo:n kowit, tehwa:n te:chilia:yah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
                <ANNOTATION_VALUE>Ke:mah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
                <ANNOTATION_VALUE>No: iwki.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts535">
                <ANNOTATION_VALUE>I..., i..., *de**, mahyá pachti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
                <ANNOTATION_VALUE>Chipa:wak a:tsí:n ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts543">
                <ANNOTATION_VALUE>Ke:mah s..., yehwa yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts555">
                <ANNOTATION_VALUE>Yo:n a:mo se: kita:..., yo:n, yo:n ika se: kitach..., ika se: kitachkwilia yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a429" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts559">
                <ANNOTATION_VALUE>Se: kitachkwilia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
                <ANNOTATION_VALUE>Ke:mah, iwki se: kitawelia ika.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts565">
                <ANNOTATION_VALUE>Ika t..., yo:n se: kiteki kowit para ika se: tachkwas sah wa:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
                <ANNOTATION_VALUE>se: kitamole:wilia wa:n se: kito:ka ne:n kamoh wa:n ke:mah kitawelia ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts571">
                <ANNOTATION_VALUE>Ke:mah. Yo:n a:..., yo:n a:m..., yo:n a:mo se: kite:ka ompa n' kowit, sanoke yeh se: tachkwa wa:n se: kitamole:wilia, ke:mah. Wa:n yo:n kamoh se: ki:x..., se: *medio** ki:xakasowa,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
                <ANNOTATION_VALUE>para ne:n, yeh, yehwa n' itsmol miaktsi:n wa:n no:, wa:n de mosowa pos</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
                <ANNOTATION_VALUE>motakxilia miakka:n inalwayo ki:sa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a439" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
                <ANNOTATION_VALUE>Wa:n komo e:wihka: t'panketsak, say..., soh se: sah n' inalwayo ki:sas wa:n a:mo miak mochi:wa n' kamoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
                <ANNOTATION_VALUE>Yo:n se: kisowa tepitsi:n para ki:sa ni:nipaka miak kamoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
