        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a467" TIME_SLOT_REF1="ts633" TIME_SLOT_REF2="ts634">
                <ANNOTATION_VALUE>Pero ke:kepo:ni, cha:cha:moltia wa:n mochi:wa ihkón poso:ni,</ANNOTATION_VALUE>
