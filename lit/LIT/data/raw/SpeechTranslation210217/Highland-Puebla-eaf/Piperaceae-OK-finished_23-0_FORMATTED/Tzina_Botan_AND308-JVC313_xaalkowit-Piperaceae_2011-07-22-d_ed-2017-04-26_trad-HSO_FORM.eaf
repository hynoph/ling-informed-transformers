        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a457" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts615">
                <ANNOTATION_VALUE>nochi yowi a n' kwomekat wa:n ke:mah motoma:wa ya. Kampa yema:nik kwaltsi:n mochi:wa yo:n.</ANNOTATION_VALUE>
