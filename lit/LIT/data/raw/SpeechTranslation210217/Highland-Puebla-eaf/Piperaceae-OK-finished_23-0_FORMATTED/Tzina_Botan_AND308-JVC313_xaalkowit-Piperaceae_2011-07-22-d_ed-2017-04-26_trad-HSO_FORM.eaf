        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a552" TIME_SLOT_REF1="ts806" TIME_SLOT_REF2="ts808">
                <ANNOTATION_VALUE>Tsope:ya iwki sah, a:mo, soh de mani, kwali molo:nik, tsope:ya ise:lti.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
