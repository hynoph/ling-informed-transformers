        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a533" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts766">
                <ANNOTATION_VALUE>ne: ki:sa ihichyoh *porque** yo:n pihpitsaktik n' komekat, ki:sa ichyoh i:pa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a534" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
                <ANNOTATION_VALUE>*porque** yo:n tein i:xehka:n ki:sa pitsa:wak wa:n yehwa n' ichyoh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a535" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
                <ANNOTATION_VALUE>Wa:n pero kamoh tein itsi:ntan *primero** tiktekis,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a536" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
                <ANNOTATION_VALUE>mahyá tikihto:ka:n tein *de primera** ohololtik ki:sa a:mo ichyoh *porque bolas**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a537" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts775">
                <ANNOTATION_VALUE>Wa:n i:n ichyoh ki:sa tein ii:xehka:n, ki:sa ichyoh ya, *a la fuerza** ki:sa *porque** we:weyak ne:n kwomekat, nalwat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a539" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts778">
                <ANNOTATION_VALUE>Yeh ka ichyoh ki:sa, ompa e:wa. Nike:kapankoto:na ki:sa i..., pané: ichyoh ihkwí:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a541" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
                <ANNOTATION_VALUE>I:p..., i:pa iwki kich..., i:n mochi:wa i:n, *por más que** ton tikchi:was, ma:ski a:mo timokwa:wawa:nas ma:ski ke:ní:w,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a542" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
                <ANNOTATION_VALUE>i:pa ki:sa ichyoh *porque** we:weyak mochi:wa wa:n *ipuntita** ompa kichi:wa n' iichyo ya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a543" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts787">
                <ANNOTATION_VALUE>Te:chkaya:wah de a:mo tikmatih *compadrito**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a545" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts791">
                <ANNOTATION_VALUE>Mah a:mo se: mokwa:wawa:na. Kanah, ka:n neli, ka:n kitawelia yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a547" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts796">
                <ANNOTATION_VALUE>Ka:n neli, neh nikitani *porque** ika tik..., moskaltihkeh, titekitikeh ika yo:n weh,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a549" TIME_SLOT_REF1="ts798" TIME_SLOT_REF2="ts800">
                <ANNOTATION_VALUE>wehka *tiempo** tikix..., titekitikeh ika yo:n ta:kilo:t. Neh niki:xmati de miak taman de yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a550" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts804">
                <ANNOTATION_VALUE>Wa:n de n..., timo..., te:chtekipanohkeh ika yo:n, timoskaltihkeh nochi yo:n ta:kilo:t. A:, yo:n kowkamoh, yo:n ato:lkamoh a:mo se: kita:lilia pane:lah, se: kita:lilia pane:lah n' ato:lkamoh, pero yo:n tsope:ya iwki sah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
