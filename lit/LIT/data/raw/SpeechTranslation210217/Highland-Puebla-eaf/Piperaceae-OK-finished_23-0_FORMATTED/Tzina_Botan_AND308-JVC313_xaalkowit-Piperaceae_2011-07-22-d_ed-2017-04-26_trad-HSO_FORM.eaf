        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>imahma:tsi:ntan, ka:mpa i..., e:wa n' ima:xiwyotsi:n ompa ima:tsa:la:n ki:sa ne:n iteyotsitsi:n ista:k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
