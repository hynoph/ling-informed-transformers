        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a448" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
                <ANNOTATION_VALUE>Ta:tapa:ni a n' kita:welia yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a449" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts599">
                <ANNOTATION_VALUE>Ke:mah, yehwa yo:n, yo:n ika, ika se: kitawelia.</ANNOTATION_VALUE>
