                <ANNOTATION_VALUE>kiliah ti:ltik xa:lkowit. Yeh mochi:wa *por rollo** n' e:wa, ika *mata** n' e:wa wa:n ye:kmiak niman mochi:wa wa:n pihpitsaktik semi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
                <ANNOTATION_VALUE>wa:n *más** tsohya:k *que** a:mo xa:lkowit tein yo:n is...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts175">
                <ANNOTATION_VALUE>ista:k xa:lkowit, tel tsohya:k ne:n ti:ltik xa:lkowit. Wa:n imetskowyo ne:, tikiliah ti:ltik xa:lkowit *porque** tihti:ltik n' imetskowyo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>Tihti:ltik wa:n *medio** pané: kohkoyoh n' ikowyo.</ANNOTATION_VALUE>
