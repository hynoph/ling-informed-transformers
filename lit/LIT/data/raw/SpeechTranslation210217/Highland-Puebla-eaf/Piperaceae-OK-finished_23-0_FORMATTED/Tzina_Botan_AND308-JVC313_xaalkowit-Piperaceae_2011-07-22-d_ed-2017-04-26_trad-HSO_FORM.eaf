        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a630" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Se cae hasta el suelo cuando se seca el árbol. A veces se seca sólo.</ANNOTATION_VALUE>
