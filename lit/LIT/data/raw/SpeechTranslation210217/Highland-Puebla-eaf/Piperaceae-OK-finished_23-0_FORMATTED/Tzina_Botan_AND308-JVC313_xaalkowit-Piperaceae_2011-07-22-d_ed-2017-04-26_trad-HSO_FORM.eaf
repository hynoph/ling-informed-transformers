            <REF_ANNOTATION ANNOTATION_ID="a687" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>las ramas, al pie del pedúnculo de las ho..., hojas ahí brotan las semillitas de color blanco. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
