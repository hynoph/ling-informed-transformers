        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a506" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts713">
                <ANNOTATION_VALUE>Pero n' kamoh mochi:wa ohololtik, wehwei mochi:wa, sake:ra ka:n chikwase:n mopilowa itech n' kwomekat.</ANNOTATION_VALUE>
