        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a454" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts609">
                <ANNOTATION_VALUE>Ke:mah, ke:mah ika se: nalwat sah iwki mochi:wa pos a:mo miak ki:sa n' kamoh, ika se: sah, o:me kamoh ki:sa,</ANNOTATION_VALUE>
