        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts603">
                <ANNOTATION_VALUE>Kipahpanketsah wa:n a:mo miak ki:sa nalwat, i:pa se: sah n' ii:x *kitocarowa**.</ANNOTATION_VALUE>
