        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a700" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>Y esta planta tiene las hojas más pequeñas, y es muy..., en el haz..., en el ha..., en el haz tiene mu..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a701" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>muchas rayas la hoja.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a702" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>Y si cortas las hojas y las machacas percibirás el olor muy fuerte, que no es igual al xa:lkowit blanco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a703" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>Así es. Y este xa:lkowit también se pueden usar las hojas para curar compadrito, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a704" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>todos los tres tipos de xa:lkowit son medicinales pero uno se usa para una planta</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a707" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>Y el mero xa:lkowit blanco del que te platico, yo sé que es medicinal,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a708" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>se usan las hojas para curar la diarrea en los adultos que a veces también nos ataca,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a625" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>este para que no vayas con el médico, cortan esas, las..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a709" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>las hojas que se encuentran en las ramas, sirven aunque sean tier..., tiernas o también hojas recias del xa:lkowit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a710" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>cortan las hojas y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a711" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>cortan un buen rollo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a712" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>y preparan el remedio para la diarrea, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a713" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>no es difícil, es rápido hacerlo, es sencillito hacer eso, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a714" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>lo que hacen bus..., quiebran, buscan pedazos de..., de teja o comal que ya no se usan,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a715" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>y en el fogón prenden leña para hacer brasa, enseguida echan unos diez pedazos de  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a716" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>teja o comal en el fogón.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a717" ANNOTATION_REF="a258">
                <ANNOTATION_VALUE>&gt;Después prenden los pedazos de teja o comal, prenden bien como el color de la brasa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a718" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>enseguida, lo..., prenden bien mientras que la persona que va a preparar el remedio</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a719" ANNOTATION_REF="a260">
                <ANNOTATION_VALUE>toma las hojas y las..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a720" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>las machaca fuertemente con las manos, busca un traste y le echa agua un..., siquiera dos medidas como de un poco más de medio litro. ahora hay trastes de plástico, unas dos medidas llenas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a722" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>machaca fuertemente las hojas, las machaca y enseguida,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a723" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>las..., las..., de una vez machacadas, toma las..., las echa en el a..., agua ya machacadas, así las machacó, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a724" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>de estar bien machacadas las hojas al echarlas en el agua, queda de color verde el agua</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a725" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>queda de color verde el agua como si fuera caldo de yerbamora.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a726" ANNOTATION_REF="a266">
                <ANNOTATION_VALUE>Enseguida de..., que están machacadas las hojas, ya están magulladas emiten una fragancia,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a727" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>luego ya van sacando los pedazos de teja o comal que tienen prendidos en el fogón, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a728" ANNOTATION_REF="a268">
                <ANNOTATION_VALUE>las van echando en el agua, suenan al chocar la brasa con en agua fría y se..., se van apagando con el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a729" ANNOTATION_REF="a269">
                <ANNOTATION_VALUE>Siguen sacando los pedazos de teja o comal hasta terminar los diez o más, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a730" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>así poco a poco se va calentado el agua, después de calentarse bien empieza a hervir, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a731" ANNOTATION_REF="a271">
                <ANNOTATION_VALUE>hierve con el..., como están prendidos los pedazos de teja o comal, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a732" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>y como son muchos los pedazos, son muchos los pedazos de comal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a733" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>se calienta el agua y empieza a hervir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a734" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>Al hervir el agua, empiezan a flotar espumas, cuando apa..., aparece la espuma, ven que ya hay espumas es porque el remedio va a ser efectivo para el paciente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a735" ANNOTATION_REF="a276">
                <ANNOTATION_VALUE>Eso quie..., quiere decir que se va a curar el enfermo. Después de que flotan las espumas y hierve bien el agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a736" ANNOTATION_REF="a277">
                <ANNOTATION_VALUE>cuelan con un..., nosotros en nuestra lengua le llamamos xola:soh, pero</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a737" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>en español le llaman coladera.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a738" ANNOTATION_REF="a279">
                <ANNOTATION_VALUE>Cuelan el agua en la coladera, la echan en,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a739" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>antes no usaban coladera, pero ocupaban un pedazo de tela, una tela que le llamaban pitsa:waktilmah, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a740" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>así colaban con..., con..., con una ta..., una tacita, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a741" ANNOTATION_REF="a282">
                <ANNOTATION_VALUE>cue..., cuelan al agua para que no lleve residuos, porque abajo quedan muchos residuos de hojas hervidas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a742" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>eso hacían para darle de tomar el té al paciente. Toma un buen pocillo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a743" ANNOTATION_REF="a284">
                <ANNOTATION_VALUE>se toma el té el paciente y desaparece la diarrea, ése remedio que toman es para evitar la diarrea. Ésa planta que se usa es el ista:kxa:lkowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a744" ANNOTATION_REF="a286">
                <ANNOTATION_VALUE>Y el otro del que  te platico es el ti:ltikxa:lkowit, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a745" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>yo he escuchado que es buen remedio para..., para curar a los niños pequeños, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a746" ANNOTATION_REF="a288">
                <ANNOTATION_VALUE>cuando comen algo como carne, comen pan o galleta,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a747" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>y se queda pegado adentro a un costado de su abdomen todo lo que comen, ellos no pueden digerir porque no pueden hacer ejercicios como..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a748" ANNOTATION_REF="a290">
                <ANNOTATION_VALUE>alguna actividad cuando todavía están chiquitos,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a812" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>se queda pegado lo que comen en su..., a un lado de su abdomen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a813" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>Y después de pegarse en su ab..., se pega a un lado, así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a815" ANNOTATION_REF="a294">
                <ANNOTATION_VALUE>también lo..., lloran los niños, después ya no quieren comer nada, tienen ganas de vomitar. A veces le dan de comer algo, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a816" ANNOTATION_REF="a295">
                <ANNOTATION_VALUE>sólo tiene ganas de vomitar y le da asco por el..., empacho que tiene.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a817" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>Y luego se dan cuenta los padres que el niño tiene empacho, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a818" ANNOTATION_REF="a297">
                <ANNOTATION_VALUE>si defe..., defeca aguado parecido al nejayote debe estar enfermo de empacho el niño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a819" ANNOTATION_REF="a298">
                <ANNOTATION_VALUE>Para curar al niño consiguen las hojas de xa:lkowit, el ti:ltikxa:lkowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a820" ANNOTATION_REF="a299">
                <ANNOTATION_VALUE>El xa:lkowit se da la mata con varas delgadas, sus hojas son en forma de corazón pero más puntiagudas y tienen un mal olor. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a821" ANNOTATION_REF="a300">
                <ANNOTATION_VALUE>Se da en lugares, por aquí también se da este..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a822" ANNOTATION_REF="a301">
                <ANNOTATION_VALUE>En Tate:mpan o allá</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a823" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>en el Tozán abunda mucho, allá se da por rollo al pie de las rocas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a824" ANNOTATION_REF="a303">
                <ANNOTATION_VALUE>esa planta se da por varas delgadas, no crece alto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a825" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>Y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a826" ANNOTATION_REF="a306">
                <ANNOTATION_VALUE>es muy duro el tallo, es muy duro su tallo. La madera de esa planta es muy dura como la madera del tekowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a827" ANNOTATION_REF="a308">
                <ANNOTATION_VALUE>Y cuando consiguen las hojas las..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a828" ANNOTATION_REF="a309">
                <ANNOTATION_VALUE>también las, también las, las..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a829" ANNOTATION_REF="a310">
                <ANNOTATION_VALUE>las machacan o las asan en el comal,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a830" ANNOTATION_REF="a311">
                <ANNOTATION_VALUE>las machacan bien como si fueran,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a831" ANNOTATION_REF="a312">
                <ANNOTATION_VALUE>las..., las..., despues de asarlas las machacan y quedan como masa, enseguida buscan un pedazo de papel ya sea de pan o periódico, ahora que hay periódico.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a749" ANNOTATION_REF="a314">
                <ANNOTATION_VALUE>la..., la..., ponen la masa en el papel ya,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a750" ANNOTATION_REF="a315">
                <ANNOTATION_VALUE>pero las hojas las asan antes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a751" ANNOTATION_REF="a316">
                <ANNOTATION_VALUE>Y luego la...., tienden la masa en el..., las hojas ya machacadas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a752" ANNOTATION_REF="a317">
                <ANNOTATION_VALUE>y enseguida le..., le agregan carbonato, si no hay carbonato le ponen tequesquite y aceite. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a753" ANNOTATION_REF="a318">
                <ANNOTATION_VALUE>Le ponen todo esto, luego le ponen al niño en emplasto a un costado de su abdomen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a754" ANNOTATION_REF="a319">
                <ANNOTATION_VALUE>Y les..., le amarran con un pedazo de tela y eso es lo que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a755" ANNOTATION_REF="a320">
                <ANNOTATION_VALUE>va bajando el empacho porque las hojas de xa:lkowit son muy apestosas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a756" ANNOTATION_REF="a322">
                <ANNOTATION_VALUE>disminu..., el que le llamamos xa:lkowit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a832" ANNOTATION_REF="a323">
                <ANNOTATION_VALUE>i..., huele muy feo, lo..., huelen mucho a empacho esas hojas compadrito. Uelen a empacho. Y con esas hojas las..., hacen buen efecto,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a757" ANNOTATION_REF="a325">
                <ANNOTATION_VALUE>con las fuerzas, con el olor que tienen pasan por dentro, quien sabe cómo hacen pero pasan a destruir el..., el empacho,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a758" ANNOTATION_REF="a326">
                <ANNOTATION_VALUE>pasa el remedio por dentro, le dan de tomar un poco de té al niño y se le qui..., quita el empacho y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a759" ANNOTATION_REF="a327">
                <ANNOTATION_VALUE>se le quita el empacho cuando lo..., se desbarata por dentro el empacho, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a760" ANNOTATION_REF="a329">
                <ANNOTATION_VALUE>cuando defeca el niño sale el excremento por cachitos que se están poxcando</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a761" ANNOTATION_REF="a331">
                <ANNOTATION_VALUE>su..., lo que come queda pegado por dentro la porquería, se queda ahí y así se desbarata el empacho con la medicina. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a835" ANNOTATION_REF="a332">
                <ANNOTATION_VALUE>Esta planta la conocemos que es muy buena para curar el empacho.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a836" ANNOTATION_REF="a334">
                <ANNOTATION_VALUE>Sí, se le agrega aceite para que ablande el empacho y así sea efectivo para atacar el empacho en los niños.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a837" ANNOTATION_REF="a335">
                <ANNOTATION_VALUE>Y la otra planta se usa para curar la diarrea en los adultos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a838" ANNOTATION_REF="a336">
                <ANNOTATION_VALUE>Esa también es muy buena.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a839" ANNOTATION_REF="a337">
                <ANNOTATION_VALUE>Y el otro xa:lkowit que hay, ése es de árbol grande y se da en matas grandes también, brotan sus retoños y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a840" ANNOTATION_REF="a338">
                <ANNOTATION_VALUE>sus tallos de los reto..., retoños crecen chuecos, casi en su..., su..., sus ramas, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a841" ANNOTATION_REF="a339">
                <ANNOTATION_VALUE>crecen como si fuera en linea quebrada,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a842" ANNOTATION_REF="a340">
                <ANNOTATION_VALUE>también es igual, tiene sus hojas un poco redondas y en el haz como</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a843" ANNOTATION_REF="a341">
                <ANNOTATION_VALUE>si fueran ho..., ho..., como si tuvieran unas rayas en las hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a844" ANNOTATION_REF="a342">
                <ANNOTATION_VALUE>y también son puntiagudas como corazoncitos y son un poco grandes,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a845" ANNOTATION_REF="a344">
                <ANNOTATION_VALUE>como si fueran corazoncitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a846" ANNOTATION_REF="a345">
                <ANNOTATION_VALUE>Y el otro del que te platico del ti:ltikxa:lkowit, tiene las hojas como corazoncitos pero son más pequeñas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a847" ANNOTATION_REF="a346">
                <ANNOTATION_VALUE>Y el otro tiene las hojas alargadas que se conoce como ma:we:weyakxa:lkowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a851" ANNOTATION_REF="a348">
                <ANNOTATION_VALUE>Y sus..., sus hojas se paracen a las hojas de planta de café, parece que sus hojas son un poco blancas, y las hojas de la planta de café son verdes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a852" ANNOTATION_REF="a349">
                <ANNOTATION_VALUE>Y las hojas de xa:lkowit son redondas acorozonadas y más grandes hasta de este tamaño</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a853" ANNOTATION_REF="a350">
                <ANNOTATION_VALUE>y son puntiagudas como corazoncitos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a854" ANNOTATION_REF="a351">
                <ANNOTATION_VALUE>Sus semillas son parecidas a las semillas de xa:lkowit ista:k.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a855" ANNOTATION_REF="a352">
                <ANNOTATION_VALUE>También son largas y se cuelgan hacia abajo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a856" ANNOTATION_REF="a354">
                <ANNOTATION_VALUE>Sus flores también son blancas y</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a857" ANNOTATION_REF="a355">
                <ANNOTATION_VALUE>y este también es medicinal, también es medicinal pero no para personas, sólo es remedio para </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a858" ANNOTATION_REF="a356">
                <ANNOTATION_VALUE>para planta como cuando se siembra yuca, los</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a762" ANNOTATION_REF="a358">
                <ANNOTATION_VALUE>i..., que siembran yuca, bueno nosotros así lo hacíamos porque mi abuelito sembraba yuca,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a763" ANNOTATION_REF="a359">
                <ANNOTATION_VALUE>y todo nos enseñaba cómo curarla, qué se usaba para hacerle un buen efecto</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a764" ANNOTATION_REF="a360">
                <ANNOTATION_VALUE>Es el kow..., ocupa el este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a765" ANNOTATION_REF="a361">
                <ANNOTATION_VALUE>el xa:lkowit va a cortar para usarlo como coa, un palo verde que lo busca en el campo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a766" ANNOTATION_REF="a362">
                <ANNOTATION_VALUE>Va a cortar el palo y lo usa para aflojar la tierra, lo..., aflo..., afloja la tierra y en seguida acomoda la estaca de yuca en la tierra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a767" ANNOTATION_REF="a363">
                <ANNOTATION_VALUE>Y después de producir camote la mata, ya hay camotes y en el momento de es..., escarbar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a768" ANNOTATION_REF="a364">
                <ANNOTATION_VALUE>ya va a cosechar este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a769" ANNOTATION_REF="a365">
                <ANNOTATION_VALUE>pues le..., le..., ya le hizo un buen efecto el palo de xa:lkowit que se usó para sembrar, y le hace ése efecto porque cuando se seca el palo,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a770" ANNOTATION_REF="a366">
                <ANNOTATION_VALUE>se..., se..., se le hacen grietas en la superficie del palo así a lo largo, queda como estrellado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a859" ANNOTATION_REF="a367">
                <ANNOTATION_VALUE>Se le hacen aperturas en la superficie así a lo largo, tiene grandes las aperturas. Se abren cuando el palo ya está bien seco</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a860" ANNOTATION_REF="a369">
                <ANNOTATION_VALUE>Y entonces le hace un buen efecto al camotes de yuca, cuando lo ponen a hervir el camote absorbe todo lo dulce y </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a771" ANNOTATION_REF="a370">
                <ANNOTATION_VALUE>se ab..., se abre el camote para que entre lo dulce, se endulza todo por dentro. Sí eso es lo que se hace, y si uno no le busca para hacerle un buen efecto a la yuca, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a861" ANNOTATION_REF="a372">
                <ANNOTATION_VALUE>el camote sale muy macizo y cuando se hierve no le entra lo dulce, cuando se come todo por dentro está blanco y no tiene sabor.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a862" ANNOTATION_REF="a373">
                <ANNOTATION_VALUE>No está dulce. Es dulce pero sólo por encima y por dentro está muy duro, no se endulza.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a863" ANNOTATION_REF="a375">
                <ANNOTATION_VALUE>Y eso es lo que veíamos nosotros que mi abuelito le hacía un buen efecto a la semilla para cuando vaya a cosechar pues ya..., ya le hizo el buen efecto para evitar problemas en el momento de hervir,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a772" ANNOTATION_REF="a376">
                <ANNOTATION_VALUE>se abre bien el camote a lo largo y le entra todo lo dulce, hasta donde se encuentra la médula se endulza muy bonito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a773" ANNOTATION_REF="a377">
                <ANNOTATION_VALUE>Así es, cuando le..., le hacen el buen efecto con el palo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a774" ANNOTATION_REF="a378">
                <ANNOTATION_VALUE>Y también les decimos xa:lkowit porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a775" ANNOTATION_REF="a380">
                <ANNOTATION_VALUE>cuando se seca  y se moja un poco, se descompone la corteza y luego se va despegando,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a776" ANNOTATION_REF="a381">
                <ANNOTATION_VALUE>se cae la corteza, se cae así en grandes porciones, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a777" ANNOTATION_REF="a382">
                <ANNOTATION_VALUE>y, y parece que son un poco largas los pedazos de corteza por encima.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a778" ANNOTATION_REF="a383">
                <ANNOTATION_VALUE>Y si uno recoge la corteza, luego se ve que por dentro tiene como granitos de arena.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a864" ANNOTATION_REF="a384">
                <ANNOTATION_VALUE>Por eso le llamamos, le llamamos xa:lkowit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a865" ANNOTATION_REF="a385">
                <ANNOTATION_VALUE>porque la corteza se ve como si tuviera unos granitos de arena.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a866" ANNOTATION_REF="a387">
                <ANNOTATION_VALUE>Ee, como si tuviera arena, por eso lo conocemos así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a867" ANNOTATION_REF="a388">
                <ANNOTATION_VALUE>También es medicinal pero para hacerle un buen efecto a la planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a779" ANNOTATION_REF="a390">
                <ANNOTATION_VALUE>Sí, los tres tipos de xa:lkowit todos son medicinales. Pero dos son para curar personas y uno es para la planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a780" ANNOTATION_REF="a394">
                <ANNOTATION_VALUE>El cultivo, sí como el camote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a877" ANNOTATION_REF="a400">
                <ANNOTATION_VALUE>Dicen que hace daño en la planta del pie, se hacen unas aperturas en la piel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a781" ANNOTATION_REF="a405">
                <ANNOTATION_VALUE>Sí, dicen que la yuca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a782" ANNOTATION_REF="a407">
                <ANNOTATION_VALUE>Sí, así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a878" ANNOTATION_REF="a409">
                <ANNOTATION_VALUE>Y se le hace un buen efecto con el palo de xa:lkowit, eso nos decían.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a783" ANNOTATION_REF="a412">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a784" ANNOTATION_REF="a414">
                <ANNOTATION_VALUE>Es igual.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a785" ANNOTATION_REF="a417">
                <ANNOTATION_VALUE>I..., i..., como si fuera hierba molida.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a879" ANNOTATION_REF="a420">
                <ANNOTATION_VALUE>Ya limpiecita el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a880" ANNOTATION_REF="a421">
                <ANNOTATION_VALUE>Así es, s..., eso es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a881" ANNOTATION_REF="a427">
                <ANNOTATION_VALUE>Esa no se..., ése palo se ocupa para aflo..., aflojar la tierra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a882" ANNOTATION_REF="a429">
                <ANNOTATION_VALUE>Se hace el hoyo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a883" ANNOTATION_REF="a431">
                <ANNOTATION_VALUE>Sí, de sa forma se le hace un buen efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a884" ANNOTATION_REF="a432">
                <ANNOTATION_VALUE> Con e..., se corta el palo sólo para aflojar la tierra y,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a885" ANNOTATION_REF="a434">
                <ANNOTATION_VALUE>se mueve la tierra y se acomoda la  estaca, así le hace el buen efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a886" ANNOTATION_REF="a435">
                <ANNOTATION_VALUE> Si. Ése no..., ése no..., no se acomoda en forma horizontal, sino que se afloja la tierra, enseguida. La estaca se pone así como un poco in..., inclinada,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a887" ANNOTATION_REF="a437">
                <ANNOTATION_VALUE>para que, broten varios retoños y también de que se inclina pues</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a888" ANNOTATION_REF="a438">
                <ANNOTATION_VALUE>brotan muchas raíces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a889" ANNOTATION_REF="a439">
                <ANNOTATION_VALUE>Y si la estaca la pones en forma vertical só..., sólo brota una raíz y no produce muchos camotes. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a890" ANNOTATION_REF="a440">
                <ANNOTATION_VALUE>Se acomoda un poco inclinada la estaca para que broten muchos  camotes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a902" ANNOTATION_REF="a441">
                <ANNOTATION_VALUE>Hay que acomodar la estaca un poco horizontal..., se afloja la tierra un poco inclinada, mueves la tierra y metes la yuca..., la estaca, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a903" ANNOTATION_REF="a443">
                <ANNOTATION_VALUE>así brotan muchos retoños y..., si tiene varios nudos la estaca pues se..., si tiene dos nudos pues,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a904" ANNOTATION_REF="a444">
                <ANNOTATION_VALUE>brotan muchas raíces y esas raíces son las que se vuelven camotes. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a905" ANNOTATION_REF="a445">
                <ANNOTATION_VALUE>Y si ya le buscaste el buen efecto, pues cuando va..., vas a cosecharlo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a906" ANNOTATION_REF="a446">
                <ANNOTATION_VALUE>lo..., cuando lo pones a hervir pues se abre bien el camote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a907" ANNOTATION_REF="a448">
                <ANNOTATION_VALUE> Se abre por recibir el buen efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a908" ANNOTATION_REF="a449">
                <ANNOTATION_VALUE>Sí, con el palo de xa:lkowit se le hace un buen efecto. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a909" ANNOTATION_REF="a451">
                <ANNOTATION_VALUE>Lo acomodan en forma vertical y así sólo brota una raíz porque nada más un nudo tiene contacto con la tierra.  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a910" ANNOTATION_REF="a453">
                <ANNOTATION_VALUE>Y así no produce muchos camotes porque s..., no inclinan la estaca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a911" ANNOTATION_REF="a454">
                <ANNOTATION_VALUE>Sí, sólo brota una raíz, así no produce muchos camotes, sólo uno o dos camotes sale, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a916" ANNOTATION_REF="a456">
                <ANNOTATION_VALUE>y si iclinaste la estaca salen muchas raíces y los camotes salen por todos lados, también se multiplican como si tuvieran ramas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a917" ANNOTATION_REF="a457">
                <ANNOTATION_VALUE>se extiende el camote y va aumentando de grosor. En lugares que está blandita la tierra se da bien. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a918" ANNOTATION_REF="a459">
                <ANNOTATION_VALUE> Así se hace ése trabajo. Nosotros conocemos porque trabajamos sobre varios cultivos, con el..., cuando crecimos nos enseñaron cómo trabajar en el campo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a919" ANNOTATION_REF="a461">
                <ANNOTATION_VALUE>Trabajaba sobre el cultivo de la yuca y del camote de castilla, conoce. Yo sé cómo cosechar el camote de castilla, conozco. Hay que saberle cómo hacer para cosechar ése camote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a920" ANNOTATION_REF="a463">
                <ANNOTATION_VALUE>Si uno no sabe, puedes ir a cosechar el camote de castilla,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a921" ANNOTATION_REF="a465">
                <ANNOTATION_VALUE>puedes ir a escarbar y pasar a lavar en el rio y lo..., hierven, llegas y lo pones a hervir,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a922" ANNOTATION_REF="a466">
                <ANNOTATION_VALUE>sí cuese bien, cuese bonito. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a923" ANNOTATION_REF="a467">
                <ANNOTATION_VALUE>Pero el camote le salen muchas aperturas, se rompe y crece como si se hinchara,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a928" ANNOTATION_REF="a468">
                <ANNOTATION_VALUE>eso le hace daño la savia, entonces le entra agua por dentro y cuando comes el camote sabe insípido, todo por den..., dentro tiene tierra porque</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a929" ANNOTATION_REF="a469">
                <ANNOTATION_VALUE>porque le entra agua sucia por dentro en ....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a930" ANNOTATION_REF="a471">
                <ANNOTATION_VALUE>Eso es lo que pasa. No sale bien el camote.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a931" ANNOTATION_REF="a472">
                <ANNOTATION_VALUE>Y si se, también se..., se espera que se seque la savia, para secar tarda ocho..., ocho días debe estar en la casa para que lo pongas a hervir,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a932" ANNOTATION_REF="a473">
                <ANNOTATION_VALUE>pero ya no este</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a933" ANNOTATION_REF="a474">
                <ANNOTATION_VALUE>ya no se echa a perder. Cuece bien el camote con un sabor agradable y ya no se rompe, cuece muy bien con un sabor que da gusto comer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a934" ANNOTATION_REF="a475">
                <ANNOTATION_VALUE>y es dulce..., dulce, se endul..., se endulza porque se seca la savia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a935" ANNOTATION_REF="a476">
                <ANNOTATION_VALUE>Y entonces de que..., así es, así es se seca la savia del camote,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a936" ANNOTATION_REF="a478">
                <ANNOTATION_VALUE>y de que se seca la savia, ya no tiene savia pues cuece bien con el agua,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a937" ANNOTATION_REF="a479">
                <ANNOTATION_VALUE>ya no se rompe, ya se ve bien y salen los camotes muy sabrosos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a938" ANNOTATION_REF="a480">
                <ANNOTATION_VALUE>Y si fuiste a cosechar ahora y al llegar lo pones a hervir es que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a939" ANNOTATION_REF="a482">
                <ANNOTATION_VALUE>cuece bien el camote, hasta aumenta de tamaño,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a940" ANNOTATION_REF="a483">
                <ANNOTATION_VALUE>se rompe y le entra el agua pero qué gusto puedes esperar cuando tiene un sabor desabrido.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a941" ANNOTATION_REF="a484">
                <ANNOTATION_VALUE>No se puede comer. Eso es, yo lo..., conozco de cómo cos..., casi cómo cosechar. Mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a942" ANNOTATION_REF="a487">
                <ANNOTATION_VALUE>Así es, pues hay este..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a943" ANNOTATION_REF="a489">
                <ANNOTATION_VALUE>El amarillo que hay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a957" ANNOTATION_REF="a493">
                <ANNOTATION_VALUE>Sí.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a958" ANNOTATION_REF="a494">
                <ANNOTATION_VALUE>Ahí se encuentra. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a959" ANNOTATION_REF="a496">
                <ANNOTATION_VALUE>Y para sembrar, ése este, se siembra el bejuco,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a960" ANNOTATION_REF="a498">
                <ANNOTATION_VALUE>el bejuco del camote de castilla, se dobla cuando se siembra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a961" ANNOTATION_REF="a499">
                <ANNOTATION_VALUE>se dobla. Si se corta el bejuco de tres cuartas se puede doblar varias veces, se dobla muchas veces,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a962" ANNOTATION_REF="a500">
                <ANNOTATION_VALUE>y se siembra el bejuco, se afloja la tierra y se acomoda el bejuco.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a963" ANNOTATION_REF="a501">
                <ANNOTATION_VALUE>Se tapa el hoyo con el talón del pie, se..., se aprieta un poco con el pie, se..., con el talón del pie. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a964" ANNOTATION_REF="a502">
                <ANNOTATION_VALUE>No se hace el hoyo con el dedo de la mano. Porque si se siembra con el dedo se dan los camotes delgados y muy chiquitos, le hace un mal efecto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a965" ANNOTATION_REF="a503">
                <ANNOTATION_VALUE>Si a..., aprietas la tierra con el talón del pie,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a966" ANNOTATION_REF="a504">
                <ANNOTATION_VALUE>cuando vas a cosechar se..., cuando ya se da..., weh..., el bejuco ya arrastra lejos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a967" ANNOTATION_REF="a505">
                <ANNOTATION_VALUE>y donde está la mata se abre la tierra hacia arriba como si se amontonara. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a971" ANNOTATION_REF="a506">
                <ANNOTATION_VALUE>Pero los camotes se dan así boludos, son grandes, una mata produce siquiera unos seis camotes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a972" ANNOTATION_REF="a508">
                <ANNOTATION_VALUE>Y luego este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a973" ANNOTATION_REF="a509">
                <ANNOTATION_VALUE>lo vas a cosechar, en el nudo del bejuco se dan los camotes alargados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a974" ANNOTATION_REF="a510">
                <ANNOTATION_VALUE>en el nudo brotan los camotes alargados, ahi no se dan los camotes boludos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a975" ANNOTATION_REF="a511">
                <ANNOTATION_VALUE>Se dan camotes boludos al pie de la mata.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a976" ANNOTATION_REF="a512">
                <ANNOTATION_VALUE>Y en los nudos del bejuco produce camotes alargados.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a977" ANNOTATION_REF="a514">
                <ANNOTATION_VALUE>Son grandes los camotes pero alargados como la yuca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a978" ANNOTATION_REF="a515">
                <ANNOTATION_VALUE>Yo conozco porque trabajamos muchos años sobre esto, ahí pasamos toda nuestra infancia. Conozco las clases de camotes, lo..., sé sembrar y sé cosecharlo. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a979" ANNOTATION_REF="a518">
                <ANNOTATION_VALUE>Â¿Cómo?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a980" ANNOTATION_REF="a520">
                <ANNOTATION_VALUE>Aa, tiene fibras, pero ése, tiene fibras pero los, los camotes que son delgados siempre.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a981" ANNOTATION_REF="a522">
                <ANNOTATION_VALUE>Algunas personas dicen que te rascaste la cabeza cuando sembraste o cuando vas a cosechar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a982" ANNOTATION_REF="a523">
                <ANNOTATION_VALUE>y otros dicen, nos engañan los que no sabemos, los que no sabemos nos engañan algunos ancianos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a983" ANNOTATION_REF="a524">
                <ANNOTATION_VALUE>Van a cosechar el camote a mediodía, porque a mediodía encontrarás más pero no es cierto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a984" ANNOTATION_REF="a525">
                <ANNOTATION_VALUE>Nosotros cosechábamos en la mañana temprano, cuando cosechábamos juntábamos unos cuatro bultos cada uno.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a985" ANNOTATION_REF="a526">
                <ANNOTATION_VALUE>Cosechábamos cuatro bolsas de camote</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a944" ANNOTATION_REF="a528">
                <ANNOTATION_VALUE>Unos dicen ve a cosechar a mediodía para encuentres más. No es cierto, a donde va a ir el camote si siempre está ahí dentro de la tie..., tierra, a donde va a ir. Nos engañan.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a986" ANNOTATION_REF="a529">
                <ANNOTATION_VALUE>Y otros dicen si te rascaste la cabeza no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a987" ANNOTATION_REF="a531">
                <ANNOTATION_VALUE>el camote va a traer muchas fibras, no te vayas rascando la cabeza, no es cierto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a988" ANNOTATION_REF="a533">
                <ANNOTATION_VALUE>es cierto que tiene fibras pero los bejucos delgados siempre producen camotes que tienen fibras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a989" ANNOTATION_REF="a534">
                <ANNOTATION_VALUE>porque los camotes que se producen en los nudos del bejuco son delgados y siempre traen fibras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a990" ANNOTATION_REF="a535">
                <ANNOTATION_VALUE>Y el camote que cosechas al pie de la mata,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a991" ANNOTATION_REF="a536">
                <ANNOTATION_VALUE>podemos decir que so los de primera porque son boludos y no tienen fibra, es porque son bolas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a992" ANNOTATION_REF="a537">
                <ANNOTATION_VALUE>Y el camote que tiene fibras es el que se produce en los nudos,tiene fibras, a la fuerza salen así porque son alargados los bejucos, las raíces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a993" ANNOTATION_REF="a539">
                <ANNOTATION_VALUE>Por eso tienen fibras, ahí se producen. Si le cortas la punta salen su..., salen así como hilitos finos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a994" ANNOTATION_REF="a541">
                <ANNOTATION_VALUE>Sie..., siempre se da..., se dan así, por más que quieras hacer algo, aunque no te rasques la cabeza o hagas otra cosa,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a995" ANNOTATION_REF="a542">
                <ANNOTATION_VALUE>siempre va a tener fibras porque son largos los camotes y en la puntita ahí salen las fibras.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a945" ANNOTATION_REF="a543">
                <ANNOTATION_VALUE>De que no sabemos nos engañan compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a996" ANNOTATION_REF="a545">
                <ANNOTATION_VALUE>Que no hay que rascarse la cabeza. No. no es cierto, eso no le hace daño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a997" ANNOTATION_REF="a547">
                <ANNOTATION_VALUE>No es cierto, yo lo he visto porque cuando cre..., crecimos trabajamos en eso mu, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a998" ANNOTATION_REF="a549">
                <ANNOTATION_VALUE>mucho años cono..., trabajamos con ése cultivo. Yo conozco varios tipos de ése producto.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a999" ANNOTATION_REF="a550">
                <ANNOTATION_VALUE>Y de..., nos..., nos criaron con eso, crecimos produciendo ése producto. Aa, la yuca, el camote de castilla no se le pone panela para endulzar, se le pone panela (la yuca dice ato:lkamoh en vez de kowkamoh), pero ése se endulza sólo</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1000" ANNOTATION_REF="a552">
                <ANNOTATION_VALUE>Se endulza sólo, no, sólo de que se hierve, hierve bien, se endulza sólo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a946" ANNOTATION_REF="a553">
                <ANNOTATION_VALUE>Se endulza. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1001" ANNOTATION_REF="a555">
                <ANNOTATION_VALUE>es más sabroso la semilla que siempre la tenemos acá.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1002" ANNOTATION_REF="a556">
                <ANNOTATION_VALUE>El camote que traen de allá arriba se ve muy bonito, son grandes así pero no son dulces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1003" ANNOTATION_REF="a557">
                <ANNOTATION_VALUE>Saben un poco aguados y no son dulces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a947" ANNOTATION_REF="a558">
                <ANNOTATION_VALUE>Y el camote que producimos acá nosotros sí es buen ca..., es un camote con un sabor agradable.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1004" ANNOTATION_REF="a559">
                <ANNOTATION_VALUE>Son muy sabrosos y dulces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1005" ANNOTATION_REF="a560">
                <ANNOTATION_VALUE>El que se da es el..., ista:kato:lkamoh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1006" ANNOTATION_REF="a562">
                <ANNOTATION_VALUE>y el que le llaman xela que es de color morado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1007" ANNOTATION_REF="a563">
                <ANNOTATION_VALUE>ése camote tiene un color bonito pero tampoco es dulce.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1008" ANNOTATION_REF="a564">
                <ANNOTATION_VALUE>Ése no es dulce. Y el amarillo es igual. El amarillo no es dulce,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1009" ANNOTATION_REF="a566">
                <ANNOTATION_VALUE>y ése, ése sa..., sabe aguado.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1010" ANNOTATION_REF="a567">
                <ANNOTATION_VALUE>Ése camote sabe aguado. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1011" ANNOTATION_REF="a569">
                <ANNOTATION_VALUE>Son suaves. El blanco es más sabroso son..., suaves con un sabor agradable.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1012" ANNOTATION_REF="a571">
                <ANNOTATION_VALUE>Eso es. Es todo compadrito,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1013" ANNOTATION_REF="a573">
                <ANNOTATION_VALUE>platicamos acerca del xa:lkowit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1014" ANNOTATION_REF="a574">
                <ANNOTATION_VALUE>y llegamos a platicar hasta del camote, mmm.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1015" ANNOTATION_REF="a575">
                <ANNOTATION_VALUE>Pero conocemos también el xa:lkowit, y conozco que los..., los tres tipos todos son medicinales. Todos son medicinales, así es. Pues por ahora es todo compadrito lo que te...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1016" ANNOTATION_REF="a577">
                <ANNOTATION_VALUE>te pregunto cómo es, si lo conoces. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1017" ANNOTATION_REF="a580">
                <ANNOTATION_VALUE>Sí. Así es. Gracias compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1018" ANNOTATION_REF="a582">
                <ANNOTATION_VALUE>Este, pues ahora compadrito, este también, platicamos de nuestro...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1019" ANNOTATION_REF="a583">
                <ANNOTATION_VALUE>lo..., del árbol que conocemos, de las hierbas o del xa:lkowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1020" ANNOTATION_REF="a584">
                <ANNOTATION_VALUE>Ahora quiero que, me digas tu nombre, cómo te llamas, de donde vienes, y eso es todo compadrito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1021" ANNOTATION_REF="a593">
                <ANNOTATION_VALUE>Ahora ya eres legítimo sanmigueleño.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1022" ANNOTATION_REF="a595">
                <ANNOTATION_VALUE>Sí. Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a619" ANNOTATION_REF="a597">
                <ANNOTATION_VALUE>Ya..., ya son muchos años, son muchos años.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1023" ANNOTATION_REF="a600">
                <ANNOTATION_VALUE>Sí. Pues , uhuh</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1024" ANNOTATION_REF="a602">
                <ANNOTATION_VALUE>Sí. Pues yo también compadrito, me llamo Ernesto Vázquez Chanico. de San Miguel Tzinacapan, de</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1025" ANNOTATION_REF="a603">
                <ANNOTATION_VALUE>domicilio conocido este Kali:ka:n</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1026" ANNOTATION_REF="a604">
                <ANNOTATION_VALUE>Sí. Sí compadrito ahí nací.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1027" ANNOTATION_REF="a606">
                <ANNOTATION_VALUE>Ahi nací. Mm, eso es todo compadrito. Gracias, sí.</ANNOTATION_VALUE>
