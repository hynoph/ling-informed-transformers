        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a501" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
                <ANNOTATION_VALUE>Se: kipanpahpacho, ika se: iko:ts se: kiteh...., [ki]tehtelowa ika se: imets, se: kitate..., ika se: iko:ts ya.</ANNOTATION_VALUE>
