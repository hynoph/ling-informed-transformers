        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a683" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>Te voy a platicar también lo que..., K..., sí también me acuerdo cómo nos platicaban nuestros abuelos co..., para qué sirve esa planta. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
