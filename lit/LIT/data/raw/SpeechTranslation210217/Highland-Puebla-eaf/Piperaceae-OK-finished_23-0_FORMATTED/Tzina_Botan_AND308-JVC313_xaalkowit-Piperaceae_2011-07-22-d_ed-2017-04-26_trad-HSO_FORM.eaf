        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a528" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
                <ANNOTATION_VALUE>Seki kihtowah nepantah xiow para tikahsis. Ka:n neli, kamoh ka:ni ya:s wa:n ompa yetok ta:l..., ta:lto:ktok, ka:ni ya:ti. Te:chkaya:wah.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a529" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts759">
                <ANNOTATION_VALUE>Wa:n seki:n kihtowah komo tmokwa:wawa:n a:mo</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
