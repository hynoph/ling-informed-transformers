        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a515" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts731">
                <ANNOTATION_VALUE>Neh niki:xmati *porque** wehka:w ika titekitikeh, ika timoskaltihkeh yo:n. Niki:xmati *de clase** de kamoh nik..., nikto:kas wa:n nikmati ke:ní:w *para nicosecharos**.</ANNOTATION_VALUE>
