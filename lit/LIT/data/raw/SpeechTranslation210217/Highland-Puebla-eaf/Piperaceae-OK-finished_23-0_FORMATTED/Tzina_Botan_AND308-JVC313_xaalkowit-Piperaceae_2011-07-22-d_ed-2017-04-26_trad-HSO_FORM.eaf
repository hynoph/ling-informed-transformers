        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a514" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
                <ANNOTATION_VALUE>Wehwei mochi:wa pero we:weyak ke:meh kowkamoh ya.</ANNOTATION_VALUE>
