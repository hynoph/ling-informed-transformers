        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a453" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
                <ANNOTATION_VALUE>Wa:n yehwa yo:n a:mo miak kamoh kite:maka *porque** s..., a:mo, a:mo ki:xakaketsah.</ANNOTATION_VALUE>
