        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts181">
                <ANNOTATION_VALUE>Ke:mah, wa:n yeh ma:pisi:ltik tepitsi:n, wa:n ye:k..., yeh yo:lix..., yo..., ii:xko ye:k...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
