    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="Traducción" PARENT_REF="Anastacio Nicolás Damián" PARTICIPANT="Anastacio Nicolás Damián" TIER_ID="AND Traducción">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a620" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Pues yo te voy a platicar lo poco que sé compadrito, este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a621" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>el xa:lkowit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a626" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>el primero, sus hojas se pueden usar para curar y otro que es el segundo se usa para,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a627" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>la madera también se usa para leña y el otro, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a628" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>se usa así. Le dicen xa:lkowit porque cuando se seca la planta y empieza a podrirse,</ANNOTATION_VALUE>
