                <ANNOTATION_VALUE>wa:n seki kihtowah, te:chkaya:wah, tein a:mo, tein a:mo tikmatih te:chkaya:wah seki ta:tahmeh.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a524" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
                <ANNOTATION_VALUE>Kichkwati yo:n kamoh nepantah, *porque** nepantah tikahsis n' kamoh, pero ka:n neli.</ANNOTATION_VALUE>
