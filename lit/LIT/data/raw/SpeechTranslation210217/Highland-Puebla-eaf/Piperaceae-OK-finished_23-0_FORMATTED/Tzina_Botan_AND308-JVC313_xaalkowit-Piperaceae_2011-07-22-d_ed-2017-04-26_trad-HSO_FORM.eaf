                <ANNOTATION_VALUE>Tehwa:n tikichkwayah de kwalka:n sah, yo:n tikichkwayah, tikichkwayah sake:ra ka:n na:wi *bulto cada quien**.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a526" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts753">
