        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a698" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>ista:kxa:lkowit, el tilti:kxa:lkowit tiene un mal olor muy fuerte. Y sus tallos son de color negro, le llamamos ti:ltikxa:lkowit porque tiene el tallo de color negro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a699" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>Es de color negro el tallo y tiene así como pequeños granitos en la corteza.</ANNOTATION_VALUE>
