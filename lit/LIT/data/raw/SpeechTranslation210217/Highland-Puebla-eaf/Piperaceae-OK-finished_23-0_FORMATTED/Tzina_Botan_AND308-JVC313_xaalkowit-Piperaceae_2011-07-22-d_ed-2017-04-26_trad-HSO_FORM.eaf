        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a520" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts741">
                <ANNOTATION_VALUE>A:, ichyoh, pero yo:n, yo:n ichyoh pero tein, tein yo:n pihpitsa:wak mochi:wa wa:n tein pihpitsa:wak i:pa.</ANNOTATION_VALUE>
