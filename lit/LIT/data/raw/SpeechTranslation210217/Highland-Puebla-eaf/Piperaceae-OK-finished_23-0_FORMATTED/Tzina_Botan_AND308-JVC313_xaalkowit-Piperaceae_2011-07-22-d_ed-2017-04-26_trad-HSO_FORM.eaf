                <ANNOTATION_VALUE>nejó:n para a:mo tiás ne: iwa:n koyo:tapahtihkeh yehwa yo:n kitekih yo:n i...,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts199">
                <ANNOTATION_VALUE>ixiwyo tein, tein ma:yeh, ma:ski seh..., tein selik ok *o** kwaltia ma:ski chika:wak a, ke:mah yehwa n' tein nimitsilia xa:lkowit,</ANNOTATION_VALUE>
