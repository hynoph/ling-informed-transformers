        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a445" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
                <ANNOTATION_VALUE>Wa:n i:pa tiktawelih ya, pos *cuando** tik..., *cuando** tiktekiti a, *ticosecharoti** a,</ANNOTATION_VALUE>
