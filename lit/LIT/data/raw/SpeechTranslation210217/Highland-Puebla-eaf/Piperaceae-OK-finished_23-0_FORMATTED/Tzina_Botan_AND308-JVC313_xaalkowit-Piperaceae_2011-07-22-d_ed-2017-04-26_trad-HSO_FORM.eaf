        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts412" TIME_SLOT_REF2="ts414">
                <ANNOTATION_VALUE>Para,</ANNOTATION_VALUE>
