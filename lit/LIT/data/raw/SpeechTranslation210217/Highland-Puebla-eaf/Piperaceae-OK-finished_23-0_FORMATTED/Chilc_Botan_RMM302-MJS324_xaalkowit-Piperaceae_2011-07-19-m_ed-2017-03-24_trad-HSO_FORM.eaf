            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Eso es, digamos que pasa a lavar los intestinos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Sí, eso es, este..., Y la otra que decimos que tiene hojas redondas, ésa no..., no se puede usar para curar, como que nadie le da uso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Sólo algunas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Sí, y el tankwa:kwi:kwil, el que le llamas tankwa:kwi:kwilkowit, ¿para qué sirve?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Digamos ¿qué usos le dan?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>Y se siembra para corral del..., digamos para cercar en donde se..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>un corral para que detenga el abono, para que no se erosione el suelo con el agua.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Yo pienso que también sirve porque esa planta luego retoña en donde se siembra la estaca.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Así es.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Entonces podemos decir que se puede usar para poner un cercado, cerca..., cercado del..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>Ajá. Sí s..., también sirve.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Bueno, este pues, </ANNOTATION_VALUE>
