        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>creo que es todo, no sé si usted quiera platicar algo más, tal vez tenga alguna idea.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Siento que es todo lo que te pregu..., te..., te pregu..., te pregunté. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Aquí escuché que hablaban de otra que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>hablaban de ésa planta xa:l..., xa:lkapolin. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Mm, pues el xa:lkapolin parece que..., </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>la verdad no sé muy bien, también quería preguntarte, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>si usted conoce también como xa:lkapolin como nosotros lo conocemos, nosotros por aquí así lo conocemos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>este chi:chi:lxoko:kkapolin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>No sé si ustedes también lo conocen así.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>o quizá la conocen con otro nombre. Nosotros decimos como que,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>como cada uno de nosotros tenemos una idea diferente a los demas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>o conocemos de manera diferente.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Y eso es lo que yo quiero saber, ¿ustedes cómo la conocen?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Yo conozco, parece que lo conocemos nosotros como, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>chi:chi:l..., chi:chi:lxoko:kkapolin</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Es lo que nos pla..., platica aquí una persona, dice que los frutos se pueden usar para preparar atolito. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>No sé usted cómo lo conoce. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Si conoce con el mismo nombre o tal  vez conozca con otro nombre diferente. </ANNOTATION_VALUE>
