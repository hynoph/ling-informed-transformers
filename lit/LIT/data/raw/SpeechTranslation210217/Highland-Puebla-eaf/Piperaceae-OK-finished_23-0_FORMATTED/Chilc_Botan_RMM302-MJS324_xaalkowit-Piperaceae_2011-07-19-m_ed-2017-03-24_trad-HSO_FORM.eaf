                <ANNOTATION_VALUE>La planta que le llaman takwa:kwi:kwil xiwit, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>nos..., bueno nosotros decimos</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>sólo por sus hojas y su tallo.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Pero su flores, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>o sus..., o sus frutos, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>podemos decir que se..., se..., se parecen. Se parecen. Sus hojas también son iguales, este, nosotros decimos xa:lkowit,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>porque sus hojas parece que tienen arena.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>Parece que tienen arena, como las hojas de tankwa:kwi:kwilxiwit que parece que también tienen arena.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Y de la planta que usted platica que es curativa también tienen arena sus hojas.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Y de la otra que platicamos que parece que tiene hojas redondas</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>también es..., también..., también es xa:lkowit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Sólo que nosotros decimos que son diferentes por sus hojas, digamos que cambian sus hojitas,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>son difrentes pero el nom..., nombre, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>podemos decir que..., es el..., es el mismo. Todos se parecen, todos se parecen a la misma planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE> Así es. Y otra cosa que..., otra pregunta, quiero preguntarle cuál, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>de esos tres tipos que usted conoce, usted conoce, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>¿cuál es el que se usa para curar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Bueno pues este, está bien nuestra plática.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Otra pregunta, ¿esa hierba sólo les ponen en emplasto o pueden hervir para tomarlo en té?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Está bien. Está bien. Este, bueno,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>yo también conozco esa plantita que si es buena para medicina.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Yo sé muy bien, así como usted me platica.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>les ponen en emplasto con aceite o así como usted dice, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>en la parte de atrás en su..., y en su abdomen,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>parece que, también sé que es muy bueno darles de tomar en té. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>que corten dos o tres puntas tiernas de la planta, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>y que lo pongan a her..., que lo pongan a hervir</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>y que se la tomen el té. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Que se la tomen como cuando nosotros decimos que vamos a tomar este, vamos a tomar este,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>como si fuera un tecito nada más. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Y que se la tomen cuando tegan empacho, así como dice usted para el empacho, yo sé que es muy buena esta planta.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Yo sé, como usted me platica, también sé que les pueden poner en emplasto en el abdomen y otro en la parte de atrás.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>y también pueden tomar en té. Digamos nosotros que es mucho más efectivo tomarlo en té.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a108">
