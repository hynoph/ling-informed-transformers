            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>¿Y usted por qué cree que le llaman xa:lkapolin? Por ...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Y, bueno, está bien.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>Este, pues nada más eso quer...,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>lo que quería saber, que lo platiquemos, que entre todos nos informemos cómo se llaman cada,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>bueno tipo de plantitas para que así pues, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>así como le digo a usted, cada uno de nosotros tenemos ideas  diferentes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>tenemos diferentes conocimientos.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>Pues es muy bueno que lo platiquemos así para que</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>que lo..., que no sólo conozcamos, que lo platiquemos. Pues  nada más eso.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>Eso es todo, muchas gracias. Yo me llamo Rubén Macario, vengo de Chilcuahuta, pertenezco a San Miguel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
