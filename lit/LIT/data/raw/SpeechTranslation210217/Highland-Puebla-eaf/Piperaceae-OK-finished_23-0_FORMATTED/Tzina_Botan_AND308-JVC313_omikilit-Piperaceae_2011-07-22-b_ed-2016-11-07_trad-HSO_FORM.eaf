        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a635" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
                <ANNOTATION_VALUE>o:mekilit wa:n nekaxa:ni:l,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a636" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
                <ANNOTATION_VALUE>wa:n yo:n sakapal. A:chá tiki:xmati n' sakapal.</ANNOTATION_VALUE>
