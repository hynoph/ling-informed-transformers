        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a637" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts789">
                <ANNOTATION_VALUE>Yo:n kostik mota:lia itech, itech xima:pan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a639" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
                <ANNOTATION_VALUE>Wa:n yo:n kwali se: kikwiti wa:n komo se: kineki se: kichi:was, ne: se: kipias,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a640" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
                <ANNOTATION_VALUE>kwali mah se: 'kwiti wa:n mah se: kitetekwino.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a641" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
                <ANNOTATION_VALUE>Wa:n kaltsi:ntan kwali se: kita:li:s, yo:n kwaltsi:n moma:ma:yo:tia.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a642" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts799">
                <ANNOTATION_VALUE>Sentakwi. Yehwa yo:n o:me, yo:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a644" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts802">
                <ANNOTATION_VALUE>s..., sakapal no:, no: semi kwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a645" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts804">
