        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a629" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts773">
                <ANNOTATION_VALUE>Ka:sá ika kipiah, kito:kah itech ko:ntsí:n,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a631" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts777">
                <ANNOTATION_VALUE>nijó:n ka:sá ika kipiah yo:n nekaxa:ni:l. Pero a:mo no..., a:mo nowián,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a633" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts781">
                <ANNOTATION_VALUE>Wa:n pos nochi kimanah wa:n yehwa yo:n,</ANNOTATION_VALUE>
