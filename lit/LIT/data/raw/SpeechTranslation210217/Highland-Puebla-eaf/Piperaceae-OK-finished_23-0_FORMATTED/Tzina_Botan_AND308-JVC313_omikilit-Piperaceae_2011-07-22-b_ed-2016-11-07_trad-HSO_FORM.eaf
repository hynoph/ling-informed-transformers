        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a522" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
                <ANNOTATION_VALUE>ata nemia se: *noparienta** ne:pa *comadr..., compadrito** ne:, na:n..., na:nah Juan, Juana mono:tsaya, Juana mono:tsaya, yehwa sah, yehwa n' tekitik ika yo:n.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a524" TIME_SLOT_REF1="ts558" TIME_SLOT_REF2="ts560">
                <ANNOTATION_VALUE>Wa:n *despuÃ©s** yehwa:n yo:n o:me:n pano:keh, yehwa no:mán wa:n pano:k na:nah Candelaria ne: Ta:lte:mpan, ka:mpa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
