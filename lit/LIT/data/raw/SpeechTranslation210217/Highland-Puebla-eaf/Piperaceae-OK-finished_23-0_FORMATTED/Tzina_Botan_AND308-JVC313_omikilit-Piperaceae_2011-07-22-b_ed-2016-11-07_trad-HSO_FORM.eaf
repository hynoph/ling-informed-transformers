        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a760" TIME_SLOT_REF1="ts1039" TIME_SLOT_REF2="ts1040">
                <ANNOTATION_VALUE>Niwa:lah n' ampón *porque** niknekik n' ampón tepitsi:n mah momachti:ka:n nopi:pilwa:n.</ANNOTATION_VALUE>
