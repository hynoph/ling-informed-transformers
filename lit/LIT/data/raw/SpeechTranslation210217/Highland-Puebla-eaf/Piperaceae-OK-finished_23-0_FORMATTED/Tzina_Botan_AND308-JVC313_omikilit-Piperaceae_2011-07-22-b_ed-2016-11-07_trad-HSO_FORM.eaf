            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a758" TIME_SLOT_REF1="ts1035" TIME_SLOT_REF2="ts1036">
                <ANNOTATION_VALUE>Pero neh niw..., niwa:lah ne: ke:manián, kipia sempowal</ANNOTATION_VALUE>
