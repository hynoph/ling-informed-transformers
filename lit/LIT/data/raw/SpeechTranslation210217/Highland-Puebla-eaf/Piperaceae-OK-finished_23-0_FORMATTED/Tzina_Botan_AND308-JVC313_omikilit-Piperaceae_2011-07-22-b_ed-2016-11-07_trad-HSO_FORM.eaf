        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a646" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
                <ANNOTATION_VALUE>*medio** matih tepitsi:n *porque** pos no: te:chilia:yah, ne:n,</ANNOTATION_VALUE>
