        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a768" TIME_SLOT_REF1="ts1055" TIME_SLOT_REF2="ts1056">
                <ANNOTATION_VALUE>Pero pos a:mo, a:mo welkeh n' ompa ne: *más maestros**, seki tamachtia:yah, seki a:mo nochi tamachtia:yah,</ANNOTATION_VALUE>
