        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>Komo:nih yo:n kiliah ne: *kwa:kopeto:meh porque** ihihkak ihkwí:n inkwa:ko nika:n,</ANNOTATION_VALUE>
