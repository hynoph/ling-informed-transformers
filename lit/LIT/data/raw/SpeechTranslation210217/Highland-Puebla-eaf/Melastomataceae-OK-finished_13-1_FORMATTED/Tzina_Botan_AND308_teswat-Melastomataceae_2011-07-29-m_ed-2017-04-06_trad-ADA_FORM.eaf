        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
                <ANNOTATION_VALUE>Pos ke:masá: no:, no: ke:masá ne: ke:wa, ke:masá: nijó:n,</ANNOTATION_VALUE>
