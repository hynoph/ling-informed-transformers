            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Seki nijó:n, ihkó:n nehnextik,</ANNOTATION_VALUE>
